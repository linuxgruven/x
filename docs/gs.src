    blockchain = include_lib("/lib/blockchain.so")
    coin = blockchain.get_coin("test", "test", "test")
    result = coin.get_address
    if not is_valid_ip(result) then
        exit "Failed to get address due to: " + result
    end if
    print "address: " + result

