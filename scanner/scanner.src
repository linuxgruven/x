GN=function(t);return "<color=#0ceb86>"+t+"</color>";end function
RD=function(t);return "<color=#f00>"+t+"</color>";end function
BL=function(t);return "<color=#00f>"+t+"</color>";end function
YL=function(t);return "<color=#ff0>"+t+"</color>";end function
WH=function(t);return "<color=#fff>"+t+"</color>";end function
OR=function(t);return "<color=#ffa500>"+t+"</color>";end function
PR=function(t);return "<color=#800080>"+t+"</color>";end function
LM=function(t);return "<color=#0f0>"+t+"</color>";end function
GY=function(t);return "<color=#888>"+t+"</color>";end function
ER=function(t);return "<color=#f44>"+t+"</color>";end function
gco=get_custom_object
_ui=@user_input
_HC=@host_computer
_hp=@has_permission
_vi=@is_valid_ip
_pn=@port_number
_gc=@get_content
_gr=@get_router
_p=@print
_s=@str
_to=@typeof
_ti=@to_int
_crPi=@poll_input
_mf=@fetch
_mr=@read
_ms=@send
_md=@delete_mail
_mda=@delete_all
_iv="Invalid selection"
_iip="Invalid IP"
_uu="    User: "
_uh="    Host: "
_up="    Path: "
_uc="Unsafe check"
_cm="computer"
_sh="shell"
_rs="/librshell.so"
_fs="ftpshell"
_mx="/metaxploit.so"
_rl="result"
_sg="string"
_gt="guest"
_sl="/var/system.log"
_rt="Result type: "
_uk="unknown"
_ch="chmod"
_sx=".src"
_hf={"chmod":1,"touch":1,"cat":1,"chown":1,"chgrp":1,"cp":1,"mv":1,"rm":1,"mkdir":1,"qrm":1,"ls":1,"pwd":1,"ps":1,"kill":1,"cd":1,"whoami":1}
_bf="Build failed: "
_fd="Firewall disabled!"
_kr="kernel_router.so"
_lr="/lib/librshell.so"
_hd=function(u);if u=="root" then return "/root";return "/home/"+u;end function
_shellHomeFile=function(shell);u=_gue(shell);if u and u.home then return u.home;return;end function
_shellHomePath=function(shell)
  h=_shellHomeFile(shell)
  if not h then return _hd(_gt)
  return h.path
end function
_userFromHome=function(h)
  if not h then return _gt
  if h.name=="root" then return "root"
  if h.name and h.name.len and h.name!=_gt then return h.name
  return _gt
end function
_userFromPath=function(p)
  if not p or not p.len then return _gt
  if p.indexOf("/root")==0 then return "root"
  pp=p.split("/")
  for i in range(0,pp.len);if pp[i]=="home" and i+1<pp.len and pp[i+1].len then return pp[i+1];end for
  return _gt
end function
_rguDef="if not get_custom_object.hasIndex(""_rgu"") then get_custom_object._rgu=function(x);obj=typeof(x);root=null;if obj==""computer"" then root=File(x,""/"");else if indexOf(obj,""shell"")!=null then root=File(host_computer(x),""/"");if not root then return ""guest"";for f in root.get_folders;if f.name==""root"" and has_permission(f,""w"") and has_permission(f,""r"") and has_permission(f,""x"") then return ""root"";if f.name==""home"" then;g=null;for h in f.get_folders;if h.name==""guest"" then g=h;continue;end if;if has_permission(h,""w"") and has_permission(h,""r"") and has_permission(h,""x"") then return h.name;end for;if g then return ""guest"";break;end if;end for;return ""guest"";end function;"
_lj=function(text,width);if text.len>=width then return text;return text+(" "*(width-text.len));end function
cbool=function(v);if v then return GN("True") else return RD("False");end function
prt=function(msg,type="i")
  if type=="e" then _p RD("[!] ")+WH(msg)
  if type=="s" then _p GN("[+] ")+WH(msg)
  if type=="w" then _p YL("[!] ")+WH(msg)
  if type=="i" then _p GY(msg)
  if type=="a" then _p YL("[*] ")+WH(msg)
end function
_pe=function(m);prt(m,"e");end function
_ps=function(m);prt(m,"s");end function
_pw=function(m);prt(m,"w");end function
_pact=function(m);prt(m,"a");end function
_plog=function(m);_p GY("  -> "+m);end function
_pfnd=function(m);_p GN("    -> [ FOUND ] ")+OR(m);end function
_pd=function(k,v);_plog(OR(k+": ")+WH(v));end function
_phint=function(m);_p GY("  ")+m;end function
_pmt=function(body,sfx=" > ");return OR("[")+WH(body)+OR("]")+WH(sfx);end function
_uig=function(x)
  if gco.H then return
  r=_ui(x)
  if r and _tl(r)=="home" then
    gco.H=true
    return
  end if
  return r
end function
_tl=function(x);return x.trim.lower;end function
_MKW=5
_miTok=function(k);return "["+k+"]";end function
_miLab=function(l)
  lab=l
  while lab.len and lab[0]==" ";lab=lab[1:];end while
  return lab
end function
_miBr=function(k);return OR("[")+GN(k)+OR("]");end function
_miKey=function(k)
  pad=""
  if _miTok(k).len<_MKW then pad=" "*(_MKW-_miTok(k).len)
  return _miBr(k)+pad
end function
_mi=function(k,l);return _miKey(k)+" "+GY(_miLab(l));end function
_visLen=function(t)
  v=t
  while v.indexOf("<color=")!=null
    s=v.indexOf("<color=")
    e=v.indexOf(">",s)
    if e==null then break
    c=v.indexOf("</color>",e)
    if c==null then break
    v=v[0:s]+v[e+1:c]+v[c+8:]
  end while
  return v.len
end function
_W=64
_FCOL=20
_miW=function(k,l,w)
  lab=_miLab(l)
  keyPad=""
  if _miTok(k).len<_MKW then keyPad=" "*(_MKW-_miTok(k).len)
  cell=_miBr(k)+keyPad+" "+GY(lab)
  vis=_visLen(_miBr(k)+keyPad+" "+lab)
  pad=""
  if vis<w then pad=" "*(w-vis)
  return cell+pad
end function
_mrow=function(items)
  if not items or not items.len then return
  compact=items.len==2
  i=0
  while i<items.len
    start=i
    n=0
    while n<3 and i<items.len
      n=n+1
      i=i+1
    end while
    if compact then
      row="  "
      j=start
      while j<start+n;if j>start then row=row+"  ";row=row+_miBr(items[j][0])+" "+GY(_miLab(items[j][1]));j=j+1;end while
      _p row
    else if n==1 then
      _p "  "+_mi(items[start][0],items[start][1])
    else
      row="  "
      j=start
      while j<start+n;row=row+_miW(items[j][0],items[j][1],_FCOL);j=j+1;end while
      _p row
    end if
  end while
end function
_scr=function(title,crumb="",target="")
  t=title.upper
  _p ""
  _p GN("┌"+("─"*(_W-2))+"┐")
  if target!="" then
    left=WH(t)
    if crumb!="" then left=left+GY("  ▸ "+crumb)
    right=GY("TARGET ")+YL(target)
    pad=_W-4-_visLen(left)-_visLen(right)
    if pad<0 then pad=0
    _p GN("│ ")+left+(" "*pad)+right+GN(" │")
  else
    cr=""
    if crumb!="" then cr="  ▸ "+crumb
    pad=_W-3-_visLen(t)-_visLen(cr)
    if pad<0 then pad=0
    _p GN("│ ")+WH(t)+GY(cr)+(" "*pad)+GN("│")
  end if
  _p GN("└"+("─"*(_W-2))+"┘")
end function
_bar=function(line)
  _p GY("─"*_W)
  _p line
  _p GY("─"*_W)
end function
_mainBar=function
  mt=RD("off");if metax then mt=GN("on")
  ct=RD("off");if crypto then ct=GN("on")
  rb=RD("off");if _crRainOk then rb=GN("on")
  rs=WH(_s(gco.rshell_servers.len))+GY("/")+WH(_s(gco.rshell_shells.len))
  line=GY("MX ")+mt+GY("  CR ")+ct+GY("  RB ")+rb+GY("  RS ")+rs
  if not _hasNet(_lc) then line=line+GY("  ")+RD("NET OFF")
  if gco.pivots.len then line=line+GY("  PV ")+YL(_s(gco.pivots.len))
  if isPivot then
    pComp=_HC(_ls)
    line=line+GY("  ")+OR(_gu(_ls)+"@"+pComp.public_ip)
  end if
  _bar(line)
end function
_hostBar=function(ex,exType,h)
  u=_gu(ex)
  rs=WH(_s(gco.rshell_servers.len))+GY("/")+WH(_s(gco.rshell_shells.len))
  line=GY("SESSION ")+WH(u+"@"+h)+GY("  TYPE ")+YL(exType)+GY("  RS ")+rs
  _bar(line)
end function
_sub=function(title)
  n=_W-title.len-4
  if n<0 then n=0
  _p ""
  _p GN("▸ ")+WH(title.upper)+GY(" "+("─"*n))
end function
_rule=function;_p GY("─"*_W);end function
_th=function(cols)
  h=""
  r=""
  for c in cols
    w=c[1]
    if w>0 then
      h=h+_lj(c[0],w)
      r=r+("─"*(w-1))+" "
    else
      h=h+c[0]
      r=r+("─"*c[0].len)
    end if
  end for
  _p GY(h)
  _p GY(r)
end function
_foot=function(actions)
  _p GY("─"*_W)
  _mrow(actions)
end function
_menu=function(ctx,actions)
  _foot(actions)
  return _uig(WH(ctx+" > "))
end function
_ask=function(label);return _uig(WH(label+" > "));end function
_mb=function(c);return not c or _tl(c)=="b";end function
_xp=function(tp,u)
  if not tp or not tp.len then return
  tp=tp.trim
  if tp=="~" then return _hd(u)
  if tp.len>=2 and tp[0:2]=="~/" then return _hd(u)+tp[1:]
  return tp
end function
_routerForShell=function(shell)
  if _atHome(shell) then return _gr
  return _grR(shell)
end function
_homePick=function(root);u=_gue(root);if u then return u.name;return _gt;end function
_exMenuActs=[["#","run"],["f","filter"],["c","custom"],["ba","bounce all"],["help","help"],["b","back"]]
// XFIX1.0: REMOVE ["nr","neuro"] from menus (whois Neurobox tag gone)
_mainMenuActs=[["r","random"],["ls","local"],["ns","lan"],["rc","recon"],["ht","hunt"],["cr","crack"],["ml","mail"],["h","host"],["pv","pivots"],["rs","rshell"],["wf","wifi"],["dg","dig"],["po","pobject"],["nr","neuro"],["help","help"],["x","exit"]]
_tgtActs=[["#","select"],["f","filter"],["help","help"],["b","back"]]
_digActs=[["e","email"],["bk","bank"],["u","users"],["s","search"],["sw","wipe"],["help","help"],["b","back"]]
d1=[["e","email"],["bk","bank"],["u","users"],["rt","root pass"],["r","rshell"],["help","help"]]
d2=[["s","search"],["sw","wipe"],["t","test IP"],["cl","clear cache"],["b","back"]]
_rcActs=[["e","email"],["bk","bank"],["u","users"],["s","search"],["d","full dig"],["help","help"],["b","back"]]
_credActs=[["#s","decrypt"],["a","all"],["f","filter"],["b","back"]]
_crActs=[["l","load words"],["r","load rainbow"],["g","gen md5"],["d","dump"],["c","crack"],["help","help"],["b","back"]]
_mailCleanTxt=function(t)
  if not t or not t.len then return t
  v=t
  while v.indexOf("<color=")!=null;s=v.indexOf("<color=");;e=v.indexOf(">",s)if e==null then break;c=v.indexOf("</color>",e);if c==null then break;v=v[0:s]+v[e+1:c]+v[c+8:];end while
  return trim(v)
end function
_mailIdFromPreview=function(m)
  m=_mailCleanTxt(m)
  pos=m.indexOf("MailID: ")
  if pos==null then return
  line=trim(m[pos:].split(char(10))[0])
  if line.len>8 then return trim(line.remove("MailID: "))
end function
_mailSubjFromPreview=function(m)
  pos=m.indexOf("Subject: ")
  if pos==null then return ""
  return trim(m[pos:][9:].split(char(10))[0])
end function
_mailClearCache=function
  gco.mailInbox=null
  gco.mailBodies={}
  gco.mailBodiesIdx={}
end function
_mailCdLeft=function
  if not gco.hasIndex("mailLastOp") then return 0
  if gco.hasIndex("mailLastMin") and _unixTs!=gco.mailLastMin then return 0
  w=2-(time-gco.mailLastOp)
  if w<=0 then return 0
  return w
end function
_mailCdOk=function
  w=_mailCdLeft
  if w>0 then
    _pw("MetaMail cooldown — "+ceil(w)+"s remaining before fetch/read/send/delete")
    return false
  end if
  return true
end function
_mailCdDone=function
  gco.mailLastMin=_unixTs
  gco.mailLastOp=time
end function
_mailInbox=function;if gco.hasIndex("mailInbox") and gco.mailInbox then return gco.mailInbox;end function
_mailInboxCount=function
  ib=_mailInbox
  if ib and ib.len then return ib.len
  return 0
end function
_mailBodyCount=function
  n=0
  if gco.hasIndex("mailBodies") and gco.mailBodies then
    for k in gco.mailBodies.indexes;if gco.mailBodies[k] and gco.mailBodies[k].len then n=n+1;end for
  end if
  return n
end function
_mailGetBody=function(mid,idx=null)
  if idx isa number and gco.hasIndex("mailBodiesIdx") and gco.mailBodiesIdx.hasIndex(idx) then return gco.mailBodiesIdx[idx]
  if not mid or not mid.len then return
  if not gco.hasIndex("mailBodies") or not gco.mailBodies then return
  if not gco.mailBodies.hasIndex(mid) then return
  return gco.mailBodies[mid]
end function
_mailSession=function(refresh=false)
  if not refresh and gco.hasIndex("mailSession") and gco.mailSession and _to(gco.mailSession)!=_sg then return gco.mailSession
  if not gco.hasIndex("mailAddr") or not gco.mailAddr or not gco.mailAddr.len then return
  if not gco.hasIndex("mailPass") or not gco.mailPass or not gco.mailPass.len then return
  ml=mail_login(gco.mailAddr.trim,gco.mailPass.trim)
  if not ml or _to(ml)==_sg then return
  gco.mailSession=ml
  gco.m=ml
  return ml
end function
_mailIsWaitErr=function(s)
  if not s or _to(s)!=_sg then return false
  if s.lower.indexOf("wait 2 second")!=null then return true
  return false
end function
_mailToText=function(v)
  if v==null then return
  if v isa list then
    if not v.len then return
    if v.len==1 then return _mailToText(v[0])
    return
  end if
  if _to(v)==_sg then return v
  return _s(v)
end function
_mailIsErr=function(s)
  if not s or _to(s)!=_sg then return false
  if s.indexOf("MailID:")!=null and s.indexOf("Subject:")!=null then return false
  if _mailIsWaitErr(s) then return true
  if s.indexOf("MetaMail:")==0 then return true
  if s=="Mail not found" then return true
  if s.indexOf("Mail not found")==0 then return true
  return false
end function
_mailParseRawBody=function(raw)
  txt=_mailToText(raw)
  if not txt or not txt.len then return
  if _mailIsErr(txt) then return txt
  sp=txt.indexOf("Subject: ")
  if sp!=null then return trim(txt[sp:].split(char(10))[1:].join(char(10)))
  lines=split(txt,char(10))
  if lines.len>3 then return trim(join(lines[3:],char(10)))
  return trim(txt)
end function
_mailReadRaw=function(ml,mid)
  mid=_mailCleanTxt(mid)
  if not mid or not mid.len then return
  ids=[mid]
  raw=ml.read(ids)
  if raw==null then raw=_mr(ml,ids)
  if raw==null then return
  if raw isa list then
    if not raw.len then return
    return raw[0]
  end if
  return raw
end function
_mailListInbox=function(ml=null)
  if not ml then ml=_mailSession
  if not ml then return _pe("Mail session expired — l to login again")
  _pact("Fetching inbox...")
  if not _mailCdOk then return
  msgs=_mf(ml)
  if not msgs then return _mailClearCache
  if _to(msgs)==_sg then
    _mailClearCache
    return msgs
  end if
  _mailCdDone
  gco.mailInbox=msgs
  gco.mailBodies={}
  gco.mailBodiesIdx={}
  if not msgs.len then _ps("Inbox empty") else _ps("Listed "+_s(msgs.len)+" message(s)")
  return msgs
end function
_mailViewList=function
  msgs=_mailInbox
  if not msgs then return _pw("Nothing cached — l login or f fetch")
  if not msgs.len then return _ps("Inbox empty")
  _sub("Inbox ("+_s(msgs.len)+")")
  i=1
  for m in msgs
    subj=_mailSubjFromPreview(m)
    if not subj.len then subj="(no subject)"
    mid=_mailIdFromPreview(m)
    mark=GY(" ○")
    if _mailGetBody(mid,i) then mark=GN(" ●")
    _p GN("["+_s(i)+"] ")+WH(subj)+mark
    i=i+1
  end for
  _phint(GY("● read  ○ unread  ")+WH("r #")+GY(" read full body"))
end function
_mailShowBody=function(body)
  txt=_mailToText(body)
  if not txt or not txt.len then return false
  if _mailIsWaitErr(txt) then
    _pw("MetaMail rate limit — wait 2s")
    return false
  end if
  if _mailIsErr(txt) then
    _pw(txt)
    return false
  end if
  for ln in split(txt,char(10));if ln.len then _p WH(ln);end for
  return true
end function
_mailReadMsg=function(pick="")
  if not pick or not pick.trim.len then
    pick=_ui(WH("Message # or MailID > "))
    if gco.H then return
    if not pick or not pick.trim.len then return
  end if
  pick=pick.trim
  msgs=_mailInbox
  if not msgs then return _pw("Nothing cached — l login or f fetch")
  if not msgs.len then return _ps("Inbox empty")
  si=null
  mid=null
  if pick.indexOf("-")==null and _ti(pick)>=1 then
    si=_ti(pick)
    if si>=1 and si<=msgs.len then mid=_mailIdFromPreview(msgs[si-1])
  end if
  if not mid or not mid.len then mid=_mailCleanTxt(pick)
  if not mid or not mid.len then return _pe("Invalid message selection")
  ml=_mailSession
  if not ml then return _pe("Login first (l)")
  if si!=null and si>=1 then _pact("Reading message "+_s(si)+"...") else _pact("Reading message...")
  if not _mailCdOk then return
  raw=_mailReadRaw(ml,mid)
  raw=_mailToText(raw)
  if raw==null then return _pw("Read failed for id="+mid+" — try l login again")
  if _mailIsWaitErr(raw) then return _pw("MetaMail rate limit — wait 2s")
  if _mailIsErr(raw) then return _pw(raw)
  body=_mailParseRawBody(raw)
  if not body or not body.len then return _pw("Empty message body")
  if not gco.hasIndex("mailBodies") or not gco.mailBodies then gco.mailBodies={}
  if not gco.hasIndex("mailBodiesIdx") or not gco.mailBodiesIdx then gco.mailBodiesIdx={}
  gco.mailBodies[mid]=body
  if si!=null and si>=1 then gco.mailBodiesIdx[si]=body
  _mailCdDone
  _mailShowBody(body)
end function
_mailActs=[["l","login"],["f","fetch"],["v","view"],["r","read"],["n","new"],["d","delete"],["a","delete all"],["o","logout"],["help","help"],["b","back"]]
_mailLogin=function
  eu=_ui(WH("Email/user > "))
  if gco.H then return
  if eu and _tl(eu)=="home" then
    gco.H=true
    return
  end if
  if not eu or not eu.trim.len then return
  ep=_ui(WH("Password > "),1)
  if gco.H then return
  if ep and _tl(ep)=="home" then
    gco.H=true
    return
  end if
  if not ep or not ep.trim.len then return _pw("Login cancelled")
  ml=mail_login(eu.trim,ep.trim)
  if not ml or _to(ml)==_sg then return _pe("Login failed: "+_s(ml))
  gco.mailSession=ml
  gco.m=ml
  gco.mailAddr=eu.trim
  gco.mailPass=ep.trim
  _mailClearCache
  _ps("Logged in as "+eu.trim)
  fr=_mailListInbox(ml)
  if fr and _to(fr)==_sg then return _pw(fr)
  _mailViewList
end function
_mailMenuGo=function(act,arg="")
  if act=="help" then return _showHelp("mail")
  if act=="l" then return _mailLogin
  if act=="o" then
    gco.mailSession=null
    gco.m=null
    gco.mailAddr=""
    gco.mailPass=""
    _mailClearCache
    return _ps("Logged out")
  end if
  if act=="v" then return _mailViewList
  if act=="r" then return _mailReadMsg(arg)
  ml=null
  if gco.hasIndex("mailSession") then ml=gco.mailSession
  if not ml then return _pe("Login first (l)")
  if act=="f" then
    ml=_mailSession
    if not ml then return _pe("Login first (l)")
    fr=_mailListInbox(ml)
    if fr and _to(fr)==_sg then return _pe(fr)
    return _mailViewList
  end if
  if act=="n" then
    dest=_ui(WH("To address > "))
    if gco.H then return
    if not dest or not dest.trim.len then return
    subj=_ui(WH("Subject > "))
    if gco.H then return
    if not subj then subj=""
    msg=_ui(WH("Message > "))
    if gco.H then return
    if not msg then msg=""
    if not _mailCdOk then return
    r=_ms(ml,dest.trim,subj,msg)
    if r==1 or r==true then
      _mailCdDone
      _ps("Sent")
      _mailClearCache
    else
      _pe("Send failed: "+_s(r))
    end if
    return
  end if
  if act=="d" then
    pick=_ui(WH("Message # or MailID (comma-separated) > "))
    if gco.H then return
    if not pick or not pick.trim.len then return
    msgs=_mailInbox
    if not msgs then return _pw("Inbox not cached — f to fetch")
    if not msgs.len then return _ps("Inbox empty")
    ids=[]
    for tok in pick.split(",")
      tok=tok.trim
      if not tok.len then continue
      si=_ti(tok)
      if si isa number and si>=1 and si<=msgs.len then
        mid=_mailIdFromPreview(msgs[si-1])
        if mid then ids.push(mid)
      else
        ids.push(tok)
      end if
    end for
    if not ids.len then return _pe("No valid message IDs")
    if not _mailCdOk then return
    r=_md(ml,ids)
    if r==1 or r==true then
      _mailCdDone
      _ps("Deleted "+_s(ids.len))
      _mailClearCache
    else
      _pe("Delete failed: "+_s(r))
    end if
    return
  end if
  if act=="a" then
    yn=_ui(WH("Delete ALL messages? (yes/no) > "))
    if gco.H then return
    if not yn or _tl(yn)!="yes" then return
    if not _mailCdOk then return
    r=_mda(ml)
    if r==1 or r==true then
      _mailCdDone
      _ps("Inbox cleared")
      _mailClearCache
    else
      _pe("Delete all failed: "+_s(r))
    end if
    return
  end if
end function
_mailMenu=function
  while true
    if gco.H then break
    _scr("Mail")
    if gco.hasIndex("mailSession") and gco.mailSession then
      addr=""
      if gco.hasIndex("mailAddr") then addr=gco.mailAddr
      cnt=_mailInboxCount
      bcnt=_mailBodyCount
      cdTxt=""
      w=_mailCdLeft
      if w>0 then cdTxt=GY("  CD ")+YL(ceil(w)+"s")
      _bar(GY("SESSION ")+WH(addr)+GY("  INBOX ")+WH(_s(cnt))+GY("  READ ")+WH(_s(bcnt))+cdTxt)
    else
      _bar(GY("Not logged in"))
    end if
    ch=_menu("mail",_mailActs)
    if not ch then continue
    if _mb(ch) then break
    ca=_arg1(ch.trim)
    _mailMenuGo(ca[0],ca[1])
  end while
end function
_mainStatus=function
  mt="no";if metax then mt="ok"
  ct="no";if crypto then ct="ok"
  rb="no";if _crRainOk then rb="ok"
  s="mx "+mt+" cr "+ct+" rb "+rb+" rs "+_s(gco.rshell_servers.len)+"/"+_s(gco.rshell_shells.len)
  if not _hasNet(_lc) then s=s+" off"
  if gco.pivots.len then s=s+" pv "+_s(gco.pivots.len)
  if isPivot then
    pComp=_HC(_ls)
    s=s+" "+_gu(_ls)+"@"+pComp.public_ip
  end if
  return s
end function
_crHome=function;u=_gu(_ls);if u=="root" then return "/root";return "/home/"+u;end function
_crPwdDir=function;return _crHome+"/Documents/passwords";end function
_crRainDir=function;return _crHome+"/Documents/rainbow";end function
_crIsMd5=function(h);return h and h.len and h.matches("^[a-f0-9]{32}$");end function
_crEnsure=function
  if not gco.hasIndex("rainbow") or not gco.rainbow then gco.rainbow={}
  if not gco.hasIndex("crWords") then gco.crWords=[]
end function
_crAL=function(w,r)
  _crEnsure
  if w and not gco.crWords.len then _crLoadWords("")
  if r and not _crRainCount and _crRainOk then _crLoadRain("")
end function
_crRainOk=function
  _crEnsure
  for k in gco.rainbow.indexes;return true;end for
  d=_lc.File(_crRainDir)
  if not d or not is_folder(d) then return false
  f=get_files(d)
  if f and f.len>0 then return true
  return false
end function
_crRainFind=function(h)
  d=_lc.File(_crRainDir)
  if not d or not is_folder(d) then return
  sp=":"+h
  for f in get_files(d)
    ct=get_content(f)
    if not ct then continue
    pos=indexOf(ct,sp)
    if pos==null then continue
    ls=pos-1
    while ls>0 and ct[ls]!=char(10);ls=ls-1;end while
    if ct[ls]==char(10) then ls=ls+1
    return ct[ls:pos]
  end for
end function
_crRH=function(h)
  if not _crIsMd5(h) then return
  h=h.lower
  _crEnsure
  if hasIndex(gco.rainbow,h) then return gco.rainbow[h]
  p=_crRainFind(h)
  if p then gco.rainbow[h]=p;return p
end function
_crH=function(h)
  if not _crIsMd5(h) then return
  h=h.lower
  p=_crRH(h)
  if p then return p
  hc=_homeCrypto()
  if hc then return hc.decipher(h)
end function
_crResolve=function(h)
  if not h or not h.len then return
  p=_crH(h)
  if p then return p
  if not _crIsMd5(h) then return h
end function
_cd=function(h)
  p=_crResolve(h)
  if p then return GN(p)
  return GY(h)
end function
_credTh=function(cols)
  cl="HASH"
  if _crRainOk or crypto then cl="PASSWORD"
  cols.push([cl,0])
  _th(cols)
end function
_crCap=function(s)
  if s.len<2 then return upper(s)
  return upper(s[0])+s[1:]
end function
_crLo1=function(s)
  if s.len<2 then return lower(s)
  return lower(s[0])+s[1:]
end function
_crRainAdd=function(t)
  if not t or not t.len then return
  _crEnsure
  c=t[0]
  if c.matches("[0-9]") then
    gco.rainbow[md5(t)]=t
    return
  end if
  if not c.matches("[a-z]") and not c.matches("[A-Z]") then
    gco.rainbow[md5(t)]=t
    return
  end if
  if c.matches("[a-z]") then
    gco.rainbow[md5(_crCap(t))]=_crCap(t)
    gco.rainbow[md5(t)]=t
    return
  end if
  if c.matches("[A-Z]") then
    gco.rainbow[md5(t)]=t
    gco.rainbow[md5(_crLo1(t))]=_crLo1(t)
  end if
end function
_crFileWords=function(f)
  if not f or is_folder(f) or is_binary(f) then return []
  ct=get_content(f)
  if not ct then return []
  return split(ct,char(10))
end function
_crProg=function(l,n,s)
  if not s then s=5000
  if n>0 and n%s==0 then _plog(l+" "+_s(n)+"...")
end function
_crLoadWords=function(path)
  _crEnsure
  if path and path.len then _pact("Loading words from "+path+"...") else _pact("Loading words from "+_crPwdDir+"...")
  all=[]
  if path and path.len then
    f=_lc.File(path)
    if f and is_folder(f) then
      fl=get_files(f)
      if fl then
        _plog("reading "+_s(fl.len)+" files...")
        fi=0
        for ff in fl
          if is_folder(ff) or is_binary(ff) then continue
          fi=fi+1
          _plog(_s(fi)+"/"+_s(fl.len)+" "+ff.name)
          all=all+_crFileWords(ff)
        end for
      end if
    end if
    if f and not is_folder(f) then all=_crFileWords(f)
  else
    d=_lc.File(_crPwdDir)
    if d and is_folder(d) then
      fl=get_files(d)
      if fl then
        _plog("reading "+_s(fl.len)+" files...")
        fi=0
        for ff in fl
          if is_folder(ff) or is_binary(ff) then continue
          fi=fi+1
          _plog(_s(fi)+"/"+_s(fl.len)+" "+ff.name)
          all=all+_crFileWords(ff)
        end for
      end if
    end if
  end if
  gco.crWords=all
  if all.len then _ps("Loaded "+_s(all.len)+" passwords")
  return all.len
end function
_crLoadRain=function(path)
  _crEnsure
  n=0
  d=null
  if path and path.len then
    f=_lc.File(path)
    if f and is_folder(f) then d=f
  end if
  if not d then d=_lc.File(_crRainDir)
  if not d or not is_folder(d) then return 0
  fl=get_files(d)
  if not fl or not fl.len then return 0
  if path and path.len then _pact("Loading rainbow tables from "+d.path+" ("+_s(fl.len)+" files)...")
  for f in fl
    ct=get_content(f)
    if not ct then continue
    for line in split(ct,char(10))
      if not line then continue
      parts=line.split(":")
      if parts.len==2 and _crIsMd5(parts[1]) then
        gco.rainbow[_tl(parts[1])]=parts[0]
        n=n+1
      end if
    end for
  end for
  if n then _ps("Loaded "+_s(n)+" rainbow entries")
  return n
end function
_crGenRain=function
  _crEnsure
  if not gco.crWords.len then return 0
  wc=gco.crWords.len
  _pact("Generating MD5 rainbow hashes from "+_s(wc)+" words...")
  s=0
  for t in gco.crWords
    if not t or not t.len then continue
    _crRainAdd(t.trim)
    s=s+1
    _crProg("  hashed",s,5000)
  end for
  if s then _ps("Generated "+_s(s)+" rainbow entries in memory")
  return s
end function
_crMkRainDir=function
  if not _lc.File(_crHome+"/Documents") then _lc.create_folder(_crHome,"Documents")
  if not _lc.File(_crRainDir) then _lc.create_folder(_crHome+"/Documents","rainbow")
end function
_crRainCount=function
  _crEnsure
  n=0
  for k in gco.rainbow.indexes;n=n+1;end for
  return n
end function
_crDumpRain=function
  _crEnsure
  if not _crRainCount then return _pe("No rainbow entries to dump")
  rc=_crRainCount
  _pact("Writing "+_s(rc)+" rainbow entries to "+_crRainDir+"...")
  _crMkRainDir
  p=_crRainDir
  rd=_lc.File(p)
  if rd then
    fl=get_files(rd)
    if fl and fl.len then
      _plog("clearing "+_s(fl.len)+" old rainbow files...")
      for f in fl;delete(f);end for
    end if
  end if
  r=[]
  cc=0
  fi=0
  wi=0
  for h in gco.rainbow.indexes
    wi=wi+1
    _crProg("  packing entries",wi,10000)
    pw=gco.rainbow[h]
    line=pw+":"+h
    ll=len(line)+1
    if cc+ll>160000 and r.len then
      _plog("writing rainbow file r"+_s(fi)+"...")
      _lc.touch(p,"r"+_s(fi))
      rf=_lc.File(p+"/r"+_s(fi))
      if rf then rf.set_content(r.join(char(10)))
      r=[]
      cc=0
      fi=fi+1
    end if
    r.push(line)
    cc=cc+ll
  end for
  if r.len then
    _plog("writing rainbow file r"+_s(fi)+"...")
    _lc.touch(p,"r"+_s(fi))
    rf=_lc.File(p+"/r"+_s(fi))
    if rf then rf.set_content(r.join(char(10)))
  end if
  _ps("Dumped rainbow to "+p+" ("+_s(fi+1)+" files)")
end function
_crCrackOne=function(label,h)
  _crAL(0,1)
  p=_crH(h)
  if p then _pfnd(label+" -> "+p);return p
  _plog(label+" not cracked")
end function
_crPollQ=function
  if _crPi=="q" then return true
  return false
end function
_crCrackEmail=function(addr,h)
  _crAL(1,1)
  p=null
  if h and h.len then p=_crH(h)
  if p then
    _pfnd(addr+" -> "+p)
    r=mail_login(addr,p)
    if r and not r isa string then _ls.launch("/usr/bin/Mail.exe","-login")
    return p
  end if
  if gco.crWords.len then
    _pact("Trying wordlist against "+addr+"... (q to cancel)")
    for pw in gco.crWords
      if _crPollQ then return
      r=mail_login(addr,pw)
      if r and not r isa string then
        _pfnd(addr+" -> "+pw)
        _ls.launch("/usr/bin/Mail.exe","-login")
        return pw
      end if
    end for
  end if
  _plog(addr+" not cracked")
end function
_crParseTarget=function(line)
  line=line.trim
  if not line.len then return
  if _crIsMd5(line) then return {"t":"md5","h":line.lower}
  parts=line.split(":")
  if parts.len<2 then
    if indexOf(line,"@")!=null then return {"t":"email","a":line,"h":null}
    return
  end if
  user=parts[0]
  h=parts[1].trim.lower
  if not _crIsMd5(h) then return
  if indexOf(user,"@")!=null then return {"t":"email","a":user,"h":h}
  return {"t":"user","u":user,"h":h}
end function
_crOpenFile=function(t)
  ex=null
  if gco.hasIndex("_crEx") and gco._crEx then ex=gco._crEx
  if ex then
    rp=_resolveRemotePath(ex,t)
    f=getFileEx(ex,rp)
    if f and not is_folder(f) then return f
  end if
  fp=_resolveLocalPath(_ls,t)
  f=_lc.File(fp)
  if not f then f=_lc.File(t)
  if f and not is_folder(f) then return f
  if not ex and _ls and _isRemoteHost(_ls) then
    rp=_resolveRemotePath(_ls,t)
    f=getFileEx(_ls,rp)
    if f and not is_folder(f) then return f
  end if
end function
_crFileLines=function(f)
  if not f or is_folder(f) then return
  ct=f.get_content
  if not ct then return
  return split(ct,char(10))
end function
_crRunTarget=function(t)
  t=t.trim
  if indexOf(t,"/")!=null or t[0]=="~" then
    f=_crOpenFile(t)
    if not f then return _pe("File not found: "+t)
    lines=_crFileLines(f)
    if not lines then return _pe("Cannot read "+f.path)
    n=0
    for line in lines
      if not line or not line.trim.len then continue
      item=_crParseTarget(line)
      if not item then continue
      n=n+1
      if item.t=="email" then _crCrackEmail(item.a,item.h)
      if item.t=="md5" then _crCrackOne(item.h,item.h)
      if item.t=="user" then _crCrackOne(item.u,item.h)
    end for
    if not n then _pe("No crackable hashes in "+f.path)
    return
  end if
  item=_crParseTarget(t)
  if not item then return _pe("Bad target (md5 user:hash email file)")
  if item.t=="email" then _crCrackEmail(item.a,item.h)
  if item.t=="md5" then _crCrackOne(item.h,item.h)
  if item.t=="user" then _crCrackOne(item.u,item.h)
end function
_crMenuGo=function(act,args)
  if act=="help" then
    _showHelp("crack")
    return "cont"
  end if
  if act=="l" then
    n=_crLoadWords(args)
    if not n then _pe("No passwords loaded")
    return "ok"
  end if
  if act=="r" then
    n=_crLoadRain(args)
    if not n then _pe("No rainbow loaded")
    return "ok"
  end if
  if act=="g" then
    _crAL(1,0)
    if not gco.crWords.len then _pe("Load words first")
    if gco.crWords.len then _crGenRain
    return "ok"
  end if
  if act=="d" then
    _crDumpRain
    return "ok"
  end if
  if act=="c" then
    tgt=args.trim
    if not tgt.len then tgt=_ask("md5 user:hash email email:hash file")
    if tgt.len then
      _pact("Cracking "+tgt.trim+"...")
      _crRunTarget(tgt.trim)
    end if
    return "ok"
  end if
  return "ok"
end function
_crackMenu=function
  _crEnsure
  while true
    if gco.H then break
    _scr("Crack")
    wn=_s(gco.crWords.len)
    rn=_s(_crRainCount)
    _bar(GY("WORDS ")+WH(wn)+GY("  RAINBOW ")+WH(rn)+GY("  DIR ")+YL(_crRainDir))
    ch=_menu("crack",_crActs)
    if not ch then continue
    if _mb(ch) then return
    ca=_arg1(ch.trim)
    act=ca[0]
    args=ca[1]
    st=_crMenuGo(act,args)
    if st=="cont" then continue
  end while
end function
_bk=_mi("b","  Back")
_ns="Need a shell"
_en="  This exploit returned null during scan."
toRoot=function(x)
  obj=_to(x)
  if obj==_cm then return x.File("/")
  if indexOf(obj,_sh)!=null then return _HC(x).File("/")
  if obj=="file" then
    f=x
    while f.parent;f=f.parent;end while
    return f
  end if
end function
_exLip=function(x)
  obj=_to(x)
  if obj==_cm then return x.local_ip
  if indexOf(obj,_sh)!=null or obj==_fs then return _HC(x).local_ip
end function
_isRemoteHost=function(x)
  lip=_exLip(x)
  if not lip then return true
  if gco.hasIndex("home") and gco.home and lip==gco.home.lip then return false
  if gco.hasIndex("homeLIP") and lip==homeLIP then return false
  return true
end function
_resolveRemotePath=function(ex,p)
  if not p or not p.len then return p
  u=_gu(ex)
  p=p.trim
  ep=_xp(p,u)
  if ep then p=ep
  if p.indexOf("/")!=0 then
    base=_hd(u)
    if gco.hasIndex("_hostWd") and gco._hostWd then base=gco._hostWd
    p=base+"/"+p
  end if
  return p
end function
_resolveLocalPath=function(shell,p)
  if not p or not p.len then return p
  u=_gu(shell)
  p=p.trim
  ep=_xp(p,u)
  if ep then p=ep
  if p.indexOf("/")!=0 then p=_hd(u)+"/"+p
  return p
end function
_gue=function(x)
  obj=_to(x)
  root=null
  if obj==_cm then
    root=x.File("/")
  else if indexOf(obj,_sh)!=null or obj==_fs then
    root=_HC(x).File("/")
  else if obj=="file" then
    root=toRoot(x)
  end if
  if not root then return {"name":_gt,"user":_gt,"home":null}
  g=null
  for f in root.get_folders
    if f.name=="root" and _hp(f,"w") and _hp(f,"r") and _hp(f,"x") then return {"name":"root","user":"root","home":f}
    if f.name=="home" then
      for h in f.get_folders
        if h.name==_gt then
          g=h
          continue
        end if
        if _hp(h,"w") and _hp(h,"r") and _hp(h,"x") then return {"name":h.name,"user":"user","home":h}
      end for
      if g then return {"name":_gt,"user":_gt,"home":g}
      break
    end if
  end for
  return {"name":_gt,"user":_gt,"home":root}
end function
_rgu=function(x);u=_gue(x);if u then return u.name;return _gt;end function
_gu=function(x);return _rgu(x);end function
getAllFiles=function(root)
  l=[]
  _=function(f);for z in f.get_files; l.push(z); end for;for d in f.get_folders;if d.is_symlink then continue;l.push(d);_(d);end for;end function
  _(root)
  return l
end function
getFileEx=function(x,p)
  obj=_to(x)
  if obj==_cm then return x.File(p)
  if indexOf(obj,_sh)!=null then return _HC(x).File(p)
  if obj=="file" then
    root=toRoot(x)
    if not root then return
    for f in getAllFiles(root);if f.path==p then return f;end for
  end if
end function
_cur=function
  pv=gco.pivots
  if pv and pv.len>0 then return pv[pv.len-1]
  return gco.home
end function
_scn=function;return gco.home;end function
_0dayMonths=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]
_0dayDays=[31,28,31,30,31,30,31,31,30,31,30,31]
_getMonthDays=function(month,year);return _0dayDays[_0dayMonths.indexOf(month)]+(month=="Feb" and year%4==0);end function
_parseDate=function(raw)
  sep=raw.split("-")
  ds=sep[0].split("/")
  ts=sep[1].split(":")
  return {"day":_ti(ds[0]),"month":ds[1],"year":_ti(ds[2]),"hour":_ti(ts[0]),"min":_ti(ts[1])}
end function
_unixTs=function
  d=_parseDate(current_date)
  m=_0dayMonths.indexOf(d.month)+1
  y=d.year-(m<=2)
  era=y;if y<0 then era=y-399;era=floor(era/400)
  yoe=floor(y-era*400)
  if m>2 then t=m-3 else t=m+9
  doy=floor((153*t+2)/5+d.day-1)
  doe=floor(yoe*365+yoe/4-yoe/100+doy)
  ep=floor(era*146097+doe-719468+1)
  return (ep*24+d.hour)*3600+d.min*60
end function
_minsToIrlSecs=function(mins);return mins*(60/14);end function
_secsToHuman=function(secs)
  d=floor(secs/3600/24)
  h=floor(secs/3600)%24
  m=floor(secs/60)%60
  s=floor(secs)%60
  parts=[]
  if d>0 then parts.push(_s(d)+"d")
  if h>0 then parts.push(_s(h)+"h")
  if m>0 then parts.push(_s(m)+"m")
  if s>0 then parts.push(_s(s)+"s")
  if not parts then return "0s"
  return parts.join(" ")
end function
_getNext0dayMins=function(min,hour,day,month,year)
  mi=_0dayMonths.indexOf(month)+1
  dr=_getMonthDays(month,year)-day
  if mi%2==0 then dr=dr+_getMonthDays(_0dayMonths[mi%_0dayMonths.len],year)
  hr=23-hour%24
  mr=60-min
  hr=hr+dr*24
  mr=mr+hr*60
  return mr
end function
_remaining0day=function(raw)
  d=_parseDate(raw)
  mi=_0dayMonths.indexOf(d.month)+1
  if mi%2!=0 then return
  if d.day>=15 then return
  rd=14-d.day
  rh=24-d.hour+(rd*24)
  rm=60-d.min+(rh*60)
  return _secsToHuman(_minsToIrlSecs(rm))
end function
_calculate0day=function(raw)
d=_parseDate(raw);mins=_getNext0dayMins(d.min,d.hour,d.day,d.month,d.year);return _secsToHuman(_minsToIrlSecs(mins))
end function
_show0dayStatus=function
  raw=current_date
  rem=_remaining0day(raw)
  if rem then
    _p GN("[0DAY] ")+WH("ACTIVE! ")+YL(rem)+WH(" remaining (IRL)")
  else
    nxt=_calculate0day(raw)
    _p RD("[0DAY] ")+WH("Inactive. Next cycle in ")+YL(nxt)+WH(" (IRL)")
  end if
  d=_parseDate(raw)
  _p GY("  Game date: "+raw)
  mi=_0dayMonths.indexOf(d.month)+1
  if mi%2==0 and d.day<15 then
    _p GY("  Window: Day 1-14 of even months")
    _p GY("  Current: Day "+_s(d.day)+" of "+d.month+" (even month)")
  else
    if mi%2==0 then
      _p GY("  Day "+_s(d.day)+" of "+d.month+" — past day 14, window closed")
    else
      nextM=_0dayMonths[mi%_0dayMonths.len]
      _p GY("  Next window: "+nextM+" day 1-14")
    end if
  end if
end function
_sw=function(s,p);return s.indexOf(p)==0;end function
_arg1=function(inp)
  sp=inp.indexOf(" ")
  if sp==null then return [inp.lower,""]
  return [inp[0:sp].lower,inp[sp+1:].trim]
end function
_argToks=function(s)
  if not s or not s.len then return []
  return s.split(" ")
end function
_apExpand=function(toks)
  out=[]
  for t in toks
    if t.len>2 and t[0]=="-" and t[1]!="-" then
      j=1
      while j<t.len;out.push("-"+t[j]);j+=1;end while
    else
      out.push(t)
    end if
  end for
  return out
end function
_apFlags=function(spec,toks)
  out={"rest":[]}
  for k in spec.indexes
    if spec[k][1]=="flag" then out[k]=false
    if spec[k][1]=="store" then out[k]=""
  end for
  i=0
  while i<toks.len
    t=toks[i]
    if not t or not t.len then
      i+=1
      continue
    end if
    if t[0]!="-" then
      out.rest.push(t)
      i+=1
      continue
    end if
    found=false
    for k in spec.indexes
      s=spec[k]
      if t=="-"+s[0] or t=="--"+k then
        found=true
        if s[1]=="flag" then out[k]=true
        if s[1]=="store" then
          i+=1
          if i>=toks.len then return _pe("Missing value for "+t)
          out[k]=toks[i]
        end if
        break
      end if
    end for
    if not found then return _pe("Unknown flag: "+t)
    i+=1
  end while
  return out
end function
_scanSpec={"local":["l","flag"],"lan":["n","flag"],"random":["r","flag"]}
_mainScanTarget=function(tgt)
  if _vi(tgt) then
    _scanTarget(tgt)
  else
    ip=nslookup(tgt)
    if not ip then
      _pe("Cannot resolve: "+tgt)
    else
      _ps(tgt+" -> "+ip)
      _scanTarget(ip)
    end if
  end if
end function
_mainScan=function(args)
  toks=_apExpand(_argToks(args))
  p=_apFlags(_scanSpec,toks)
  if not p then return
  if p.local then return localScan(_ls)
  if p.lan then return scanLAN(_ls)
  if p.random then
    ip=getRandomIP
    if not ip then _pe("No random IP") else _scanTarget(ip)
    return
  end if
  if p.rest.len then return _mainScanTarget(p.rest[0])
  _pe("Usage: sc <ip> | sc -l | sc -n | r")
end function
_ma={"sc":"scan","ls":"scan","ns":"scan","w":"whois","whois":"whois","r":"random","random":"random","rc":"recon","recon":"recon","ht":"hunt","hunt":"hunt","cr":"crack","crack":"crack","ml":"mail","mail":"mail","email":"mail","em":"mail","cl":"clear","clear":"clear","dg":"dig","dig":"dig","po":"pobject","pobject":"pobject","wf":"wifi","wifi":"wifi","pv":"pivots","pivots":"pivots","h":"host","host":"host","rs":"rshell","rshell":"rshell","nr":"neuro","neuro":"neuro","0d":"0day","0day":"0day","rl":"reload","reload":"reload","?":"help","help":"help","x":"exit","exit":"exit","scan":"scan"}
_mainAlias=function(c)
  if _ma.hasIndex(c) then return _ma[c]
  return c
end function
_ha={"w":"whois","i":"whois","whois":"whois","c":"crack","passwd":"passwd","pw":"passwd","k":"md5","md5":"md5","cr":"crack","crack":"crack","ml":"mail","mail":"mail","email":"mail","em":"mail","cl":"clear","clear":"clear","rc":"recon","recon":"recon","ht":"hunt","hunt":"hunt","s":"su","su":"su","a":"apps","apps":"apps","l":"local","local":"local","n":"lan","lan":"lan","dg":"dig","dig":"dig","f":"browse","browse":"browse","seek":"seek","d":"download","download":"download","r":"rename","rename":"rename","u":"upload","upload":"upload","ul":"uploadlib","uploadlib":"uploadlib","pc":"cached","cached":"cached","p":"passwords","passwords":"passwords","rs":"rshell","rshell":"rshell","dv":"devices","devices":"devices","wf":"wifi","wifi":"wifi","po":"pobject","pobject":"pobject","g":"grab","grab":"grab","pv":"pivot","pivot":"pivot","dy":"deploy","deploy":"deploy","0d":"0day","0day":"0day","ld":"loadlib","load":"loadlib","loadlib":"loadlib","lg":"getlog","getlog":"getlog","tr":"tree","tree":"tree","rl":"reload","reload":"reload","wl":"wipe","wipe":"wipe","?":"help","help":"help"}
_hcAlias=function(c)
  if _ha.hasIndex(c) then return _ha[c]
  return c
end function
_nx=function(h)
  if h.len then
    _pe("Unknown args — type help")
    return true
  end if
end function
_resolveTarget=function(t)
  t=t.trim
  if not t.len then return
  if _vi(t) then return t
  return nslookup(t)
end function
_ct=function(c,v);return c.indexOf(v)!=null;end function
_slvExtract=function(s,mark,d=" ")
  st=s.indexOf(mark)
  if st==null then return
  sub=s[st+mark.len:]
  ep=sub.indexOf(d)
  if ep==null then return sub
  return sub[:ep]
end function
_slvExtractVar=function(s,mark)
  w=_slvExtract(s,mark," ")
  if w==null then return
  c=w.indexOf(",")
  if c!=null then w=w[:c]
  return w
end function
_slvInsert=function(arr,idx,items);if not items isa list then items=[items];return arr[:idx+1]+items+arr[idx+1:];end function
_slvLineType=function(l)
  if _sw(l,"func_") then return "function"
  if _sw(l,"if ") then return "if"
  if _sw(l,"for ") then return "for"
  if _ct(l,"push") then return "listPush"
  if _ct(l,"[") and _ct(l,"]") then return "listSet"
  if _ct(l,"end") then return "end"
  return "other"
end function
_slvMath={"is equal to ":"== ","is not equal to ":"!= ","is greater than or equal to ":">= ","is less than or equal to ":"<= ","is greater than ":"> ","is less than ":"< ","minus ":"- ","plus ":"+ ","multiplied by ":"* ","multiplying it by ":"{VARNAME} * ","divided by ":"/ ","dividing it by ":"{VARNAME} / "}
_slvEq=function(s,v="{VARNAME}")
  for k in _slvMath.indexes;s=s.replace(k,_slvMath[k]);end for
  s=s.replace("{VARNAME}",v)
  l=s.split(" ")
  if l.len==3 and (l[1]=="*" or l[1]=="+") then
    if l[2]=="i" or len(l[2])>len(l[1]) then l.reverse
  end if
  return l.join(" ")
end function
_slvForRange=function(s);s=s.split(" to ");return "range("+s[0]+", "+s[1]+")";end function
_slvVD=function(V,fn,vn);if V[fn].indexOf(vn)==null then V[fn].push(vn);end function
_slvVU=function(V,A,fn,vn)
  if V[fn].indexOf(vn)==null then
    if A[fn].indexOf(vn)==null then A[fn].push(vn)
    V[fn].push(vn)
  end if
end function
_slvInitParse=function(r)
  p=[]
  i=[]
  for l in r.split(char(10))
    l=l.trim
    if l=="" or l=="Potential problems have been found in the following code:" then continue
    if l.indexOf(":")==null then i=i+l.split("\.") else p.push(l[l.indexOf(":")+2:])
  end for
  return {"program":p,"info":i}
end function
_slvParseInfo=function(info)
  if not info or not info isa list or not info.len then return
  F=null
  V={}
  A={}
  p=info[0:]
  n=0
  while n<p.len
    l=p[n].trim
    if n!=0 and p[n-1]==p[n] and p[n]=="" then
      p.remove(n)
      continue
    end if
    if _sw(l,"and ") then l=l[4:]
    if _sw(l,"then ") then l=l[5:]
    parsed=null
    if _sw(l,"The function ") then
      fn=l[13:24]
      V[fn]=[]
      A[fn]=[]
      F=fn
      clauses=l[25:].split(", ")
      r=[fn+" = function"]
      if _sw(clauses[0],"For each") or _sw(clauses[0],"If ") then r.push(clauses.join(", ")) else r=r+clauses
      parsed={_rl:r}
    else if _sw(l,"If the value of ") then
      parts=l.split(", ")
      r=["if "+_slvEq(parts[0][16:])+" then"]
      r=r+parts[1:]
      r.push("end if")
      parsed={_rl:r}
    else if _sw(l,"For each ") then
      lv=l[9:]
      lv=lv[:indexOf(lv," ")]
      rs=l[indexOf(l,lv)+lv.len+1:]
      rs=rs[:indexOf(rs,", ")]
      if _sw(rs,"from ") then rs=rs[5:]
      _slvVD(V,F,"i")
      body=l.split(", ")[1:]
      r=["for "+lv+" in "+_slvForRange(rs)]
      r=r+body
      r.push("end for")
      parsed={_rl:r}
    else if _sw(l,"creates a list ") then
      vn=_slvExtractVar(l,"creates a list ")
      _slvVD(V,F,vn)
      r=[vn+" = []"]
      r=r+l.split(", ")[1:]
      parsed={_rl:r}
    else if _sw(l,"assigns ") then
      tv=_slvExtract(l,"assigns "," ")
      _slvVD(V,F,tv)
      sa=_slvExtract(l," to the first element of "," ")
      _slvVU(V,A,F,sa)
      parsed={_rl:[tv+" = "+sa+"[0]"]}
    else if _sw(l,"calls the function ") then
      fn2=_slvExtract(l,"calls the function "," ")
      av=_slvExtract(l," with "," ")
      _slvVU(V,A,F,av)
      parsed={_rl:[av+" = "+fn2+"("+av+")"]}
    else if _sw(l,"adds ") then
      val=_slvExtract(l,"adds "," ")
      _slvVU(V,A,F,val)
      ln2=_slvExtract(l," to "," ")
      _slvVU(V,A,F,ln2)
      parsed={_rl:[ln2+".push("+val+")"]}
    else if _sw(l,"calculates ") then
      rv=_slvExtract(l,"calculates "," ")
      _slvVU(V,A,F,rv)
      parsed={_rl:[rv+" = "+_slvEq(l[11:],rv)]}
    else if _sw(l,"updates ") then
      uv=_slvExtract(l,"updates "," ")
      _slvVU(V,A,F,uv)
      expr=l[indexOf(l," by ")+4:]
      if _sw(expr,"calculating ") then expr=expr[12:]
      parsed={_rl:[uv+" = "+_slvEq(expr,uv)]}
    else if _sw(l,"Finally, it") then
      p[n]=l[11:]
      continue
    else if _sw(l,"returns ") then
      parsed={_rl:["return "+_slvEq(l[8:]),"end function"]}
    else
      p[n]=l
      n=n+1
      continue
    end if
    if parsed and parsed.result then
      p[n]=parsed.result[0]
      if parsed.result.len>1 then p=_slvInsert(p,n,parsed.result[1:])
    end if
    n=n+1
  end while
  out=[]
  indent=0
  for l in p
    y=_slvLineType(l)
    if y=="end" then indent=indent-1
    if y=="function" then
      m=l[:indexOf(l," ")]
      l=m+" = function("+join(A[m],", ")+")"
    end if
    out.push("    "*indent+l)
    if _ct(["function","if","for"],y) then indent=indent+1
  end for
  return out
end function
_slvSimilarity=function(a,b)
  y=a
  z=b
  a=a.split(" ")
  b=b.split(" ")
  bm={}
  for x in b;bm[x]=true;end for
  am={}
  for x in a;am[x]=true;end for
  s=0
  for x in a;if bm.hasIndex(x) then s=s+x.len+0.1;end for
  for x in b;if not am.hasIndex(x) then s=s-0.1;end for
  s=s-abs(y.len-z.len)/10
  return s
end function
_slvWrongTokens=function(a,b)
  y=a.split(" ")
  z=b.split(" ")
  am={}
  for x in y;am[x]=true;end for
  bm={}
  for x in z;bm[x]=true;end for
  s=0
  for x in am.indexes;if hasIndex(bm,x) then s=s+1;end for
  return (am.indexes.len-s+bm.indexes.len-s)/2
end function
_slvCompare=function(p,i)
  if not p or not i or not p.len or not i.len then return []
  r=[]
  a=0
  b=0
  while a<i.len and b<p.len
    c=p[b]!=i[a]
    if c and b<p.len and a+1<i.len then
      if _slvWrongTokens(p[b],i[a])>0.5 then
        if _slvLineType(p[b])!=_slvLineType(i[a]) then
          r.push(b+1)
          b=b-1
          c=false
        else
          ok=true
          offset=0
          while offset<=2
            pi=b+offset
            ii=a+offset+1
            if pi>=p.len or ii>=i.len then break
            cs=_slvSimilarity(p[pi],i[a+offset])
            ns=_slvSimilarity(p[pi],i[ii])
            if not (ns>cs or p[pi]==i[ii]) then
              ok=false
              break
            end if
            offset=offset+1
          end while
          if ok then
            r.push(b+1)
            b=b-1
            c=false
          end if
        end if
      end if
    end if
    if c then r.push(b+1)
    b=b+1
    a=a+1
  end while
  out=[]
  for x in r;if out.indexOf(x)==null then out.push(x);end for
  return out
end function
_slvSolve=function(raw)
  r=_slvInitParse(raw)
  f=_slvParseInfo(r.info)
  if not f then return
  u=_slvCompare(r.program,f)
  return {"errors":u,"patch":f}
end function
_hasNet=function(c);p=c.public_ip;return p and p!="0.0.0.0";end function
_classifyEx=function(ex,ln)
  if not ex then
    if ln==_kr then return ["bounce",""]
    return ["null",""]
  end if
  if ex isa number then
    if ln==_kr then return ["firewall",""]
    return [_uk,""]
  end if
  obj=_to(ex)
  if obj==_fs then obj=_sh
  if obj==_sh then return [_sh,_rgu(ex)]
  if obj==_cm then
    if ln==_kr then return ["bounce",""]
    return [_cm,_rgu(ex)]
  end if
  if obj=="file" then return ["file",_rgu(ex)]
  return [_uk,""]
end function
_exTag=function(e)
  t=e.type
  tc=@GY
  if t==_sh then tc=@GN
  if t==_cm then tc=@YL
  if t=="file" then tc=@RD
  if t=="bounce" then tc=@PR
  if t=="firewall" then tc=@LM
  ut=@GY;uv="-"
  if e.user=="root" then ut=@GN;uv=e.user
  if e.user==_gt then ut=@RD;uv=e.user
  if e.user!="" and e.user!="root" and e.user!=_gt then ut=@YL;uv=e.user
  return WH(_lj(_s(e.i),5))+tc(_lj(t,12))+ut(_lj(uv,12))+BL(_lj(e.addr,14))+GY(e.val)
end function
_exFilterTok=function(t)
  if not t or not t.len then return
  t=_tl(t)
  if t=="all" or t=="*" then return
  if t=="sh" or t=="shell" then return _sh
  if t=="co" or t=="computer" or t=="cm" then return _cm
  if t=="fi" or t=="file" then return "file"
  if t=="bo" or t=="bounce" then return "bounce"
  if t=="fw" or t=="firewall" then return "firewall"
  if t=="nu" or t=="null" then return "null"
  if t=="un" or t=="unknown" then return _uk
end function
_exFiltered=function(exploits,ftype)
  if not ftype then return exploits
  r=[]
  for e in exploits;if e.type==ftype then r.push(e);end for
  return r
end function
_exCountType=function(tgt,t)
  n=0
  if not tgt or not tgt.exploits then return 0
  for e in tgt.exploits;if e.type==t then n=n+1;end for
  return n
end function
_exPickFilter=function(inp,cur)
  t=inp.trim
  if _sw(_tl(t),"f ") then
    ft=_exFilterTok(t[2:])
    if ft==null and _tl(t[2:])!="all" then return ["err","Unknown type: "+t[2:],cur]
    return ["ok",ft,""]
  end if
  if _tl(t)=="f" then return ["ok",null,""]
  return ["skip","",cur]
end function
_exTypeLabel=function(t)
  if t==_sh then return "shell"
  if t==_cm then return "computer"
  if t=="file" then return "file"
  if t=="bounce" then return "bounce"
  if t=="firewall" then return "firewall"
  if t=="null" then return "null"
  return t
end function
_exFilterTotal=function(list,ftype)
  n=0
  for tgt in list;n=n+_exCountType(tgt,ftype);end for
  return n
end function
_tgtCountsLine=function(tgt)
  if tgt.hasIndex("ct") then return WH("Sh")+OR(":")+GN(_s(tgt.ct.shells))+YL(" - ")+WH("Co")+OR(":")+YL(_s(tgt.ct.computers))+YL(" - ")+WH("Fi")+OR(":")+RD(_s(tgt.ct.files))+YL(" - ")+WH("Bo")+OR(":")+PR(_s(tgt.ct.bounces))+YL(" - ")+WH("Un")+OR(":")+ER(_s(tgt.ct.unknown))
  bd=""
  if tgt.hasIndex("port") and tgt.port==0 then bd=YL(" - ")+WH("Bo")+OR(":")+PR(_s(tgt.bounces))+YL(" - ")+WH("Fw")+OR(":")+LM(_s(tgt.firewalls))
  return WH("Sh")+OR(":")+GN(_s(tgt.shells))+YL(" - ")+WH("Co")+OR(":")+YL(_s(tgt.computers))+YL(" - ")+WH("Fi")+OR(":")+RD(_s(tgt.files))+bd+YL(" - ")+WH("Un")+OR(":")+ER(_s(tgt.unknown))
end function
_tgtTotal=function(tgt)
  if tgt.hasIndex("total") then return tgt.total
  return tgt.shells+tgt.computers+tgt.files+tgt.bounces+tgt.firewalls+tgt.unknown
end function
_printAttackVector=function(tgt,idx,typeFilter,showPort=false)
  t=PR("[")+WH(_s(idx))+PR("] ")+OR(tgt.ln)+WH(" (Version: "+tgt.ver+") ")
  if showPort then
    if tgt.port==0 then _p t+BL("-> ")+YL(tgt.lan)+WH(":")+GN("0") else _p t+BL("-> ")+YL(tgt.lan)+WH(":")+GN(_s(tgt.port))
  else
    _p t
  end if
  _p GN("    |-> ")+tgt.patchStr
  if typeFilter then
    exs=_exFiltered(tgt.exploits,typeFilter)
    fl=_exTypeLabel(typeFilter)
    _p "    "+WH(_s(exs.len))+" "+fl+WH(" of "+_s(_tgtTotal(tgt))+" total")
    if exs.len then
      _p GY("  #   TYPE         USER         ADDRESS        VALUE")
      for e in exs;e.i=__e_idx+1;_p "    "+_exTag(e);end for
    end if
  else
    _p "    "+GN(_s(_tgtTotal(tgt)))+WH(" exploits — ")+_tgtCountsLine(tgt)
  end if
end function
_exFilterFoot=function(ftype,showList,allList)
  fc=_exFilterTotal(showList,ftype)
  fl=_exTypeLabel(ftype)
  _p GY("  Showing ")+WH(_s(fc))+" "+fl+GY(" in ")+WH(_s(showList.len))+GY("/"+_s(allList.len)+" libs · ")+WH("#")+GY(" run · f all clears")
end function
_debugSolve=function(dLib,_am=false)
  scanResult=dLib.scan
  if not scanResult then return _pe("scan returned no results")
  _sub("Debug Scan Output")
  lines=scanResult.split(char(10))
  for line in lines;if not line then continue;_p GY(_s(__line_idx+1)+": ")+WH(line);end for
  _rule
  if _am then
    mode="a"
  else
    modeAns=_menu("solve",[["a","auto"],["m","manual"]])
    if not modeAns then return
    mode=_tl(modeAns)
  end if
  if mode=="a" or mode=="auto" then
    _pact("Auto-solving...")
    solved=_slvSolve(scanResult)
    if not solved or not solved.errors or not solved.errors.len then
      _pw("Auto-solve found no errors, switching to manual")
    else
      _ps("Error lines: "+join(solved.errors,", "))
      _sub("Corrected Code")
      for l in solved.patch;_p GY(l);end for
      _rule
      if _am then return solved
      ans=_menu("solve",[["enter","accept"],["#","override"],["m","manual"]])
      if not ans or not len(ans.trim) then return solved
      if _tl(ans)!="m" then
        errLines=[]
        for pt in ans.trim.split(" ");nn=_ti(pt.trim);if nn isa number then errLines.push(nn);end for
        if errLines then solved.errors=errLines
        return solved
      end if
      _pw("Switching to manual")
    end if
  end if
  _pact("Enter ER line numbers (space-separated)")
  ans=_ask("error lines")
  if not ans or not len(ans.trim) or _tl(ans)=="b" then return
  errLines=[]
  for pt in ans.trim.split(" ");nn=_ti(pt.trim);if nn isa number then errLines.push(nn);end for
  if not errLines then return
  return {"errors":errLines,"patch":null}
end function
_getNeuroCreds=function
  if gco.hasIndex("neuro_creds") and gco.neuro_creds then return gco.neuro_creds
  _pact("Neurobox engineer credentials required")
  u=_ask("Neurobox user")
  if not u or not u.trim.len then return
  p=_ask("Neurobox pass")
  if not p or not p.trim.len then return
  cred={"user":u.trim,"pass":p.trim}
  gco.neuro_creds=cred
  return cred
end function
// XFIX1.0: REMOVE _neuroScan + nr/neuro menus/-nr/_cmds.neuro — whois dropped "[Neurobox Network]"
_neuroScan=function
  _scr("Neurobox Scanner","find target IP via email")
  e=_ask("Email address")
  if not e or not e.trim.len then return _pe("Email required")
  e=e.trim
  p=_ask("Email password")
  if not p or not p.trim.len then return _pe("Password required")
  p=p.trim
  t=_ask("Target name (chat log)")
  if not t or not t.trim.len then return _pe("Target name required")
  t=t.trim
  partial=_ask("Partial IP (XXX=unknown)")
  if not partial or not partial.trim.len then return _pe("Partial IP required")
  partial=partial.trim
  if indexOf(partial,"XXX")==null then return _pe("IP must contain XXX as unknown octet")
  fi=indexOf(partial,"XXX")
  if indexOf(partial,"XXX",fi+3)!=null then partial=partial[:fi+3]+partial[fi+3:].replace("XXX","YYY")
  hasYYY=indexOf(partial,"YYY")!=null
  yStart=0
  skipN=10
  if hasYYY then
    ys=_ask("2nd octet start (0-255, def 0)")
    if ys and ys.trim.len then
      ys=_ti(ys.trim)
      if ys isa number and ys>=0 and ys<=255 then yStart=ys
    end if
    sk=_ask("Skip after N misses (def 10)")
    if sk and sk.trim.len then
      sk=_ti(sk.trim)
      if sk isa number and sk>=0 then skipN=sk
    end if
  end if
  M=mail_login(e,p)
  if M isa string then return _pe("Mail login failed: "+M)
  if hasYYY then
    total=(256-yStart)*256
    _ps("Authenticated. Scanning "+_s(total)+" IPs (2 octets)...")
  else
    _ps("Authenticated. Scanning 256 IPs...")
  end if
  _cd=0
  // XFIX1.0: REMOVE — whois "[Neurobox Network]" tag gone in Grey Hack 1.0
  _getNB=function(ip)
    d=whois(ip)
    if d.indexOf("Neurobox")!=null then return d.split(char(10))[0].replace("Domain name: www.","@")
  end function
  _testMail=function(addr)
    w=2-(time-outer._cd)
    if w>0.01 then wait(w)
    r=M.send(t+addr,t,t)
    outer._cd=time
    a=0
    while r==false and a<3;wait(1);a=a+1;r=M.send(t+addr,t,t);end while
    if r!=1 then return false else return true
  end function
  _tryIP=function(ip)
    d=_getNB(ip)
    if not d then return false
    _pw("Neurobox found at "+ip+" — verifying email...")
    n=_testMail(d)
    if n then
      _ps("NETWORK FOUND: "+ip)
      _ps("Domain: "+d)
      _ps("Time: "+_s(floor(time))+"s")
      return true
    end if
    return false
  end function
  if hasYYY then
    j=yStart
    while j<256
      base=partial.replace("YYY",_s(j))
      i=0
      ms=0
      while i<256
        u=base.replace("XXX",_s(i))
        i=i+1
        cnt=(j-yStart)*256+i
        if cnt%64==0 then _p GY("  Checked "+_s(cnt)+"... (YYY="+_s(j)+" XXX="+_s(i-1)+")")
        d=_getNB(u)
        if not d then
          ms=0
          continue
        end if
        _pw("Neurobox found at "+u+" — verifying email...")
        n=_testMail(d)
        if n then
          _ps("NETWORK FOUND: "+u)
          _ps("Domain: "+d)
          _ps("Time: "+_s(floor(time))+"s")
          return
        end if
        ms=ms+1
        if skipN>0 and ms>=skipN then
          _pw("Skipping octet "+_s(j)+" ("+_s(skipN)+"+ misses)")
          break
        end if
      end while
      j=j+1
    end while
  else
    i=0
    while i<256
      u=partial.replace("XXX",_s(i))
      i=i+1
      if i%16==0 then _p GY("  Checked "+_s(i)+"/256...")
      if _tryIP(u) then return
    end while
  end if
  _pw("No networks found")
end function
_patchLib=function(shell,lib)
  if not lib then return _pe("No library provided")
  if lib.is_patched then return _ps(lib.lib_name+" v"+lib.version+" already patched ("+lib.is_patched(1)+")")
  cred=_getNeuroCreds
  if not cred then return _pe("No credentials provided")
  dLib=lib.debug_tools(cred.user,cred.pass)
  if not dLib then return _pe("debug_tools returned null — bad credentials?")
  if _to(dLib)!="debugLibrary" then return _pe("debug_tools ER: "+dLib)
  _pact("Scanning "+lib.lib_name+" v"+lib.version+"...")
  solved=_debugSolve(dLib,_am)
  if not solved then return _pw("Solve aborted")
  _pact("Running unit_testing with lines: "+solved.errors.join(", "))
  testResult=dLib.unit_testing(solved.errors)
  if testResult then _p GY(testResult)
  comp=_HC(shell)
  u=_gu(shell)
  home=_hd(u)
  comp.touch(home,"_patch_.txt")
  pf=comp.File(home+"/_patch_.txt")
  if not pf then return _pe("Failed to create patch file")
  if solved.patch then
    pf.set_content(solved.patch.join(char(10)))
  else
    _pw("No auto-generated patch. Enter patch code or 'b' to abort")
    pc=_ask("patch")
    if not pc or _tl(pc)=="b" then
      qrm(comp,pf)
      return _pw("Aborted")
    end if
    pf.set_content(pc.trim)
  end if
  _pact("Applying patch...")
  r=dLib.apply_patch(pf.path)
  qrm(comp,pf)
  if r then _ps(r) else _pe("apply_patch returned null")
end function
_patchMenu=function(shell)
  comp=_HC(shell)
  rMetax=_getShellMetax(shell)
  if not rMetax then return
  libDir=comp.File("/lib")
  if not libDir then return _pe("Cannot access /lib")
  libFiles=libDir.get_files
  if not libFiles then return _pe("No libraries found in /lib")
  while true
    if gco.H then break
    _scr("Library Patching",comp.public_ip)
    _th([["#",5],["LIBRARY",25],["VERSION",12],["PATCHED",0]])
    for lf in libFiles
      i=__lf_idx+1
      ml=load(rMetax,path(lf))
      if not ml then
        _p WH(_lj(_s(i),5))+YL(_lj(name(lf),25))+GY("(cannot load)")
        continue
      end if
      p=ml.is_patched(1)
      if p isa string then
        ps=GN("Yes ("+p+")")
      else if p==1 then
        ps=GN("Yes")
      else
        ps=RD("No")
      end if
      _p WH(_lj(_s(i),5))+YL(_lj(ml.lib_name,25))+BL(_lj(ml.version,12))+ps
    end for
    c=_menu("patch",[["#","patch"],["a","all unpatched"],["b","back"]])
    if not c or _tl(c)=="b" then return
    if _tl(c)=="a" then
      for lf in libFiles
        ml=rMetax.load(path(lf))
        if not ml then continue
        if ml.is_patched then continue
        _patchLib(shell,ml)
      end for
      continue
    end if
    sel=_ti(c.trim)
    if not sel isa number or sel<1 or sel>libFiles.len then
      _pe(_iv)
      continue
    end if
    ml=rMetax.load(libFiles[sel-1].path)
    if not ml then
      _pe("Cannot load library")
      continue
    end if
    _patchLib(shell,ml)
  end while
end function
_poParsePData=function(testResult)
  mem=null
  vuln=null
  cperm=null
  fperm=null
  for l in testResult.split(char(10))
    if not l then continue
    if l.indexOf("A potential")!=null then
      mem=split(l," ")[-1]
    else if l.indexOf("New vulnerability found:")!=null then
      s=l.indexOf("<b>")
      e=l.indexOf("</b>")
      if s!=null and e!=null then vuln=l[s+3:e]
    else if l.indexOf("* Computer")!=null then
      if l.indexOf("[root]")!=null then
        cperm="root"
      else if l.indexOf("[normal_user]")!=null then
        cperm="user"
      else
        cperm=_gt
      end if
    else if l.indexOf("* File")!=null then
      if l.indexOf("[root]")!=null then
        fperm="root"
      else if l.indexOf("[normal_user]")!=null then
        fperm="user"
      else
        fperm=_gt
      end if
    end if
  end for
  return {"memory":mem,"vuln":vuln,"computer":cperm,"file":fperm}
end function
_poAcquire=function(dLib,memZone,libPath)
  _pact("Executing payload...")
  if libPath then result=dLib.payload(memZone,libPath) else result=dLib.payload(memZone)
  if not result then return _pe("payload returned null")
  if _to(result)==_sg then return _pe("payload ER: "+result)
  if not result isa list or not result.len then return _pe("Unexpected payload result: "+_to(result))
  _pc=result[0]
  pfile=null
  pmlib=null
  if result.len>=2 then pfile=result[1]
  if result.len>=3 then pmlib=result[2]
  if not _pc then return _pe("No partial computer obtained")
  _ps("Got partial computer!")
  if pfile then _ps("Got partial file!")
  if pmlib then _ps("Got partial metalib!")
  return {"_pc":_pc,"pfile":pfile,"pmlib":pmlib}
end function
_poScanLib=function(ml,dLib,_am=false)
  _pact("Scanning "+ml.lib_name+" v"+ml.version+"...")
  solved=_debugSolve(dLib,_am)
  if not solved then return
  _pact("Running unit_testing...")
  testResult=dLib.unit_testing(solved.errors)
  if not testResult then return _pe("unit_testing returned null")
  _p GY(testResult)
  pd=_poParsePData(testResult)
  if pd.memory then
    _ps("Auto-detected memory zone: "+pd.memory)
    if pd.computer then _ps("Computer: ["+pd.computer+"]")
    if pd.file then _ps("File: ["+pd.file+"]")
    if not _am then
      ov=_ask("Memory zone (enter="+pd.memory+")")
      if ov and len(ov.trim) then pd.memory=ov.trim
    end if
  else
    _pw("Could not auto-detect memory zone")
    mz=_ask("Memory zone (0x...)")
    if not mz or not len(mz.trim) then return
    pd.memory=mz.trim
  end if
  _poSaveExploit(ml,pd)
  return {"dLib":dLib,"pd":pd,"ml":ml}
end function
_poSaveExploit=function(ml,pd)
  if not pd.vuln or not pd.memory then return
  entry=ml.lib_name+" v"+ml.version+" @ "+pd.memory+" "+pd.vuln
  comp=_HC(get_shell)
  u=_gu(get_shell)
  home=_hd(u)
  f=comp.File(home+"/0day_exploits")
  if f then
    content=_gc(f)
    if content then
      for line in content.split(char(10));if line==entry then return;end for
      f.set_content(content+char(10)+entry)
    else
      f.set_content(entry)
    end if
  else
    comp.touch(home,"0day_exploits")
    f=comp.File(home+"/0day_exploits")
    if f then f.set_content(entry)
  end if
  _ps("Saved exploit: "+entry)
end function
_pObjectMenu=function(_poShell=null)
  sMx=_homeMetax()
  if not sMx then return _pe("Scan metax not loaded")
  _psh=_poShell
  if not _psh then _psh=_ls
  if _atHome(_psh) and not _poShell then
    oMx=sMx
    comp=_lc
  else if _poShell then
    oMx=_grM(_poShell)
    if not oMx then return _pe("Cannot load metaxploit on remote")
    comp=_HC(_poShell)
  else
    oMx=_getShellMetax(_psh)
    if not oMx then return _pe("No metax")
    comp=_HC(_psh)
  end if
  libDir=comp.File("/lib")
  pip=comp.public_ip
  lip=comp.local_ip
  if _atHome(_psh) and not _poShell then router=_gr(pip) else router=_grR(_psh)
  _al={}
  _lo=[]
  libCache={}
  _cc={}
  fmap={_ch:_ch,"cp":"copy","mv":"move","rm":"delete","rename":"rename","rn":"rename","chown":"set_owner","chgrp":"set_group"}
  curDLib=null
  curPD=null
  curML=null
  _pc=null
  pfile=null
  pmlib=null
  _tip=null
  while true
    if gco.H then break
    _scr("PObject Interface",pip)
    _p GY("  Public: ")+YL(pip)+GY("   Local: ")+YL(lip)
    if router then
      _sub("Edge Router Ports ("+router.local_ip+")")
      _p YL("  0   ")+GN(_lj(router.local_ip,16))+WH("kernel_router")
      for p in router.used_ports;if p.is_closed then continue;_p YL("  "+_lj(_s(_pn(p)),4))+GN(_lj(p.get_lan_ip,16))+WH(router.port_info(p));end for
    end if
    if libDir then
      _sub("Local Libraries /lib")
      libFiles=libDir.get_files
      if libFiles then
        for lf in libFiles
          ml2=oMx.load(lf.path)
          if ml2 then
            pt=ml2.is_patched(1)
            if pt isa string then
              ps=GN(" [P:"+pt+"]")
            else if pt==1 then
              ps=GN(" [P]")
            else
              ps=""
            end if
            _p GY("  "+_lj(_s(__lf_idx+1),4))+YL(_lj(lf.name,22))+BL(ml2.version)+ps
          else
            _p GY("  "+_lj(_s(__lf_idx+1),4))+YL(_lj(lf.name,22))+GY("(cannot load)")
          end if
        end for
      end if
    end if
    _p ""
    if _am then am=GN("ON") else am=GY("OFF")
    _p GY("  Auto-accept prompts: ")+am
    _p GY("  Scan input: ip:port, lib name/path, or # from list")
    _psh=_poShell
    if not _psh then _psh=_ls
    // XFIX1.0: REMOVE ["nr","neuro"] + nr branch below
    acts=[["scan","scan"],["nr","neuro"],["auto","toggle"]]
    if _psh and _gu(_psh)=="root" then acts.push(["pt","patch libs"])
    acts.push(["b","back"])
    c=_menu("po",acts)
    if not c or _tl(c)=="b" then return
    ch=c.trim
    if ch.lower=="nr" then
      _neuroScan
      continue
    end if
    if ch.lower=="auto" or ch.lower=="a" then
      _am=not _am
      if _am then _ps("Auto mode ON") else _pw("Auto mode OFF")
      continue
    end if
    if ch.lower=="pt" then
      _psh=_poShell
      if not _psh then _psh=_ls
      if _psh and _gu(_psh)=="root" then _patchMenu(_psh) else _pe("Root shell required")
      continue
    end if
    if ch.lower[:5]=="scan " then ch=trim(ch[5:])
    ml=null
    libPath=null
    sn=_ti(ch)
    if sn isa number and libFiles and sn>=1 and sn<=libFiles.len then ch=libFiles[sn-1].name
    chParts=split(ch," ")
    if chParts.len==2 and _vi(chParts[0]) then ch=chParts[0]+":"+chParts[1]
    if ch.indexOf(":")!=null then
      rp=ch.split(":")
      ip=rp[0]
      pt=_ti(rp[1])
      if not _vi(ip) or not pt isa number then
        _pe("Format: ip:port (e.g. 1.2.3.4:22)")
        continue
      end if
      _pact("Connecting to "+ip+":"+_s(pt)+"...")
      ml=dump_lib(net_use(oMx,ip,pt))
      if not ml then
        _pe("dump_lib returned null for "+ip+":"+_s(pt))
        continue
      end if
      if _to(ml)==_sg then
        _pe("dump_lib ER: "+ml)
        continue
      end if
      libPath="/lib/"+lib_name(ml)
    else
      lch=ch.lower
      if lch.indexOf("/")==null then lch="/lib/"+lch
      if lch.indexOf(".so")==null then lch=lch+".so"
      ml=oMx.load(lch)
      if not ml then
        _pe("Cannot load "+lch)
        continue
      end if
      libPath=lch
    end if
    if ml.is_patched(1) then
      _ps(ml.lib_name+" v"+ml.version+" patched "+ml.is_patched(1))
      continue
    end if
    cred=_getNeuroCreds
    if not cred then continue
    dLib=ml.debug_tools(cred.user,cred.pass)
    if not dLib then
      _pe("debug_tools returned null")
      continue
    end if
    if _to(dLib)!="debugLibrary" then
      _pe("debug_tools ER: "+dLib)
      continue
    end if
    sr=_poScanLib(ml,dLib,_am)
    if not sr then continue
    po=_poAcquire(sr.dLib,sr.pd.memory,libPath)
    if not po then continue
    curDLib=sr.dLib
    curPD=sr.pd
    curML=ml
    if pip then _tip=pip
    gco._eip=_tip
    _pc=po._pc
    pfile=po.pfile
    pmlib=po.pmlib
    ref={"file":"file","create_folder":"mkdir","touch":"touch","show_procs":"ps","change_password":"passwd","create_user":"useradd","delete_user":"userdel","create_group":"groupadd","delete_group":"groupdel","close_program":"kill"}
    fileRef={_ch:_ch,"copy":"cp","move":"mv","rename":"rn","delete":"rm","set_owner":"chown","set_group":"chgrp"}
    _cm2=[]
    _fm=[]
    for idx in _pc.__isa.indexes;if ref.hasIndex(idx) then _cm2.push(ref[idx]);end for
    if pfile then
      for idx in pfile.__isa.indexes;if fileRef.hasIndex(idx) then _fm.push(fileRef[idx]);end for
    end if
    pm={}
    _autoFn=function;outer._am=not _am;if _am then _ps("Auto mode ON") else _pw("Auto mode OFF");end function
    pm.auto=@_autoFn
    pm.a=@_autoFn
    pm.probe=function
      if not argv.len then return _pw("Usage: probe <path>")
      pp=argv[0]
      r=curDLib.payload(curPD.memory,pp)
      if r isa list and r.len>=2 and _to(r[1])=="pfile" then _pe("Exists: "+pp,"s") else _pw("Not found: "+pp)
    end function
    pm.meta=function
      mlib=null
      if argv.len and _al.hasIndex(argv[0]) then
        mlib=_al[argv[0]][2]
      else if argv.len and argv[0].indexOf(".so")==null and _al.hasIndex(argv[0]+".so") then
        mlib=_al[argv[0]+".so"][2]
      else
        mlib=curML
      end if
      if not mlib then return _pe("No metalib available")
      mAddrs=sMx.scan(mlib)
      if not mAddrs then return _pe("scan returned no addresses for "+mlib.lib_name)
      mExploits=[]
      lk=mlib.lib_name+"_"+mlib.version
      for ma in mAddrs
        vi=sMx.scan_address(mlib,ma)
        if not vi then continue
        for vl in vi.split(char(10))
          if vl.indexOf(_uc)==0 then
            s=vl.indexOf("<b>")+3
            d=vl.indexOf("</b>")
            if s>2 and d!=null then mExploits.push({"addr":ma,"val":vl[s:d]})
          end if
        end for
      end for
      if not mExploits then return _pe("No exploits found for "+mlib.lib_name)
      _pact("Running "+_s(mExploits.len)+" exploits...")
      oArg=null
      if _al.hasIndex(_kr) then
        rr=null
        if _tip then rr=_gr(_tip)
        if rr then oArg=rr.local_ip
      end if
      mResults=[]
      for me in mExploits
        if oArg then ex=mlib.overflow(me.addr,me.val,oArg) else ex=mlib.overflow(me.addr,me.val)
        ot=_to(ex)
        etype=_uk
        euser=""
        if ot==_sh or ot==_fs then
          etype=_sh
          euser=_gu(ex)
        else if ot==_cm then
          etype=_cm
          euser=_gu(ex)
        else if ot=="file" then
          etype="file"
        else if not ex then
          etype="null"
        else if ex isa number then
          etype="firewall"
        else
          etype=_s(ot)
        end if
        mResults.push({"addr":me.addr,"val":me.val,"ex":ex,"type":etype,"user":euser})
        if not _cc.hasIndex(lk) then _cc[lk]={"a":me.addr,"v":me.val}
      end for
      while true
        if gco.H then break
        _sub("Exploits: "+mlib.lib_name+" v"+mlib.version)
        _ei=1
        for mr in mResults
          tc=@GY
          if mr.type==_sh then tc=@GN
          if mr.type==_cm then tc=@BL
          if mr.type=="file" then tc=@YL
          ul=""
          if mr.user then ul=GY(" (")+WH(mr.user)+GY(")")
          _p GY(_lj(_s(_ei),4))+YL(mr.addr)+GY(" -> ")+tc(mr.type)+ul
          _ei=_ei+1
        end for
        ma2=_menu("meta",[["#","run"],["b","back"]])
        if not ma2 or _tl(ma2)=="b" then break
        mi=_ti(ma2.trim)
        if not mi isa number or mi<1 or mi>mResults.len then
          _pe(_iv)
          continue
        end if
        mr=mResults[mi-1]
        if mr.type==_sh or mr.type==_cm or mr.type=="file" then _exM(mr.ex,mr.type) else _pw(mr.addr+" -> "+mr.type+" ("+_s(mr.ex)+")")
      end while
    end function
    pm.methods=function
      _p ""
      _p OR("Computer methods:")
      for idx in _pc.__isa.indexes;_p "  "+GN(idx);end for
      if pfile then
        _p OR("File methods:")
        for idx in pfile.__isa.indexes;_p "  "+GN(idx);end for
      end if
    end function
    pm.ports=function
      rr=null
      if _tip then rr=_gr(_tip)
      if not rr then rr=router
      if rr then
        _p YL("  0   ")+GN(_lj(_s(local_ip(rr)),16))+WH("kernel_router")
        for p in used_ports(rr);if is_closed(p) then continue;_p YL("  "+_lj(_s(_pn(p)),4))+GN(_lj(get_lan_ip(p),16))+WH(port_info(rr,p));end for
      else
        _pw("No router available")
      end if
    end function
    pm.libs=function
      _libs=["init.so","kernel_module.so",_kr,"net.so","aptclient.so","crypto.so","metaxploit.so","libssh.so","libftp.so","libhttp.so","libsmtp.so","libsql.so","librshell.so","librepository.so","libcam.so","libchat.so","libsmartappliance.so","libtrafficnet.so"]
      _ln=1
      outer._al={}
      outer._lo=[]
      for l in _libs
        r=curDLib.payload(curPD.memory,"/lib/"+l)
        if r isa list and r.len==3 then
          rm=r[2]
          pt=rm.is_patched(1)
          if pt isa string then
            ps=GN(" [P:"+pt+"]")
          else if pt==1 then
            ps=GN(" [P]")
          else
            ps=""
          end if
          _p GY(_lj(_s(_ln),4))+YL(_lj(l,22))+BL(rm.version)+ps
          _al[l]=r
          _lo.push(l)
          _ln=_ln+1
        end if
      end for
      if libCache and libCache.len then
        _p OR("Cached partial libs:")
        for k in libCache.indexes;_p "  "+YL(k);end for
      end if
    end function
    pm.scan=function
      if not argv.len then return _pw("Usage: scan <lib name|port>")
      sp=_ti(argv[0])
      if not sp isa number then
        lk=trim(argv[0])
        if lk.indexOf(".so")==null then lk=lk+".so"
        if _al.hasIndex(lk) and _al[lk] isa list then
          nml=_al[lk][2]
        else
          nml=null
          r=curDLib.payload(curPD.memory,"/lib/"+lk)
          if r isa list and r.len==3 then
            nml=r[2]
            _al[lk]=r
          end if
        end if
        if not nml then return _pe("Library "+lk+" not found on target")
        lp="/lib/"+lk
      else if sp>20 or sp==0 then
        tip=_tip
        if not tip then tip=pip
        _pact("Connecting to "+_s(tip)+":"+_s(sp)+"...")
        nml=dump_lib(net_use(oMx,tip,sp))
        if not nml or _to(nml)==_sg then return _pe("Failed to get lib from port "+_s(sp))
        lp="/lib/"+nml.lib_name
      else
        if not _lo or sp<1 or sp>_lo.len then return _pe("Invalid lib # (run libs first)")
        lk=_lo[sp-1]
        nml=_al[lk][2]
        if not nml then return _pe("Cannot load library")
        lp="/lib/"+lk
      end if
      if nml.is_patched then return _ps(nml.lib_name+" patched "+nml.is_patched(1))
      cred=_getNeuroCreds
      if not cred then return
      nd=nml.debug_tools(cred.user,cred.pass)
      if not nd or _to(nd)!="debugLibrary" then return _pe("debug_tools failed")
      sr=_poScanLib(nml,nd,_am)
      if not sr then return
      po=_poAcquire(sr.dLib,sr.pd.memory,lp)
      if not po then return
      outer.curDLib=sr.dLib
      outer.curPD=sr.pd
      outer.curML=nml
      outer._pc=po._pc
      outer.pfile=po.pfile
      outer.pmlib=po.pmlib
      outer._cm2=[]
      outer._fm=[]
      for idx in _pc.__isa.indexes;if ref.hasIndex(idx) then _cm2.push(ref[idx]);end for
      if pfile then
        for idx in pfile.__isa.indexes;if fileRef.hasIndex(idx) then _fm.push(fileRef[idx]);end for
      end if
    end function
    pm.mkdir=function
      if not argv.len then return _p(GY("mkdir <path>"))
      if _pc.__isa.hasIndex("create_folder") then
        r=_pc.create_folder(argv[0])
        if r==1 then
          _ps("Done")
          _poCommit(oMx,pmlib,_al,_cc)
        else if r isa string then
          _p GY(r)
        end if
      end if
    end function
    pm.touch=function
      if argv.len<2 then return _p(GY("touch <dir> <name>"))
      if _pc.__isa.hasIndex("touch") then
        r=_pc.touch(argv[0],argv[1])
        if r==1 then
          _ps("Done")
          _poCommit(oMx,pmlib,_al,_cc)
        else if r isa string then
          _p GY(r)
        end if
      end if
    end function
    pm.ps=function
      if _pc.__isa.hasIndex("show_procs") then
        r=_pc.show_procs
        if r then
          for p in r;_p GY(p.user+"  "+_s(p.pid)+"  "+p.program);end for
        end if
      end if
    end function
    pm.passwd=function
      if argv.len<2 then return _p(GY("passwd <user> <pass>"))
      if _pc.__isa.hasIndex("change_password") then
        r=_pc.change_password(argv[0],argv[1])
        if r==1 then
          _ps("Done")
          _poCommit(oMx,pmlib,_al,_cc)
        else if r isa string then
          _p GY(r)
        end if
      end if
    end function
    pm.useradd=function
      if argv.len<2 then return _p(GY("useradd <user> <pass>"))
      if _pc.__isa.hasIndex("create_user") then
        r=_pc.create_user(argv[0],argv[1])
        if r==1 then
          _ps("Done")
          _poCommit(oMx,pmlib,_al,_cc)
        else if r isa string then
          _p GY(r)
        end if
      end if
    end function
    pm.userdel=function
      if not argv.len then return _p(GY("userdel <user>"))
      if _pc.__isa.hasIndex("delete_user") then
        r=_pc.delete_user(argv[0])
        if r==1 then
          _ps("Done")
          _poCommit(oMx,pmlib,_al,_cc)
        else if r isa string then
          _p GY(r)
        end if
      end if
    end function
    pm.kill=function
      if not argv.len then return _p(GY("kill <pid>"))
      if _pc.__isa.hasIndex("close_program") then
        r=_pc.close_program(_ti(argv[0]))
        if r==1 then
          _ps("Done")
          _poCommit(oMx,pmlib,_al,_cc)
        else if r isa string then
          _p GY(r)
        end if
      end if
    end function
    while true
      if gco.H then break
      _scr("PObject Interpreter",curML.lib_name+" v"+curML.version)
      if _am then am=GN("  Auto Enabled") else am=GY("  Auto Disabled")
      _p GY("  Memory zone: "+curPD.memory)
      _p am
      if curPD.computer then _p GN("  Computer: ["+curPD.computer+"]")
      if curPD.file then _p GN("  File:     ["+curPD.file+"]")
      if _cm2 then _p GN("  Comp: ")+WH(join(_cm2,", "))
      if _fm then _p GN("  File: ")+WH(join(_fm,", "))
      _p GN("  scan, probe, meta, libs, ports, methods, auto, exit")
      _p ""
      cmd=_ui(PR("[PObject] ")+WH(":~$ "))
      if not cmd or not len(cmd.trim) then continue
      parts=cmd.trim.split(" ")
      c0=lower(parts[0])
      argv=parts[1:]
      if c0=="exit" or c0=="b" or c0=="back" or c0=="quit" then break
      if hasIndex(pm,c0) then
        pm[c0]
      else if fmap.hasIndex(c0) then
        fc=c0;if fc=="rn" then fc="rename"
        rflag=false
        if argv.len and (argv[0]=="-r" or argv[0]=="-R") then
          rflag=true
          argv=argv[1:]
        end if
        na=2;if fc=="rm" then na=1
        if argv.len>=na then
          pf=_poGetFile(curDLib,curPD.memory,argv[0])
          if pf and pf.__isa.hasIndex(fmap[fc]) then
            if fc=="cp" then
              dp=argv[1].split("/")
              dn=dp[-1]
              dd=dp[:-1].join("/")
              if not dd then dd="/"
              r=pf.copy(dd,dn)
            else if fc=="mv" then
              dp=argv[1].split("/")
              dn=dp[-1]
              dd=dp[:-1].join("/")
              if not dd then dd="/"
              r=pf.move(dd,dn)
            else if fc==_ch then
              perm=argv[1]
              if _ti(perm) isa number and perm.len==3 then
                r=null
                for ow in [[_ti(perm[0]),"u"],[_ti(perm[1]),"g"],[_ti(perm[2]),"o"]]
                  v=ow[0];w=ow[1]
                  if rflag then r=pf.chmod(w+"-rwx",rflag) else r=pf.chmod(w+"-rwx")
                  if r isa string and r.len then break
                  if bitAnd(v,4) then
                    if rflag then r=pf.chmod(w+"+r",rflag) else r=pf.chmod(w+"+r")
                    if r isa string and r.len then break
                  end if
                  if bitAnd(v,2) then
                    if rflag then r=pf.chmod(w+"+w",rflag) else r=pf.chmod(w+"+w")
                    if r isa string and r.len then break
                  end if
                  if bitAnd(v,1) then
                    if rflag then r=pf.chmod(w+"+x",rflag) else r=pf.chmod(w+"+x")
                    if r isa string and r.len then break
                  end if
                end for
              else
                if rflag then r=pf.chmod(perm,rflag) else r=pf.chmod(perm)
              end if
            else if fc=="rename" then
              r=pf.rename(argv[1])
            else if fc=="chown" then
              if rflag then r=pf.set_owner(argv[1],rflag) else r=pf.set_owner(argv[1])
            else if fc=="chgrp" then
              if rflag then r=pf.set_group(argv[1],rflag) else r=pf.set_group(argv[1])
            else
              if rflag then r=pf.delete(rflag) else r=pf.delete
            end if
            if fc=="cp" or fc=="mv" then ok=(r==1) else ok=not r
            if ok then
              _ps("Done")
              _poCommit(oMx,pmlib,_al,_cc)
            else if r isa string then
              _p GY(r)
            end if
          end if
        else
          u={_ch:"[-r] <path> <perm|octal>","cp":"<path> <dst>","mv":"<path> <dst>","rm":"[-r] <path>","rename":"<path> <name>","chown":"[-r] <path> <user>","chgrp":"[-r] <path> <grp>"}
          _p GY(c0+" "+u[fc])
          if fc==_ch then _p GY("  octal: 777=rwx 755=rwxr-xr-x 700=rwx------ 644=rw-r--r--")
        end if
      else
        _pw("Unknown: "+c0)
      end if
    end while
  end while
end function
_poCommit=function(oMx,ml,aLibs,cache)
  sMx=_homeMetax()
  libs=[]
  if ml then libs.push(ml)
  if aLibs then
    for k in aLibs.indexes
      if aLibs[k] isa list and len(aLibs[k])==3 and aLibs[k][2] then
        al=aLibs[k][2]
        if al!=ml then libs.push(al)
      end if
    end for
  end if
  for lb in libs;lk=lb.lib_name+"_"+lb.version;if cache.hasIndex(lk) then return lb.overflow(cache[lk].a,cache[lk].v);end for
  if not sMx then return
  for lb in libs
    a=sMx.scan(lb)
    if not a then continue
    vi=sMx.scan_address(lb,a[0])
    if not vi then continue
    for l in vi.split(char(10))
      if l.indexOf(_uc)==0 then
        s=l.indexOf("<b>")+3
        d=l.indexOf("</b>")
        if s>2 and d!=null then
          lk=lb.lib_name+"_"+lb.version
          cache[lk]={"a":a[0],"v":l[s:d]}
          return lb.overflow(a[0],l[s:d])
        end if
      end if
    end for
  end for
end function
_poGetFile=function(dLib,memZone,filePath)
  r=dLib.payload(memZone,filePath)
  if not r then return _pe("payload returned null for "+filePath)
  if _to(r)==_sg then return _pe("payload ER: "+r)
  if not r isa list then return _pe("Unexpected result")
  for obj in r;if _to(obj)=="pfile" then return obj;end for
  return _pe("No pfile in payload result for "+filePath)
end function
_ppw=function(passwdFile)
  content=passwdFile.get_content
  if not content then
    _pw("passwd file is empty")
    return []
  end if
  entries=[]
  for line in split(content,char(10))
    if not line or not line.len then continue
    parts=line.split(":")
    if parts.len<2 then continue
    entries.push({"user":parts[0],"hash":parts[1]})
  end for
  if not entries then
    _pw("No accounts found")
    return []
  end if
  _credTh([["#",5],["USER",16]])
  for e in entries;i=__e_idx+1;_p WH(_lj(_s(i),5))+WH(_lj(e.user,16))+_cd(e.hash);end for
  cracked=[]
  _crAL(1,1)
  for e in entries
    p=_crH(e.hash)
    if not p then p=_crResolve(e.hash)
    if p then cracked.push({"user":e.user,"pass":p})
  end for
  if cracked.len==entries.len then return cracked
  if not _homeCrypto() and not _crRainCount and not gco.crWords.len then return cracked
  while true
    if gco.H then return cracked
    ans=_menu("crack",[["#","crack"],["a","all"],["b","skip"]])
    if not ans or _tl(ans)=="b" then return cracked
    if _tl(ans)=="a" then
      for e in entries
        _p YL("["+_s(__e_idx+1)+"/"+_s(entries.len)+"] ")+GY("Cracking "+e.user+"...")
        pass=_crH(e.hash)
        if not pass then
          _p WH(_lj(e.user,16))+RD("failed")
        else
          _p WH(_lj(e.user,16))+GN(pass)
          cracked.push({"user":e.user,"pass":pass})
        end if
      end for
      return cracked
    end if
    sel=_ti(ans.trim)
    if not sel isa number or sel<1 or sel>entries.len then
      _pe(_iv)
      continue
    end if
    e=entries[sel-1]
    _pact("Cracking "+e.user+"...")
    pass=_crH(e.hash)
    if not pass then
      _p WH(_lj(e.user,16))+RD("failed")
    else
      _p WH(_lj(e.user,16))+GN(pass)
      cracked.push({"user":e.user,"pass":pass})
    end if
  end while
end function
wipeLog=function(x)
  obj=_to(x)
  if obj==_cm then comp=x
  if obj==_sh or obj==_fs then comp=_HC(x)
  if obj=="file" then
    root=toRoot(x)
    if not root then return _pe("Cannot resolve root from file object")
    logFile=null
    for f in getAllFiles(root)
      if f.path==_sl then
        logFile=f
        break
      end if
    end for
    if not logFile then return _pe("system.log not found")
    if not _hp(logFile,"w") then return _pe("No write permission to system.log")
    wf=null
    for f in getAllFiles(root)
      if f.path==_sl then continue
      if _hp(f,"r") and _hp(f,"w") then
        wf=f
        break
      end if
    end for
    if not wf then return _pe("No writable file found to use for wipe")
    wf.copy("/var","system.log")
    return _ps("system.log wiped")
  end if
  if not comp then return _pe("Cannot get computer from object")
  logFile=comp.File(_sl)
  if not logFile then return _pe("system.log not found")
  if not _hp(logFile,"w") then return _pe("No write permission to system.log")
  r=comp.touch("/var","_t")
  if r isa string then
    if r=="The file already exists" then comp.File("/var/_t").move("/var","system.log") else return _pe(r)
  else if r isa number then
    comp.File("/var/_t").move("/var","system.log")
  else
    return _pe("Failed to create temp file")
  end if
  _ps("system.log wiped")
end function
qrm=function(comp,f)
  if not f then return
  p=f.parent
  if not p then return
  dir=p.path
  if not comp.File(dir+"/.111111111") then comp.create_folder(dir,".111111111")
  comp.create_folder(dir+"/.111111111",".111000111")
  f.move(dir+"/.111111111/.111000111","z")
  h=comp.File(dir+"/.111111111")
  if h then h.move(dir+"/.111111111/.111000111/","bye")
end function
_cwl=function(x)
  obj=_to(x)
  if obj==_cm then
    lf=x.File(_sl)
    if lf and _hp(lf,"w") then return true
    return false
  end if
  if obj==_sh or obj==_fs then
    lf=_HC(x).File(_sl)
    if lf and _hp(lf,"w") then return true
    return false
  end if
  if obj=="file" then
    root=toRoot(x)
    if not root then return false
    for f in getAllFiles(root)
      if f.path==_sl then
        if _hp(f,"w") then return true
        return false
      end if
    end for
  end if
  return false
end function
_rnd3=function
  _n="";_l=3
  while _l>0;_n=_n+char(97+floor(rnd*26));_l=_l-1;end while
  return _n
end function
_suHome=function(ex)
  u=_gu(ex)
  comp=_HC(ex)
  home=_hd(u)
  hdir=comp.File(home)
  if not hdir or not _hp(hdir,"w") then
    home="/tmp"
    hdir=comp.File(home)
    if not hdir or not _hp(hdir,"w") then return
  end if
  return home
end function
_hfp=function(c,u)
  for line in c.split(char(10))
    if not line or not line.len then continue
    p=line.split(":")
    if p.len<2 or p[0]!=u then continue
    h=p[1]
    if not h or not h.len then return {"t":"empty"}
    if not _crIsMd5(h) then return {"t":"plain","pass":h}
    return {"t":"hash","hash":h.lower}
  end for
end function
_suDictLoop=function(u)
  nl=char(10)
  return "W=get_custom_object[""packWords""]"+nl+"for p in W"+nl+"  s=get_shell("""+u+""",p)"+nl+"  if s then"+nl+"    get_custom_object[""packPw""]=p"+nl+"    break"+nl+"  end if"+nl+"end for"
end function
_suShellLoop=function(u)
  nl=char(10)
  return "W=get_custom_object[""packWords""]"+nl+"for p in W"+nl+"  s=get_shell("""+u+""",p)"+nl+"  if s then"+nl+"    get_custom_object[""packSh""]=s"+nl+"    get_custom_object[""packPw""]=p"+nl+"    break"+nl+"  end if"+nl+"end for"
end function
_suBuild=function(ex,home,code)
  comp=_HC(ex)
  n=_rnd3()
  fn=n+_sx
  comp.touch(home,fn)
  f=comp.File(home+"/"+fn)
  if not f then return false
  f.set_content(code)
  r=ex.build(f.path,home)
  if r!="" then
    qrm(comp,f)
    _pw(_bf+r)
    return false
  end if
  gco.packSh=null
  gco.packPw=null
  ex.launch(home+"/"+n)
  f=comp.File(home+"/"+fn)
  if f then qrm(comp,f)
  f=comp.File(home+"/"+n)
  if f then qrm(comp,f)
  return true
end function
_suRun=function(ex,home,u,words)
  gco.packWords=words
  gco.packSh=null
  gco.packPw=null
  if not _suBuild(ex,home,_suShellLoop(u)) then return
  if gco.packSh then return {"shell":gco.packSh,"user":u,"pass":gco.packPw}
end function
_suProbe=function(ex,home,u,words)
  gco.packWords=words
  gco.packPw=null
  if not _suBuild(ex,home,_suDictLoop(u)) then return
  return gco.packPw
end function
_suC=function(ex,u,creds)
  if not creds or not creds.len then return
  got=[]
  for c in creds;if c.user==u then got.push(c);end for
  if not got.len then return
  if got.len==1 then
    c=got[0]
    sh=_suShell(ex,c.user,c.pass)
    if sh then return {"shell":sh,"user":c.user,"pass":c.pass}
    return
  end if
  sh=connectAs(got,ex)
  if sh then return {"shell":sh,"user":_gu(sh),"pass":null}
end function
_suDict=function(ex,u)
  if indexOf(_to(ex),_sh)==null then return
  _crAL(1,0)
  w=gco.crWords
  if not w.len then return _pw("No passwords in "+_crPwdDir)
  home=_suHome(ex)
  if not home then return
  _pact("Dict su "+_s(w.len)+"...")
  pass=_suProbe(ex,home,u,w)
  gco.packWords=null
  if not pass then return _pw("Dict su failed")
  _pd("Password",pass)
  sh=_suShell(ex,u,pass)
  if sh then return {"shell":sh,"user":u,"pass":pass}
  return _pw("Dict su failed")
end function
_suTry=function(ex,u)
  if indexOf(_to(ex),_sh)==null then return
  _crAL(0,1)
  comp=_HC(ex)
  pf=comp.File("/etc/passwd")
  pass=null
  hash=null
  if pf and _hp(pf,"r") then
    c=_gc(pf)
    if c and c.len then
      pe=_hfp(c,u)
      if pe then
        if pe.t=="empty" then pass=""
        else if pe.t=="plain" then pass=pe.pass
        else hash=pe.hash
      end if
    end if
  end if
  if pass==null and hash then pass=_crRH(hash)
  if pass!=null then
    _pd("Password",pass)
    sh=_suShell(ex,u,pass)
    if sh then return {"shell":sh,"user":u,"pass":pass}
  end if
  sr=_suDict(ex,u)
  if sr then return sr
  if hash then
    hc=_homeCrypto()
    if hc then
      pass=hc.decipher(hash)
      if pass then
        _pd("Password",pass)
        sh=_suShell(ex,u,pass)
        if sh then return {"shell":sh,"user":u,"pass":pass}
      end if
    end if
  end if
end function
_suApply=function(newShell,user,pass,sh)
  if not newShell then return
  if sh and pass!=null then _acr(sh,user,pass)
  _ps("Su successful")
  _pd("User",_gu(newShell))
  _pd("Host",_HC(newShell).public_ip)
  return newShell
end function
_suShell=function(ex,u,pass)
  if not ex or not u or pass==null then return
  home=_suHome(ex)
  if not home then return
  sr=_suRun(ex,home,u,[pass])
  if sr then return sr.shell
end function
connectAs=function(creds,ex)
  if not creds then return _pw("No cracked credentials available")
  _sub("Cracked Credentials")
  for c in creds;_p WH("  "+_s(__c_idx+1)+") ")+GN(c.user)+GY(" : ")+YL(c.pass);end for
  while true
    if gco.H then break
    ans=_menu("connect",[["#","login"],["b","skip"]])
    if not ans or not len(ans.trim) then continue
    if _tl(ans)=="b" then return
    ci=_ti(ans.trim)
    if not ci isa number or ci<1 or ci>creds.len then
      _pe(_iv)
      continue
    end if
    break
  end while
  cred=creds[ci-1]
  return _suShell(ex,cred.user,cred.pass)
end function
_atHome=function(sh);if not sh then sh=_ls;if gco.pivots.len then return false;return not _isRemoteHost(sh);end function
_shellNeedsPack=function(sh);return not _atHome(sh);end function
_getShellMetax=function(sh)
  if _atHome(sh) then return _homeMetax()
  packed=_packCO(sh)
  if not packed then return
  return packed.metax
end function
_homeMetax=function;h=gco.home;if h and h.metax then return h.metax;return metax;end function
_homeCrypto=function;h=gco.home;if h and h.crypto then return h.crypto;return crypto;end function
_opsCrypto=function(sh);if not sh then sh=_ls;if _atHome(sh) then return _homeCrypto();return crypto;end function
_mxs=function(sh)
  if not sh then sh=_ls
  s=_homeMetax()
  if not s then return
  if _atHome(sh) then return {"s":s,"n":s}
  n=_getShellMetax(sh)
  if not n then return
  return {"s":s,"n":n}
end function
_findHostMx=function(comp,home)
  for try in [home+_mx,"/lib/metaxploit.so"]
    f=comp.File(try)
    if f then return try
  end for
  libDir=comp.File("/lib")
  if libDir then
    for f in get_files(libDir);if f.name=="metaxploit.so" then return f.path;end for
  end if
  homeDir=comp.File(home)
  if homeDir then
    for f in get_files(homeDir);if f.name=="metaxploit.so" or f.name==".metaxploit.so" then return f.path;end for
  end if
end function
_packCO=function(shell,targetIp=null)
  if not _shellNeedsPack(shell) then return {"metax":metax,"router":_gr,"mpath":metaxPath}
  comp=_HC(shell)
  lip=comp.local_ip
  pip=comp.public_ip
  if not lip then lip=pip
  mk=pip+":"+lip
  if gco.hasIndex("packCOs") and gco.packCOs.hasIndex(mk) and gco.packCOs[mk] then return gco.packCOs[mk]
  hdir=_shellHomeFile(shell)
  if not hdir or not _hp(hdir,"w") then return _pe("No write permission on "+hdir.path)
  home=hdir.path
  _h=gco.home
  if gco.hasIndex("packMetaxploit") then gco.packMetaxploit=null
  if gco.hasIndex("packRouter") then gco.packRouter=null
  mpath=_findHostMx(comp,home)
  uploaded=false
  if mpath then
    _pact("Packing host metaxploit from "+mpath+"...")
  else
    if not _h.metaxPath then return _pe("metaxploit.so not loaded on main")
    _pact("Uploading metaxploit.so...")
    r=scp(_h.shell,_h.metaxPath,home,shell)
    if r isa string then return _pe("SCP failed: "+r)
    mpath=home+_mx
    uploaded=true
  end if
  if targetIp then code="get_custom_object[""packMetaxploit""]=include_lib("""+mpath+""");get_custom_object[""packRouter""]=get_router("""+targetIp+""")" else code="get_custom_object[""packMetaxploit""]=include_lib("""+mpath+""");get_custom_object[""packRouter""]=get_router"
  comp.touch(home,".x_co.src")
  f=comp.File(home+"/.x_co.src")
  if not f then return _pe("Failed to create packCO loader")
  f.set_content(code)
  _pact("Packing metaxploit...")
  r=shell.build(f.path,home)
  if r!="" then
    f=comp.File(home+"/.x_co.src")
    if f then qrm(comp,f)
    if uploaded then
      mf=comp.File(mpath)
      if mf then qrm(comp,mf)
    end if
    return _pe(_bf+r)
  end if
  shell.launch(home+"/.x_co")
  f=comp.File(home+"/.x_co.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_co")
  if f then qrm(comp,f)
  if uploaded then
    mf=comp.File(mpath)
    if mf then qrm(comp,mf)
  end if
  if not gco.hasIndex("packMetaxploit") or not gco.packMetaxploit then return _pe("Failed to pack metaxploit")
  router=null
  if gco.hasIndex("packRouter") then router=gco.packRouter
  gco.packMxPath=mpath
  result={"metax":gco.packMetaxploit,"router":router,"mpath":mpath}
  if not gco.hasIndex("packCOs") then gco.packCOs={}
  gco.packCOs[mk]=result
  _ps("Packed metaxploit for "+mk)
  return result
end function
_grM=function(shell)
  comp=_HC(shell)
  lip=comp.local_ip
  pip=comp.public_ip
  if not lip and not pip then return
  mk=pip+":"+lip
  if gco.hasIndex("metas") and gco.metas.hasIndex(mk) and gco.metas[mk] then return gco.metas[mk]
  if not lip then lip=pip
  home=_shellHomePath(shell)
  _pact("Uploading metaxploit.so...")
  _h=gco.home
  r=scp(_h.shell,_h.metaxPath,home,shell)
  if r isa string then return _pe("SCP failed: "+r)
  if gco.hasIndex("meta_local") then gco.meta_local=null
  if gco.hasIndex("router_local") then gco.router_local=null
  code="m=include_lib("""+home+"/metaxploit.so"");if not m or typeof(m)!=""MetaxploitLib"" then;_g=function;p=File(host_computer(get_shell),""/"");d=get_folders(p)+get_files(p);while len(d);f=pull(d);if is_folder(f) then d=d+get_folders(f)+get_files(f);if name(f)==""metaxploit.so"" or name(f)=="".metaxploit.so"" then;l=include_lib(path(f));if l and typeof(l)==""MetaxploitLib"" then return l;end if;end while;end function;m=_g;end if;if m then get_custom_object[""meta_local""]=m;c=host_computer(get_shell);if c.public_ip and c.public_ip!=""0.0.0.0"" then get_custom_object[""router_local""]=get_router"
  comp.touch(home,".x_m.src")
  f=comp.File(home+"/.x_m.src")
  if not f then
    f=comp.File(home+_mx)
    if f then qrm(comp,f)
    return _pe("Failed to create loader")
  end if
  f.set_content(code)
  _pact("Building loader...")
  r=shell.build(f.path,home)
  if r!="" then
    f=comp.File(home+"/.x_m.src")
    if f then qrm(comp,f)
    f=comp.File(home+_mx)
    if f then qrm(comp,f)
    return _pe(_bf+r)
  end if
  shell.launch(home+"/.x_m")
  f=comp.File(home+"/.x_m.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_m")
  if f then qrm(comp,f)
  if not gco.hasIndex("meta_local") or not gco.meta_local then
    f=comp.File(home+_mx)
    if f then qrm(comp,f)
    return _pe("Failed to load metaxploit")
  end if
  rMetax=gco.meta_local
  rRouter=null
  if gco.hasIndex("router_local") and gco.router_local then rRouter=gco.router_local
  f=comp.File(home+_mx)
  if f then qrm(comp,f)
  gco.metas[mk]=rMetax
  if rRouter then gco.routers[mk]=rRouter
  _ps("Cached metaxploit for "+mk)
  return rMetax
end function
_rlov=function(shell,libPath,addr,val,extra)
  comp=_HC(shell);home=_shellHomePath(shell);_h=gco.home
  if not _h.metaxPath then return
  mx=home+"/metaxploit.so"
  r=scp(_h.shell,_h.metaxPath,home,shell)
  if r isa string then return
  gco.lo_result="__none";eStr=""
  if extra then eStr=","""+extra+""""
  code="m=include_lib("""+mx+""");if m then;l=m.load("""+libPath+""");if l then;get_custom_object[""lo_result""]=l.overflow("""+addr+""","""+val+""""+eStr+");end if;end if"
  comp.touch(home,".x_ov.src");f=comp.File(home+"/.x_ov.src")
  if not f then
    mf=comp.File(mx);if mf then qrm(comp,mf)
    return
  end if
  f.set_content(code);r=shell.build(f.path,home)
  sf=comp.File(home+"/.x_ov.src");if sf then qrm(comp,sf)
  if r!="" then
    bf=comp.File(home+"/.x_ov");if bf then qrm(comp,bf)
    mf=comp.File(mx);if mf then qrm(comp,mf)
    return
  end if
  shell.launch(home+"/.x_ov")
  bf=comp.File(home+"/.x_ov");if bf then qrm(comp,bf)
  mf=comp.File(mx);if mf then qrm(comp,mf)
  res=gco.lo_result;gco.lo_result=null
  if res=="__none" then return
  return res
end function
localScan=function(remoteShell)
  comp=_HC(remoteShell)
  lip=comp.local_ip
  if not lip then lip=comp.public_ip
  if not lip then return _pe("Cannot determine IP for this shell")
  hMetax=_homeMetax()
  if not hMetax then return _pe("Scan metax not loaded")
  _ps("Scanning local libraries on "+lip)
  _p ""
  libDir=File(comp,"/lib")
  if not libDir then return _pe("Cannot access /lib")
  libFiles=get_files(libDir)
  if not libFiles then return _pw("No library files found in /lib")
  libList=[]
  for lf in libFiles;if name(lf)=="metaxploit.so" then continue;libList.push(lf);end for
  if not libList then return _pw("No scannable libraries found")
  lTargets=[]
  while true
    if gco.H then break
    _scr("Local Scan",lip)
    _th([["#",5],["LIBRARY",30],["PATH",0]])
    for lf in libList;i=__lf_idx+1;_p WH(_lj(_s(i),5))+YL(_lj(lf.name,30))+GY(lf.path);end for
    if lTargets then
      _sub("Previously Scanned")
      for tgt in lTargets
        i=__tgt_idx+1
        t=PR("[")+WH(_s(i))+PR("] ")+OR(tgt.ln)+WH(" (Version: "+tgt.ver+") ")
        _p t
        _p "    "+GN(_s(tgt.total))+WH(" exploits")
      end for
    end if
    if libList.len==1 and not lTargets then
      _pact("Single library, auto-scanning...")
      c="a"
    else
      c=_menu("local",[["#","scan lib"],["a","all"],["b","back"],["help","help"]])
    end if
    if not c or _tl(c)=="b" then break
    if c.trim=="help" then
      _showHelp("scan")
      continue
    end if
    scanLibs=[]
    if _tl(c)=="a" then
      scanLibs=libList
    else
      sel=_ti(c.trim)
      if not sel isa number or sel<1 or sel>libList.len then
        _pe(_iv)
        continue
      end if
      scanLibs.push(libList[sel-1])
    end if
    newLibs=[]
    for lf in scanLibs
      already=false
      for tgt in lTargets;if tgt.ln==lf.name then;already=true;break;end if;end for
      if not already then newLibs.push(lf)
    end for
    if not newLibs then
      ans=_ui(YL("[!] Already scanned. Rescan? (y/N) "))
      if ans and _tl(ans)=="y" then newLibs=scanLibs
    end if
    if newLibs then
      _pact("Scanning "+_s(newLibs.len)+" libraries...")
      _p ""
      for lf in newLibs
        tgt=_scanLocalLib(remoteShell,lf)
        if not tgt then continue
        lTargets.push(tgt)
      end for
    end if
    if not lTargets then
      _pw("No exploitable libraries found")
      if libList.len==1 then break
      continue
    end if
    typeFilter=null
    while true
      if gco.H then break
      _scr("Local Targets",lip)
      showList=lTargets
      if typeFilter then
        showList=[]
        for tgt in lTargets;if _exCountType(tgt,typeFilter)>0 then showList.push(tgt);end for
      end if
      for tgt in showList;_printAttackVector(tgt,__tgt_idx+1,typeFilter,false);end for
      if typeFilter then
        if not showList.len then _pw("No "+_exTypeLabel(typeFilter)+" exploits")
        _exFilterFoot(typeFilter,showList,lTargets)
      end if
      c=_menu("local-tgt",_tgtActs)
      if not c then continue
      if _mb(c) then break
      fp=_exPickFilter(c,typeFilter)
      if fp[0]=="err" then
        _pe(fp[1])
        continue
      end if
      if fp[0]=="ok" then
        typeFilter=fp[1]
        continue
      end if
      if c.trim=="help" then
        _showHelp("scan")
        continue
      end if
      sel=_ti(c.trim)
      if not sel isa number or sel<1 or sel>showList.len then
        _pe(_iv)
        continue
      end if
      tgt=showList[sel-1]
      _exploitMenu(tgt,"",typeFilter)
    end while
  end while
end function
_grabAccounts=function(ex)
  root=toRoot(ex)
  if not root then return _pe("Cannot resolve filesystem")
  entries=[]
  for f in getAllFiles(root)
    if f.is_folder then continue
    n=f.name
    if n!="Mail.txt" and n!="Bank.txt" then continue
    if not _hp(f,"r") then
      entries.push({"type":n.replace(".txt",""),"user":f.path,"acct":"[no read]","hash":"","path":f.path})
      continue
    end if
    content=_gc(f)
    if not content then continue
    for line in content.split(char(10))
      if not line then continue
      parts=line.split(":")
      if parts.len<2 then continue
      tag="Email"
      if n=="Bank.txt" then tag="Bank"
      pp=f.path.split("/")
      usr="?"
      for pi in range(0,pp.len)
        if pp[pi]=="home" and pi+1<pp.len then
          usr=pp[pi+1]
          break
        end if
      end for
      entries.push({"type":tag,"user":usr,"acct":parts[0],"hash":parts[1],"path":f.path})
    end for
  end for
  if not entries then return _pw("No email or bank accounts found")
  _sub("Email & Bank Accounts")
  _credTh([["#",5],["TYPE",8],["USER",14],["ACCOUNT",28]])
  for e in entries;i=__e_idx+1;if e.type=="Email" then tClr=YL(_lj(e.type,8)) else tClr=GN(_lj(e.type,8));_p WH(_lj(_s(i),5))+tClr+WH(_lj(e.user,14))+BL(_lj(e.acct,28))+_cd(e.hash);end for
  if not _homeCrypto() and not _crRainOk then return _pw("No crypto or rainbow tables — cannot crack")
  cracked=[]
  while true
    if gco.H then return cracked
    ans=_menu("crack",[["#","crack"],["a","all"],["b","skip"]])
    if not ans or _tl(ans)=="b" then return cracked
    if _tl(ans)=="a" then
      for e in entries
        if not e.hash or not e.hash.len then continue
        _p YL("["+_s(__e_idx+1)+"/"+_s(entries.len)+"] ")+GY("Cracking "+e.type+" "+e.acct+"...")
        pass=_crH(e.hash)
        if not pass then
          _p WH(_lj(e.acct,28))+RD("failed")
        else
          _p WH(_lj(e.acct,28))+GN(pass)
          cracked.push({"type":e.type,"user":e.user,"acct":e.acct,"pass":pass})
        end if
      end for
      return cracked
    end if
    sel=_ti(ans.trim)
    if not sel isa number or sel<1 or sel>entries.len then
      _pe(_iv)
      continue
    end if
    e=entries[sel-1]
    if not e.hash or not e.hash.len then
      _pe("No hash to crack")
      continue
    end if
    _pact("Cracking "+e.type+" "+e.acct+"...")
    pass=_crH(e.hash)
    if not pass then
      _p WH(_lj(e.acct,28))+RD("failed")
    else
      _p WH(_lj(e.acct,28))+GN(pass)
      cracked.push({"type":e.type,"user":e.user,"acct":e.acct,"pass":pass})
    end if
  end while
end function
_szU=["B","KB","MB","GB","TB"]
_fmtSz=function(f)
  b=val(size(f))
  i=0
  while b>1024;b=b/1024;i=i+1;end while
  return _s(round(b,2))+_szU[i]
end function
_fmtP=function(p)
  o=""
  for c in p
    if c=="r" then
      o=o+GN(c)
    else if c=="w" then
      o=o+OR(c)
    else if c=="x" then
      o=o+RD(c)
    else
      o=o+GY(c)
    end if
  end for
  return o
end function
_tree=function(ex,startPath=null)
  if startPath and startPath.len then
    root=getFileEx(ex,startPath)
    if not root then return _pe("Path not found: "+startPath)
    if not root.is_folder then return _pe("Not a directory: "+startPath)
  else
    root=toRoot(ex)
  end if
  if not root then return _pe("Cannot resolve filesystem")
  all=getAllFiles(root)
  _scr("File Tree")
  _th([["PERMS",12],["OWNER",16],["GROUP",16],["SIZE",10],["PATH",0]])
  dirs=0
  fls=0
  for f in all
    p=_fmtP(f.permissions)
    o=f.owner
    g=f.group
    if f.is_folder then
      sz="-"
      n=BL(f.path+"/")
      dirs=dirs+1
    else
      sz=_fmtSz(f)
      n=WH(f.path)
      fls=fls+1
    end if
    _p _fmtP(_lj(f.permissions,12))+GY(_lj(o,16))+GY(_lj(g,16))+YL(_lj(sz,10))+n
  end for
  _p ""
  _p GY(_s(dirs)+" directories, "+_s(fls)+" files, "+_s(all.len)+" total")
end function
_specExts=["pdf","txt","jpg","log","exe","bin"]
_specHl={"pdf":1,"jpg":1,"log":1,"bin":1}
_specDefBin=["cd","ls","ps","pwd","ifconfig","iwconfig","iwlist","cat","rm","mv","cp","ssh","ftp","mkdir","rmdir","chmod","reboot","whois","sudo","useradd","userdel","passwd","nslookup","build","touch","chown","chgrp","groupadd","groupdel","groups","kill","ping","apt-get","man","whoami","ln","scp","bash","airmon","aireplay","aircrack"]
_specDefUsr=["FileExplorer.exe","Terminal.exe","Mail.exe","Browser.exe","Notepad.exe","Settings.exe","LogViewer.exe","CodeEditor.exe","ImageViewer.exe","PDFReader.exe","Map.exe","Manual.exe","ScanLan.exe","AdminMonitor.exe"]
_specDefPaths={}
for _db in _specDefBin;_specDefPaths["/bin/"+_db]=1;end for
for _du in _specDefUsr;_specDefPaths["/usr/bin/"+_du]=1;end for
_specDefPaths["/var/system.log"]=1
_isDefSpecBin=function(f)
  if hasIndex(_specDefPaths,f.path) then return true
  return false
end function
_isSpecFile=function(f)
  if f.is_folder then return false
  n=f.name
  parts=n.split("\.")
  ext=parts[-1]
  if parts.len==1 then ext=null
  if indexOf(_specExts,ext)!=null then return true
  if f.is_binary and n.indexOf(".")==null then return true
  return false
end function
_pathInBin=function(p)
  ps=p.split("/")
  if ps.len>=2 and ps[1]=="bin" then return true
  return false
end function
_collectSpec=function(ex,includeBin=false)
  root=toRoot(ex)
  if not root then return
  hits=[]
  for f in getAllFiles(root)
    if f.is_folder then continue
    if _isDefSpecBin(f) then continue
    if not includeBin and _pathInBin(f.path) then continue
    if not _isSpecFile(f) then continue
    hits.push(f)
  end for
  return hits
end function
_showSpec=function(files,detail=false)
  if not files or not files.len then
    _p GY("  (no special files found)")
    return
  end if
  if detail then
    for f in files
      _p ""
      _p OR(f.name)
      _p GY("  Path: ")+BL(f.path)
      _p GY("  Perms: ")+_fmtP(f.permissions)+GY("  Owner: ")+WH(f.owner)+GY("  Group: ")+WH(f.group)
      if f.is_binary then
        _p GY("  Type: ")+YL("binary")+GY("  Size: ")+WH(_fmtSz(f))
      else
        _p GY("  Type: ")+BL("text")+GY("  Size: ")+WH(_fmtSz(f))
        if _hp(f,"r") then
          c=_gc(f)
          if c then
            lines=c.split(char(10))
            _p GY("  Lines: ")+WH(_s(lines.len))+GY("  Chars: ")+WH(_s(c.len))
          end if
        else
          _p RD("  No read permission")
        end if
      end if
    end for
    _p ""
    _p GY("  "+_s(files.len)+" special file(s)")
  else
    _th([["#",5],["PERMS",12],["PATH",0]])
    for f in files
      idx=__f_idx+1
      parts=f.name.split("\.")
      ext=parts[-1]
      if parts.len==1 then ext=""
      if hasIndex(_specHl,ext) then pTag=YL(f.path) else pTag=BL(f.path)
      _p WH(_lj(_s(idx),5))+_fmtP(_lj(f.permissions,12))+pTag
    end for
    _p GY("  "+_s(files.len)+" special file(s)")
  end if
end function
_seekFiles=function(ex)
  detail=false
  includeBin=false
  while true
    if gco.H then break
    opts=""
    if detail then opts=opts+" detail"
    if includeBin then opts=opts+" +bin"
    _scr("Seek Special Files","pdf txt jpg log exe bin"+opts)
    files=_collectSpec(ex,includeBin)
    if files==null then return _pe("Cannot resolve filesystem")
    _showSpec(files,detail)
    c=_menu("seek",[["#","view"],["d","detail"],["i","bin"],["r","refresh"],["b","back"]])
    if _tl(c)=="b" then return
    if not c or not c.trim.len then continue
    if _tl(c)=="d" then
      detail=not detail
      continue
    end if
    if _tl(c)=="i" then
      includeBin=not includeBin
      continue
    end if
    if _tl(c)=="r" then continue
    sel=_ti(c.trim)
    if sel isa number and sel>=1 and sel<=files.len then
      f=files[sel-1]
      if not _hp(f,"r") then
        _pe("No read permission")
        continue
      end if
      if f.is_binary then
        _plog(f.name+" (binary, "+_fmtSz(f)+")")
      else
        content=_gc(f)
        if not content then
          _pw("File is empty")
        else
          _sub(f.name)
          _p content
        end if
      end if
    else
      _pe(_iv)
    end if
  end while
end function
_bfParse=function(s)
  if not s or not s.len then return ["",""]
  p=s.trim;sp=p.indexOf(" ")
  if sp==null then return [p,""]
  return [p[0:sp],p[sp+1:].trim]
end function
_bfFile=function(ex,sh,f,args)
  if f.is_binary then
    if _to(ex)==_cm or _to(ex)=="file" or not sh then return _pe("Need shell to launch")
    if not _hp(f,"x") then return _pe("No execute permission")
    fp=f.path
    if args and args.len then r=sh.launch(fp,args) else r=sh.launch(fp)
    if r==1 or r==true then return _ps("Launched "+f.name)
    if r isa string then return _pe(r)
    return _pw("Launch failed")
  end if
  if not _hp(f,"r") then return _pe("No read permission")
  ct=_gc(f)
  if not ct then return _pw("Empty or unreadable")
  _sub(f.name)
  _p ct
end function
_bfGo=function(ex,u,cur,raw)
  if not raw or not raw.len then return
  p=raw.trim
  if not p or not p.len then return
  if not u then u=_gu(ex)
  xp=_xp(p,u);if xp then p=xp
  if p.indexOf("/")!=0 then;bp=cur.path;if bp=="/" then p="/"+p else p=bp+"/"+p;end if
  return getFileEx(ex,p)
end function
browseFiles=function(ex,u=null,startPath=null,sh=null)
  root=toRoot(ex)
  if not root then return _pe("Cannot resolve filesystem")
  if not sh then
    if gco.hasIndex("_hs") and gco._hs then sh=gco._hs
    if not sh and indexOf(_to(ex),_sh)!=null then sh=ex
    if not sh and _to(ex)==_fs then sh=ex
  end if
  cur=root
  if startPath and startPath.len then
    xu=u
    if not xu then xu=_gu(ex)
    sp=_xp(startPath,xu)
    if sp then
      hf=getFileEx(ex,sp)
      if hf and hf.is_folder then cur=hf
      if hf and not hf.is_folder and hf.parent then cur=hf.parent
      if not hf then _pe("Path not found: "+sp)
    end if
  else if u then
    hp=_hd(u)
    hf=null
    obj=_to(ex)
    if obj==_cm then
      hf=ex.File(hp)
    else if indexOf(obj,_sh)!=null then
      hf=_HC(ex).File(hp)
    end if
    if hf then cur=hf
  end if
  hist=[]
  interesting=["Bank.txt","Mail.txt","Browser.txt","passwd","shadow","system.log",".key","authorized_keys"]
  while true
    if gco.H then break
    _scr("File Browser",cur.path)
    folders=cur.get_folders
    files=cur.get_files
    items=[]
    if folders then
      for f in folders;items.push({"obj":f,"isDir":true});end for
    end if
    if files then
      for f in files;items.push({"obj":f,"isDir":false});end for
    end if
    if not items then
      _p GY("  (empty)")
    else
      _th([["#",5],["PERMS",12],["OWNER",16],["GROUP",16],["SIZE",10],["NAME",0]])
      for it in items
        idx=__it_idx+1
        f=it.obj
        p=f.permissions
        o=f.owner
        g=f.group
        sz="-"
        if not it.isDir then sz=_fmtSz(f)
        n=f.name
        isInteresting=false;
        for iName in interesting;if n.indexOf(iName)!=null then;isInteresting=true;break;end if;end for
        if it.isDir then
          nTag=BL(n+"/")
        else if isInteresting then
          nTag=YL(n)+RD(" *")
        else
          nTag=WH(n)
        end if
        _p WH(_lj(_s(idx),5))+_fmtP(_lj(p,12))+GY(_lj(o,16))+GY(_lj(g,16))+GY(_lj(sz,10))+nTag
      end for
    end if
    c=_menu("files",[["#","open (+args)"],["b","back"],["x","exit"]])
    if c then c=c.trim else c=""
    if not c.len then
      p=cur.parent
      if p then;hist.push(cur);cur=p;end if
      continue
    end if
    if _tl(c)=="x" then return
    if _tl(c)=="b" then
      if hist.len then cur=hist.pop
      continue
    end if
    pa=_bfParse(c)
    sel=_ti(pa[0])
    args=pa[1]
    f=null
    if sel isa number and sel>=1 and sel<=items.len then
      f=items[sel-1].obj
    else
      f=_bfGo(ex,u,cur,pa[0])
      if not f then
        _pe("Not found: "+pa[0])
        continue
      end if
    end if
    if f.is_folder then
      hist.push(cur)
      cur=f
    else
      _bfFile(ex,sh,f,args)
    end if
  end while
end function
downloadFile=function(ex,rpath=null,rShell=null)
  root=toRoot(ex)
  if not root then return _pe("Cannot resolve filesystem")
  lShell=gco.home.shell
  isPv=_cur!=gco.home
  if isPv and not rpath then
    ch=_ask("Download to (m=main/p=pivot)")
    if ch and _tl(ch)=="p" then lShell=_cur.shell
  end if
  lComp=_HC(lShell)
  lUser=_gu(lShell)
  lHome=_hd(lUser)
  saveTo=lHome+"/Downloads/"
  if rpath and rpath.len then
    p=rpath.trim
    _p GY("  Download from remote -> save to ")+YL(saveTo)
  else
    _p ""
    _p GY("  Download from remote host -> your machine")
    _p GY("  Saves to ")+YL(saveTo)
    p=_ask("Remote file path ('b' cancel)")
    if not p or _tl(p)=="b" then return
    p=p.trim
  end if
  p=_resolveRemotePath(ex,p)
  target=getFileEx(ex,p)
  if not target then return _pe("File not found: "+p)
  if target.is_folder then return _pe("Cannot download a folder")
  if not _hp(target,"r") then return _pe("No read permission")
  dlDir=lComp.File(lHome+"/Downloads")
  if not dlDir then
    r=lComp.create_folder(lHome,"Downloads")
    if r isa string then return _pe(r)
  end if
  remoteShell=rShell
  if not remoteShell then
    obj=_to(ex)
    if indexOf(obj,_sh)!=null or obj==_fs then remoteShell=ex
  end if
  if remoteShell then
    r=remoteShell.scp(p,lHome+"/Downloads",lShell)
    if r isa string then return _pe("SCP failed: "+r)
    _ps("Downloaded "+target.name+" -> "+lHome+"/Downloads/"+target.name)
  else
    content=_gc(target)
    if content==null then return _pe("Cannot read file (binary — need shell for scp)")
    fn=target.name
    existing=lComp.File(lHome+"/Downloads/"+fn)
    if existing then fn=fn+"_"+_s(floor(rnd*9999))
    r=lComp.touch(lHome+"/Downloads",fn)
    if r isa string then return _pe(r)
    df=lComp.File(lHome+"/Downloads/"+fn)
    if not df then return _pe("Failed to create local file")
    set_content(df,content)
    _ps("Downloaded "+target.name+" -> "+lHome+"/Downloads/"+fn)
  end if
end function
_hostComp=function(ex,exType)
  if exType==_cm then return ex
  if exType==_sh then return _HC(ex)
end function
_hostHasFs=function(ex,exType)
  if exType==_cm or exType==_sh then return true
  if _to(ex)=="file" and toRoot(ex) then return true
  return false
end function
_hostFile=function(comp,ex,p)
  if not p or not p.len then return
  rp=_resolveRemotePath(ex,p.trim)
  if comp then
    pf=comp.File(rp)
    if pf then return pf
  end if
  return getFileEx(ex,rp)
end function
_hostListDir=function(comp,ex,u,path)
  if not path or not path.len then
    if gco.hasIndex("_hostWd") and gco._hostWd then path=gco._hostWd else path=_hd(u)
  else
    path=_resolveRemotePath(ex,path)
  end if
  df=null
  if comp then df=comp.File(path)
  if not df then df=getFileEx(ex,path)
  if not df then return _pe("Not found: "+path)
  if not df.is_folder then return _pe("Not a directory: "+path)
  if not _hp(df,"r") then return _pe("No read permission")
  folders=df.get_folders
  files=df.get_files
  if folders then
    for f in folders
      if _hp(f,"r") then p=_fmtP(f.permissions) else p=RD("??????")
      _p GY("d")+p+GY(" ")+WH(f.owner)+GY(":")+WH(f.group)+GY(" ")+BL(f.name+"/")
    end for
  end if
  if files then
    for f in files
      if _hp(f,"r") then p=_fmtP(f.permissions) else p=RD("??????")
      _p GY("-")+p+GY(" ")+WH(f.owner)+GY(":")+WH(f.group)+GY(" ")+WH(_fmtSz(f))+GY(" ")+BL(f.name)
    end for
  end if
end function
_downloadLog=function(ex,shell)
  lShell=gco.home.shell
  lComp=_HC(lShell)
  lUser=_gu(lShell)
  lHome=_hd(lUser)
  comp=null
  if shell then
    comp=_HC(shell)
  else if _to(ex)==_cm then
    comp=ex
  else
    comp=_HC(ex)
  end if
  if not comp then return _pe("Cannot resolve host")
  pip=comp.public_ip
  lip=comp.local_ip
  logName=pip+"-"+lip+".log"
  target=getFileEx(ex,_sl)
  if not target then return _pe("system.log not found")
  if not _hp(target,"r") then return _pe("No read permission on system.log")
  dlDir=lComp.File(lHome+"/Downloads")
  if not dlDir then
    r=lComp.create_folder(lHome,"Downloads")
    if r isa string then return _pe(r)
  end if
  if shell then
    r=shell.scp(_sl,lHome+"/Downloads",lShell)
    if r isa string then return _pe("SCP failed: "+r)
    df=lComp.File(lHome+"/Downloads/system.log")
    if not df then return _pe("Download failed")
  else
    content=_gc(target)
    if content==null then return _pe("Cannot read system.log (need shell)")
    r=lComp.touch(lHome+"/Downloads","system.log")
    if r isa string then return _pe(r)
    df=lComp.File(lHome+"/Downloads/system.log")
    if not df then return _pe("Failed to create local file")
    set_content(df,content)
  end if
  old=lComp.File(lHome+"/Downloads/"+logName)
  if old then qrm(lComp,old)
  mr=df.move(lHome+"/Downloads",logName)
  if mr==1 or mr==true or mr=="" then
    _ps("Downloaded system.log -> "+lHome+"/Downloads/"+logName)
  else if mr isa string and mr.len then
    _pe(mr)
  else
    _ps("Downloaded -> "+lHome+"/Downloads/"+logName)
  end if
end function
_hostFileCmd=function(shell,comp,ex,exType,u,line)
  _pt=trim(line).split(" ")
  if not _pt.len then return
  _cmd=_tl(_pt[0])
  _args=""
  if _pt.len>1 then _args=_pt[1:].join(" ")
  rflag=false
  if _args.len and (_args.lower.indexOf("-r")!=null or _args.lower.indexOf("-R")!=null) then rflag=true
  if _cmd==_ch and _pt.len>=3 then
    perm=null
    tp=_pt[-1]
    for _ptok in _pt[1:];if _ti(_ptok) isa number and _ptok.len==3 then perm=_ptok;end for
    if perm then
      pf=_hostFile(comp,ex,tp)
      if not pf then return _pe("File not found: "+tp)
      for ow in [[_ti(perm[0]),"u"],[_ti(perm[1]),"g"],[_ti(perm[2]),"o"]]
        v=ow[0];w=ow[1]
        if rflag then r=pf.chmod(w+"-rwx",rflag) else r=pf.chmod(w+"-rwx")
        if r isa string and r.len then break
        if bitAnd(v,4) then
          if rflag then r=pf.chmod(w+"+r",rflag) else r=pf.chmod(w+"+r")
        end if
        if bitAnd(v,2) then
          if rflag then r=pf.chmod(w+"+w",rflag) else r=pf.chmod(w+"+w")
        end if
        if bitAnd(v,1) then
          if rflag then r=pf.chmod(w+"+x",rflag) else r=pf.chmod(w+"+x")
        end if
      end for
      return _ps("chmod "+perm+" "+tp)
    end if
  end if
  if _cmd=="touch" and _args.len then
    if not comp then return _pe(_ns)
    if _pt.len>=3 then
      dr=_resolveRemotePath(ex,_pt[1])
      fn=_pt[2]
    else
      ps=_resolveRemotePath(ex,_args).split("/")
      fn=ps[-1]
      dr=ps[:-1].join("/")
      if not dr then dr="/"
    end if
    r=comp.touch(dr,fn)
    if r isa string and r.len then _pe(r) else _ps("Created "+dr+"/"+fn)
    return
  end if
  if _cmd=="chown" and _pt.len>=3 then
    off=1
    if _pt[1]=="-r" or _pt[1]=="-R" then off=2
    if _pt.len<off+2 then return _pe("chown [-r] user path")
    pf=_hostFile(comp,ex,_pt[off+1])
    if not pf then return _pe("Not found: "+_pt[off+1])
    if rflag or _pt[1]=="-r" or _pt[1]=="-R" then r=pf.set_owner(_pt[off],true) else r=pf.set_owner(_pt[off])
    if r==1 or r==true or r=="" then
      _ps("chown "+_pt[off]+" "+pf.path)
    else if r isa string then
      _pe(r)
    end if
    return
  end if
  if _cmd=="chgrp" and _pt.len>=3 then
    off=1
    if _pt[1]=="-r" or _pt[1]=="-R" then off=2
    if _pt.len<off+2 then return _pe("chgrp [-r] group path")
    pf=_hostFile(comp,ex,_pt[off+1])
    if not pf then return _pe("Not found: "+_pt[off+1])
    if _pt[1]=="-r" or _pt[1]=="-R" then r=pf.set_group(_pt[off],true) else r=pf.set_group(_pt[off])
    if r==1 or r==true or r=="" then
      _ps("chgrp "+_pt[off]+" "+pf.path)
    else if r isa string then
      _pe(r)
    end if
    return
  end if
  if _cmd=="cat" and _args.len then
    pf=_hostFile(comp,ex,_args)
    if not pf then return _pe("Not found: "+_args)
    if not _hp(pf,"r") then return _pe("No read permission")
    if pf.is_binary then return _pe("Binary — use download")
    c=_gc(pf)
    if not c then return _pe("Cannot read file")
    for ln in c.split(char(10));if ln.len then _p WH(ln);end for
    return
  end if
  if _cmd=="cp" and _pt.len>=3 then
    pf=_hostFile(comp,ex,_pt[1])
    if not pf then return _pe("Not found: "+_pt[1])
    dp=_resolveRemotePath(ex,_pt[2]).split("/")
    dn=dp[-1]
    dd=dp[:-1].join("/")
    if not dd then dd="/"
    r=pf.copy(dd,dn)
    if r==1 or r==true then
      _ps("Copied -> "+_pt[2])
    else if r isa string then
      _pe(r)
    end if
    return
  end if
  if _cmd=="mv" and _pt.len>=3 then
    pf=_hostFile(comp,ex,_pt[1])
    if not pf then return _pe("Not found: "+_pt[1])
    dp=_resolveRemotePath(ex,_pt[2]).split("/")
    dn=dp[-1]
    dd=dp[:-1].join("/")
    if not dd then dd="/"
    r=pf.move(dd,dn)
    if r==1 or r==true then
      _ps("Moved -> "+_pt[2])
    else if r isa string then
      _pe(r)
    end if
    return
  end if
  if _cmd=="rm" and _args.len then
    pf=_hostFile(comp,ex,_args)
    if not pf then return _pe("Not found: "+_args)
    if rflag then r=pf.delete(true) else r=pf.delete
    if r==1 or r==true or r=="" then
      _ps("Removed "+pf.path)
    else if r isa string then
      _pe(r)
    end if
    return
  end if
  if _cmd=="mkdir" and _args.len then
    if not comp then return _pe(_ns)
    dp=_resolveRemotePath(ex,_args)
    ps=dp.split("/");fn=ps[-1];dr=ps[:-1].join("/")
    if not dr then dr="/"
    r=comp.create_folder(dr,fn)
    if r isa string and r.len then _pe(r) else _ps("Created "+dp)
    return
  end if
  if _cmd=="qrm" and _args.len then
    pf=_hostFile(comp,ex,_args)
    if not pf then return _pe("Not found: "+_args)
    if comp then
      qrm(comp,pf)
    else
      if rflag then r=pf.delete(true) else r=pf.delete
      if r isa string and r.len then return _pe(r)
    end if
    _ps("Removed "+pf.path)
    return
  end if
  if _cmd=="cd" then
    if not _args.len then
      gco._hostWd=_hd(u)
      return
    end if
    np=_resolveRemotePath(ex,_args)
    df=_hostFile(comp,ex,np)
    if not df then return _pe("Not found: "+_args)
    if not df.is_folder then return _pe("Not a directory: "+_args)
    gco._hostWd=np
    return
  end if
  if _cmd=="whoami" then
    _p WH(u)
    return
  end if
  _bin=null
  if shell and comp then
    if comp.File("/bin/"+_cmd) then _bin="/bin/"+_cmd
    if not _bin and comp.File("/usr/bin/"+_cmd) then _bin="/usr/bin/"+_cmd
    if _bin then
      if _args.len then
        shell.launch(_bin,_args)
      else if _cmd=="ls" then
        if u=="root" then shell.launch(_bin,"/root") else shell.launch(_bin,"/home/"+u)
      else
        shell.launch(_bin)
      end if
      return
    end if
  end if
  if _cmd=="ls" then return _hostListDir(comp,ex,u,_args)
  if _cmd=="pwd" then
    wd=_hd(u)
    if gco.hasIndex("_hostWd") and gco._hostWd then wd=gco._hostWd
    _p WH(wd)
    return
  end if
  if _cmd=="ps" then
    if not comp then return _pe(_ns)
    procs=comp.show_procs
    if procs then _p WH(procs) else _pe("No procs")
    return
  end if
  if _cmd=="kill" then
    if not _args.len or not _ti(_pt[1]) isa number then return _pe("kill <pid>")
    if not comp then return _pe(_ns)
    r=comp.close_program(_ti(_pt[1]))
    if r==1 or r==true then
      _ps("Killed "+_s(_pt[1]))
    else if r isa string then
      _pe(r)
    else
      _pe("Failed")
    end if
    return
  end if
  _pe("Unknown: "+_cmd)
end function
uploadFile=function(ex,lpath=null,dest=null)
  if _to(ex).indexOf(_sh)==null and _to(ex)!=_fs then return _pe(_ns+" to upload files")
  lShell=gco.home.shell
  isPv=_cur!=gco.home
  if isPv and not lpath then
    ch=_ask("Upload from (m=main/p=pivot)")
    if ch and _tl(ch)=="p" then lShell=_cur.shell
  end if
  lComp=_HC(lShell)
  comp=_HC(ex)
  u=_gu(ex)
  rHome=_hd(u)
  lUser=_gu(lShell)
  lHome=_hd(lUser)
  if lpath and lpath.len then
    lp=lpath.trim
  else
    _p ""
    _p GY("  Upload from your machine -> remote host")
    _p GY("  Remote: ")+WH(u)+GY("@")+YL(comp.public_ip)+GY("  default dir ")+YL(rHome+"/")
    _p GY("  Local home: ")+YL(lHome+"/")
    lp=_ask("Local file path ('b' cancel)")
    if not lp or _tl(lp)=="b" then return
    lp=lp.trim
  end if
  lp=_resolveLocalPath(lShell,lp)
  src=lComp.File(lp)
  if not src then return _pe("Local file not found: "+lp)
  if src.is_folder then return _pe("Cannot upload a folder")
  if dest and dest.len then
    dest=_resolveRemotePath(ex,dest.trim)
  else
    _p GY("  Uploading ")+WH(src.name)+GY(" -> ")+YL(u+"@"+comp.public_ip)
    _p GY("  Remote directory (enter = ")+YL(rHome)+GY(")")
    dest=_ask("Remote dir")
    if not dest or not dest.trim.len then dest=rHome else dest=_resolveRemotePath(ex,dest.trim)
  end if
  r=lShell.scp(src.path,dest,ex)
  if r isa string then return _pe("SCP failed: "+r)
  _ps("Uploaded "+src.name+" -> "+dest+"/"+src.name)
end function
_uploadLib=function(shell,lpath=null,dest=null)
  if not shell then return _pe(_ns+" to upload")
  if not _isRemoteHost(shell) then return _pe("Only on remote hosts")
  hShell=gco.home.shell
  hComp=_HC(hShell)
  hu=_gu(hShell)
  hHome=_hd(hu)
  if not lpath or not lpath.trim.len then
    lpath=_ask("Library (.so) name or path ('b' cancel)")
    if not lpath or _tl(lpath)=="b" then return
    lpath=lpath.trim
  else
    lpath=lpath.trim
  end if
  lp=lpath
  if lp.indexOf("/")==null then
    sp=hHome+"/Downloads/"+lp
    if not hComp.File(sp) and lp.indexOf(".so")==null then sp=hHome+"/Downloads/"+lp+".so"
    lp=sp
  else
    lp=_resolveLocalPath(hShell,lp)
  end if
  src=hComp.File(lp)
  if not src then return _pe("Not found: "+lp)
  comp=_HC(shell)
  if dest and dest.len then
    dest=_resolveRemotePath(shell,dest.trim)
  else
    dest="/lib"
    if not comp.File(dest) then return _pe("Cannot access /lib")
  end if
  _pact("Uploading "+src.name+"...")
  r=hShell.scp(lp,dest,shell)
  if r isa string then return _pe("SCP failed: "+r)
  _ps("Uploaded "+src.name+" -> "+dest+"/"+src.name)
end function
renameFile=function(ex,rpath=null,newname=null)
  root=toRoot(ex)
  if not root then return _pe("Cannot resolve filesystem")
  if rpath and rpath.len then
    p=rpath.trim
  else
    _p ""
    _p GY("  Enter path of file/folder to rename")
    p=_ask("Path ('b' cancel)")
    if not p or _tl(p)=="b" then return
    p=p.trim
  end if
  target=null
  for f in getAllFiles(root);if f.path==p.trim then;target=f;break;end if;end for
  if not target then return _pe("Not found: "+p)
  if not _hp(target,"w") then return _pe("No write permission")
  if newname and newname.len then
    nn=newname.trim
  else
    _p GY("  Current name: ")+WH(target.name)
    nn=_ask("New name ('b' cancel)")
    if not nn or _tl(nn)=="b" then return
    nn=nn.trim
  end if
  r=target.rename(nn)
  if r=="" then _ps("Renamed -> "+nn.trim) else _pe(_s(r))
end function
_findRsHome=function(hComp,hHome)
  f=hComp.File(_lr)
  if f then return _lr
  f=hComp.File(current_path+_rs)
  if f then return current_path+_rs
  f=hComp.File(hHome+"/Downloads/librshell.so")
  if f then return hHome+"/Downloads/librshell.so"
  _pp=split(current_path,"/")
  _pp.pop
  _pPath=join(_pp,"/")
  if not _pPath then _pPath="/"
  f=hComp.File(_pPath+_rs)
  if f then return _pPath+_rs
end function
_rsSrvRun=function(p)
  if not p or not p.len then return false
  for ln in p.split(char(10))
    if ln.indexOf("rshell_client")!=null then continue
    if ln.indexOf("rshell")!=null then return true
  end for
  return false
end function
_rsDone=function(sh,c)
  _ps("rshell server installed!")
  pip=c.public_ip
  if pip then importRshellServer(pip,sh)
end function
_rsInstallRemote=function(shell,comp,libPath)
  home="/root"
  code="a=include_lib("""+libPath+""");if not a then exit(""Error: librshell.so not found"");c=install_service(a);if c!=true then exit(c);print(""rshell server installed"")"
  comp.touch(home,".x_rs.src")
  f=comp.File(home+"/.x_rs.src")
  if not f then
    if libPath==home+_rs then
      f=comp.File(home+_rs)
      if f then qrm(comp,f)
    end if
    return _pe("Failed to create installer")
  end if
  f.set_content(code)
  _pact("Installing rshell server...")
  r=build(shell,path(f),home)
  if r!="" then
    f=comp.File(home+"/.x_rs.src")
    if f then qrm(comp,f)
    if libPath==home+_rs then
      f=comp.File(home+_rs)
      if f then qrm(comp,f)
    end if
    return _pe(_bf+r)
  end if
  shell.launch(home+"/.x_rs")
  f=comp.File(home+"/.x_rs.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_rs")
  if f then qrm(comp,f)
  if libPath==home+_rs then
    f=comp.File(home+_rs)
    if f then qrm(comp,f)
  end if
  _rsDone(shell,comp)
end function
installRshellServer=function(shell)
  comp=_HC(shell)
  u=_gu(shell)
  if u!="root" then return _pe("Need root shell to install rshell server")
  procs=comp.show_procs
  if _rsSrvRun(procs) then return _pw("rshell service appears to be running already")
  if _atHome(shell) and comp.File(_lr) then
    rsLib=include_lib(_lr)
    if rsLib then
      r=rsLib.install_service
      if r!=true and r isa string then return _pe(r)
      return _rsDone(shell,comp)
    end if
  end if
  if comp.File("/bin/rshell-server") then
    r=shell.launch("/bin/rshell-server")
    if r==1 or r==true then return _rsDone(shell,comp)
  end if
  rsPath=null
  if comp.File(_lr) then rsPath=_lr
  if not rsPath then
    home="/root"
    if comp.File(home+_rs) then rsPath=home+_rs
    if not rsPath then
      pp=_hd(u)+"/payload/librshell.so"
      if comp.File(pp) then rsPath=pp
    end if
  end if
  if rsPath then return _rsInstallRemote(shell,comp,rsPath)
  hComp=_HC(gco.home.shell)
  hHome=_hd(_gu(gco.home.shell))
  rshellPath=_findRsHome(hComp,hHome)
  if not rshellPath then return _pe("librshell.so not found")
  home="/root"
  _pact("Uploading librshell.so...")
  r=gco.home.shell.scp(rshellPath,home,shell)
  if r isa string then return _pe("SCP failed: "+r)
  _rsInstallRemote(shell,comp,home+_rs)
end function
startRshellClient=function(shell)
  comp=_HC(shell)
  u=_gu(shell)
  home=_hd(u)
  hdir=comp.File(home)
  if not hdir or not _hp(hdir,"w") then
    home="/tmp"
    hdir=comp.File(home)
    if not hdir or not _hp(hdir,"w") then return _pe("No writable directory found")
  end if
  myIP=_ask("Your rshell server IP")
  if not myIP or not _vi(myIP.trim) then return _pe(_iip)
  myIP=myIP.trim
  port=_ask("Port (default 1222)")
  if not port or not len(port.trim) then port="1222"
  port=port.trim
  procName=_ask("Process name (default ps)")
  if not procName or not len(procName.trim) then procName="ps"
  procName=procName.trim
  code="_g=function;p=File(host_computer(get_shell),""/"");d=get_folders(p)+get_files(p);while len(d);f=pull(d);if is_folder(f) then d=d+get_folders(f)+get_files(f);if name(f)==""metaxploit.so"" or name(f)=="".metaxploit.so"" then;l=include_lib(path(f));if l and typeof(l)==""MetaxploitLib"" then return l;end if;end while;end function;m=_g;if m then rshell_client(m,"""+myIP+""","+port+","""+procName+""")"
  comp.touch(home,".x_rc.src")
  f=comp.File(home+"/.x_rc.src")
  if not f then return _pe("Failed to create rshell client")
  f.set_content(code)
  _pact("Building rshell client...")
  r=build(shell,path(f),home)
  if r!="" then
    f=comp.File(home+"/.x_rc.src")
    if f then qrm(comp,f)
    return _pe(_bf+r)
  end if
  shell.launch(home+"/.x_rc")
  f=comp.File(home+"/.x_rc.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_rc")
  if f then qrm(comp,f)
  _ps("rshell client launched as '"+procName+"' -> "+myIP+":"+port)
end function
importRshellServer=function(ip,remoteShell=null)
  _pact("Importing rshell server "+ip+"...")
  if remoteShell then
    rMetax=_grM(remoteShell)
    if not rMetax then return _pe("Cannot get metaxploit on remote")
  else
    if not metax then return _pe("metaxploit.so not loaded")
    rMetax=metax
  end if
  shells=rMetax.rshell_server
  if shells isa list then
    gco.rshell_servers[ip]=rMetax
  else if shells==null or shells==false then
    gco.rshell_servers[ip]=rMetax
    shells=[]
  else
    return _pe(_s(shells))
  end if
  refreshRshellShells(true)
  if shells isa list and shells then
    _ps("Imported "+ip+" — "+_s(shells.len)+" shell(s)")
  else
    _ps("Imported "+ip+" — 0 shells (waiting for connections)")
  end if
end function
refreshRshellShells=function(quiet=false)
  if not gco.rshell_servers then return _pe("No rshell servers imported")
  gco.rshell_shells=[]
  for srv in gco.rshell_servers;shells=rshell_server(srv.value);if not shells isa list then continue;for s in shells;gco.rshell_shells.push(s);end for;end for
  if not quiet then _ps("Refreshed: "+_s(gco.rshell_shells.len)+" shell(s) from "+_s(gco.rshell_servers.len)+" server(s)")
end function
rshellMenu=function(shell=null)
  if not metax then return _pe("metaxploit.so not loaded")
  while true
    if gco.H then break
    srvCount=gco.rshell_servers.len
    shellCount=gco.rshell_shells.len
    _scr("RShell Manager")
    _bar(GY("SRV ")+WH(_s(srvCount))+GY("  SH ")+WH(_s(shellCount)))
    if gco.rshell_servers then
      _sub("Imported Servers")
      idx=0
      for srv in gco.rshell_servers;_p WH("    "+_lj(_s(idx+1),4))+YL(srv.key);idx=idx+1;end for
    end if
    if gco.rshell_shells then
      _sub("Connected Shells")
      for s in gco.rshell_shells
        i=__s_idx+1
        sComp=_HC(s)
        u=_gu(s)
        pip=sComp.public_ip
        lip=sComp.local_ip
        _p WH("    "+_lj(_s(i),4))+GN(_lj(u,15))+YL(pip)+GY(":")+BL(lip)
      end for
    end if
    racts=[]
    if shell then racts.push(["s","install"])
    if shell then racts.push(["c","client"])
    racts.push(["i","import"])
    racts.push(["r","refresh"])
    if shellCount then racts.push(["#","open shell"])
    racts.push(["help","help"])
    racts.push(["b","back"])
    ans=_menu("rshell",racts)
    if not ans or _mb(ans) then break
    _ra=_tl(ans)
    if _ra=="help" then _showHelp("rshell");continue
    if _ra=="s" and shell then
      installRshellServer(shell)
    else if _ra=="c" and shell then
      startRshellClient(shell)
    else if _ra=="i" then
      defIP=null
      if shell then defIP=_HC(shell).public_ip
      prompt="Server IP to import"
      if defIP then prompt=prompt+" (default "+defIP+")" else prompt=prompt+" (default local)"
      ip=_ask(prompt)
      if not ip or not len(ip.trim) then
        if defIP then importRshellServer(defIP,shell) else importRshellServer(_HC(get_shell).public_ip)
      else
        ip=ip.trim
        if _vi(ip) then importRshellServer(ip,shell) else _pe(_iip)
      end if
    else if _ra=="r" then
      refreshRshellShells
    else
      sel=_ti(ans.trim)
      if not sel isa number or sel<1 or sel>gco.rshell_shells.len then
        _pe(_iv)
      else
        s=gco.rshell_shells[sel-1]
        _ps("Opening shell...")
        _pd("User",_gu(s))
        _pd("Host",_HC(s).public_ip)
        _exM(s,_sh)
      end if
    end if
  end while
end function
_pivotMenu=function
  pv=gco.pivots
  while true
    if gco.H then break
    _scr("Pivot Sessions")
    _bar(GY("HOME ")+YL(gco.home.ip)+GY(":")+YL(gco.home.lip))
    if not pv or pv.len==0 then
      _phint("No active pivots")
    else
      i=0
      _len=pv.len
      while i<_len
        n=pv[i]
        idx=_s(i+1)
        _p GN("  ["+idx+"] ")+YL(n.ip)+GY(":")+YL(n.lip)+GY(" metax:")+cbool(n.metax)+GY(" crypto:")+cbool(n.crypto)
        i=i+1
      end while
    end if
    c=_menu("pivots",[["help","help"],["x","kill all"],["b","back"]])
    if not c or _tl(c)=="b" then return
    if _tl(c)=="help" then _showHelp("pivot");continue
    if _tl(c)=="x" then
      if not pv or pv.len==0 then
        _pw("No pivots to kill")
        continue
      end if
      ans=_ui(YL("[!] Kill all "+_s(pv.len)+" pivot sessions? (y/N) "))
      if ans and _tl(ans)=="y" then
        while pv.len>0;pv.pop;end while
        _ps("All pivot sessions cleared")
      end if
    end if
  end while
end function
_libTry=function(s)
  pp=program_path
  bd=current_path
  if pp then;i=pp.lastIndexOf("/");if i!=null and i>0 then bd=pp[0:i];end if
  p=bd+s;f=_HC(_initShell).File(p);if f then;l=include_lib(path(f));if l then return {"l":l,"p":p};end if
  p=_payDir+s;f=_HC(_initShell).File(p);if f then;l=include_lib(path(f));if l then return {"l":l,"p":p};end if
  p=current_path+s;f=_HC(_initShell).File(p);if f then;l=include_lib(path(f));if l then return {"l":l,"p":p};end if
end function
_pivotScanner=function(shell)
  comp=_HC(shell)
  u=_gu(shell)
  home=_hd(u)
  hdir=comp.File(home)
  if not hdir or not _hp(hdir,"w") then
    home="/tmp"
    hdir=comp.File(home)
    if not hdir or not _hp(hdir,"w") then return _pe("No writable directory on remote")
  end if
  pip=comp.public_ip
  lip=comp.local_ip
  parts=_selfPath.split("/")
  binName=parts[parts.len-1]
  payDir=home+"/payload"
  _pact("Pivoting "+binName+" to "+pip+" ("+lip+")")
  pf=comp.File(payDir)
  if not pf then comp.create_folder(home,"payload")
  pf=comp.File(payDir)
  if not pf then return _pe("Failed to create payload folder")
  _pact("Uploading "+binName+"...")
  _c=_cur
  r=_c.shell.scp(_selfPath,payDir,shell)
  if r isa string then return _pe("SCP upload binary failed: "+r)
  hmPath=_c.metaxPath
  hShell=_c.shell
  hComp=_HC(hShell)
  if hmPath then
    _pact("Uploading metaxploit.so...")
    r=hShell.scp(hmPath,payDir,shell)
    if r isa string then _pw("metaxploit.so upload failed: "+r)
  end if
  cPath=null
  if hComp.File("/lib/crypto.so") then cPath="/lib/crypto.so"
  if not cPath and hComp.File(current_path+"/crypto.so") then cPath=current_path+"/crypto.so"
  if cPath then
    _pact("Uploading crypto.so...")
    r=hShell.scp(cPath,payDir,shell)
    if r isa string then _pw("crypto.so upload failed: "+r)
  end if
  rsPath=_findRsHome(hComp,_hd(_gu(hShell)))
  if rsPath then
    _pact("Uploading librshell.so...")
    r=hShell.scp(rsPath,payDir,shell)
    if r isa string then _pw("librshell.so upload failed: "+r)
  end if
  for fn in [binName,"metaxploit.so","crypto.so","librshell.so"]
    f=comp.File(payDir+"/"+fn)
    if f then f.set_owner(u)
  end for
  _ps("Launching "+binName+" on "+pip+"...")
  _p GY("  x at main menu returns to parent")
  _p ""
  shell.launch(payDir+"/"+binName,"pivot")
  pf=comp.File(payDir)
  if pf then qrm(comp,pf)
  if gco.hasIndex("pivots") then
    pv=gco.pivots
    if pv and pv.len>0 then pv.pop
  end if
  _ps("Returned from pivot on "+pip)
end function
_echo=function(raw,c)
  ap=raw.indexOf(">>")
  ow=raw.indexOf(">")
  if ap!=null then
    t=raw[:ap].trim;fp=raw[ap+2:].trim
    if fp.indexOf("/")!=0 then fp=_hd(_gu(c))+"/"+fp
    f=c.File(fp)
    if not f then return _pe("Not found: "+fp)
    f.set_content(_gc(f)+char(10)+t);_ps("Appended to "+fp)
  else if ow!=null then
    t=raw[:ow].trim;fp=raw[ow+1:].trim
    if fp.indexOf("/")!=0 then fp=_hd(_gu(c))+"/"+fp
    ps=fp.split("/");fn=ps[-1];dr=ps[:-1].join("/")
    if not dr then dr="/"
    f=c.File(fp)
    if f then f.set_content(t) else c.touch(dr,fn);f=c.File(fp);if f then f.set_content(t) else return _pe("Cannot create "+fp)
    _ps("Wrote "+fp)
  else
    _p WH(raw)
  end if
end function
_deploy=function(shell)
  comp=_HC(shell)
  u=_gu(shell)
  home=_hd(u)
  hShell=gco.home.shell
  hComp=_HC(hShell)
  hu=_gu(hShell)
  hHome=_hd(hu)
  bn=_ask("Bin name or path ('b' cancel)")
  if not bn or _tl(bn)=="b" then return
  bn=bn.trim
  if bn.indexOf("/")!=null then
    sp=bn
  else
    sp=hHome+"/Downloads/"+bn
    if not hComp.File(sp) then
      _pw(sp+" not found")
      sp=_ask("Full path on main")
      if not sp or _tl(sp)=="b" then return
      sp=sp.trim
    end if
  end if
  sf=hComp.File(sp)
  if not sf then return _pe("Not found: "+sp)
  _pact("Uploading "+sf.name+"...")
  r=hShell.scp(sp,home,shell)
  if r isa string then return _pe("SCP failed: "+r)
  _ps("Launching "+sf.name+"...")
  shell.launch(home+"/"+sf.name)
  _ps("Deployed "+sf.name)
end function
_crow=function(ws,lite=false)
  r=""
  for w in ws;r=r+WH(w)+" ";end for
  if lite then _phint(r) else _p GY("  ")+r
end function
_exM=function(ex,exType)
  gco._crEx=ex
  gco._hostWd=null
  gco._hx=ex
  gco._hs=null
  if exType==_sh then gco._hs=ex
  shell=null
  if exType==_sh then shell=ex
  _comp=null
  _cip=[]
  u=null
  cmds={}
  cmds.passwd=function(hargs)
    if _nx(hargs) then return
    passwd=getFileEx(ex,"/etc/passwd")
    if passwd then
      _sub("/etc/passwd")
      creds=_ppw(passwd)
      _cip2=null
      if gco.hasIndex("_eip") then _cip2=gco._eip
      if shell then _cip2=_HC(shell).local_ip
      for cr in creds;_acr2(_cip2,cr.user,cr.pass);end for
    else
      _pe("Cannot read /etc/passwd")
    end if
  end function
  cmds.md5=function(hargs)
    if hargs.len then return _crRunTarget(hargs)
    h=_ask("MD5 hash")
    if h and h.trim.len then _crRunTarget(h.trim)
  end function
  cmds.crack=function(hargs)
    if hargs.len then
      _pact("Cracking "+hargs+"...")
      _crRunTarget(hargs)
      return
    end if
    pf=getFileEx(ex,"/etc/passwd")
    if pf and _hp(pf,"r") then
      _sub("/etc/passwd")
      cracked=_ppw(pf)
      if cracked and cracked.len then
        _cip2=null
        if gco.hasIndex("_eip") then _cip2=gco._eip
        if shell then _cip2=_HC(shell).local_ip
        for cr in cracked;_acr2(_cip2,cr.user,cr.pass);end for
      end if
      return
    end if
    _crackMenu
  end function
  cmds.mail=function(hargs)
    if _nx(hargs) then return
    _mailMenu
  end function
  cmds.clear=function(hargs)
    if _nx(hargs) then return
    clear_screen
  end function
  cmds.recon=function(hargs)
    if not shell then return _pe(_ns+" for recon")
    if hargs.len then
      parts=hargs.split(" ")
      rcIP=_resolveTarget(parts[0])
      if not rcIP then return _pe("Cannot resolve: "+parts[0])
      if parts.len>1 then
        _recon(rcIP,_tl(parts[1]))
      else
        ch=_menu("recon",_rcActs)
        if ch and _tl(ch)=="help" then _showHelp("recon")
        if ch and not _mb(ch) and _tl(ch)!="help" then _recon(rcIP,_tl(ch))
      end if
      return
    end if
    defIP=_HC(shell).public_ip
    rcIP=_ask("Recon target IP ["+defIP+"]")
    if not rcIP or not rcIP.trim.len then rcIP=defIP
    resolved=_resolveTarget(rcIP.trim)
    if not resolved then return _pe("Cannot resolve: "+rcIP.trim)
    ch=_menu("recon",_rcActs)
    if ch and _tl(ch)=="help" then _showHelp("recon")
    if ch and not _mb(ch) and _tl(ch)!="help" then _recon(resolved,_tl(ch))
  end function
  cmds.hunt=function(hargs)
    if hargs.len then
      parts=hargs.split(" ")
      hMx=null
      hVf=null
      if parts.len>1 and _ti(parts[1]) isa number then hMx=_ti(parts[1])
      if parts.len>2 then hVf=_tl(parts[2])
      _hunt(_tl(parts[0]),hMx,hVf)
    else
      _hunt
    end if
  end function
  cmds.su=function(hargs)
    if not shell then return _pw(_ns+" for su")
    if _gu(ex)=="root" then return _pw("Already root")
    suUser="root"
    suPass=null
    ns=null
    if hargs.len then
      parts=hargs.split(" ")
      if parts.len>=2 then
        suUser=_tl(parts[0])
        suPass=parts[1]
      else
        suPass=hargs.trim
      end if
      ns=_suApply(_suShell(ex,suUser,suPass),suUser,suPass,shell)
    else
      if _cip.len then
        sr=_suC(ex,"root",_cip)
        if sr then ns=_suApply(sr.shell,sr.user,sr.pass,shell)
      end if
      if not ns then
        sr=_suTry(ex,"root")
        if sr then ns=_suApply(sr.shell,sr.user,sr.pass,shell)
      end if
    end if
    if ns then
      gco._hx=ns
      gco._hs=ns
      ex=ns
      shell=ns
      exType=_sh
      gco._crEx=ns
      gco._hostWd=null
    end if
  end function
  cmds.apps=function(hargs)
    if _nx(hargs) then return
    if not shell then return _pw(_ns+" for apps")
    comp=_HC(shell)
    apps=[]
    dirs=["/usr/bin","/bin"]
    for d in dirs
      df=comp.File(d)
      if not df then continue
      for f in df.get_files;apps.push({"name":f.name,"dir":d});end for
    end for
    hf=comp.File("/home")
    if hf then
      for ud in hf.get_folders
        if ud.name==_gt then continue
        for f in ud.get_files;if f.name.indexOf(".exe")!=null then apps.push({"name":f.name,"dir":ud.path});end for
      end for
    end if
    if apps then
      while true
        if gco.H then break
        _sub("Applications")
        curDir=""
        row=""
        col=0
        for a in apps
          if a.dir!=curDir then
            if row then _p "  "+row
            row=""
            col=0
            if curDir then _p ""
            curDir=a.dir
            _p GY("  "+curDir+":")
          end if
          row=row+WH(_lj("["+_s(__a_idx+1)+"] ",5))+BL(_lj(a.name,18))
          col=col+1
          if col==4 then
            _p "  "+row
            row=""
            col=0
          end if
        end for
        if row then _p "  "+row
        sel=_menu("apps",[["#","launch (+args)"],["b","back"]])
        if not sel or _tl(sel)=="b" then break
        st=sel.trim
        sp=st.indexOf(" ")
        if sp==null then
          numStr=st
          appArgs=null
        else
          numStr=st[0:sp]
          appArgs=st[sp+1:]
        end if
        si=_ti(numStr)
        if si isa number and si>=1 and si<=apps.len then
          appPath=apps[si-1].dir+"/"+apps[si-1].name
          if appArgs!=null and appArgs.len then shell.launch(appPath,appArgs) else shell.launch(appPath)
        else
          _pe(_iv)
        end if
      end while
    else
      _pw("No apps found")
    end if
  end function
  cmds.local=function(hargs)
    if _nx(hargs) then return
    if not shell then return _pw(_ns+" for local scan")
    localScan(shell)
  end function
  cmds.lan=function(hargs)
    if _nx(hargs) then return
    if not shell then return _pw(_ns+" for LAN scan")
    scanLAN(shell)
  end function
  cmds.dig=function(hargs)
    if not shell then return _pe(_ns+" for dig")
    if hargs.len then
      da=_arg1(hargs)
      _digA(shell,da[0],da[1])
      return
    end if
    _digS(shell)
  end function
  cmds.browse=function(hargs)
    u=_gu(ex)
    if hargs.len then browseFiles(ex,u,hargs,shell) else browseFiles(ex,u,null,shell)
  end function
  cmds.seek=function(hargs)
    if _nx(hargs) then return
    _seekFiles(ex)
  end function
  cmds.download=function(hargs)
    if not _isRemoteHost(ex) then return _pe("Only on remote hosts")
    if hargs.len then downloadFile(ex,hargs,shell) else downloadFile(ex,null,shell)
  end function
  cmds.rename=function(hargs)
    if hargs.len then
      parts=hargs.split(" ")
      if parts.len>=2 then renameFile(ex,parts[0],parts[1]) else renameFile(ex,parts[0],null)
    else
      renameFile(ex)
    end if
  end function
  cmds.upload=function(hargs)
    if not shell then return _pw(_ns+" to upload")
    if not _isRemoteHost(shell) then return _pe("Only on remote hosts")
    if hargs.len then
      parts=hargs.split(" ")
      dest=null
      if parts.len>=2 then dest=parts[1]
      uploadFile(shell,parts[0],dest)
    else
      uploadFile(shell)
    end if
  end function
  cmds.cached=function(hargs)
    if _nx(hargs) then return
    tc=0
    for k in gco._nc.indexes
      cl=gco._nc[k]
      if not cl.len then continue
      _p GN("  "+k+":")
      for c in cl;_p WH("    "+_lj(c.user,16))+GN(c.pass);end for
      tc=tc+cl.len
    end for
    if tc==0 then _p GY("  No cached credentials") else _p GY("  "+_s(gco._nc.len)+" hosts, "+_s(tc)+" creds")
  end function
  cmds.passwords=function(hargs)
    if hargs.len then
      parts=hargs.split(" ")
      if parts.len>=2 and shell then
        _acr(shell,parts[0],parts[1])
        _ps("Added "+parts[0]+":"+parts[1])
        return
      end if
    end if
    creds=_gcr2(ex,exType)
    if creds.len then
      _p GY("  Cached creds for this host:")
      for c in creds;_p WH("    "+_lj(c.user,16))+GN(c.pass);end for
    else
      _p GY("  No cached creds for this host")
    end if
    pw=_ask("Add root password (enter=skip)")
    if pw and pw.trim.len then
      _acr(shell,"root",pw.trim)
      _ps("Added root:"+pw.trim)
    end if
  end function
  cmds.rshell=function(hargs)
    if _nx(hargs) then return
    rshellMenu(shell)
  end function
  cmds.devices=function(hargs)
    if _nx(hargs) then return
    if shell then _devMenu(shell) else _pe(_ns)
  end function
  cmds.wifi=function(hargs)
    if _nx(hargs) then return
    if shell then _wifiCrack(shell) else _pe(_ns)
  end function
  cmds.pobject=function(hargs)
    if _nx(hargs) then return
    _pObjectMenu(shell)
  end function
  cmds.grab=function(hargs)
    if _nx(hargs) then return
    _grabAccounts(ex)
  end function
  cmds.pivot=function(hargs)
    if _nx(hargs) then return
    if not shell then return _pe(_ns+" to pivot")
    _pivotScanner(shell)
  end function
  cmds.deploy=function(hargs)
    if _nx(hargs) then return
    if not shell or _HC(shell).public_ip==gco.home.ip then return _pe("Only on remote shells")
    _deploy(shell)
  end function
  cmds["0day"]=function(hargs)
    if _nx(hargs) then return
    _show0dayStatus
  end function
  cmds.loadlib=function(hargs)
    if not shell then return _pe(_ns)
    if hargs.len then return _loadRemoteLib(shell,hargs)
    lPath=_ask("Lib path on remote (e.g. /lib/crypto.so)")
    if lPath and lPath.trim.len then _loadRemoteLib(shell,lPath.trim)
  end function
  cmds.uploadlib=function(hargs)
    if not shell then return _pe(_ns)
    if not _isRemoteHost(shell) then return _pe("Only on remote hosts")
    if hargs.len then
      parts=hargs.split(" ")
      dest=null
      if parts.len>=2 then dest=parts[1]
      _uploadLib(shell,parts[0],dest)
    else
      _uploadLib(shell)
    end if
  end function
  cmds.tree=function(hargs)
    if hargs.len then return _tree(ex,_xp(hargs,_gu(ex)))
    tp=_ask("Path (blank=/, ~=home)")
    if tp then _tree(ex,_xp(tp,_gu(ex)))
  end function
  cmds.reload=function(hargs)
    if _nx(hargs) then return
    _init
  end function
  cmds.wipe=function(hargs)
    if _nx(hargs) then return
    if _cwl(ex) then wipeLog(ex) else _pe("No write permission to system.log")
  end function
  cmds.getlog=function(hargs)
    if _nx(hargs) then return
    _downloadLog(ex,shell)
  end function
  cmds.whois=function(hargs)
    if hargs.len then return _whois(hargs)
    wIP=null
    if exType==_sh then
      wIP=_HC(ex).public_ip
    else if exType==_cm then
      wIP=ex.public_ip
    end if
    wTarget=_ask("whois target"+((wIP!=null)*(" ["+wIP+"]")))
    if not wTarget or not len(wTarget.trim) then
      if wIP then _whois(wIP) else _pe("No target specified")
    else
      _whois(wTarget.trim)
    end if
  end function
  cmds.help=function(hargs)
    if hargs.len then _showHelp(hargs) else _showHelp("all")
  end function
  while true
    if gco.H then break
    ex=gco._hx
    shell=gco._hs
    _scr("Host Console")
    _cip=[]
    if shell then _cip=_gcr(shell)
    u=_gu(ex)
    if exType==_sh then
      h=_HC(ex).public_ip
    else if exType==_cm then
      h=ex.public_ip
    else
      h=gco._eip
    end if
    _hostBar(ex,exType,h)
    hacts=_hostActs(ex,shell)
    ans=_menu(u+"@"+h+" "+exType,hacts)
    if not ans or not len(ans.trim) then continue
    if _mb(ans) then break
    _comp=_hostComp(ex,exType)
    if _sw(ans,"echo ") then
      if _comp then _echo(ans[5:],_comp) else _pe("No computer access")
      continue
    end if
    if _sw(ans,"e ") then
      if _comp then _echo(ans[2:],_comp) else _pe("No computer access")
      continue
    end if
    if _sw(_tl(ans),"tree ") then
      _tree(ex,_xp(ans[5:],u))
      continue
    end if
    if _sw(_tl(ans),"tr ") then
      _tree(ex,_xp(ans[3:],u))
      continue
    end if
    if ans[0]=="!" and _hostHasFs(ex,exType) then
      _hostFileCmd(shell,_comp,ex,exType,u,ans[1:])
      continue
    end if
    hca=_arg1(ans)
    if _hf.hasIndex(_tl(hca[0])) and _hostHasFs(ex,exType) then
      _hostFileCmd(shell,_comp,ex,exType,u,ans)
      continue
    end if
    hcmd=_hcAlias(hca[0])
    hargs=hca[1]
    if hasIndex(cmds,hcmd) then
      _fn=cmds[hcmd]
      _fn(hargs)
    else
      _pe("Unknown command: "+hca[0]+" — type help")
    end if
  end while
  gco._crEx=null
  gco._hostWd=null
  gco._hx=null
  gco._hs=null
  if gco.hasIndex("mailSession") then gco.mailSession=null
  if gco.hasIndex("m") then gco.m=null
  if gco.hasIndex("mailAddr") then gco.mailAddr=""
  if gco.hasIndex("mailPass") then gco.mailPass=""
  _mailClearCache
end function
_exR=function(ex)
  if ex isa string then return _pe(ex)
  if not ex then return _pe("Exploit returned null")
  obj=_to(ex)
  if obj==_sh or obj==_fs then
    _ps("Got shell!")
    _pd("User",_gu(ex))
    _pd("Host",_HC(ex).public_ip)
    _exM(ex,_sh)
  else if obj==_cm then
    _ps("Got computer!")
    _pd("User",_gu(ex))
    _pd("Host",ex.public_ip)
    _exM(ex,_cm)
  else if obj=="file" then
    _ps("Got file!")
    _pd("User",_gu(ex))
    _pd("Path",ex.path)
    _pd("Name",ex.name)
    _exM(ex,"file")
  else if ex isa number then
    _ps(_fd)
  else
    _pw(_rt+_to(ex))
  end if
end function
_exploitMenu=function(tgt,crumb="",ftype=null)
  while true
    if gco.H then break
    exs=_exFiltered(tgt.exploits,ftype)
    if crumb!="" then
      crumbLine=crumb
      if ftype then crumbLine=crumbLine+" · "+ftype
      _scr("Exploits — "+tgt.ln+":"+tgt.ver,crumbLine)
    end if
    if ftype then _p GY("  Filter ")+WH(ftype)+GY(" — ")+WH(_s(exs.len))+GY("/"+_s(tgt.exploits.len)+" exploits")
    _th([["#",5],["TYPE",12],["USER",12],["ADDRESS",14],["VALUE",0]])
    if not exs then
      _pw("No "+ftype+" exploits — f <type> or f all to change filter")
    else
      for e in exs;e.i=__e_idx+1;_p _exTag(e);end for
    end if
    c2=_menu("exploit",_exMenuActs)
    if not c2 then continue
    if _mb(c2) then return
    fp=_exPickFilter(c2,ftype)
    if fp[0]=="err" then
      _pe(fp[1])
      continue
    end if
    if fp[0]=="ok" then
      ftype=fp[1]
      continue
    end if
    if _tl(c2)=="help" then
      _showHelp("exploit")
      continue
    end if
    if _tl(c2)=="c" or _sw(c2.trim.lower,"c ") then
      cca=_arg1(c2.trim)
      if cca[0]=="c" and cca[1].len then
        cparts=cca[1].split(" ")
        if cparts.len>=2 then
          _exR(tgt.lib.overflow(cparts[0],cparts[1]))
          continue
        end if
      end if
      ca=_ask("Memory address")
      if not ca or not ca.trim.len then continue
      cv=_ask("Unsafe check value")
      if not cv or not cv.trim.len then continue
      _exR(tgt.lib.overflow(ca.trim,cv.trim))
      continue
    end if
    if _tl(c2)=="ba" then
      bip=_ui(_pmt("Bounce target IP"))
      if not bip or not _vi(bip.trim) then
        _pe(_iip)
        continue
      end if
      bip=bip.trim
      for ne in tgt.exploits
        if ne.type!="null" then continue
        _plog("Trying "+ne.addr+" "+ne.val+" -> "+bip)
        ex=tgt.lib.overflow(ne.addr,ne.val,bip)
        if not ex then
          _plog("null")
          continue
        end if
        if ex isa string then
          _plog(ex)
          continue
        end if
        _exR(ex)
      end for
      continue
    end if
    if not exs then continue
    esel=_ti(c2.trim)
    if not esel isa number or esel<1 or esel>exs.len then
      _pe(_iv)
      continue
    end if
    exploit=exs[esel-1]
    gco.meta_local=null
    if exploit.type=="bounce" then
      bounceIP=_ui(_pmt("Bounce target IP"))
      if not bounceIP or not _vi(bounceIP.trim) then
        _pe(_iip)
        continue
      end if
      ex=tgt.lib.overflow(exploit.addr,exploit.val,bounceIP.trim)
    else if exploit.type=="null" then
      _p GY(_en)
      ans=_ask("Password or bounce IP ('b' skip)")
      if _mb(ans) then continue
      ex=tgt.lib.overflow(exploit.addr,exploit.val,ans.trim)
      if not ex then
        _pe("Exploit returned null again")
        continue
      end if
      if ex isa string then
        _pe(ex)
        continue
      end if
      obj=_to(ex)
      if obj==_cm then
        _ps("Got computer (bounce)!")
        _pd("User",_gu(ex))
        _pd("Host",ex.public_ip)
        _exM(ex,_cm)
      else
        _ps("Password change may have succeeded!")
      end if
      continue
    else
      ex=tgt.lib.overflow(exploit.addr,exploit.val)
    end if
    _exR(ex)
  end while
end function
_buildLanScan=function(shell)
  comp=_HC(shell)
  if not _hasNet(comp) then return _pe("No internet connection")
  home=_shellHomePath(shell)
  if gco.hasIndex("scanlan_result") then gco.scanlan_result=null
  code="deep=function(t,s);R=[];if indexOf(s,t)!=null then return R;D={""ip"":t,""ports"":[],""devices"":[],""type"":""device"",""fw"":false,""fwd"":false};if not ping(get_shell,t) then;R.push(D);return R;end if;s.push(t);r=get_router(t);if r!=null then;F=firewall_rules(r);if F isa list and F then;D[""fw""]=true;for z in F;if indexOf(z,""DENY"")!=null then D[""fwd""]=true;end for;end if;if local_ip(get_router(public_ip(r)))==t then;D[""type""]=""edge"";else;if get_switch(t)!=null then D[""type""]=""switch"" else D[""type""]=""router"";end if;for p in device_ports(r,t);if port_number(p)==8080 then push(D[""ports""],{""pn"":0,""lip"":local_ip(r),""pip"":public_ip(r),""svc"":""router"",""ver"":kernel_version(r),""st"":""open""});d={};d[""pn""]=port_number(p);d[""lip""]=get_lan_ip(p);d[""pip""]=public_ip(r);i=split(port_info(r,p),"" "");d[""svc""]=i[0];d[""ver""]=i[1];d[""st""]=""open"";push(D[""ports""],d);end for;v=devices_lan_ip(r);for c2 in v;if indexOf(s,c2)!=null or c2==t then continue;u=deep(c2,s);for l in u;push(D[""devices""],l);end for;end for;else;M=get_router(s[0]);if M!=null then;for p in device_ports(M,t);d={};d[""pn""]=port_number(p);d[""lip""]=get_lan_ip(p);d[""pip""]=public_ip(M);i=split(port_info(M,p),"" "");d[""svc""]=i[0];d[""ver""]=i[1];d[""st""]=""open"";pn=d[""pn""];if pn==37777 then D[""type""]=""CCTV"";if pn==1883 then D[""type""]=""SAPP"";if pn==1222 then D[""type""]=""RSHL"";if pn==5555 then D[""type""]=""ADB"";push(D[""ports""],d);end for;end if;end if;R.push(D);return R;end function;get_custom_object[""scanlan_result""]=deep(local_ip(get_router),[])"
  comp.touch(home,".x_ls.src")
  f=comp.File(home+"/.x_ls.src")
  if not f then return _pe("Failed to create LAN scanner")
  f.set_content(code)
  r=shell.build(f.path,home)
  if r!="" then
    f=comp.File(home+"/.x_ls.src")
    if f then qrm(comp,f)
    return _pe(_bf+r)
  end if
  shell.launch(home+"/.x_ls")
  f=comp.File(home+"/.x_ls.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_ls")
  if f then qrm(comp,f)
  if not gco.hasIndex("scanlan_result") or not gco.scanlan_result then return _pe("LAN scan returned no results")
  return gco.scanlan_result
end function
_packRouter=function(shell,ip)
  mk=_HC(shell).public_ip+":"+_HC(shell).local_ip+":"+ip
  if gco.routers.hasIndex(mk) then return gco.routers[mk]
  comp=_HC(shell)
  home=_shellHomePath(shell)
  gco._dgR=null
  comp.touch(home,".x_pr.src")
  f=comp.File(home+"/.x_pr.src")
  if not f then return
  f.set_content("get_custom_object[""_dgR""]=get_router("""+ip+""")")
  r=build(shell,path(f),home)
  if r!="" then
    f=comp.File(home+"/.x_pr.src")
    if f then qrm(comp,f)
    return
  end if
  shell.launch(home+"/.x_pr")
  f=comp.File(home+"/.x_pr.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_pr")
  if f then qrm(comp,f)
  if gco._dgR then gco.routers[mk]=gco._dgR
  return gco._dgR
end function
_scanLocalLib=function(sh,lf)
  px=_mxs(sh)
  if not px then return
  lib=px.n.load(lf.path)
  if not lib then return
  ln=lib.lib_name
  ver=lib.version
  addresses=px.s.scan(lib)
  if not addresses then return
  exploits=[]
  for addr in addresses
    vulnInfo=px.s.scan_address(lib,addr)
    if not vulnInfo then continue
    for line in vulnInfo.split(char(10))
      if line.indexOf(_uc)==0 then
        s=line.indexOf("<b>")+3
        d=line.indexOf("</b>")
        if s>2 and d!=null then exploits.push({"addr":addr,"val":line[s:d]})
      end if
    end for
  end for
  p=lib.is_patched(1)
  if p isa string then
    patchStr=GN("Patched To: "+p)
  else if p==1 then
    patchStr=GN("Patched")
  else
    patchStr=RD("Not Patched")
  end if
  ct={"shells":0,"computers":0,"files":0,"bounces":0,"unknown":0}
  classified=[]
  for e in exploits
    ex=lib.overflow(e.addr,e.val)
    r=_classifyEx(ex,ln)
    if r[0]==_sh then
      ct.shells=ct.shells+1
    else if r[0]==_cm then
      ct.computers=ct.computers+1
    else if r[0]=="file" then
      ct.files=ct.files+1
    else if r[0]=="bounce" then
      ct.bounces=ct.bounces+1
    else
      ct.unknown=ct.unknown+1
    end if
    classified.push({"addr":e.addr,"val":e.val,"type":r[0],"user":r[1]})
  end for
  return {"lib":lib,"ln":ln,"ver":ver,"exploits":classified,"patchStr":patchStr,"total":classified.len,"ct":ct,"libPath":lf.path}
end function
_scanLanPort=function(sh,dev,pt)
  px=_mxs(sh)
  if not px then return
  plip=_lanPortLip(sh,dev,pt)
  session=net_use(px.n,plip,pt.pn)
  if not session then return
  lib=dump_lib(session)
  if not lib then return
  ln=lib.lib_name
  ver=lib.version
  addresses=px.s.scan(lib)
  if not addresses then return
  exploits=[]
  for addr in addresses
    vulnInfo=px.s.scan_address(lib,addr)
    if not vulnInfo then continue
    for line in vulnInfo.split(char(10))
      if line.indexOf(_uc)==0 then
        s=line.indexOf("<b>")+3
        d2=line.indexOf("</b>")
        if s>2 and d2!=null then exploits.push({"addr":addr,"val":line[s:d2]})
      end if
    end for
  end for
  p=lib.is_patched(1)
  if p isa string then
    patchStr=GN("Patched To: "+p)
  else if p==1 then
    patchStr=GN("Patched")
  else
    patchStr=RD("Not Patched")
  end if
  ct={"shells":0,"computers":0,"files":0,"bounces":0,"firewalls":0,_uk:0}
  classified=[]
  for e in exploits
    ex=lib.overflow(e.addr,e.val)
    r=_classifyEx(ex,ln)
    if ct.hasIndex(r[0]+"s") then ct[r[0]+"s"]=ct[r[0]+"s"]+1 else ct.unknown=ct.unknown+1
    classified.push({"addr":e.addr,"val":e.val,"type":r[0],"user":r[1]})
  end for
  return {"lib":lib,"ln":ln,"ver":ver,"lan":pt.lip,"port":pt.pn,"exploits":classified,"patchStr":patchStr,"shells":ct.shells,"computers":ct.computers,"files":ct.files,"bounces":ct.bounces,"firewalls":ct.firewalls,_uk:ct.unknown}
end function
_lanPortLip=function(shell,dev,pt)
  lip=pt.lip
  if not _shellNeedsPack(shell) then return lip
  if pt.pn==0 and dev.you and dev.type=="edge" then
    r=_grR(shell)
    if r then lip=local_ip(r)
  else
    lip=dev.ip
  end if
  return lip
end function
scanLAN=function(remoteShell)
  hMetax=_homeMetax()
  if not hMetax then return _pe("Scan metax not loaded")
  comp=_HC(remoteShell)
  lip=comp.local_ip
  if not lip then lip=comp.public_ip
  _pact("Building network map...")
  lanData=_buildLanScan(remoteShell)
  if not lanData then return
  devList=[]
  _flatten=function(devices);for dev in devices;dev.you=false;if dev.ip==lip then dev.you=true;devList.push(dev);if dev.devices then _flatten(dev.devices);end for;end function
  _flatten(lanData)
  if not devList then return _pw("No LAN devices found")
  while true
    if gco.H then break
    _scr("LAN Devices",comp.public_ip)
    _th([["#",5],["LAN IP",18],["TYPE",12],["FW",5],["PORTS",0]])
    for d in devList
      di=__d_idx+1
      tag=d.type
      clr="BL"
      if tag=="edge" then
        tStr="Edge Rtr"
        clr="WH"
      else if tag=="router" then
        tStr="Router"
        clr="WH"
      else if tag=="switch" then
        tStr="Switch"
        clr="YL"
      else if tag=="CCTV" then
        tStr="Camera"
        clr="OR"
      else if tag=="SAPP" then
        tStr="Appliance"
        clr="OR"
      else if tag=="RSHL" then
        tStr="RShell"
        clr="PR"
      else if tag=="ADB" then
        tStr="ADB"
        clr="OR"
      else
        tStr="Device"
      end if
      fwStr="-"
      fwClr="GY"
      if d.fw then
        fwStr="F"
        if d.fwd then fwClr="RD" else fwClr="GN"
      end if
      portNums=[]
      for pt in d.ports;portNums.push(_s(pt.pn));end for
      pStr=""
      if portNums then pStr=WH(join(portNums,","))
      youTag=""
      if d.you then youTag=" "+GN("[YOU]")
      line=_lj(_s(di),5)+_lj(d.ip,18)+_lj(tStr,12)+_lj(fwStr,5)
      cLine=WH(line[:5])+YL(line[5:23])
      if clr=="WH" then
        cLine=cLine+WH(line[23:35])
      else if clr=="YL" then
        cLine=cLine+YL(line[23:35])
      else if clr=="OR" then
        cLine=cLine+OR(line[23:35])
      else if clr=="PR" then
        cLine=cLine+PR(line[23:35])
      else
        cLine=cLine+BL(line[23:35])
      end if
      if fwClr=="RD" then
        cLine=cLine+RD(line[35:40])
      else if fwClr=="GN" then
        cLine=cLine+GN(line[35:40])
      else
        cLine=cLine+GY(line[35:40])
      end if
      _p cLine+pStr+youTag
    end for
    c=_menu("lan",[["#","scan dev"],["r","refresh"],["b","back"]])
    if not c or _tl(c)=="b" then return
    if _tl(c)=="r" then
      _pact("Refreshing network map...")
      lanData=_buildLanScan(remoteShell)
      if not lanData then return
      devList=[]
      _flatten(lanData)
      continue
    end if
    sel=_ti(c.trim)
    if not sel isa number or sel<1 or sel>devList.len then
      _pe(_iv)
      continue
    end if
    dev=devList[sel-1]
    dTargets=[]
    typeFilter=null
    while true
      if gco.H then break
      _scr("Ports — "+dev.ip,dev.type)
      _th([["PORT",8],["STATE",9],["SERVICE",14],["VERSION",11],["LAN",0]])
      for pt in dev.ports;if pt.st=="open" then state=GN(_lj("open",9)) else state=RD(_lj("closed",9));_p GN(_lj(_s(pt.pn),8))+state+BL(_lj(pt.svc,14))+BL(_lj(pt.ver,11))+LM(pt.lip);end for
      if dTargets then
        _sub("Previously Scanned")
        for tgt in dTargets
          i=__tgt_idx+1
          total=tgt.shells+tgt.computers+tgt.files+tgt.bounces+tgt.firewalls+tgt.unknown
          t=PR("[")+WH(_s(i))+PR("] ")+OR(tgt.ln)+WH(" ("+tgt.ver+") ")
          _p t+BL("-> ")+YL(tgt.lan)+WH(":")+GN(_s(tgt.port))
          bd=""
          if tgt.port==0 then bd=YL(" - ")+WH("Bo")+OR(":")+PR(_s(tgt.bounces))+YL(" - ")+WH("Fw")+OR(":")+LM(_s(tgt.firewalls))
          _p "    "+WH("Sh")+OR(":")+GN(_s(tgt.shells))+YL(" - ")+WH("Co")+OR(":")+YL(_s(tgt.computers))+YL(" - ")+WH("Fi")+OR(":")+RD(_s(tgt.files))+bd+YL(" - ")+WH("Un")+OR(":")+ER(_s(tgt.unknown))
        end for
      end if
      _p ""
      if dev.ports.len==1 and not dTargets then
        _pact("Single port, auto-scanning...")
        pc="a"
      else
        pc=_menu("ports",[["a","all"],["b","back"]])
      end if
      if not pc then continue
      if _tl(pc)=="b" then break
      scanPts=[]
      if _tl(pc)=="a" then
        scanPts=dev.ports
      else
        psel=_ti(pc.trim)
        if not psel isa number then
          _pe(_iv)
          continue
        end if
        found=false
        for pt in dev.ports;if pt.pn==psel then;scanPts.push(pt);found=true;break;end if;end for
        if not found then
          if dTargets and psel>0 and psel<=dTargets.len then
            scanPts=[]
          else
            _pe("Port not found: "+_s(psel))
            continue
          end if
        end if
      end if
      newPts=[]
      for pt in scanPts;already=false;for tgt in dTargets;if tgt.port==pt.pn then;already=true;break;end if;end for;if not already then newPts.push(pt);end for
      if scanPts and not newPts then
        ans=_ui(YL("[!] Already scanned. Rescan? (y/N) "))
        if ans and _tl(ans)=="y" then newPts=scanPts
      end if
      if newPts then
        _pact("Scanning "+_s(newPts.len)+" ports for exploits...")
        _p ""
        for pt in newPts
          tgt=_scanLanPort(remoteShell,dev,pt)
          if not tgt then continue
          dTargets.push(tgt)
        end for
      end if
      if not dTargets then
        _pw("No exploitable services found")
        if dev.ports.len==1 then break
        continue
      end if
    while true
      if gco.H then break
      _scr("Attack Vectors",dev.ip)
      showList=dTargets
      if typeFilter then
        showList=[]
        for tgt in dTargets;if _exCountType(tgt,typeFilter)>0 then showList.push(tgt);end for
      end if
      for tgt in showList;_printAttackVector(tgt,__tgt_idx+1,typeFilter,true);end for
      if typeFilter then
        if not showList.len then _pw("No "+_exTypeLabel(typeFilter)+" exploits")
        _exFilterFoot(typeFilter,showList,dTargets)
      end if
      c2=_menu("vectors",_tgtActs)
      if not c2 then continue
      if _mb(c2) then break
      fp=_exPickFilter(c2,typeFilter)
      if fp[0]=="err" then
        _pe(fp[1])
        continue
      end if
      if fp[0]=="ok" then
        typeFilter=fp[1]
        continue
      end if
      if c2.trim=="help" then
        _showHelp("scan")
        continue
      end if
      tsel=_ti(c2.trim)
      if not tsel isa number or tsel<1 or tsel>showList.len then
        _pe(_iv)
        continue
      end if
      tgt=showList[tsel-1]
      _exploitMenu(tgt,dev.ip+":"+_s(tgt.port),typeFilter)
    end while
    end while
  end while
end function
_grR=function(shell)
  mk=_HC(shell).public_ip+":"+_HC(shell).local_ip
  if gco.routers.hasIndex(mk) then return gco.routers[mk]
  comp=_HC(shell)
  u=_gu(shell)
  home=_hd(u)
  gco._dgR=null
  comp.touch(home,".x_gr.src")
  f=comp.File(home+"/.x_gr.src")
  if not f then return
  f.set_content("c=host_computer(get_shell);if c.public_ip and c.public_ip!=""0.0.0.0"" then get_custom_object[""_dgR""]=get_router")
  r=build(shell,path(f),home)
  if r!="" then
    f=comp.File(home+"/.x_gr.src")
    if f then qrm(comp,f)
    return
  end if
  shell.launch(home+"/.x_gr")
  f=comp.File(home+"/.x_gr.src")
  if f then qrm(comp,f)
  f=comp.File(home+"/.x_gr")
  if f then qrm(comp,f)
  if gco._dgR then gco.routers[mk]=gco._dgR
  return gco._dgR
end function
_digBo=function(shell,testIP=null)
  comp=_HC(shell)
  lip=comp.local_ip
  px=_mxs(shell)
  if not px then return _pe("No metax")
  oMx=px.n
  scanMx=px.s
  router=_atHome(shell) and _gr or _grR(shell)
  if not router then return _pe("No router found")
  libDir=comp.File("/lib")
  if not libDir then return _pe("Cannot access /lib")
  libFiles=libDir.get_files
  if not libFiles then return _pe("No libraries in /lib")
  if testIP then
    _pact("Using test IP: "+testIP)
  else
    lanIPs=router.devices_lan_ip
    for ip in lanIPs;if ip!=lip then;testIP=ip;break;end if;end for
    if not testIP then return _pe("No LAN targets to test bounce")
  end if
  _pact("Scanning /lib for bounce exploits...")
  best=null
  for lf in libFiles
    if lf.name=="metaxploit.so" then continue
    lib=oMx.load(lf.path)
    if not lib then continue
    addresses=scanMx.scan(lib)
    if not addresses then continue
    for addr in addresses
      vulnInfo=scanMx.scan_address(lib,addr)
      if not vulnInfo then continue
      for line in vulnInfo.split(char(10))
        if line.indexOf(_uc)!=0 then continue
        s=line.indexOf("<b>")+3
        d2=line.indexOf("</b>")
        if s<3 or d2==null then continue
        unsec=line[s:d2]
        ex=lib.overflow(addr,unsec,testIP)
        if not ex or _to(ex)!=_cm then continue
        usr=_gu(ex)
        _ps("Bounce: "+lf.name+" ["+addr+"] -> "+usr)
        if usr=="root" then
          best={"lib":lib,"addr":addr,"val":unsec,"user":usr,"ln":lf.name}
          break
        end if
        if not best or (best.user==_gt and usr!=_gt) then best={"lib":lib,"addr":addr,"val":unsec,"user":usr,"ln":lf.name}
      end for
      if best and best.user=="root" then break
    end for
    if best and best.user=="root" then break
  end for
  return best
end function
_digX=function(shell,bounce,extreme)
  comp=_HC(shell)
  lip=comp.local_ip
  if _atHome(shell) then router=_gr else router=_grR(shell)
  if not router then return _pe("No router found")
  lanIPs=router.devices_lan_ip
  results=[]
  seen={}
  rIPs=[]
  for ip in lanIPs;dp=router.device_ports(ip);if not dp then continue;for q in dp;if _pn(q)==8080 then;rIPs.push(ip);break;end if;end for;end for
  if not rIPs then
    _pe("No routers found on LAN")
    return results
  end if
  exLimit=50
  if extreme then exLimit=255
  _pact("Sweeping "+_s(rIPs.len)+" subnet(s) (0-"+_s(exLimit)+")...")
  _p ""
  for rip in rIPs
    parts=rip.split("\.")
    prefix=parts[0]+"."+parts[1]+"."+parts[2]+"."
    fails=0
    i=0
    while i<=exLimit
      t=prefix+_s(i)
      if t==lip or seen.hasIndex(t) then
        i=i+1
        continue
      end if
      seen[t]=true
      ex=bounce.lib.overflow(bounce.addr,bounce.val,t)
      if ex==null then
        if fails>=30 then break
        fails=fails+1
        i=i+1
        continue
      end if
      if _to(ex)!=_cm then
        i=i+1
        continue
      end if
      usr=_gu(ex)
      results.push({"ip":t,"ex":ex,"user":usr})
      _pfnd(t+" -> "+usr)
      fails=0
      i=i+1
    end while
  end for
  return results
end function
_digC=function(results,fname)
  items=[]
  denied=0
  for r in results
    c2=r.ex
    hDir=c2.File("/home")
    if not hDir then
      denied=denied+1
      continue
    end if
    for ud in hDir.get_folders
      mf=c2.File(ud.path+"/Config/"+fname)
      if not mf or not _hp(mf,"r") then continue
      mc=_gc(mf)
      if not mc then continue
      p=mc.split(":")
      if p.len>=2 then items.push({"ip":r.ip,"lip":c2.local_ip,"user":ud.name,"acct":p[0],"hash":p[1]})
    end for
  end for
  if denied then _pw(_s(denied)+"/"+_s(results.len)+" hosts denied (permissions)")
  return items
end function
_digRow=function(e,i);_p GY(_lj(_s(i),4))+YL(_lj(e.ip,18))+WH(_lj(e.user,14))+BL(_lj(e.acct,28))+_cd(e.hash);end function
_duRow=function(h,i);_p GY(_lj(_s(i),4))+YL(h.ip);_p GY("    ")+WH(h.user)+GY(" ")+_cd(h.phash);if h.hasIndex("email") then _p GY("    ")+BL(h.email)+GY(" ")+_cd(h.ehash);if h.hasIndex("bank") then _p GY("    ")+BL(h.bank)+GY(" ")+_cd(h.bhash);end function
_crL=function(items)
  if not _homeCrypto() and not _crRainOk then return
  cur=items
  while true
    if gco.H then break
    ans=_menu("creds",_credActs)
    if not ans or _mb(ans) then break
    ans=_tl(ans)
    if ans.indexOf("f ")==0 then
      q=ans[2:]
      cur=[]
      idx=0
      for e in items
        rp=_crResolve(e.hash)
        if e.ip.indexOf(q)!=null or e.user.lower.indexOf(q)!=null or e.acct.lower.indexOf(q)!=null or e.hash.indexOf(q)!=null or (rp and rp.lower.indexOf(q)!=null) then
          _digRow(e,idx)
          cur.push(e)
        end if
        idx=idx+1
      end for
      _ps(_s(cur.len)+"/"+_s(items.len)+" match")
      continue
    end if
    if ans=="f" then
      cur=items
      idx=0
      for e in items;_digRow(e,idx);idx=idx+1;end for
      _ps("Filter cleared")
      continue
    end if
    tc=[]
    if ans=="a" then
      tc=cur
    else
      for n in ans.split(",");n=n.trim;if n==_s(_ti(n)) and _ti(n)>=0 and _ti(n)<items.len then tc.push(items[_ti(n)]);end for
    end if
    for e in tc;p=_crResolve(e.hash);if p then _p GN("  ")+BL(e.acct)+GN(" -> ")+YL(p);end for
  end while
end function
_digE=function(results)
  _pact("Collecting email accounts from "+_s(results.len)+" hosts...")
  emails=_digC(results,"Mail.txt")
  _sub("Emails ("+_s(emails.len)+")")
  if not emails then return _pw("No emails found")
  _credTh([["#",4],["IP",18],["USER",14],["ACCOUNT",28]])
  idx=0
  for e in emails;_digRow(e,idx);idx=idx+1;end for
  _crL(emails)
end function
_digB=function(results)
  _pact("Collecting bank accounts from "+_s(results.len)+" hosts...")
  banks=_digC(results,"Bank.txt")
  _sub("Banks ("+_s(banks.len)+")")
  if not banks then return _pw("No bank accounts found")
  _credTh([["#",4],["IP",18],["USER",14],["ACCOUNT",28]])
  idx=0
  for b in banks;_digRow(b,idx);idx=idx+1;end for
  _crL(banks)
end function
_digR=function(results)
  rshells=_digC(results,"Mail.txt")
  _sub("RShell Data ("+_s(rshells.len)+")")
  if not rshells then return _pw("No rshell data found")
  _credTh([["#",4],["IP",18],["LAN",18],["USER",14],["ACCOUNT",28]])
  idx=0
  for r in rshells;_p GY(_lj(_s(idx),4))+YL(_lj(r.ip,18))+YL(_lj(r.lip,18))+WH(_lj(r.user,14))+BL(_lj(r.acct,28))+_cd(r.hash);idx=idx+1;end for
  _crL(rshells)
end function
_digU=function(results)
  _pact("Collecting user data from "+_s(results.len)+" hosts...")
  rootHash=null
  allH=[]
  denied=0
  seen={}
  for r in results
    c2=r.ex
    lip2=c2.local_ip
    pf=c2.File("/etc/passwd")
    if not pf or not _hp(pf,"r") then
      denied=denied+1
      continue
    end if
    content=_gc(pf)
    if not content then continue
    for line in content.split(char(10))
      if not line then continue
      parts=line.split(":")
      if parts.len<2 then continue
      un=parts[0]
      ph=parts[1]
      if un=="root" then
        if not rootHash then rootHash=ph
        continue
      end if
      key=lip2+":"+un
      if seen.hasIndex(key) then continue
      seen[key]=true
      rec={"ip":lip2,"user":un,"phash":ph}
      hDir=c2.File("/home/"+un)
      if hDir then
        mf=c2.File("/home/"+un+"/Config/Mail.txt")
        if mf and _hp(mf,"r") then
          mc=_gc(mf)
          if mc then
            mp=mc.split(":")
            if mp.len>=2 then
              rec.email=mp[0]
              rec.ehash=mp[1]
            end if
          end if
        end if
        bf=c2.File("/home/"+un+"/Config/Bank.txt")
        if bf and _hp(bf,"r") then
          bc=_gc(bf)
          if bc then
            bp=bc.split(":")
            if bp.len>=2 then
              rec.bank=bp[0]
              rec.bhash=bp[1]
            end if
          end if
        end if
      end if
      allH.push(rec)
    end for
  end for
  if denied then _pw(_s(denied)+"/"+_s(results.len)+" hosts denied (permissions)")
  if rootHash then
    _p OR("ROOT: ")+_cd(rootHash)
    _p ""
  end if
  if not allH then return _pw("No user data found")
  _sub("User Data ("+_s(allH.len)+")")
  idx=0
  for h in allH;_duRow(h,idx);idx=idx+1;end for
  if not _homeCrypto() and not _crRainOk then return
  while true
    if gco.H then break
    ans=_menu("creds",_credActs)
    if not ans or _mb(ans) then break
    ans=_tl(ans)
    if ans.indexOf("f ")==0 then
      q=ans[2:]
      cnt=0
      idx=0
      for h in allH
        mt=h.ip.indexOf(q)!=null or h.user.lower.indexOf(q)!=null or h.phash.indexOf(q)!=null
        if not mt and h.hasIndex("email") then mt=h.email.lower.indexOf(q)!=null
        if not mt and h.hasIndex("bank") then mt=h.bank.lower.indexOf(q)!=null
        if mt then
          _duRow(h,idx)
          cnt=cnt+1
        end if
        idx=idx+1
      end for
      _ps(_s(cnt)+"/"+_s(allH.len)+" match")
      continue
    end if
    if ans=="f" then
      idx=0
      for h in allH;_duRow(h,idx);idx=idx+1;end for
      _ps("Filter cleared")
      continue
    end if
    tc=[]
    if ans=="a" then
      tc=allH
    else
      for n in ans.split(",");n=n.trim;if n==_s(_ti(n)) and _ti(n)>=0 and _ti(n)<allH.len then tc.push(allH[_ti(n)]);end for
    end if
    for h in tc
      _p GN("  "+h.ip+" ")+WH(h.user)
      wh=_ask("[p]asswd [e]mail [b]ank [a]ll")
      if not wh then continue
      wh=_tl(wh)
      if wh=="p" or wh=="a" then
        p=_crH(h.phash)
        if p then _p GN("    passwd -> ")+YL(p) else _p GY("  passwd: not cracked")
      end if
      if h.hasIndex("ehash") and (wh=="e" or wh=="a") then
        p=_crH(h.ehash)
        if p then _p GN("    email  -> ")+YL(p) else _p GY("  email: not cracked")
      end if
      if h.hasIndex("bhash") and (wh=="b" or wh=="a") then
        p=_crH(h.bhash)
        if p then _p GN("    bank   -> ")+YL(p) else _p GY("  bank: not cracked")
      end if
    end for
  end while
end function
_digFS=function(results,fn)
  _pact("Searching "+_s(results.len)+" machines for "+fn+"...")
  found=[]
  for r in results;c2=r.ex;for f in getAllFiles(c2);if f.name==fn then;found.push({"ip":r.ip,"path":f.path,"file":f});_pfnd(r.ip+" "+f.path);end if;end for;end for
  if not found then _pw("File not found on any machine")
end function
_digW=function(results)
  wiped=0
  for r in results
    c2=r.ex
    bf=c2.File("/boot")
    if not bf or not _hp(bf,"w") then continue
    for f in bf.get_files;if _hp(f,"w") then f.delete;end for
    wiped=wiped+1
    _p RD("  [x] ")+YL(r.ip)+GY(" /boot wiped")
  end for
  _ps(_s(wiped)+"/"+_s(results.len)+" machines wiped")
end function
_digA=function(shell,task,extra="")
  comp=_HC(shell)
  if not comp.File("/lib/kernel_router.so") then return _pe("you must be on a router to run dig")
  t=_tl(task)
  if t=="rt" then
    bounce=_digBo(shell)
    if not bounce then return _pe("No bounce found")
    router=_routerForShell(shell)
    lip=comp.local_ip
    testTarget=extra
    if not testTarget or not testTarget.len then
      if router and router.devices_lan_ip then
        for ip in router.devices_lan_ip;if ip!=lip then testTarget=ip;break;end for
      end if
    end if
    if not testTarget then return _pe("No LAN target")
    ex=bounce.lib.overflow(bounce.addr,bounce.val,testTarget)
    if not ex or _to(ex)!=_cm then return _pe("Could not get computer from "+testTarget)
    pf=ex.File("/etc/passwd")
    if not pf or not _hp(pf,"r") then return _pe("Cannot read /etc/passwd")
    content=_gc(pf)
    if not content then return _pe("Empty passwd file")
    for line in content.split(char(10))
      if not line then continue
      parts=line.split(":")
      if parts.len>=2 and parts[0]=="root" then
        _p OR("ROOT: ")+_cd(parts[1])
        rp=_crH(parts[1])
        if rp then
          _acr(shell,"root",rp)
          _ps("Added root:"+rp+" to cache")
        end if
        break
      end if
    end for
    return
  end if
  bounce=_digBo(shell)
  if not bounce then return _pe("No bounce found")
  _ps(bounce.ln+" ["+bounce.addr+"] "+bounce.user)
  results=_digX(shell,bounce,false)
  if not results then return _pe("No machines")
  _ps(_s(results.len)+" hosts")
  if t=="e" then
    _digE(results)
  else if t=="bk" then
    _digB(results)
  else if t=="u" then
    _digU(results)
  else if t=="r" then
    _digR(results)
  else if t=="sw" then
    ans=_ui(RD("[!] This will wipe /boot on ALL LAN machines. Type YES > "))
    if ans!="YES" then return _pw("Cancelled")
    _digW(results)
  else if t=="s" then
    fn=extra
    if not fn or not fn.len then
      fnAsk=_ask("Filename")
      if not fnAsk or not fnAsk.trim.len then return
      fn=fnAsk.trim
    end if
    _digFS(results,fn)
  else
    _pe("Unknown dig task: "+task)
  end if
end function
_digResultsMenu=function(res)
  while true
    if gco.H then break
    ch=_menu("dig",_digActs)
    if not ch then continue
    dca=_arg1(ch.trim)
    dact=dca[0]
    dargs=dca[1]
    if _mb(dact) then return
    if dact=="help" then _showHelp("dig");continue
    if dact=="e" then _digE(res)
    if dact=="bk" then _digB(res)
    if dact=="u" then _digU(res)
    if dact=="sw" then _digW(res)
    if dact=="s" then
      fn=dargs
      if not fn.len then fn=_ask("filename")
      if fn and fn.trim.len then _digFS(res,fn.trim)
    end if
  end while
end function
_recon=function(_tip,task="d")
  px=_mxs(_ls)
  if not px then return _pe("No metax")
  if not _hasNet(_lc) then return _pe("No internet connection")
  _pact("Recon: "+_tip+":0...")
  ses=net_use(px.n,_tip)
  if not ses then return _pe("Cannot connect to "+_tip+":0")
  lib=ses.dump_lib
  if not lib then return _pe("Cannot dump lib "+_tip+":0")
  addrs=px.s.scan(lib)
  if not addrs then return _pe("No exploits on "+_tip+":0")
  shell=null
  bns=[]
  for addr in addrs
    vi=px.s.scan_address(lib,addr)
    if not vi then continue
    for line in vi.split(char(10))
      if line.indexOf(_uc)!=0 then continue
      s=line.indexOf("<b>")+3
      d=line.indexOf("</b>")
      if s<=2 or d==null then continue
      val=line[s:d]
      ex=lib.overflow(addr,val)
      if not ex then continue
      obj=_to(ex)
      if obj==_sh or obj==_fs then
        if not shell or _gu(ex)=="root" then shell=ex
      else if obj==_cm then
        usr=_gu(ex)
        bns.push({"lib":lib,"addr":addr,"val":val,"user":usr,"ln":lib_name(lib)})
        _p GN("  [bounce] ")+GY(addr+" -> ")+WH(usr)
      end if
    end for
  end for
  if bns.len and shell then
    sb=[];ub=[];gb=[]
    for b in bns;if b.user=="root" then;sb.push(b);else if b.user==_gt then;gb.push(b);else;ub.push(b);end if;end for
    bns=sb+ub+gb
    _ps(_s(bns.len)+" bounce(s) on edge router")
    _rule
    for i in range(0,bns.len);b=bns[i];_p GN("  ["+_s(i+1)+"] ")+WH(b.user)+GY(" — "+b.addr);end for
    _rule
    sel=_menu("bounce",[["#","select"],["s","skip"]])
    if sel and _tl(sel)!="s" then
      idx=sel.trim.val-1
      if idx>=0 and idx<bns.len then
        best=bns[idx]
        _ps("Shell: "+_gu(shell)+" on "+_HC(shell).public_ip)
        _ps("Bounce: "+best.ln+" ["+best.addr+"] "+best.user)
        res=_digX(shell,best,false)
        if not res then return _pe("No machines")
        _ps(_s(res.len)+" hosts")
        if task!="d" then return _digA(shell,task)
        _digResultsMenu(res)
      end if
    end if
  else if bns.len then
    _pw(_s(bns.len)+" bounce(s) but no shell for LAN")
  end if
  if not shell then return _pe("No shell on router")
  _ps(_gu(shell)+" shell on "+_HC(shell).public_ip)
  if task=="d" then return _digS(shell)
  _digA(shell,task)
end function
_digS=function(shell)
  comp=_HC(shell)
  if not comp.File("/lib/kernel_router.so") then return _pe("you must be on a router to run dig")
  lip=comp.local_ip
  router=_routerForShell(shell)
  if not router then return _pe("No router found")
  lanIPs=router.devices_lan_ip
  if not lanIPs then return _pe("No LAN devices found")
  testIP=null
  while true
    if gco.H then break
    _scr("DIG Recon",router.public_ip)
    tLine=GY("  Router: ")+YL(router.public_ip)+GY(" LAN: ")+YL(lip)
    if testIP then tLine=tLine+GY(" Test: ")+YL(testIP)
    _p tLine
    _mrow(d1)
    _mrow(d2)
    ch=_uig(WH("dig> "))
    if not ch then continue
    dca=_arg1(ch.trim)
    dact=dca[0]
    dargs=dca[1]
    if _mb(dact) then break
    if dact=="help" then
      _showHelp("dig")
      continue
    end if
    if dact=="t" then
      ti=_ask("Test IP (blank=auto)")
      if ti and len(ti.trim) then testIP=ti.trim else testIP=null
      continue
    end if
    if dact=="cl" then
      _ck=router.public_ip
      if not gco.hasIndex("digCache") then gco.digCache={}
      dc=gco.digCache
      if dc.hasIndex(_ck) then dc.remove(_ck)
      _ps("Cache cleared for "+_ck)
      continue
    end if
    if dact!="e" and dact!="bk" and dact!="u" and dact!="rt" and dact!="r" and dact!="s" and dact!="sw" then
      _pe("Invalid option")
      continue
    end if
    fn=null
    if dact=="s" then
      fn=dargs
      if not fn.len then
        fnAsk=_ask("Filename")
        if not fnAsk or not len(fnAsk.trim) then continue
        fn=fnAsk.trim
      end if
    end if
    if dact=="sw" then
      ans=_ui(RD("[!] This will wipe /boot on ALL LAN machines. Type YES > "))
      if ans!="YES" then
        _pw("Cancelled")
        continue
      end if
    end if
    exAns=_ask("Extreme? Sweep subnets 0-255 (y/N)")
    extreme=exAns and _tl(exAns)=="y"
    _ck=router.public_ip
    if not gco.hasIndex("digCache") then gco.digCache={}
    dc=gco.digCache
    bounce=null
    libDir=_HC(shell).File("/lib")
    libCount=0
    if libDir then libCount=len(libDir.get_files)
    if dc.hasIndex(_ck) and dc[_ck].bounce then
      if dc[_ck].hasIndex("libCount") and dc[_ck].libCount!=libCount then
        _ps("Libraries changed — rescanning bounce")
        dc.remove(_ck)
      else
        bounce=dc[_ck].bounce
        _ps("Using cached bounce: "+bounce.ln+" ["+bounce.addr+"] as "+bounce.user)
      end if
    end if
    if not bounce then
      _pact("Searching /lib for bounce exploit...")
      bounce=_digBo(shell,testIP)
      if not bounce then
        _pe("No bounce exploit found in /lib")
        continue
      end if
      if not dc.hasIndex(_ck) then dc[_ck]={}
      dc[_ck].bounce=bounce
      dc[_ck].libCount=libCount
      _ps("Using: "+bounce.ln+" ["+bounce.addr+"] as "+bounce.user)
    end if
    if dact=="rt" then
      testTarget=null
      if testIP then testTarget=testIP
      if not testTarget then
        for ip in lanIPs
          if ip!=lip then
            testTarget=ip
            break
          end if
        end for
      end if
      if not testTarget then
        _pe("No LAN target")
        continue
      end if
      ex=bounce.lib.overflow(bounce.addr,bounce.val,testTarget)
      if not ex or _to(ex)!=_cm then
        _pe("Could not get computer from "+testTarget)
        continue
      end if
      pf=ex.File("/etc/passwd")
      if not pf or not _hp(pf,"r") then
        _pe("Cannot read /etc/passwd")
        continue
      end if
      content=_gc(pf)
      if not content then
        _pe("Empty passwd file")
        continue
      end if
      for line in content.split(char(10))
        if not line then continue
        parts=line.split(":")
        if parts.len>=2 and parts[0]=="root" then
          _p OR("ROOT: ")+_cd(parts[1])
          rp=_crH(parts[1])
          if rp then
            _acr(shell,"root",rp)
            _ps("Added root:"+rp+" to cache")
          end if
          break
        end if
      end for
      continue
    end if
    results=null
    exKey="results"
    if extreme then exKey="results_ex"
    if dc[_ck].hasIndex(exKey) then
      results=dc[_ck][exKey]
      _ps("Using cached results: "+_s(results.len)+" machines")
    else
      results=_digX(shell,bounce,extreme)
      if not results then
        _pe("No machines compromised")
        continue
      end if
      dc[_ck][exKey]=results
    end if
    _ps(_s(results.len)+" machines compromised")
    if dact=="e" then _digE(results)
    if dact=="bk" then _digB(results)
    if dact=="u" then _digU(results)
    if dact=="r" then _digR(results)
    if dact=="s" then _digFS(results,fn)
    if dact=="sw" then _digW(results)
  end while
end function
_cpw=function(ex)
  pf=getFileEx(ex,"/etc/passwd")
  if not pf then return 0
  c=_gc(pf)
  if not c then return 0
  n=0
  for line in c.split(char(10));if not line or not line.len then continue;pp=line.split(":");if pp.len<2 then continue;n=n+1;end for
  return n
end function
_hostActs=function(ex,shell)
  pCnt=_cpw(ex)
  rsCnt=_s(gco.rshell_servers.len)+"/"+_s(gco.rshell_shells.len)
  ps="("+_s(pCnt)+")"
  if shell then
    acts=[["f","browse"],["a","apps"],["d","download"],["u","upload"],["ul","uploadlib"],["ld","loadlib"],["l","local"],["n","lan"],["dg","dig"],["po","pobject"],["rc","recon"],["ht","hunt"],["wf","wifi"],["dv","devices"],["pv","pivot"],["dy","deploy"],["ml","mail"],["g","grab"],["c","crack"],["k","md5"],["rs","rshell ("+rsCnt+")"],["p","passwords"],["pc","cached"]]
    if _gu(ex)!="root" then
      cip=_gcr(shell)
      if cip.len then acts.push(["s","su ("+_s(cip.len)+")"]) else acts.push(["s","su"])
    end if
    acts=acts+[["lg","getlog"],["wl","wipe"],["tr","tree"],["rl","reload"],["0d","0day"],["cl","clear"],["w","whois"],["pw","passwd "+ps],["help","help"],["b","back"]]
    return acts
  end if
  return [["f","browse"],["d","download"],["g","grab"],["cr","crack "+ps],["k","md5"],["ml","mail"],["lg","getlog"],["wl","wipe"],["w","whois"],["tr","tree"],["rl","reload"],["0d","0day"],["cl","clear"],["help","help"],["b","back"]]
end function
_gcr=function(sh)
  lip=_HC(sh).local_ip
  r=[]
  if gco.hasIndex("_eip") and gco._eip and gco._nc.hasIndex(gco._eip) then r=r+gco._nc[gco._eip]
  if gco._nc.hasIndex(lip) then r=r+gco._nc[lip]
  return r
end function
_gcr2=function(ex,exType)
  if exType==_sh then
    lip=_HC(ex).local_ip
  else if exType==_cm then
    lip=ex.local_ip
  else
    return []
  end if
  r=[]
  if gco.hasIndex("_eip") and gco._eip and gco._nc.hasIndex(gco._eip) then r=r+gco._nc[gco._eip]
  if gco._nc.hasIndex(lip) then r=r+gco._nc[lip]
  return r
end function
_acr2=function(ip,u,p)
  if not ip or not p then return
  k=ip
  if u=="root" and gco.hasIndex("_eip") and gco._eip then k=gco._eip
  if not gco._nc.hasIndex(k) then gco._nc[k]=[]
  for c in gco._nc[k];if c.user==u then return;end for
  gco._nc[k].push({"user":u,"pass":p})
end function
_acr=function(sh,u,p);_acr2(_HC(sh).local_ip,u,p);end function
_loadDevLib=function(shell,libName)
  comp=_HC(shell)
  pip=comp.public_ip
  lip=comp.local_ip
  dk="dev_"+libName
  if gco.hasIndex(dk) and gco[dk] then return gco[dk]
  f=comp.File("/lib/"+libName)
  if not f then return
  u=_gu(shell)
  home=_hd(u)
  if gco.hasIndex(dk) then gco[dk]=null
  code="get_custom_object["""+dk+"""]=include_lib(""/lib/"+libName+""")"
  comp.touch(home,".x_d.src")
  sf=comp.File(home+"/.x_d.src")
  if not sf then return
  sf.set_content(code)
  r=shell.build(path(sf),home)
  if r!="" then
    sf=comp.File(home+"/.x_d.src")
    if sf then qrm(comp,sf)
    return
  end if
  shell.launch(home+"/.x_d")
  sf=comp.File(home+"/.x_d.src")
  if sf then qrm(comp,sf)
  sf=comp.File(home+"/.x_d")
  if sf then qrm(comp,sf)
  if not gco.hasIndex(dk) or not gco[dk] then return
  result=gco[dk]
  return result
end function
_loadRemoteLib=function(shell,libPath)
  comp=_HC(shell)
  f=comp.File(libPath)
  if not f then return _pe("Not found: "+libPath)
  u=_gu(shell)
  home=_hd(u)
  dk="rlib_"+libPath
  gco[dk]=null
  code="l=include_lib("""+libPath+""");if l then get_custom_object["""+dk+"""]=l;get_custom_object[""rlib_type""]=typeof(l)"
  comp.touch(home,".x_rl.src")
  sf=comp.File(home+"/.x_rl.src")
  if not sf then return _pe("Failed to create loader")
  sf.set_content(code)
  r=shell.build(path(sf),home)
  if r!="" then
    sf=comp.File(home+"/.x_rl.src")
    if sf then qrm(comp,sf)
    return _pe(_bf+r)
  end if
  shell.launch(home+"/.x_rl")
  sf=comp.File(home+"/.x_rl.src")
  if sf then qrm(comp,sf)
  sf=comp.File(home+"/.x_rl")
  if sf then qrm(comp,sf)
  if not gco.hasIndex(dk) or not gco[dk] then return _pe("Failed to load: "+libPath)
  lib=gco[dk]
  lt=gco.rlib_type
  mk=comp.public_ip+":"+comp.local_ip
  if lt=="MetaxploitLib" then
    gco.metas[mk]=lib
    _ps("Loaded remote metaxploit: "+libPath)
  else if lt=="cryptoLib" then
    _ps("Loaded remote crypto: "+libPath)
  else
    _ps("Loaded "+lt+": "+libPath)
  end if
end function
_devMenu=function(shell)
  if not shell then return _pe(_ns)
  comp=_HC(shell)
  pip=comp.public_ip
  lip=comp.local_ip
  while true
    if gco.H then break
    _scr("Devices")
    _p _mi("sa"," Smart Appliance (port 1883)")
    _p _mi("tf"," Traffic Net (port 37777)")
    _p _bk
    dc=_uig(_pmt("devices"))
    if not dc or _tl(dc)=="b" then break
    _dc=_tl(dc)
    if _dc=="sa" then
      _pact("Loading libsmartappliance.so...")
      sa=_loadDevLib(shell,"libsmartappliance.so")
      if not sa then
        _pe("libsmartappliance.so not found on target")
        continue
      end if
      while true
        if gco.H then break
        _sub("Smart Appliance")
        _p _mi("m","  Model ID")
        _p _mi("o","  Override settings (power/temp)")
        _p _mi("a","  Toggle alarm")
        _p _bk
        sc=_uig(_pmt("appliance"))
        if not sc or _tl(sc)=="b" then break
        _sc=_tl(sc)
        if _sc=="m" then
          r=sa.model
          if r then _p GY("  Model: ")+YL(_s(r)) else _pe("Failed")
        else if _sc=="o" then
          pw=_ask("Power (default 500)")
          tp=_ask("Temperature (default 50)")
          p=500
          t=50
          if pw and len(pw.trim) then p=_ti(pw.trim)
          if tp and len(tp.trim) then t=_ti(tp.trim)
          r=sa.override_settings(p,t)
          if r==1 then _pe("Override successful","s") else _pe("Failed: "+_s(r))
        else if _sc=="a" then
          en=_ask("Enable alarm? (y/N)")
          v=0
          if en and _tl(en)=="y" then v=1
          r=sa.set_alarm(v)
          if r==1 then _pe("Alarm "+["disabled","enabled"][v],"s") else _pe("Failed: "+_s(r))
        end if
      end while
    else if _dc=="tf" then
      _pact("Loading libtrafficnet.so...")
      tf=_loadDevLib(shell,"libtrafficnet.so")
      if not tf then
        _pe("libtrafficnet.so not found on target")
        continue
      end if
      while true
        if gco.H then break
        _sub("Traffic Net")
        _p _mi("c","  Camera system (open viewer)")
        _p _mi("v","  Locate vehicle")
        _p _mi("i","  Get NPC credentials")
        _p _bk
        tc=_uig(_pmt("traffic"))
        if not tc or _tl(tc)=="b" then break
        _tc=_tl(tc)
        if _tc=="c" then
          r=tf.camera_link_system
          if r==1 then _pe("Camera broadcast initiated","s") else _pe("Failed: "+_s(r))
        else if _tc=="v" then
          pl=_ask("License plate")
          if not pl or not len(pl.trim) then continue
          pw=_ask("Password")
          if not pw then pw=""
          r=tf.locate_vehicle(pl.trim,pw)
          if r==1 then _pe("Vehicle found!","s") else _pw("Result: "+_s(r))
        else if _tc=="i" then
          r=tf.get_credentials_info
          if r then _p GY("  ")+YL(_s(r)) else _pe("Failed")
        end if
      end while
    end if
  end while
end function
_wifiCrack=function(sh=null)
  if not sh then sh=get_shell
  cr=_opsCrypto(sh)
  if not cr then return _pe("crypto.so not loaded")
  comp=_HC(sh)
  if comp.active_net_card!="WIFI" then return _pe("WiFi not active")
  nets=comp.wifi_networks("wlan0")
  if not nets then return _pe("No networks found")
  _scr("WiFi Networks")
  i=1
  for n in nets;p=n.split(" ");_p YL("  "+_lj(_s(i),4))+GN(_lj(p[0],20))+WH(_lj(p[1],6))+GY(p[2]);i=i+1;end for
  _foot([["a","crack all"],["#","crack one"],["help","help"],["q","cancel"]])
  ch=_uig(_pmt("wifi"))
  if not ch or ch.lower=="q" then return
  if ch.lower=="help" then _showHelp("wifi");return
  targets=[]
  if ch.lower=="a" then
    targets=nets
  else
    sn=_ti(ch)
    if not sn isa number or sn<1 or sn>nets.len then return _pe("Invalid")
    targets.push(nets[sn-1])
  end if
  r=cr.airmon("start","wlan0")
  if r isa string then return _pe(r)
  if not r then return _pe("airmon failed")
  cracked=[]
  for n in targets
    p=n.split(" ")
    bssid=p[0];pwr=p[1];essid=p[2]
    s=_ti(pwr.replace("%",""))
    acks=ceil(300000/(s+15))
    _pact("Cracking "+essid+" ("+bssid+") ACKs:"+_s(acks)+"...")
    cr.aireplay(bssid,essid,acks)
    capPath=_shellHomePath(sh)+"/file.cap"
    pw=cr.aircrack(capPath)
    cf=comp.File(capPath)
    if cf then cf.delete
    if pw and pw!="null" then
      _ps("Cracked "+essid)
      _pd("Password",pw)
      cracked.push({"bssid":bssid,"essid":essid,"pass":pw})
    else
      _p RD("  [-] ")+GY(essid+" failed")
    end if
  end for
  if not cracked.len then return _pe("No passwords cracked")
  _sub("Cracked Networks")
  i=1
  for c in cracked;_p YL("  "+_s(i)+"  ")+GN(c.essid);i=i+1;end for
  _foot([["#","connect"],["q","cancel"]])
  while true
    if gco.H then break
    ch=_uig(_pmt("connect"))
    if not ch or not len(ch.trim) then continue
    if ch.lower=="q" then return
    sn=_ti(ch)
    if sn isa number and sn>=1 and sn<=cracked.len then
      c=cracked[sn-1]
      _pact("Connecting to "+c.essid+"...")
      r=comp.connect_wifi("wlan0",c.bssid,c.essid,c.pass)
      if r isa string then _pe(r) else _ps("Connected to "+c.essid)
      return
    end if
  end while
end function
_whois=function(target)
  if not target then return _pe("Usage: whois <ip or domain>")
  if target[:3]=="www" then
    target=nslookup(target)
    if target=="Not found" then return _pe("Invalid web address")
  end if
  if not _vi(target) then
    resolved=nslookup(target)
    if not resolved then return _pe("Cannot resolve: "+target)
    target=resolved
  end if
  info={}
  _lc=_HC(_ls)
  if _hasNet(_lc) then
    router=_gr(target)
    if router then
      info.BSSID=router.bssid_name
      info.ESSID=router.essid_name
    end if
  end if
  whoisData=whois(target)
  if indexOf(whoisData,"Domain name")==null then return _pe(whoisData)
  whoisData=whoisData.replace("Domain name: ","")
  whoisData=whoisData.replace("Administrative contact: ","")
  whoisData=whoisData.replace("Email address: ","")
  whoisData=whoisData.replace("Phone: ","")
  lines=split(whoisData,char(10))
  info.web=lines[0]
  info.ip=target
  info.domain=lines[0].replace("www.","")
  info.email=lines[2]
  info.admin=lines[1]
  info.phone=lines[3]
  info.company=info.web.split("\.")[1]
  _scr("Whois","",target)
  _p ""
  if info.hasIndex("BSSID") then _pd("BSSID",info.BSSID)
  if info.hasIndex("ESSID") then _pd("ESSID",info.ESSID)
  _pd("Public IP",info.ip)
  _pd("Website",info.web)
  _pd("Domain",info.domain)
  _pd("Company",info.company)
  _pd("Admin",info.admin)
  _pd("Email",info.email)
  _pd("Phone",info.phone)
  if lines.len>4 then
    i=4
    _len=lines.len
    while i<_len;if len(trim(lines[i])) then _pd("Info",lines[i]);i=i+1;end while
  end if
  _p ""
end function
_showHelp=function(topic)
  if not topic then topic="all"
  t=topic.lower
  _scr("Scanner Help")
  if t=="all" or t=="main" then
    _sub("Status Bar")
    _p GY("  MX/CR/RB on/off  RS servers/shells  NET OFF  PV pivot count")
    _p ""
    _sub("Main Commands")
    _crow(["<ip>","r","ls","ns","sc -l"])
    _crow(["recon","hunt","crack","mail","host","pivots"])
    // XFIX1.0: REMOVE "neuro" from crow when _neuroScan goes
    _crow(["rshell","wifi","dig","pobject","neuro","help","clear","reload","exit"])
    _p GY("  help — full manual   help <topic> — one section")
    _p ""
  end if
  if t=="all" or t=="scan" then
    _sub("Scan command flags")
    _p GY("  <ip> / hostname     scan remote target")
    _p GY("  sc 1.2.3.4           same as typing IP")
    _p GY("  sc example.com       resolve then scan")
    _p GY("  sc -l / --local      local library scan")
    _p GY("  sc -n / --lan        LAN device scan")
    _p GY("  r / sc -r            random public IP")
    _p ""
    _sub("Exploit scan menu")
    _p GY("  port 0=kernel; open ports show LAN NAT hop")
    _p GY("  # port/a scan exploits; # opens list")
    _p GY("  f type filter; # run exploit")
    _p GY("  Types: shell computer file bounce firewall null unknown")
    _p GY("  kernel_router: bounce=LAN hop  firewall=number prompt")
    _p ""
  end if
  if t=="all" or t=="exploit" then
    _sub("Exploit Menu")
    _p GY("  # run listed exploit")
    _p GY("  f shell|sh — filter list (f all clears)")
    _p GY("  c custom — enter memory addr + unsafe value manually")
    _p GY("  c <addr> <val> — one-line overflow")
    _p GY("  ba <lan-ip> — try every bounce exploit against IP")
    _p ""
  end if
  if t=="all" or t=="host" or t=="uploadlib" or t=="ul" or t=="loadlib" or t=="ld" then
    _sub("Host Commands")
    _p GY("  With shell:")
    _crow(["browse","apps","download","upload","uploadlib","loadlib","local","lan","dig"])
    _crow(["pobject","recon","hunt","wifi","devices","pivot","deploy","mail"])
    _crow(["grab","crack","md5","rshell","passwords","cached","getlog","wipe"])
    _crow(["tree","reload","0day","clear","whois","passwd","help"])
    _p GY("  Without shell (computer/file):")
    _crow(["browse","download","grab","crack","md5","mail","getlog","wipe"])
    _crow(["whois","tree","reload","0day","clear","help"])
    _p GY("  Typed: seek rename  ·  su: cache rainbow dict crypto")
    _p GY("  File: ls cd cp mv rm chmod ps kill")
    if t=="all" or t=="host" or t=="uploadlib" or t=="ul" then
      _p ""
      _sub("Upload library (ul / uploadlib)")
      _p GY("  ul: SCP .so from main Downloads")
      _p GY("  ul crypto.so — from Downloads")
      _p GY("  ul /main/path/lib.so [dest=/lib]")
    end if
    if t=="all" or t=="host" or t=="loadlib" or t=="ld" then
      _p ""
      _sub("Load library (ld / loadlib)")
      _p GY("  ld path e.g. /lib/crypto.so on host")
    end if
    _p ""
  end if
  if t=="all" or t=="mail" then
    _sub("Mail (ml)")
    _p GY("  l login + fetch listing   f refetch   v view subjects")
    _p GY("  r [#|MailID] read full body via read([id])")
    _p GY("  n send   d delete([ids])   a delete_all   o logout")
    _p GY("  MetaMail: 2s cooldown — bar shows CD when active")
    _p GY("  Session kept until logout or leaving host menu")
    _p ""
  end if
  if t=="all" or t=="crack" then
    _sub("Crack / Rainbow")
    _p GY("  l [path] words from Documents/passwords")
    _p GY("  r [path] rainbow pass:md5 in Documents/rainbow/r*")
    _p GY("  g gen MD5 entries (lower/Upper/case variants)")
    _p GY("  d dump memory table to Documents/rainbow/")
    _p GY("  c: md5 user:hash email file path")
    _p GY("  Rainbow: mem disk r* crypto")
    _p ""
  end if
  if t=="all" or t=="dig" then
    _sub("Dig (router shell required)")
    _p GY("  bounce from /lib scan sweeps LAN")
    _p GY("  sweep 0-50; Extreme (y) 0-255")
    _p GY("  e/bk/u/rt/r collect emails banks users root rshell data")
    _p GY("  s filename  sw wipe /boot (type YES)  t test bounce IP")
    _p GY("  cl clear dig cache for this router")
    _p ""
  end if
  if t=="all" or t=="recon" then
    _sub("Recon (rc)")
    _p GY("  Single router IP :0 — get shell, optional bounce pick")
    _p GY("  e/bk/u/s run one task without full dig sweep")
    _p GY("  d opens full dig menu on that router")
    _p ""
  end if
  if t=="all" or t=="hunt" then
    _sub("Hunt (ht)")
    _p GY("  ht — interactive   ht ssh 50 — service + max random IPs")
    _p GY("  ht http 100 2.4 — optional version filter on banner")
    _p GY("  Services: ssh ftp http smtp sql repo rshell cam")
    _p GY("  Scans random public IPs; lists router port + LAN device")
    _p ""
  end if
  if t=="all" or t=="wifi" then
    _sub("WiFi (wf)")
    _p GY("  Needs active WiFi on current shell host (wlan0)")
    _p GY("  a = crack all networks   # = crack one by list number")
    _p GY("  Flow: airmon start -> aireplay -> aircrack -> connect")
    _p ""
  end if
  // XFIX1.0: REMOVE neuro help block with _neuroScan
  if t=="all" or t=="neuro" then
    _sub("Neurobox Scan (nr)")
    _p GY("  Find hidden Neurobox IP via mail + partial whois brute")
    _p GY("  Needs email login that can mail_login + send to target")
    _p GY("  Partial IP uses XXX for unknown octet (e.g. 10.XXX.1.2)")
    _p ""
  end if
  if t=="all" or t=="0day" then
    _sub("0day Window (0d)")
    _p GY("  0d — show active window + time remaining (IRL clock)")
    _p GY("  days 1-14 of even months only")
    _p ""
  end if
  if t=="all" or t=="pivot" then
    _sub("Pivot (pv) & Deploy (dy)")
    _p GY("  pv — list/kill pivot sessions (x = kill all)")
    _p GY("  pv: SCP scanner+libs to remote payload/")
    _p GY("  pivot child: x at main returns home")
    _p GY("  dy — deploy bin from main Downloads to remote shell home")
    _p ""
  end if
  if t=="all" or t=="rshell" then
    _sub("RShell (rs)")
    _p GY("  needs metaxploit; bar rs=servers/shells")
    _p GY("  s install server on current shell (host menu only)")
    _p GY("  c start client on current shell")
    _p GY("  i import server IP (default current host)")
    _p GY("  r refresh connected shells from imported servers")
    _p GY("  # open shell by list number")
    _p ""
  end if
  if t=="all" or t=="main" then
    _sub("PObject (! po)")
    _p GY("  scan probe meta libs ports  mkdir touch ps passwd kill")
    _p GY("  chmod octal/symbolic  cp mv rm rn chown chgrp  -r recursive")
    _p ""
    _sub("Tips")
    _p GY("  Root password in /etc/passwd works across that LAN")
    _p GY("  help <topic> — host mail crack dig recon wifi 0day pv rs")
  end if
  _rule
  _p ""
end function
getRandomIP=function
  while true
    a=floor(rnd*255)+1
    b=floor(rnd*255)
    c=floor(rnd*255)
    d=floor(rnd*255)+1
    ip=a+"."+b+"."+c+"."+d
    if a==10 then continue
    if a==172 and b>=16 and b<=31 then continue
    if a==192 and b==168 then continue
    if a==127 then continue
    if a==0 or a>=224 then continue
    return ip
  end while
end function
_loadLib=function(libPath)
  libPath=libPath.trim
  lib=include_lib(libPath)
  if not lib then return _pe("Failed to load: "+libPath)
  t=_to(lib)
  if t=="MetaxploitLib" then
    metax=lib
    metaxPath=libPath
    _n=_cur
    _n.metax=metax
    _n.metaxPath=metaxPath
    homeLIP=_HC(get_shell).local_ip
    if homeLIP then gco.metas[homeLIP]=metax
    if not isPivot then
      gco.home.metax=metax
      gco.home.metaxPath=metaxPath
    end if
    _ps("Loaded metaxploit: "+libPath)
  else if t=="cryptoLib" then
    crypto=lib
    _cur.crypto=crypto
    if not isPivot then gco.home.crypto=crypto
    _ps("Loaded crypto: "+libPath)
  else
    _pe("Unknown lib type: "+t)
  end if
end function
_selfPath=program_path
_selfParts=_selfPath.split("/")
_selfName=_selfParts[_selfParts.len-1]
_initShell=get_shell
_initUser=_userFromPath(current_path)
if _initUser==_gt then _initUser=_userFromHome(_shellHomeFile(_initShell))
if _initUser==_gt then _initUser=_homePick(_HC(_initShell).File("/"))
if _initUser=="root" then _payDir="/root/payload" else _payDir="/home/"+_initUser+"/payload"
isPivot=false
for arg in params;if arg=="pivot" then isPivot=true;end for
_init=function
  _scr(_selfName+" Scanner","init")
  _pact("Initializing scanner...")
  _pact("Load metaxploit...")
  outer.metax=include_lib("/lib/metaxploit.so")
  outer.metaxPath=null
  if metax then
    outer.metaxPath="/lib/metaxploit.so"
  else
    _pact("Search payload metax...")
    r=_libTry(_mx)
    if r then;outer.metax=r.l;outer.metaxPath=r.p;end if
  end if
  if metax then _ps("Loaded metaxploit: "+metaxPath) else _pe("metaxploit.so not found")
  _pact("Load crypto...")
  outer.crypto=include_lib("/lib/crypto.so")
  if not crypto then
    _pact("Search payload crypto...")
    r=_libTry("/crypto.so")
    if r then outer.crypto=r.l
  end if
  if crypto then _ps("Loaded crypto") else _pe("crypto.so not found")
  outer._ls=_initShell
  outer._lc=_HC(_ls)
  _node={"shell":_ls,"metax":metax,"metaxPath":metaxPath,"crypto":crypto,"ip":_lc.public_ip,"lip":_lc.local_ip}
  gco.metas={}
  gco.routers={}
  gco._nc={}
  if not isPivot then
    gco.home=_node
    if not gco.hasIndex("pivots") then gco.pivots=[]
  else
    if not gco.hasIndex("pivots") then gco.pivots=[]
    gco.pivots.push(_node)
  end if
  gco.H=false
  if not gco.hasIndex("rshell_servers") then gco.rshell_servers={}
  if not gco.hasIndex("rshell_shells") then gco.rshell_shells=[]
  if not gco.hasIndex("neuro_creds") then gco.neuro_creds=null
  outer.homeLIP=_lc.local_ip
  if metax and homeLIP then gco.metas[homeLIP]=metax
  _crEnsure
  rd=_lc.File(_crRainDir)
  if rd and is_folder(rd) then
    rf=get_files(rd)
    if rf and rf.len then
      _pact("Found "+_s(rf.len)+" rainbow table files, loading...")
      rn=_crLoadRain("")
      if not rn then _pw("Rainbow files found but no entries loaded")
    end if
  end if
end function
_init
quickMode=false
_am=true
_tip=null
for arg in params;if arg=="pivot" then continue;if arg=="-r" then;_tip=getRandomIP;else if arg=="-q" then;quickMode=true;else;if not _tip and arg.indexOf("-")!=0 then _tip=arg;end if;end for
if not isPivot then
  for a in params
    al=a.lower
    if al=="-po" then
      _pObjectMenu
      exit
    // XFIX1.0: REMOVE -nr CLI entry with _neuroScan
    else if al=="-nr" then
      _neuroScan
      exit
    else if al=="-dg" or al=="-dig" then
      _digS(_ls)
      exit
    else if al=="-ls" then
      localScan(_ls)
      exit
    else if al=="-ns" then
      scanLAN(_ls)
      exit
    else if al=="-wf" then
      _wifiCrack
      exit
    else if al=="-rc" then
      rcIP=_tip
      if not rcIP then rcIP=_ask("Recon target IP")
      if rcIP and rcIP.trim.len then
        resolved=_resolveTarget(rcIP.trim)
        if not resolved then _pe("Cannot resolve: "+rcIP.trim)
        if resolved then
          ch=_menu("recon",_rcActs)
          if ch and _tl(ch)=="help" then _showHelp("recon")
          if ch and not _mb(ch) and _tl(ch)!="help" then _recon(resolved,_tl(ch))
        end if
      end if
      exit
    end if
  end for
end if
_scanTarget=function(_tip)
  gco._eip=_tip
  gco.metas={}
  gco.routers={}
  hm=gco.home.metax
  if hm and gco.home.lip then gco.metas[gco.home.lip]=hm
  gco.meta_local=null
  if gco.hasIndex("packSh") then gco.packSh=null
  if gco.hasIndex("packWords") then gco.packWords=null
  if gco.hasIndex("scanlan_result") then gco.scanlan_result=null
  gco._nc={}
  if not _hasNet(_HC(_ls)) then return _pe("No internet connection")
  router=_gr(_tip)
  if not router then return _pe("No route to "+_tip)
  _pact("Fetching remote target specifications...")
  _plog("Router "+router.kernel_version+" @ "+router.local_ip)
  ports=[0]+router.used_ports
  if ports.len>1 and _to(ports[1])==_sg then return _pe(ports[1])
  portTable=[]
  portHeader=GY(_lj("PORT",8))+GY(_lj("STATE",9))+GY(_lj("SERVICE",14))+GY(_lj("VERSION",11))+GY("LAN")
  portTable.push(portHeader)
  for port in ports
    if port==0 then
      svc="router"
      ver=router.kernel_version
      lan=router.local_ip
      state=GN(_lj("open",9))
      row=GN(_lj("0",8))+state+BL(_lj(svc,14))+BL(_lj(ver,11))+LM(lan)
      portTable.push(row)
      continue
    end if
    info=router.port_info(port).split(" ")
    svc=info[0]
    ver=info[1]
    lan=port.get_lan_ip
    portNum=_pn(port)
    if port.is_closed then state=RD(_lj("closed",9)) else state=GN(_lj("open",9))
    row=GN(_lj(_s(portNum),8))+state+BL(_lj(svc,14))+BL(_lj(ver,11))+LM(lan)
    portTable.push(row)
  end for
  if quickMode then
    _scr("Scanner","",_tip)
    _mainBar
    for row in portTable;_p row;end for
    return
  end if
  lanDevices=router.devices_lan_ip
  allTargets=[]
  gco._nc={}
  while true
    if gco.H then break
    _scr("Scanner","",_tip)
    _mainBar
    for row in portTable;_p row;end for
    if lanDevices and lanDevices.len>0 then
      _sub("LAN Devices ("+_s(lanDevices.len)+")")
      for ld in lanDevices;ldPorts=router.device_ports(ld);pList=[];for p in ldPorts;pList.push(_s(_pn(p)));end for;pStr="";if pList then pStr=GY(" ports:")+WH(pList.join(","));_p GY("  ")+YL(ld)+pStr;end for
    end if
    if allTargets then
      _sub("Previously Scanned")
      for tgt in allTargets
        i=__tgt_idx+1
        total=tgt.shells+tgt.computers+tgt.files+tgt.bounces+tgt.firewalls+tgt.unknown
        t=PR("[")+WH(_s(i))+PR("] ")+OR(tgt.ln)+WH(" (Version: "+tgt.ver+") ")
        if tgt.port==0 then _p t+BL("-> ")+YL(tgt.lan)+WH(":")+GN("0") else _p t+BL("-> ")+YL(tgt.lan)+WH(":")+GN(_s(tgt.port))
        bd=""
        if tgt.port==0 then bd=YL(" - ")+WH("Bo")+OR(":")+PR(_s(tgt.bounces))+YL(" - ")+WH("Fw")+OR(":")+LM(_s(tgt.firewalls))
        _p "    "+WH("Sh")+OR(":")+GN(_s(tgt.shells))+YL(" - ")+WH("Co")+OR(":")+YL(_s(tgt.computers))+YL(" - ")+WH("Fi")+OR(":")+RD(_s(tgt.files))+bd+YL(" - ")+WH("Un")+OR(":")+ER(_s(tgt.unknown))
      end for
    end if
    _p ""
    if ports.len==1 and not allTargets then
      _pact("Single port, auto-scanning...")
      c="a"
    else
      c=_menu("ports",[["a","all"],["help","help"],["b","back"]])
    end if
    if not c then continue
    if _tl(c)=="b" then break
    if c.trim=="help" then
      _showHelp("scan")
      continue
    end if
    scanPorts=[]
    if _tl(c)=="a" then
      scanPorts=ports
    else
      sel=_ti(c.trim)
      if not sel isa number then
        _pe(_iv)
        continue
      end if
      found=false
      for port in ports
        if port==0 then
          if sel==0 then
            scanPorts.push(port)
            found=true
            break
          end if
        else
          if _pn(port)==sel then
            scanPorts.push(port)
            found=true
            break
          end if
        end if
      end for
      if not found then
        if allTargets and sel>0 and sel<=allTargets.len then
          scanPorts=[]
        else
          _pe("Port not found: "+_s(sel))
          continue
        end if
      end if
    end if
    newPorts=[]
    for port in scanPorts
      pn=0
      if port!=0 then pn=_pn(port)
      already=false
      for tgt in allTargets;if tgt.port==pn then;already=true;break;end if;end for
      if not already then newPorts.push(port)
    end for
    if scanPorts and not newPorts then
      ans=_ui(YL("[!] Already scanned. Rescan? (y/N) "))
      if ans and _tl(ans)=="y" then newPorts=scanPorts
    end if
    px=_mxs(_ls)
    if newPorts and not px then
      _pe("No metax")
      newPorts=null
    end if
    if newPorts then
      _pact("Scanning for exploits...")
      _p ""
      for port in newPorts
        portNum=0
        lan=router.local_ip
        if port!=0 then
          if port.is_closed then continue
          portNum=_pn(port)
          lan=port.get_lan_ip
        end if
        if portNum==0 then session=net_use(px.n,router.public_ip) else session=px.n.net_use(router.public_ip,portNum)
        if not session then continue
        lib=session.dump_lib
        if not lib then continue
        ln=lib.lib_name
        ver=lib.version
        addresses=px.s.scan(lib)
        if not addresses then continue
        exploits=[]
        for addr in addresses
          vulnInfo=px.s.scan_address(lib,addr)
          if not vulnInfo then continue
          for line in vulnInfo.split(char(10))
            if line.indexOf(_uc)==0 then
              s=line.indexOf("<b>")+3
              d=line.indexOf("</b>")
              if s>2 and d!=null then
                unsecured=line[s:d]
                exploits.push({"addr":addr,"val":unsecured})
              end if
            end if
          end for
        end for
        if not exploits then continue
        p=lib.is_patched(1)
        if p isa string then
          patchStr=GN("Patched To: "+p)
        else if p==1 then
          patchStr=GN("Patched")
        else
          patchStr=RD("Not Patched")
        end if
        ct={"shells":0,"computers":0,"files":0,"bounces":0,"firewalls":0,_uk:0}
        classified=[]
        for e in exploits
          ex=lib.overflow(e.addr,e.val)
          r=_classifyEx(ex,ln)
          if ct.hasIndex(r[0]+"s") then ct[r[0]+"s"]=ct[r[0]+"s"]+1 else ct.unknown=ct.unknown+1
          classified.push({"addr":e.addr,"val":e.val,"type":r[0],"user":r[1]})
        end for
        allTargets.push({"lib":lib,"ln":ln,"ver":ver,"lan":lan,"port":portNum,"session":session,"exploits":classified,"patchStr":patchStr,"shells":ct.shells,"computers":ct.computers,"files":ct.files,"bounces":ct.bounces,"firewalls":ct.firewalls,_uk:ct.unknown})
      end for
    end if
    if not allTargets then
      _pw("No exploitable services found")
      if ports.len==1 then break
      continue
    end if
    typeFilter=null
    while true
      if gco.H then break
      _scr("Scanner","",_tip)
      _mainBar
      for row in portTable;_p row;end for
      _sub("Attack Vectors")
      showList=allTargets
      if typeFilter then
        showList=[]
        for tgt in allTargets;if _exCountType(tgt,typeFilter)>0 then showList.push(tgt);end for
      end if
      for tgt in showList;_printAttackVector(tgt,__tgt_idx+1,typeFilter,true);end for
      if typeFilter then
        if not showList.len then _pw("No "+_exTypeLabel(typeFilter)+" exploits")
        _exFilterFoot(typeFilter,showList,allTargets)
      end if
      c=_menu("targets",_tgtActs)
      if not c then continue
      if _mb(c) then break
      fp=_exPickFilter(c,typeFilter)
      if fp[0]=="err" then
        _pe(fp[1])
        continue
      end if
      if fp[0]=="ok" then
        typeFilter=fp[1]
        continue
      end if
      if c.trim=="help" then
        _showHelp("scan")
        continue
      end if
      sel=_ti(c.trim)
      if not sel isa number or sel<1 or sel>showList.len then
        _pe(_iv)
        continue
      end if
      tgt=showList[sel-1]
      _exploitMenu(tgt,tgt.lan+":"+_s(tgt.port),typeFilter)
    end while
  end while
end function
if _tip then
  if not _vi(_tip) then
    resolved=nslookup(_tip)
    if not resolved then exit(RD("[!] Cannot resolve: "+_tip))
    _tip=resolved
  end if
  _scanTarget(_tip)
  if quickMode then exit
end if
_hunt=function(svc=null,mx=null,vf=null)
  if not _hasNet(_lc) then return _pe("No internet connection")
  if not svc or not svc.len then
    svc=_ask("Service: ssh,ftp,http,smtp,sql,repo,rshell,cam")
    if not svc or not len(svc.trim) then return
    svc=_tl(svc)
  else
    svc=_tl(svc)
  end if
  if mx==null then
    mx=50
    cnt=_ask("Max IPs to scan (default 50)")
    if cnt and _ti(cnt.trim) isa number then mx=_ti(cnt.trim)
  end if
  if vf==null then
    vfAns=_ask("Version filter (optional, blank=any)")
    if vfAns and vfAns.trim.len then vf=_tl(vfAns.trim)
  end if
  hMsg="Hunting for "+svc
  if vf then hMsg=hMsg+" v"+vf
  _pact(hMsg+" across "+_s(mx)+" random IPs...")
  found=[]
  i=0
  while i<mx
    ip=getRandomIP
    if not ip then
      i=i+1
      continue
    end if
    r=_gr(ip)
    if not r then
      i=i+1
      continue
    end if
    ports=r.used_ports
    if not ports or _to(ports)==_sg then
      i=i+1
      continue
    end if
    for p in ports
      inf=r.port_info(p)
      if not inf then continue
      if inf.lower.indexOf(svc)!=null then
        lip=p.get_lan_ip
        pip=r.public_ip
        sv=inf.split(" ")
        if vf and (sv.len<2 or _tl(sv[1]).indexOf(vf)==null) then continue
        found.push({"ip":pip,"lip":lip,"port":_pn(p),"svc":sv[0],"ver":sv[1]})
        _pfnd(pip+":"+lip+" port "+_s(_pn(p))+" "+inf)
      end if
    end for
    i=i+1
  end while
  svcLbl=svc
  if vf then svcLbl=svc+" v"+vf
  if not found.len then _pe("No "+svcLbl+" services found in "+_s(mx)+" IPs") else _ps("Found "+_s(found.len)+" "+svcLbl+" services")
end function
_cmds={}
_cmds.scan=function(a,o)
  if o=="ls" then
    _mainScan("-l")
  else
    if o=="ns" then _mainScan("-n") else _mainScan(a)
  end if
end function
_cmds.clear=function(a,o);clear_screen;end function
_cmds.help=function(a,o)
  if a.len then _showHelp(a) else _showHelp("all")
end function
_cmds.whois=function(a,o)
  if a.len then
    _whois(a)
  else
    wTarget=_ask("Whois target")
    if wTarget then _whois(wTarget.trim)
  end if
end function
_cmds.random=function(a,o)
  ip=getRandomIP
  if not ip then _pe("No random IP") else _scanTarget(ip)
end function
_cmds.recon=function(a,o)
  if not a.len then
    rcIP=_ask("Recon target IP")
    if rcIP and rcIP.trim.len then
      resolved=_resolveTarget(rcIP.trim)
      if not resolved then _pe("Cannot resolve: "+rcIP.trim)
      if resolved then
        ch=_menu("recon",_rcActs)
        if ch and _tl(ch)=="help" then _showHelp("recon")
        if ch and not _mb(ch) and _tl(ch)!="help" then _recon(resolved,_tl(ch))
      end if
    end if
    return
  end if
  parts=a.split(" ")
  rcIP=_resolveTarget(parts[0])
  if not rcIP then return _pe("Cannot resolve: "+parts[0])
  if parts.len>1 then
    _recon(rcIP,_tl(parts[1]))
  else
    ch=_menu("recon",_rcActs)
    if ch and _tl(ch)=="help" then _showHelp("recon")
    if ch and not _mb(ch) and _tl(ch)!="help" then _recon(rcIP,_tl(ch))
  end if
end function
_cmds.hunt=function(a,o)
  if not a.len then
    _hunt
  else
    parts=a.split(" ")
    hMx=null
    hVf=null
    if parts.len>1 and _ti(parts[1]) isa number then hMx=_ti(parts[1])
    if parts.len>2 then hVf=_tl(parts[2])
    _hunt(_tl(parts[0]),hMx,hVf)
  end if
end function
_cmds.crack=function(a,o);if not a.len then _crackMenu else _crRunTarget(a);end function
_cmds.mail=function(a,o)
  if a.len then return _pe("Use mail alone for mail menu")
  _mailMenu
end function
_cmds.dig=function(a,o);if not a.len then _digS(_ls) else da=_arg1(a);_digA(_ls,da[0],da[1]);end function
_cmds.pobject=function(a,o);_pObjectMenu;end function
_cmds.wifi=function(a,o);_wifiCrack;end function
_cmds.pivots=function(a,o);_pivotMenu;end function
_cmds.host=function(a,o);_exM(_ls,_sh);end function
_cmds.rshell=function(a,o)
  sh=null
  if gco.hasIndex("_hs") and gco._hs then sh=gco._hs
  if not sh and gco.hasIndex("_hx") and _to(gco._hx)==_sh then sh=gco._hx
  rshellMenu(sh)
end function
// XFIX1.0: REMOVE _cmds.neuro with _neuroScan
_cmds.neuro=function(a,o);_neuroScan;end function
_cmds["0day"]=function(a,o);_show0dayStatus;end function
_cmds.reload=function(a,o);_init;end function
_cmds.exit=function(a,o);return "exit";end function
while true
  gco.H=false
  if isPivot then _scr(_selfName+" Scanner","PIVOTED") else _scr(_selfName+" Scanner")
  _mainBar
  inp=_menu("scanner",_mainMenuActs)
  if not inp then continue
  inp=inp.trim
  if _sw(inp,"echo ") then
    _echo(inp[5:],_HC(_ls))
    continue
  end if
  if _sw(inp,"e ") then
    _echo(inp[2:],_HC(_ls))
    continue
  end if
  ca=_arg1(inp)
  orig=ca[0]
  cmd=_mainAlias(orig)
  args=ca[1]
  if hasIndex(_cmds,cmd) then
    _fn=_cmds[cmd]
    dr=_fn(args,orig)
    if dr=="exit" then break
    continue
  end if
  if args.len then
    _pe("Unknown command: "+inp+" — type help")
    continue
  end if
  if _vi(inp) then
    _scanTarget(inp)
  else
    ip=nslookup(inp)
    if not ip then
      _pe("Cannot resolve: "+inp)
    else
      _ps(inp+" -> "+ip)
      _scanTarget(ip)
    end if
  end if
end while