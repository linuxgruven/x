  __main=function(argv)
    //if Net.hasInternet(Obj) isa Warning then return
    if not argv then return Man.help(["main"])
    Arg1=argv[0]
    if (Arg1=="-u" or Arg1=="-d") and hasIndex(globals.G_pipe,"stdin") and globals.G_pipe.stdin!=null then
      _stdin=trim(str(globals.G_pipe.stdin))
      if _stdin!="" then
        for _line in split(_stdin,char(10))
          for _item in split(trim(_line)," ")
            _item=trim(_item)
            if _item!="" then push(argv,_item)
          end for
        end for
      end if
    end if
    if Arg1=="-u" then return Io.upload(Obj,argv[1:])
    if Arg1=="-d" then return Io.download(Obj,argv[1:])
    if hasIndex(globals.G_main.commands,Arg1) then globals.G_main.commands[Arg1](argv[1:]) else return Error.set("check your syntax...there is no main command [ "+Arg1+" ]")
  end function
  __rat=function(argv);if Net.hasInternet(Obj) isa Warning then return;Utility.rat(argv);end function
	__ssh=function(argv)
    if Net.hasInternet(Obj) isa Warning then return
    if not argv then return Man.help(["ssh"])
    _p=ArgumentParser.init
    _p.addArgument("P",false,"store")  // Password for SSH connection
    _p.addArgument("p",false,"storeNumber")  // Port number (default: 22)
    _p.addArgument("t",false,"flag")  // Use tunneled connection
    _p.addArgument("l",false,"flag")  // Use proxy shell (force through proxy)
    _p.addArgument("d",false,"flag")  // Dictionary attack mode
    _p.addArgument("start",true,"storeNumber")  // Long flag: --start (start index in wordlist)
    _p.addArgument("stop",true,"storeNumber")  // Long flag: --stop (end index in wordlist)
    argv=_p.parseArgs("ssh",argv)
    if argv isa Error then return
    if hasIndex(argv,"useAI") then
      argv.rest=[]
      i=Gui.input({"text":"Enter user ip"})
      if i!=null then push(argv,i) else return Error.set("Invalid ip: "+i)
      u=Gui.input({"text":"Enter user name"})
      if u==null then return Error.set("User name is required")
      push(argv.rest,u+"@"+i)
      p=Gui.inputPass("Enter user password")
      if not p then return Error.set("User password is required")
      argv.P=p
      argv.p=Gui.inputInt({"text":"Enter port number","default":22})
      if G_proxy then
        if Gui.yesNo("Use proxy shell?") then argv.l=true else argv.l=null
      end if
      if Gui.yesNo("Use tunneled connection?") then argv.t=true else argv.t=null
    end if
    //if argv.P and len(argv.rest)==1 then push(argv.rest,argv.P)
    if not argv.p then argv.p=22
    _targetIp=split(argv.rest[0],"@");_targetIp=_targetIp[len(_targetIp)-1]
    if is_lan_ip(_targetIp) and Obj.type!="computer" and Obj.type!="file" then
      S=Obj
    else if argv.l then
      S=globals.G_main
    else
      if G_proxy then S=G_proxy else S=globals.G_main
    end if
    if argv.d then
      _c=split(argv.rest[0],"@")
      _dIp=_c[len(_c)-1];_dUser=_c[0]
      if is_lan_ip(_dIp) and Obj.type!="computer" and Obj.type!="file" then return Crack.dictNetworkLan(_dIp,argv.p,_dUser,"ssh",S.shell)
      _dArg={"rest":[_dIp,""+argv.p],"u":_dUser,"start":0,"stop":null}
      if argv.start then _dArg.start=argv.start
      if argv.stop then _dArg.stop=argv.stop
      return Crack.dictNetwork(_dArg,"ssh")
    end if
    if Obj.type=="computer" or Obj.type=="file" then argv.t=null
    if argv.t then s=Builder.buildConnection(S,argv,"ssh") else s=Net.makeConnection(S,argv,"ssh")
    if s isa Error then return
    launch(s,"/usr/bin/Terminal.exe")
	end function
