			"-l":@fileView,
			"-a":@putFile,
			"-ap":@putPasswd,
			"-g":@getFile,
			"-r":@fileDel,
			"-x":@clear,
			"-v":@filePeek,
			"-m":@manage,
			"-z":@fileDelRange
		}
		if hasIndex(Obj,"shell") then cmds["-al"]=@putLog
