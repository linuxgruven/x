	__vfile=function(argv)
    //if Net.hasInternet(Obj) isa Warning then return
    if not argv then Arg1="-l" else Arg1=lower(argv[0])
		Obj=outer.Obj
		fileView=function(arg);Session.fileView;end function
		putFile=function(arg);if not arg then return Man.help(["vfile"]);Session.putFile(Obj,arg);end function
		putLog=function(arg);Session.putFile(Obj,[File(Obj.computer,"/var/system.log")]);end function
		putPasswd=function(arg);Session.putFile(Obj,[File(Obj.computer,"/etc/passwd")]);end function
		filePeek=function(arg);if not arg then return Man.help(["vfile"]);Session.filePeek(to_int(arg[0]));end function
		getFile=function(arg);if not arg then return Man.help(["vfile"]);Session.getFile(Obj,arg);end function
		fileDel=function(arg);if not arg then return Man.help(["vfile"]);Session.fileDel(arg);end function
		fileClear=function(arg);Session.fileClear;end function
		toShare=function(arg);Session.toShare(Obj);end function
		cmds={
			"-l":@fileView,
			"-a":@putFile,
			"-ap":@putPasswd,
			"-g":@getFile,
			"-r":@fileDel,
			"-x":@fileClear,
			"-v":@filePeek
		}
		if hasIndex(Obj.type,"shell") then
			cmds["-al"]=@putLog
			cmds["-ts"]=@toShare
		end if
		if not hasIndex(cmds,Arg1) then return Error.set(Text.msg.flag+Arg1+" ]")
		cmds[Arg1](argv[1:])
	end function
	__rshell=function(argv)
    if Net.hasInternet(Obj) isa Warning then return
    if not Library.haveMetaxploit then return
    if not argv then Arg1="-l" else Arg1=lower(argv[0])
		Obj=outer.Obj
		view=function(arg);if globals.G_settings.rshell then Rshell.view else RshellLite.view;end function
		start=function(arg)
			if globals.G_settings.rshell then
				if Utility.checkValid(Obj) then Rshell.start(arg) else Rshell.start(arg,Obj)
			else
				if Utility.checkValid(Obj) then RshellLite.start(arg) else RshellLite.start(arg,Obj)
			end if
		end function
		doBuild=function(arg);Rshell.build(Obj);end function
		doInstall=function(arg);Rshell.install(Obj);end function
		doBoth=function(arg);if Rshell.build(Obj) then Rshell.install(Obj);end function
		killSingle=function(arg)
			if not arg then return Man.help(["rshell"])
      if globals.G_settings.rshell then
        if len(arg)==1 then Rshell.killSingle(to_int(arg[0])) else Rshell.killSingle(to_int(arg[0]),arg[1])
      else
        if len(arg)==1 then RshellLite.killSingle(to_int(arg[0])) else RshellLite.killSingle(to_int(arg[0]),arg[1])
      end if
		end function
		getShell=function(arg);if not arg then return Man.help(["rshell"]);if globals.G_settings.rshell then Rshell.shell(to_int(arg[0])) else RshellLite.shell(to_int(arg[0]));end function
		killall=function(arg);if globals.G_settings.rshell then Rshell.killall(arg) else RshellLite.killall(arg);end function
		getLogs=function(arg);if globals.G_settings.rshell then Rshell.getLogs(Obj) else RshellLite.getLogs(Obj);end function
		doImport=function(arg)
			rs=Rshell
			if not globals.G_settings.rshell then rs=RshellLite
			rs.import(Obj.meta.public_ip,Obj)
		end function
		refresh=function(arg);if globals.G_settings.rshell then Rshell.refresh else RshellLite.refresh;end function
		showList=function(arg);if globals.G_settings.rshell then Rshell.list else RshellLite.list;end function
		history=function(arg);if globals.G_settings.rshell then Rshell.history(Obj,arg) else RshellLite.history(Obj,arg);end function
		clear=function(arg);Rshell.clear(arg);end function
		exec=function(arg);if not globals.G_settings.rshell then return Error.set("Not available in rshell lite");Rshell.exec(arg);end function
		execAll=function(arg);if not globals.G_settings.rshell then return Error.set("Not available in rshell lite");Rshell.execAll(arg);end function
		download=function(arg);if globals.G_settings.rshell then Rshell.download(arg) else RshellLite.download(arg);end function
		downloadAll=function(arg);if globals.G_settings.rshell then Rshell.downloadAll(arg) else RshellLite.downloadAll(arg);end function
		downloadCurrent=function(arg);if globals.G_settings.rshell then Rshell.downloadCurrent(Obj,arg) else RshellLite.downloadCurrent(Obj,arg);end function
		downloadCurrentAll=function(arg);if globals.G_settings.rshell then Rshell.downloadCurrentAll(Obj,arg) else RshellLite.downloadCurrentAll(Obj,arg);end function
		upload=function(arg);if globals.G_settings.rshell then Rshell.upload(arg) else RshellLite.upload(arg);end function
		uploadAll=function(arg);if globals.G_settings.rshell then Rshell.uploadAll(arg) else RshellLite.uploadAll(arg);end function
		uploadCurrent=function(arg);if globals.G_settings.rshell then Rshell.uploadCurrent(Obj,arg) else RshellLite.uploadCurrent(Obj,arg);end function
		uploadCurrentAll=function(arg);if globals.G_settings.rshell then Rshell.uploadAllCurrent(Obj,arg) else RshellLite.uploadAllCurrent(Obj,arg);end function
    dump=function(arg);Rshell.dump(arg);end function
    select=function(arg)
      if not globals.G_settings.rshell then return Error.set("Not available in rshell lite")
      _p=ArgumentParser.init
      _p.addArgument("e",false,"flag")  // Execute command in selected shells
      _p.addArgument("k",false,"flag")  // Kill/close selected shells
      _p.addArgument("u",false,"flag")  // Upload file to selected shells
      _p.addArgument("d",false,"flag")  // Download file from selected shells
      arg=_p.parseArgs("rshell",arg)
      if arg isa Error then return
      if not arg.rest then return Error.set("You need to specify a shell id(s) and a command to execute")
      i=split(arg.rest[0],",")
      if arg.e then
        c=arg.rest[1]
        if len(arg.rest)>=2 then p=arg.rest[1:] else p=[]
        for s in i;exec([s]+p);end for
      else if arg.k then
        for s in i;killSingle([s]+arg.rest);end for
      else if arg.u then
        if not Obj.type=="shell" then return Error.set("You can only use -u with a shell object")
        for s in i;upload([s]+arg.rest);end for
      else if arg.d then
        if not Obj.type=="shell" then return Error.set("You can only use -d with a shell object")
        for s in i;download([s]+arg.rest);end for
      else
        return Error.set("Invalid parameters. Use -e, -k, -u or -d")
      end if
    end function
		cmds={
			"-z":@select,
			"dump":@dump,
			"-ea":@execAll,
			"-e":@exec,
			"-c":@clear,
			"-x":@killall,
			"-u":@getShell,
			"--use":@getShell,
			"-l":@view,
			"-k":@killSingle,
			"logs":@getLogs,
			"import":@doImport,
			"refresh":@refresh,
			"list":@showList,
			"-h":@history
		}
		if hasIndex(Obj,"shell") then
			cmds["-pca"]=@uploadCurrentAll
			cmds["-pc"]=@uploadCurrent
			cmds["-pa"]=@uploadAll
			cmds["-p"]=@upload
			cmds["-dca"]=@downloadCurrentAll
			cmds["-dc"]=@downloadCurrent
			cmds["-da"]=@downloadAll
			cmds["-d"]=@download
			cmds["-s"]=@start
			cmds["-b"]=@doBuild
			cmds["-i"]=@doInstall
			cmds["-bi"]=@doBoth
		end if
		if not hasIndex(cmds,Arg1) then return Error.set(Text.msg.flag+Arg1+" ]")
		cmds[Arg1](argv[1:])
	end function
