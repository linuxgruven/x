    if argv.d then
      _c=split(argv.rest[0],"@")
      _dIp=_c[len(_c)-1];_dUser=_c[0]
      if is_lan_ip(_dIp) and Obj.type!="computer" and Obj.type!="file" then return Crack.dictNetworkLan(_dIp,argv.p,_dUser,"sssh",S.shell)
      _dArg={"rest":[_dIp,""+argv.p],"u":_dUser,"start":0,"stop":null}
      if argv.start then _dArg.start=argv.start
      if argv.stop then _dArg.stop=argv.stop
      return Crack.dictNetwork(_dArg,"ssh")
    end if
    if Obj.type=="computer" or Obj.type=="file" then argv.t=null
    if argv.t then s=Builder.buildConnection(S,argv,"ssh") else s=Net.makeConnection(S,argv,"ssh")
    if s isa Error then return
    Exploit.getShell(s)
  end function
	__ftp=function(argv)
    if Net.hasInternet(Obj) isa Warning then return
    if not argv then return Man.help(["ftp"])
    _p=ArgumentParser.init
    _p.addArgument("P",false,"store")  // Password for FTP connection
    _p.addArgument("p",false,"storeNumber")  // Port number (default: 21)
    _p.addArgument("t",false,"flag")  // Use tunneled connection
    _p.addArgument("l",false,"flag")  // Use proxy shell (force through proxy)
    _p.addArgument("d",false,"flag")  // Dictionary attack mode
    _p.addArgument("start",true,"storeNumber")  // Long flag: --start (start index in wordlist)
    _p.addArgument("stop",true,"storeNumber")  // Long flag: --stop (end index in wordlist)
    argv=_p.parseArgs("ftp",argv)
    if argv isa Error then return
    if hasIndex(argv,"useAI") then
      argv.rest=[]
      i=Gui.input({"text":"Enter user ip"})
      if i!=null then push(argv.rest,i) else return Error.set("Invalid ip: "+i)
      u=Gui.input({"text":"Enter user name"})
      if u==null then return Error.set("User name is required")
      push(argv.rest,u+"@"+i)
      p=Gui.inputPass("Enter user password")
      if not p then return Error.set("User password is required")
      argv.P=p
      t=Gui.inputInt({"text":"Enter port number","default":21})
      if t isa number then argv.p=t else return Error.set("Invalid port: "+t)
      if G_proxy then
        if Gui.yesNo("Use proxy shell?") then argv.l=true else argv.l=null
      end if
      if Gui.yesNo("Use tunneled connection?") then argv.t=true else argv.t=null
    end if
    //if argv.P and len(argv.rest)==1 then push(argv.rest,argv.P)
    if not argv.p then argv.p=21
    _targetIp=split(argv.rest[0],"@");_targetIp=_targetIp[len(_targetIp)-1]
    if is_lan_ip(_targetIp) and Obj.type!="computer" and Obj.type!="file" then
      S=Obj
    else if argv.l then
      S=globals.G_main
    else
      if G_proxy then S=G_proxy else S=globals.G_main
    end if
    if argv.d then
      _c=split(argv.rest[0],"@")
      _dIp=_c[len(_c)-1];_dUser=_c[0]
      if is_lan_ip(_dIp) and Obj.type!="computer" and Obj.type!="file" then return Crack.dictNetworkLan(_dIp,argv.p,_dUser,"ftp",S.shell)
      _dArg={"rest":[_dIp,""+argv.p],"u":_dUser,"start":0,"stop":null}
      if argv.start then _dArg.start=argv.start
      if argv.stop then _dArg.stop=argv.stop
      return Crack.dictNetwork(_dArg,"ftp")
    end if
    if Obj.type=="computer" or Obj.type=="file" then argv.t=null
    if argv.t then s=Builder.buildConnection(S,argv,"ftp") else s=Net.makeConnection(S,argv,"ftp")
    if s isa Error then return
    _=new FTPShellObject
    return _.run(_,s.shell,s["public_ip"],s["port"])
	end function
	__favs=function(argv);System.favs(argv);end function
  __fw=function(argv);Command.folderWatcher(Obj,argv);end function
	__email=function(argv)
    if not argv then return Man.help(["email"])
    // Inject piped credentials (email pass) into argv for -c and -l
    if hasIndex(globals.G_pipe,"stdin") and globals.G_pipe.stdin!=null then
      _parts=split(trim(str(globals.G_pipe.stdin))," ")
      if len(_parts)>=2 then
        _len=len(argv)
        i=0
        while i<_len
          if argv[i]=="-c" or argv[i]=="-l" then
            argv=argv[:i+1]+_parts+argv[i+1:]
            break
          end if
          i=i+1
        end while
      end if
    end if
		Arg1=lower(argv[0])
      client=function(arg)
        if arg and len(arg)>=2 then
          // XFIX1.0: mm=mail_login(arg[0],arg[1])  // no pack needed
          mm=Builder.packMailLogin(globals.G_main,arg[0],arg[1])
          if mm isa Error or not mm then return Info.error("Login failed")
          Email.mail=mm
          Email.account.user=arg[0]
          Email.account.pass=arg[1]
          Email.client(true)
        else
          Email.client
        end if
      end function
		view=function(arg);Email.view;end function
		open=function(arg);Email.open(to_int(arg[0]));end function
		login=function(arg);Email.login(arg);end function
		setup=function(arg);Email.setup;end function
		newEmail=function(arg);Email.newEmail;end function
		bomb=function(arg);Email.bomb(arg);end function
		doRemove=function(arg);Email.remove(to_int(arg[0]));end function
		clear=function(arg);Email.clear;end function
		monitor=function(arg);Email.monitor(arg);end function
		clearCreds=function(arg);Email.clearCreds(arg);end function
		cmds={
			"-c":@client,
			"-v":@view,
			"-o":@open,
			"-l":@login,
			"-s":@setup,
			"-n":@newEmail,
			"-b":@bomb,
			"-r":@doRemove,
			"-x":@clear,
			"-cc":@clearCreds
		}
		if Utility.checkValid(Obj) then cmds["-m"]=@monitor
		if not hasIndex(cmds,Arg1) then return Error.set(Text.msg.flag+Arg1+" ]")
		cmds[Arg1](argv[1:])
	end function
	__libs=function(argv)
    //if Net.hasInternet(Obj) isa Warning then return
    if not argv then Arg1="-l" else Arg1=lower(argv[0])
		Obj=outer.Obj
		fileView=function(arg);SavedLibs.fileView;end function
		putFile=function(arg);if not arg then return Man.help(["libs"]);SavedLibs.putFile(Obj,arg);end function
		doInstall=function(arg);if not Utility.checkValid(Obj,true) then return Warning.set("Only available for PROXY|PIVOT|MAIN objects");SavedLibs.install(Obj,arg);end function
		getFile=function(arg);if not arg then return Man.help(["libs"]);SavedLibs.getFile(Obj,arg);end function
		fileDel=function(arg);if not arg then return Man.help(["libs"]);SavedLibs.fileDel(arg);end function
		clear=function(arg);SavedLibs.clear;end function
		cmds={
			"-l":@fileView,
			"-r":@fileDel,
			"-x":@clear
		}
		if hasIndex(Obj,"shell") then
			cmds["-a"]=@putFile
			cmds["-g"]=@getFile
			cmds["-i"]=@doInstall
		end if
		if not hasIndex(cmds,Arg1) then return Error.set(Text.msg.flag+Arg1+" ]")
		cmds[Arg1](argv[1:])
	end function
	__list=function(argv)
		if not argv then return Man.help(["list"])
    argv=ArgumentParser.check(argv)
		Arg1=lower(argv[0])
		Obj=outer.Obj
		Command=outer.Command
		passwd=function(arg);Command.postPW(Obj);end function
		vulnerableFiles=function(arg)
			Obj=outer.Obj
			Command=outer.Command
			run=function(Obj,f)
				Command=outer.Command
				X=true
				man=function(ar);Man.help(ar);end function
				vfile=function(ar);Session.putFile(Obj,[f]);outer.X=false;end function
				share=function(ar);Share.putFile(Obj,[f]);outer.X=false;end function
				libs=function(ar);SavedLibs.putFile(Obj,[f]);outer.X=false;end function
				edit=function(ar);Io._edit(Obj,f);outer.X=false;end function
				dec=function(ar);Io._dec(Obj,f);outer.X=false;end function
				enc=function(ar);Io._enc(Obj,f);outer.X=false;end function
				post=function(ar);Io._post(f);outer.X=false;end function
				zip=function(ar);Io._zip(Obj,f);outer.X=false;end function
				lock=function(ar);Io._lock(Obj,f);outer.X=false;end function
				doScan=function(ar);Io._scan(Obj,f);outer.X=false;end function
				echo=function(ar);r=Io._echo(f,ar);if r isa string then return Error.set(r) else outer.X=false;end function
				rm=function(ar)
					if not has_permission(f,"w") then return Error.set(Info.message.NOW)
					Gui.delPrompt(f)
					outer.X=false
				end function
				set=function(ar);r=Io._set(f,ar);if r isa string then return Error.set(r) else outer.X=false;end function
				rn=function(ar);r=Io._rn(f,ar);if r then return Error.set(r) else outer.X=false;end function
				cp=function(ar);r=Io._cp(Obj,f);if r isa string then return Error.set(r) else outer.X=false;end function
				mv=function(ar);r=Io._mv(Obj,f);if r isa string then return Error.set(r) else outer.X=false;end function
				get=function(ar);r=Io._get(Obj,f,ar);if r isa string then return Error.set(r) else outer.X=false;end function
				info=function(ar);Command.file(Obj,[f]);end function
				view=function(ar);Io._view(f);end function
				help=function(ar);Man.commands(["browsefiles"]);end function
				chog=function(ar);r=Io._chog(f,ar);if r then return Error.set(r) else outer.X=false;end function
				doChown=function(ar);r=Io._chown(f,ar);if r then return Error.set(r) else outer.X=false;end function
				doChmod=function(ar);r=Io._chmod(f,ar);if r then return Error.set(r) else outer.X=false;end function
				doChgrp=function(ar);r=Io._chgrp(f,ar);if r then return Error.set(r) else outer.X=false;end function
				qrm=function(ar);Command.qrm(Obj,[f]);outer.X=false;end function
				cmds={
          "qrm":@qrm,
          "man":@man,
          "libs":@libs,
          "vfile":@vfile,
          "share":@share,
          "edit":@edit,
          "dec":@dec,
          "enc":@enc,
          "post":@post,
          "info":@info,
          "zip":@zip,
          "lock":@lock,
          "?":@help,
          "help":@help,
          "cmds":@help,
          "view":@view,
          "peek":@view,
          "get":@get,
          "mv":@mv,
          "cp":@cp,
          "rn":@rn,
          "set":@set,
          "rm":@rm,
          "echo":@echo,
          "scan":@doScan,
          "chog":@chog,
          "chown":@doChown,
          "chmod":@doChmod,
          "chgrp":@doChgrp
				}
				while X
					Info.info("What would you like to do with the file: "+name(f)+" ?")
					c=split(trim(user_input(Gui.closeNR))," ")
          if not c then continue
					Arg1=lower(c[0])
					if Arg1=="x" then return
					if hasIndex(cmds,Arg1) then cmds[Arg1](c[1:]) else Error.set(Text.msg.command+Arg1+" ]")
				end while
			end function
			while true
				CH=[white("Browse files:")]
				k=[]
				for f in Io.getAll(Obj.root)
					canRead=has_permission(f,"r")
					canWrite=has_permission(f,"w")
					push(k,f)
					p=permissions(f)
					if canRead and canWrite then
						c=@green
					else if canRead or canWrite then
						c=@yellow
					else
						c=@red
					end if
					if is_folder(f) then
						push(CH,c(path(f)+" ["+p+"] (dir)"))
					else if is_binary(f) then
						push(CH,c(path(f)+" ["+p+"] (bin)"))
					else
						push(CH,c(path(f)+" ["+p+"]"))
					end if
				end for
				push(CH,iyellow("--- Stop browsing files"))
				UCH=Gui.choiceHybrid(CH,{},len(CH)-1)
				if UCH==len(CH)-1 then break
				run(Obj,k[UCH-1])
			end while
		end function
		vulnerableDirectorys=function(arg)
			Info.info("Found the following folders:")
			for f in Io.getAll(Obj.root)
				if not is_folder(f) then continue
				canRead=has_permission(f,"r")
				canWrite=has_permission(f,"w")
				p=permissions(f)
				if canRead and canWrite then
					print green(path(f)+" ["+p+"]")
				else if canRead or canWrite then
					print yellow(path(f)+" ["+p+"]")
				else
					print red(path(f)+" ["+p+"]")
				end if
			end for
		end function
		allFiles=function(arg)
			z=0
			d=0
			s="   "
			Info.info("Found the following folders/files:")
      for f in Io.getAll(Obj.root)
				if is_folder(f) then
					d+=1
					print green("Directory at ")+orange(path(f))
					print yellow("Permissions:")+white("----")+blue(permissions(f))
					print yellow("Owner:")+white("----------")+blue(owner(f))
					print yellow("Group:")+white("----------")+blue(group(f))
					c=len(get_files(f))
					if not c then c=0
					print yellow("File Count:")+white("-----")+blue(str(c))
					print yellow("Directory Count:")+blue(str(len(get_folders(f))))
					print yellow("Size:")+white("-----------")+blue(str(Io.size(val(size(f)))))
				else
					z+=1
					if is_binary(f) then
						print blue("]"+yellow("*")+"[")+orange(name(f))
						print yellow(s+"Full path:")+white("------")+blue(path(f))
						print yellow(s+"Permissions:")+white("----")+blue(permissions(f))
						print yellow(s+"Owner:")+white("----------")+blue(owner(f))
						print yellow(s+"Group:")+white("----------")+blue(group(f))
						print yellow(s+"File type:")+white("------")+blue("binary")
					else
						print blue("]-[")+orange(name(f))
						print yellow(s+"Full path:")+white("------")+blue(path(f))
						print yellow(s+"Permissions:")+white("----")+blue(permissions(f))
						print yellow(s+"Owner:")+white("----------")+blue(owner(f))
						print yellow(s+"Group:")+white("----------")+blue(group(f))
						print yellow(s+"File type:")+white("------")+blue("text file")
						if has_permission(f,"r") then
							print yellow(s+"Line Count:")+white("-----")+blue(str(len(split(get_content(f),char(10)))))
							print yellow(s+"Char Count:")+white("-----")+blue(str(len(get_content(f))))
						else
							print yellow(s+"Line Count:")+white("-----")+red("Don't have read permissions for "+name(f))
							print yellow(s+"Char Count:")+white("-----")+red("Don't have read permissions for "+name(f))
						end if
					end if
					print yellow(s+"Size:")+white("-----------")+blue(str(Io.size(val(size(f)))))
				end if
			end for
			print white("Total directory count: "+d)
			print white("Total file count     : "+z)
		end function
		localNetworks=function(arg)
      if Net.hasInternet(Obj) isa Warning then return
			if not Obj.net.lan then return Info.info("No local ip's to show")
			if Utility.checkValid(Obj) then
				for d in Obj.net.lan
					j=get_router(d)
					if not j then j=get_router
					c=Utility.machine(d,j)
					if Obj.type=="file" then
						print green("[---] ")+c+" "+yellow(d)
					else
						if d==Obj.computer.local_ip then print green("[---] ")+c+" "+green(d) else print green("[---] ")+c+" "+yellow(d)
					end if
					f=firewall_rules(j)
					if len(f) then
						print green("[---] ")+white("Firewall Rules for:"+d)
						Net.firewallRules(f)
					end if
					for o in devices_lan_ip(j)
						z=Utility.machine(o,j)
						if indexOf(Obj.net.lan,o)==null then
							u=device_ports(j,o)
							if u and len(u)>0 then
								if Obj.type=="file" then
									print orange("[------> ")+z+" "+yellow(o)
								else
									if o==Obj.computer.local_ip then print orange("[------> ")+z+" "+yellow(o) else print orange("[------> ")+z+" "+yellow(o)
								end if
								for p in u
									if port_info(j,p)!=null then i=split(port_info(j,p)," ")[0] else i=null
									if i!=null then
										if is_closed(p) then a=red("-X->") else a=green("--->")
										w=split(port_info(j,p)," ")
										print orange("[-----")+blue("•")+a+orange(" :")+green(ljust(str(port_number(p)),5)+ljust(" "+w[0],14))+" "+blue(ljust(str(w[1]),8))
									end if
								end for
							else
								print orange("[------> ")+z+" "+yellow(o)
								print orange("[-----")+blue("•")+red("x-x> No ports detected")
							end if
						end if
					end for
				end for
			else
				Info.info("Showing basic information for local ip's")
				for d in Obj.net.lan;print green("[---] ")+Utility.machine(d,Obj.net.router)+" "+yellow(d);end for
			end if
		end function
		accounts=function(arg);Net.snoop(Obj,arg);end function
		allConfigContents=function(arg)
			for a in get_folders(Obj.root)
				if name(a)=="root" then
					for b in get_folders(a)
						if name(b)!="Config" then continue
						if len(get_files(b))==0 then continue
						print yellow("Contents of /"+name(a)+"/Config:")
						for c in get_files(b)
							if is_binary(c) then continue
							if name(c)=="Theme.conf" then continue
							if not has_permission(c,"r") then continue
							print green(name(c)+":")
							for e in split(get_content(c),char(10));print white(e);end for
						end for
					end for
					continue
				end if
				if name(a)=="home" then
					homeFolders=get_folders(a)
					for b in homeFolders
						userFolders=get_folders(b)
						for c in userFolders
							if name(c)!="Config" then continue
							configFiles=get_files(c)
							if len(configFiles)==0 then continue
							print yellow("Contents of /home/"+name(b)+"/Config:")
							for d in configFiles
								if name(d)=="Theme.conf" then continue
								if is_binary(d) then continue
								if not has_permission(d,"r") then continue
								print green(name(d)+":")
								for e in split(get_content(d),char(10));print white(e);end for
							end for
						end for
					end for
				end if
			end for
		end function
		libraryVersions=function(arg)
			if arg then Arg1=arg[0] else Arg1=null
			if not Library.haveMetaxploit then return
			if not Exploit.have then return
			d=null
			if Arg1 then d=Io.getFileObj(Obj,Arg1) else d=Io.getFileObj(Obj,"/lib")
			if d isa Error then return
			for f in get_files(d);lib=load(Library.metaxploit,path(f));if typeof(lib)=="MetaLib" then print blue(ljust(name(f),18))+green(" : ")+yellow(lib.version) else continue;end for
		end function
		mapConf=function(arg)
			m=null
			if indexOf(Obj.type,"shell")!=null or Obj.type=="computer" then m=File(Obj.computer,path(Obj.user.home)+"/Config/Map.conf")
			if Obj.type=="file" then m=Io.getFileObj(Obj,path(Obj.user.home)+"/Config/Map.conf")
			if m isa Error then return Info.warning("Map.conf file not found")
			if not has_permission(m,"r") then return Error.set("Don't have read permision for Map.conf")
			m=get_content(m)[14:-27].replace(char(34),"")
			i=0;while i<=len(m);m=m.remove("user:").remove("ip:").remove("password:");i+=1;end while
			for i in split(m,"\},\{");print purple("["+white(str(__i_idx+1))+"] "+green(ljust(split(i,",")[1],45))+" "+yellow(split(i,",")[0])+" "+password(split(i,",")[2]));end for
		end function
		hiddenFiles=function(arg)
			s="   "
			Info.info("Found the following hidden folders/files:")
			for f in Io.getAll(Obj.root)
				if name(f)[0]=="." then
					if is_folder(f) then
						print green("Directory at ")+orange(path(f))
						print yellow("Permissions:")+white("----")+blue(permissions(f))
						print yellow("Owner:")+white("----------")+blue(owner(f))
						print yellow("Group:")+white("----------")+blue(group(f))
						c=len(get_files(f))
						if not c then c=0
						print yellow("File Count:")+white("-----")+blue(str(c))
						print yellow("Directory Count:")+blue(str(len(get_folders(f))))
						print yellow("Size:")+white("-----------")+blue(str(Io.size(val(size(f)))))
					else if is_binary(f) then
						print blue("]"+yellow("*")+"[")+orange(name(f))
						print yellow(s+"Full path:")+white("------")+blue(path(f))
						print yellow(s+"Permissions:")+white("----")+blue(permissions(f))
						print yellow(s+"Owner:")+white("----------")+blue(owner(f))
						print yellow(s+"Group:")+white("----------")+blue(group(f))
						print yellow(s+"File type:")+white("------")+blue("binary")
					else
						print blue("]-[")+orange(name(f))
						print yellow(s+"Full path:")+white("------")+blue(path(f))
						print yellow(s+"Permissions:")+white("----")+blue(permissions(f))
						print yellow(s+"Owner:")+white("----------")+blue(owner(f))
						print yellow(s+"Group:")+white("----------")+blue(group(f))
						print yellow(s+"File type:")+white("------")+blue("text file")
						if has_permission(f,"r") then
							print yellow(s+"Line Count:")+white("-----")+blue(str(len(split(get_content(f),char(10)))))
							print yellow(s+"Char Count:")+white("-----")+blue(str(len(get_content(f))))
						else
							print yellow(s+"Line Count:")+white("-----")+red("Don't have read permissions for "+name(f))
							print yellow(s+"Char Count:")+white("-----")+red("Don't have read permissions for "+name(f))
						end if
					end if
				end if
			end for
		end function
		detailed=function(arg)
			D=null
			B=null
			for _da in arg
				if _da=="--detail" then D=1
				if _da=="--bin" then B=1
			end for
			e=["pdf","txt","jpg","log","exe","bin"]
			Info.info("Found the following special files:")
			for f in Io.getAll(Obj.root)
				if is_folder(f) then continue
				if not B and split(path(f),"\/")[1]=="bin" then continue
				_n=name(f)
				_isBinNoExt=is_binary(f) and indexOf(_n,".")==null
				if indexOf(e,split(_n,"\.")[-1])!=null or _isBinNoExt then
					if D then
						print orange(name(f))
						print yellow("Full path:")+white("------")+blue(path(f))
						print yellow("Permissions:")+white("----")+blue(permissions(f))
						print yellow("Owner:")+white("----------")+blue(owner(f))
						print yellow("Group:")+white("----------")+blue(group(f))
						if is_binary(f) then
							print yellow("File type:")+white("------")+blue("binary")
						else
							print yellow("File type:")+white("------")+blue("text file")
							if has_permission(f,"r") then
								print yellow("Line Count:")+white("-----")+blue(str(len(split(get_content(f),char(10)))))
								print yellow("Char Count:")+white("-----")+blue(str(len(get_content(f))))
							else
								print yellow("Line Count:")+white("-----")+red("Don't have read permissions for "+name(f))
								print yellow("Char Count:")+white("-----")+red("Don't have read permissions for "+name(f))
							end if
						end if
						print yellow("Size:")+white("-----------")+blue(str(Io.size(val(size(f)))))
					else
						t=split(name(f),"\.")[-1]
						if hasIndex({"pdf":0,"jpg":0,"log":0,"bin":0},t) then print green("+")+white(permissions(f))+" "+yellow(path(f)) else print green("+")+white(permissions(f))+" "+blue(path(f))
					end if
				end if
			end for
		end function
		textFiles=function(arg)
			z=0
			s="   "
			Info.info("Found the following text files:")
      for f in Io.getAll(Obj.root)
				if Io.isBinFolder(f) then continue
				z+=1
				print blue("]-[")+orange(name(f))
				print yellow(s+"Full path:")+white("------")+blue(path(f))
				print yellow(s+"Permissions:")+white("----")+blue(permissions(f))
				print yellow(s+"Owner:")+white("----------")+blue(owner(f))
				print yellow(s+"Group:")+white("----------")+blue(group(f))
				print yellow(s+"File type:")+white("------")+blue("text file")
				if has_permission(f,"r") then
					print (s+"Line Count:")+white("-----")+blue(str(len(split(get_content(f),char(10)))))
					print (s+"Char Count:")+white("-----")+blue(str(len(get_content(f))))
				else
					print yellow(s+"Line Count:")+white("-----")+red("Don't have read permissions for "+name(f))
					print yellow(s+"Char Count:")+white("-----")+red("Don't have read permissions for "+name(f))
				end if
				print yellow(s+"Size:")+white("-----------")+blue(str(Io.size(val(size(f)))))
			end for
			print white("Total file count : "+z)
		end function
		allFileContents=function(arg)
			a=Io.getAll(Obj.root)
			if a isa Error then return
			_pat=""
			if arg and len(arg)>0 then _pat=arg[0]
			s="   "
			Info.info("Found the following text files:")
			for f in a
				if is_binary(f) then continue
				if is_folder(f) then continue
				if _pat and not Io.matchName(name(f),_pat) then continue
				print blue("]-[")+orange(name(f))
				print yellow(s+"Full path:")+white("------")+blue(path(f))
				print yellow(s+"Permissions:")+white("----")+blue(permissions(f))
				print yellow(s+"Owner:")+white("----------")+blue(owner(f))
				print yellow(s+"Group:")+white("----------")+blue(group(f))
				print yellow(s+"Size:")+white("-----------")+blue(str(Io.size(val(size(f)))))
				if has_permission(f,"r") then
					_c=get_content(f)
					if _c then
						print cyan(s+"+-- contents --+")
						for _ln in split(_c,char(10));print white(s+"| ")+_ln;end for
						print cyan(s+"+----------------+")
					end if
				end if
			end for
		end function
		getSpecial=function(arg)
			a=Io.getAll(Obj.root)
			if a isa Error then return
			for f in a
				if name(f)=="system.log" then continue
				if is_folder(f) then continue
				if hasIndex(Text.specialFiles,split(name(f),"\.")[-1])!=null then
					print green(name(f)+":")
					print "  "+white(path(f))
				end if
			end for
		end function
		cmds={
			"-x":@getSpecial,
			"-t":@textFiles,
			"-m":@mapConf,
			"--password":@passwd,
			"-f":@vulnerableFiles,
			"-d":@vulnerableDirectorys,
			"-a":@allFiles,
			"-n":@localNetworks,
			"-s":@accounts,
			"-c":@allConfigContents,
			"-z":@hiddenFiles,
			"-h":@detailed,
			"-i":@allFileContents
		}
		if Utility.checkValid(Obj) then cmds["-l"]=@libraryVersions
		if not hasIndex(cmds,Arg1) then return Error.set(Text.msg.flag+Arg1+" ]")
		_li=0;_llen=len(argv)
		while _li<_llen
			_lf=argv[_li]
			if hasIndex(cmds,_lf) then
				_largs=[]
				_lj=_li+1
				while _lj<_llen
					if hasIndex(cmds,argv[_lj]) then break
					push(_largs,argv[_lj])
					_lj+=1
				end while
				cmds[_lf](_largs)
				_li=_lj
			else
				_li+=1
			end if
		end while
	end function
	__wipe=function(argv)
		if not argv then return Man.help(["wipe"])
    Arg1=lower(argv[0])
		Obj=outer.Obj
		doLog=function(arg);Log.log(Obj);end function
    transLog=function(arg);Log.transLog(Obj);end function
		logx=function(arg);Log.logX(Obj);end function
		logc=function(arg);Log.logC(Obj);end function
		boot=function(arg)
      //Trailing yes enables session yes (same as running the yes command)
      if arg and len(arg)>0 and lower(str(arg[0]))=="yes" then globals.G_auto_yes=true
      Attack.boot(Obj,Gui.skipConfirm(false))
    end function
		system=function(arg)
      if arg and len(arg)>0 and lower(str(arg[0]))=="yes" then globals.G_auto_yes=true
      Attack.system(Obj,Gui.skipConfirm(false))
    end function
		proxyLogs=function(arg)
			m=Proxy.getMapConf(Obj).accounts.values
			if not m then return Info.info("No systems in Map.conf. Run [ get -m (count) ] to add systems to Map.conf")
			for i in m
				if not len(i)==3 then continue
				s=connect_service(Obj.shell,i.ip,22,i.user,i.password)
				if not s then
					Error.set("Could not connect to "+i.ip)
					continue
				end if
				Info.info("Cleaning "+i.ip+" system.log")
				Log.shellLog(s)
			end for
			Info.info("Cleaning complete :-)")
		end function
		xConfig=function(arg)
			if not Gui.yesNo("This will remove all x's config files. Continue?",false) then return
			c=File(Obj.computer,path(Obj.dir.data)+"/.xrc")
			if c then delete(c)
			c=File(Obj.computer,path(Obj.dir.data)+"/.erc")
			if c then delete(c)
			c=File(Obj.computer,path(Obj.dir.data)+"/.hrc")
			if c then delete(c)
			Info.info("X's config files removed")
			Info.info("X is now restarting...")
			launch(get_shell,program_path)
		end function
		trash=function(arg);Attack.trash(Obj);end function
		xTraces=function(arg)
      if not hasIndex(Obj,"computer") then return Error.set("This command is only for shell/computer objects")
      if not hasIndex(Obj.dir,"payload") then return Error.set("No payload directory found for this object")
			if not File(Obj.computer,path(Obj.dir.payload)) then return
			x=File(Obj.computer,program_path)
			if x then move(x,path(Obj.dir.data),"x")
			move(Obj.dir.payload,path(Obj.dir.data),"bye")
			Log.log(Obj,null)
		end function
		logMessage=function(arg);Log.logT(Obj);end function
    deploy=function(arg)
      _p=ArgumentParser.init
      arg=_p.parseArgs("wipe",arg)
      if arg isa Error then return
      Log.deploy(Obj,arg)
    end function
		cmds={
			"-t":@trash,
			"-l":@doLog,
			"-b":@boot,
			"-s":@system,
			"-lx":@logx,
			"-lc":@logc,
			"-lt":@logMessage,
			"-a":@transLog
		}
		if Utility.checkValid(Obj,true) then
			cmds["-x"]=@xTraces
			cmds["-m"]=@proxyLogs
			cmds["-c"]=@xConfig
			cmds["--deploy"]=@deploy
		end if
		if not hasIndex(cmds,Arg1) then return Error.set(Text.msg.flag+Arg1+" ]")
		cmds[Arg1](argv[1:])
	end function
	__shadow=function(argv)
    if not argv then Arg1="-l" else Arg1=lower(argv[0])
		Obj=outer.Obj
		view=function(arg);Shadow.view;end function
		add=function(arg)
			if not arg then return Error.set("Invalid params")
			if not is_valid_ip(arg[0]) then return Error.set(arg[0]+" is not a valid ip")
			Shadow.add(arg)
		end function
		clear=function(arg);Shadow.clear(arg);end function
		readFile=function(arg);Shadow.readFile(Obj,arg);end function
		writeFile=function(arg);Shadow.writeFile(Obj,arg);end function
		cmds={
			"-l":@view,
			"-a":@add,
			"-x":@clear
		}
		if Utility.checkValid(Obj) then
			cmds["-r"]=@readFile
			cmds["-w"]=@writeFile
		end if
		if not hasIndex(cmds,Arg1) then return Error.set(Text.msg.flag+Arg1+" ]")
		cmds[Arg1](argv[1:])
	end function
