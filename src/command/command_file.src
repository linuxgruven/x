// =============================================================================
// COMMAND_FILE
// File session callbacks: file ops, text processing, crypto, remote access.
// =============================================================================
//FileSessionCallbacks
Command.fileCallbacks=function(Obj)
	Command=@self
  __alias=function(argv)
    if not argv then return Man.help(["alias"])
    Arg1=lower(argv[0])
    setAlias=function(arg)
      if globals.G_pipe.stdin then
        _stdinLines=globals.G_pipe.stdin.split(char(10))
        globals.G_pipe.stdin=null
        for _line in _stdinLines
          _line=trim(_line)
          if not _line then continue
          _toks=_line.split(" ")
          if len(_toks)<2 then continue
          setAlias(_toks)
        end for
        return
      end if
      if len(arg)<2 then return Error.set("Alias and command expected")
      if hasIndex(globals.G_main.commands,arg[0]) or hasIndex(globals.G_settings.alias,arg[0]) then return Error.set("'"+arg[0]+"' is a built-in command and cannot be used as an alias")
      _aliasVal=arg[1:]
      if len(_aliasVal)==1 and indexOf(_aliasVal[0]," ")!=null then _aliasVal=_aliasVal[0].split(" ")
      globals.G_settings.alias[arg[0]]=_aliasVal
      if Config.save then Info.info("Alias '"+arg[0]+"' set to '"+join(arg[1:]," ")+"'")
    end function
    removeAlias=function(arg)
      if not globals.G_settings.alias then return Info.info("No aliases available to remove")
      if not arg then return Error.set("Alias expected")
      a=arg[0]
      if not hasIndex(globals.G_settings.alias,a) then return Error.set("Alias '"+a+"' not found")
      remove(globals.G_settings.alias,a)
      if Config.save then Info.info("Alias '"+a+"' removed")
    end function
    listAliases=function(arg)
      if not globals.G_settings.alias then return Info.info("No aliases set")
      if hasIndex(globals.G_pipe,"PIPE_MODE") and globals.G_pipe.PIPE_MODE then
        for a in globals.G_settings.alias;push(globals.G_pipe.stdout,a.key+" => "+join(a.value," "));end for
        return
      end if
      for a in globals.G_settings.alias;print white(a.key)+yellow(" => ")+green(join(a.value," "));end for
    end function
    clearAll=function(arg)
      if not globals.G_settings.alias or len(globals.G_settings.alias)==0 then return Info.info("No aliases to clear")
      count=len(globals.G_settings.alias)
      globals.G_settings.alias={}
      if Config.save then Info.info("Cleared "+count+" alias(s)")
    end function
    cmds={
      "-s":@setAlias,
      "-r":@removeAlias,
      "-l":@listAliases,
      "--clear":@clearAll
    }
    if not hasIndex(cmds,Arg1) then return Error.set(Text.msg.flag+Arg1+" ]")
    cmds[Arg1](argv[1:])
  end function
