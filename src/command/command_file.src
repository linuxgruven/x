	__hex=function(argv);Command.hex(Obj,argv);end function
	__compare=function(argv);if len(argv)!=2 then return Man.help(["compare"]);print yellow(argv[0])+green(str(Math.compare(val(argv[0]),val(argv[1]))))+yellow(argv[1]);end function
	__decimal=function(argv);Command.decimal(Obj,argv);end function
