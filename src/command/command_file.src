    //if Net.hasInternet(Obj) isa Warning then return
    if not argv then Arg1="-l" else Arg1=lower(argv[0])
		Obj=outer.Obj
		fileView=function(arg);Share.fileView;end function
		putFile=function(arg);if not arg then return Man.help(["share"]);Share.putFile(Obj,arg);end function
		putLog=function(arg);Share.putFile(Obj,[File(Obj.computer,"/var/system.log")]);end function
		putPasswd=function(arg);Share.putFile(Obj,["/etc/passwd"]);end function
		filePeek=function(arg);if not arg then return Man.help(["share"]);Share.filePeek(to_int(arg[0]));end function
		getFile=function(arg);if not arg then return Man.help(["share"]);Share.getFile(Obj,arg);end function
