	__home=function(argv)
    // Already at main — nowhere to go
    if Obj.id==0 then return Info.info("I'll file this under 'user error'")
    // If on a proxy or pivot, it becomes "home"
    if globals.G_hasPivoted then
      // Already on the proxy/pivot — we are home
      if Obj.layer=="proxy" or Obj.layer=="pivot" then return Info.info("Achievement unlocked: going nowhere")
      // Child session under proxy/pivot — set back+home to unwind menus
      globals.G_attributes.back=true
      globals.G_attributes.home=true
      Obj.running=false
      return
    end if
    // No proxy/pivot — kill IPC and return to main
    if globals.G_IPC then Ipc.killAll
	end function
