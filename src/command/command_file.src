	__cache=function(argv)
		if Net.hasInternet(Obj) isa Warning then return
    if not argv then return Man.help(["cache"])
		Arg1=lower(argv[0])
		Obj=outer.Obj
		view=function(arg);Cache.view;end function
		use=function(arg)
			if not arg then return Man.help(["cache"])
			if Obj.type=="computer" or Obj.type=="file" then
        // CONTEXT ROUTING: If G_proxy exists, use proxy session for SSH connections
        // This routes cache operations through the proxy chain instead of direct
        if globals.G_proxy then o=globals.G_proxy else o=globals.G_main
        Cache.use(o,to_int(arg[0]))
      else
        // CONTEXT ROUTING: Use proxy session if available for correct routing
        if globals.G_proxy then o=globals.G_proxy else o=Obj
        Cache.use(o,to_int(arg[0]))
      end if
		end function
		edit=function(arg);if not arg then return Man.help(["cache"]);Cache.edit(to_int(arg[0]));end function
		doLoad=function(arg);Cache.load(1);end function
		custom=function(arg);Cache.custom;end function
		loadFile=function(arg);Cache.loadFile;end function
		dump=function(arg);Cache.dump(Obj);end function
		removeBy=function(arg);if not arg then return Man.help(["cache"]);Cache.remove(to_int(arg[0]));end function
		purge=function(arg);Cache.purge;end function
		useCustom=function(arg)
			if Obj.type=="computer" or Obj.type=="file" then
        //if there is a proxy shell then use it
        if globals.G_proxy then o=globals.G_proxy else o=globals.G_main
        Cache.useCustom(o,arg)
      else
        //if there is a proxy shell then use it
        if globals.G_proxy then o=globals.G_proxy else o=Obj
        Cache.useCustom(o,arg)
      end if
		end function
		cmds={
      "-v":@loadFile,
      "-u":@use,
      "-e":@edit,
      "-y":@doLoad,
      "-n":@custom,
      "-l":@view,
      "-d":@dump,
      "-r":@removeBy,
      "-x":@purge,
      "--u":@useCustom
		}
		if not hasIndex(cmds,Arg1) then return Error.set(Text.msg.flag+Arg1+" ]")
		cmds[Arg1](argv[1:])
	end function
