	__sessions=function(argv)
    if Net.hasInternet(Obj) isa Warning then return
    if not argv then Arg1="-l" else Arg1=lower(argv[0])
		Obj=outer.Obj
		check=function(arg)
      //if Utility.checkValid(Obj) then return Warning.set("Unable to add a session for PROXY|PIVOT|MAIN")
			if Session.check(Obj,arg) then Info.info("Current session added") else Info.warning("Current session already in sessions")
		end function
		view=function(arg);Session.view(Obj);end function
		use=function(arg);if not arg then return Man.help(["sess"]);Session.use(Obj,to_int(arg[0]));end function
		doRemove=function(arg)
			if not arg then return Man.help(["sess"])
      n=to_int(pull(arg))
      if not n isa number then return Error.set("Session id expected")
      _p=ArgumentParser.init
      _p.addArgument("y",false,"flag")  // Confirm session removal (yes)
      _p.addArgument("n",false,"flag")  // Cancel session removal (no)
      arg=_p.parseArgs("session",arg)
      if arg isa Error then return
      y=true
      if arg.n then y=false
			Session.remove(Obj,n,y)
		end function
		removeByNick=function(arg)
			if not arg then return Man.help(["sess"])
      n=pull(arg)
      _p=ArgumentParser.init
      _p.addArgument("y",false,"flag")  // Confirm session removal (yes)
      _p.addArgument("n",false,"flag")  // Cancel session removal (no)
      arg=_p.parseArgs("session",arg)
      if arg isa Error then return
      y=true
      if arg.n then y=false
			Session.removeByNick(Obj,n,y)
		end function
		nick=function(arg);if not arg or not len(arg)>=2 then return Man.help(["sess"]);Session.nick(arg);end function
		clear=function(arg);Session.clear(Obj);end function
		manage=function(arg);Session.manage(Obj);end function
    pass=function(arg);Session.pass(Obj,arg);end function
    exec=function(arg);Session.exec(arg);end function
    goto=function(arg);Session.goto(Obj,arg);end function
    back=function(arg);Session.back(Obj);end function
		cmds={
      "-a":@check,
      "-l":@view,
      "-u":@use,
      "-r":@doRemove,
      "-x":@clear,
      "-m":@manage,
      "-n":@nick,
      "-p":@pass,
      "-e":@exec,
      "-g":@goto,
      "back":@back,
      "-rn":@removeByNick
		}
		if not hasIndex(cmds,Arg1) then return Error.set(Text.msg.flag+Arg1+" ]")
		cmds[Arg1](argv[1:])
	end function
