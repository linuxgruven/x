  end function
  fileexplorer=function(args)
    if args isa Error then return
    targetObj=null
    if args.l then targetObj=globals.G_main else targetObj=Obj
    if args.rest then
      if args.rest[0][0]!="/" then args.rest[0]=Io._getPath(targetObj,args.rest[0])
    end if
    exeFile=File(targetObj.computer,"/usr/bin/FileExplorer.exe")
    if exeFile then
      launch(targetObj.shell,path(exeFile),join(args.rest," "))
      return System.tryWait(2)
    end if
    exeFile=Io.getExe(targetObj.root,"FileExplorer.exe")
    if exeFile isa Error then return Error.set("File Explorer not found")
    launch(targetObj.shell,path(exeFile),join(args.rest," "))
    System.tryWait(2)
  end function
  codeeditor=function(args)
    targetObj=null
    if args.l then targetObj=globals.G_main else targetObj=Obj
    if args.rest then
      if args.rest[0][0]!="/" then args.rest[0]=Io._getPath(targetObj,args.rest[0])
    end if
    // Inject code via --code flag if specified
    if args["code"] then
      insert(args.rest,0,"-code")
      insert(args.rest,1,args["code"])
    end if
    exeFile=File(targetObj.computer,"/usr/bin/CodeEditor.exe")
    if exeFile then
      launch(targetObj.shell,path(exeFile),join(args.rest," "))
      return System.tryWait(2)
    end if
    exeFile=Io.getExe(targetObj.root,"CodeEditor.exe")
    if exeFile isa Error then return Error.set("Code Editor not found")
    launch(targetObj.shell,path(exeFile),join(args.rest," "))
    System.tryWait(2)
  end function
