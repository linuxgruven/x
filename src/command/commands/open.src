// =============================================================================
// OPEN
// Launch GUI applications; supports 21 apps with local or remote targeting.
// XFIX1.0: stubs for News.exe, ConfigCompany.exe, HiringManager.exe (rg XFIX1.0)
// =============================================================================
Command.open=function(Obj,argv)
  if not argv then return Man.help(["open"])
  appName=lower(pull(argv))
  argv=ArgumentParser.promoteWords(argv,["login","deploy"],false)
  _p=ArgumentParser.init
  _p.addArgument("l",true,"flag") // Local execution mode
  _p.addArgument("f",false,"storeNumber") // Browser favorite number
  _p.addArgument("login",true,"flag") // login / --login (email)
  _p.addArgument("code",true,"store") // Code injection for editor
  _p.addArgument("deploy",true,"flag") // deploy / --deploy
  argv=_p.parseArgs("open",argv)
  if argv isa Error then return
  if (Obj.type=="computer" or Obj.type=="file") then argv.l=true
  isRunning=function(targetObj,exeName)
    if not hasIndex(targetObj,"computer") then return false
    procs=show_procs(targetObj.computer)
    if not procs then return false
    procs=split(procs,char(10))[1:]
    for proc in procs;parsedItem=split(proc," ");if indexOf(parsedItem[4],exeName)!=null then return true;end for
    return false
  end function
  terminal=function(args)
    targetObj=null
    if args.l then targetObj=globals.G_main else targetObj=Obj
    exeFile=File(targetObj.computer,"/usr/bin/Terminal.exe")
    if exeFile then
      launch(targetObj.shell,path(exeFile),join(args.rest," "))
      return System.tryWait(2)
    end if
    exeFile=Io.getExe(targetObj.root,"Terminal.exe")
    if exeFile isa Error then
      Builder.launchApp(targetObj,"Terminal.exe",args.rest)
    else
      launch(targetObj.shell,path(exeFile),join(args.rest," "))
      System.tryWait(2)
    end if
  end function
  browser=function(args)
    targetObj=null
    if args.l then targetObj=globals.G_main else targetObj=Obj
    if args.f isa number then
      favoritesFile=File(targetObj.computer,path(targetObj.user.home)+"/Config/Browser.txt")
      if favoritesFile then
        favorites=split(get_content(favoritesFile),char(10))
        if hasIndex(favorites,args.f) then push(args.rest,favorites[args.f])
      end if
    end if
    url=null
    if args.rest then
      url=args.rest[0]
      if url then url=Net.lookup(url)
    end if
    exeFile=File(targetObj.computer,"/usr/bin/Browser.exe")
    if exeFile then
      if url then launch(targetObj.shell,path(exeFile),url) else launch(targetObj.shell,path(exeFile))
      return System.tryWait(2)
    end if
    exeFile=Io.getExe(targetObj.root,"Browser.exe")
    if exeFile isa Error then return Error.set("Browser not found")
    if url then launch(targetObj.shell,path(exeFile),url) else launch(targetObj.shell,path(exeFile))
    System.tryWait(2)
  end function
  email=function(args)
    targetObj=null
    if args.l then targetObj=globals.G_main else targetObj=Obj
    if args.login then insert(args.rest,0,"-login")
    exeFile=File(targetObj.computer,"/usr/bin/Mail.exe")
    if exeFile then
      launch(targetObj.shell,path(exeFile),join(args.rest," "))
      return System.tryWait(2)
    end if
    exeFile=Io.getExe(targetObj.root,"Mail.exe")
    if exeFile isa Error then return Error.set("Mail not found")
    launch(targetObj.shell,path(exeFile),join(args.rest," "))
    System.tryWait(2)
  end function
  settings=function(args)
    targetObj=null
    if args.l then targetObj=globals.G_main else targetObj=Obj
    exeFile=File(targetObj.computer,"/usr/bin/Settings.exe")
