    launch(targetObj.shell,path(exeFile))
    System.tryWait(2)
  end function
  // Application launcher dispatch map (flag/name -> function reference)
  launchers={
    "-a":@admin,
    "admin":@admin,
    "-t":@terminal,
    "term":@terminal,
    "-b":@browser,
    "web":@browser,
    "-e":@email,
    "email":@email,
    "-s":@settings,
    "set":@settings,
    "-f":@fileexplorer,
    "file":@fileexplorer,
    "-c":@codeeditor,
    "code":@codeeditor,
    "-n":@notepad,
    "note":@notepad,
    "-l":@logviewer,
    "log":@logviewer,
    "-w":@scanlan,
    "scan":@scanlan,
    "-g":@configlan,
    "config":@configlan,
    "-m":@mapviewer,
    "map":@mapviewer,
    "-d":@pdf,
    "pdf":@pdf,
    "-i":@image,
    "image":@image,
    "-k":@stocks,
    "stocks":@stocks,
    "-x":@exploit,
    "exploit":@exploit,
    "-y":@employee,
    "employee":@employee,
    "-r":@traffic,
    "traffic":@traffic,
    "-p":@police,
    "police":@police,
    "-u":@student,
    "student":@student,
    "-h":@hire,
    "hire":@hire,
    "-j":@chat,
    "chat":@chat
    // XFIX1.0: "-o":@news, "news":@news,
    // XFIX1.0: "-z":@configcompany, "company":@configcompany, "cfgco":@configcompany
  }
  if not hasIndex(launchers,appName) then return Error.set(Text.msg.flag+appName+" ]")
  if hasIndex(globals.G_pipe,"stdin") and globals.G_pipe.stdin!=null and not globals.G_pipe.XARGS_MODE then
    _pipeFiles=[]
    for _line in globals.G_pipe.stdin.split(char(10))
      _line=trim(_line)
      if _line!="" then push(_pipeFiles,_line)
    end for
    if len(_pipeFiles)>0 then
      for _pipeFile in _pipeFiles
        argv.rest=[_pipeFile]
        gco=get_custom_object
        _gcoSaved={}
        _gcoKeys=[]
        for k in gco;push(_gcoKeys,k.key);end for
        for k in _gcoKeys;_gcoSaved[k]=gco[k];remove(gco,k);end for
        launchers[appName](argv)
        gco=get_custom_object
        for k in _gcoSaved;gco[k.key]=k.value;end for
      end for
      return
    end if
  end if
  if argv.deploy then
    exeNames={
      "-a":"AdminMonitor.exe","admin":"AdminMonitor.exe",
      "-t":"Terminal.exe","term":"Terminal.exe",
      "-b":"Browser.exe","web":"Browser.exe",
      "-e":"Mail.exe","email":"Mail.exe",
      "-s":"Settings.exe","set":"Settings.exe",
      "-f":"FileExplorer.exe","file":"FileExplorer.exe",
      "-c":"CodeEditor.exe","code":"CodeEditor.exe",
      "-n":"Notepad.exe","note":"Notepad.exe",
      "-l":"LogViewer.exe","log":"LogViewer.exe",
      "-w":"ScanLan.exe","scan":"ScanLan.exe",
      "-g":"ConfigLan.exe","config":"ConfigLan.exe",
      "-m":"Map.exe","map":"Map.exe",
      "-d":"PDFReader.exe","pdf":"PDFReader.exe",
      "-i":"ImageViewer.exe","image":"ImageViewer.exe",
      "-k":"Stocks.exe","stocks":"Stocks.exe",
      "-x":"ExploitReport.exe","exploit":"ExploitReport.exe",
      "-j":"Chat.exe","chat":"Chat.exe"
      // XFIX1.0: "-o":"News.exe","news":"News.exe",
      // XFIX1.0: "-z":"ConfigCompany.exe","company":"ConfigCompany.exe","cfgco":"ConfigCompany.exe",
      // XFIX1.0: "-h":"HiringManager.exe","hire":"HiringManager.exe"
    }
    if hasIndex(exeNames,appName) then return Builder.launchApp(Obj,exeNames[appName],argv.rest)
    return Error.set("Cannot deploy "+appName)
  end if
  gco=get_custom_object
  _gcoSaved={}
  _gcoKeys=[]
  for k in gco;push(_gcoKeys,k.key);end for
  for k in _gcoKeys;_gcoSaved[k]=gco[k];remove(gco,k);end for
  launchers[appName](argv)
  gco=get_custom_object
  for k in _gcoSaved;gco[k.key]=k.value;end for
end function