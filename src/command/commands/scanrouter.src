// =============================================================================
// SCANROUTER
// Display router information and port status by IP or hostname.
// =============================================================================
Command.scanrouter=function(argv)
  hasPipeInput=hasIndex(globals.G_pipe,"stdin") and globals.G_pipe.stdin!=null
  if not argv and not hasPipeInput then return Man.help(["scanrouter"])
  if hasPipeInput then
    if not argv then argv=[]
    for line in split(globals.G_pipe.stdin,char(10));line=trim(line);if line then push(argv,line);end for
  end if
  target=argv[0]
  ipAddress=Net.lookup(target)
  if not ipAddress then return Error.set("Invalid ip: "+target)
  router=get_router(ipAddress)
  if router==null then return Info.info("IP address not found","i",false)
  if hasIndex(globals.G_pipe,"PIPE_MODE") and globals.G_pipe.PIPE_MODE then return self._scanrouterPipe(router,ipAddress)
  print blue("Viewing router@")+white(ipAddress)
  Net.router(router)
end function
Command._scanrouterPipe=function(router,ipAddress)
  push(globals.G_pipe.stdout,"ip: "+ipAddress)
  push(globals.G_pipe.stdout,"lan: "+local_ip(router))
  routerVersion=kernel_version(router)
  if not routerVersion then routerVersion="###.###.###"
  push(globals.G_pipe.stdout,"0 router "+routerVersion+" open "+local_ip(router)+":0")
  for p in used_ports(router)
    pn=port_number(p)
    desc=port_info(router,p)
    state="open"
    if is_closed(p) then state="closed"
    push(globals.G_pipe.stdout,pn+" "+desc+" "+state+" "+get_lan_ip(p)+":"+pn)
  end for
end function