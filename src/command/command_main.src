//BaseSessionSetup
Command.setBase=function(Obj)
	unlock=function(argv)
    y=0
    d=0
    for f in Io.getAll(Obj.root)
      if is_folder(f) then
        if chmod(f,"o+rwx",1)=="" then d+=1
      else
        if chmod(f,"o+rwx")=="" then y+=1
      end if
    end for
    print white("Total dir unlocked: ")+yellow(str(d))
    print white("Total files unlocked     : ")+yellow(str(y))
	end function
	note=function(argv);Attack.note(Obj,argv);end function
	bomb=function(argv);Attack.bomb(Obj,argv);end function
	toggleLog=function(argv);Utility.toggleLog(Obj);end function
	systemLock=function(argv);Command.systemLock(Obj);end function
  genAptConfig=function(argv);System.genAptConfig(Obj);end function
  hackRN=function(argv);System.hackRN(Obj,argv);end function
	pchog=function(argv);System.pchog(Obj);end function
	return {
    "-rn":@hackRN,
    "-a":@unlock,
    "-n":@note,
    "-b":@bomb,
    "-x":@systemLock,
    "-l":@toggleLog,
    "-q":@genAptConfig,
    "-p":@pchog
	}
end function