// =============================================================================
// BOOT
// X shell bootstrap; initializes system state, manages pivot/proxy operations, and coordinates startup.
// =============================================================================
Boot={}
//Initialize encryption type (set by database connections)
Boot.e=null
//Reset packed objects in custom_object to null
Boot.resetCOPacked=function
  co=get_custom_object
  //Clear packed password
  co.packPasswd=null
  //Clear packed metaxploit library
  co.packMetaxploit=null
  //Clear packed crypto library
  co.packCrypto=null
  //Clear packed router library
  co.packRouter=null
  //Clear packed root shell
  co.packRootShell=null
  //Clear packed appliance library
  co.packAppliance=null
  //Clear packed traffic library
  co.packTraffic=null
//End resetCOPacked
end function
//Clear all entries from custom_object
Boot.clearCO=function
  co=get_custom_object
  //Iterate through all custom_object keys
  for i in indexes(co);remove(co,i);end for
//End clearCO
end function
//Save global state to custom_object before pivot
// Uses direct dot-notation (not globals[string]) so the compiler correctly
// renames each global reference during obfuscation.
Boot.pivotCOLoad=function
  co=get_custom_object
  co.main=globals.G_main
  co.hasPivoted=globals.G_hasPivoted
  co.proxy=globals.G_proxy
  co.piping=globals.G_piping
  co.pendingExit=globals.G_pendingExit
  co.clearAllSessions=globals.G_clearAllSessions
  co.settings=globals.G_settings
  co.errors=globals.G_errors
  co.GF=globals.G_CF
  co.sessions=globals.G_sessions
  co.netSessions=globals.G_netSessions
  co.rainbow=globals.G_rainbow
  co.names=globals.G_names
  co.virtualFiles=globals.G_virtualFiles
  co.cachePasswords=globals.G_cachePasswords
  co.shadow=globals.G_shadow
  co.server=globals.G_server
  co.libServer=globals.G_libServer
  co.xclip=globals.G_xclip
  co.tar=globals.G_tar
  co.Zday=globals.G_Zday
  co.attributes=globals.G_attributes
  co.poDebug=globals.G_poDebug
  co.exploitCache=globals.G_exploitCache
  co.exploitBtree=globals.G_exploitBtree
  co.digCache=globals.G_digCache
  co.rtree=globals.G_rtree
  co.rtreeRev=globals.G_rtreeRev
  co.frtree=globals.G_frtree
  co.stree=globals.G_stree
  co.streeRev=globals.G_streeRev
  co.fstree=globals.G_fstree
  co.mtree=globals.G_mtree
  co.mtreeRev=globals.G_mtreeRev
  co.fmtree=globals.G_fmtree
  co.libraryCache=globals.G_libraryCache
  co.metaxploit=globals.G_metaxploit
  co.initMetaxploit=globals.G_initMetaxploit
  co.crypto=globals.G_crypto
  co.initCrypto=globals.G_initCrypto
  co.initAptClient=globals.G_initAptClient
  co.initBlockchain=globals.G_initBlockchain
  co.agent=globals.G_agent
  co.bash=globals.G_bash
  co.dirty=globals.G_dirty
  co.rshell=globals.G_rshell
  co.pobjcreds=globals.G_pobjcreds
  co.IPC=globals.G_IPC
  co.IPCSafe=globals.G_IPCSafe
  co.cshell=globals.G_cshell
  co.hops=globals.G_hops
  co.continuation_cmds=globals.G_continuation_cmds
  co.deferred_cmds=globals.G_deferred_cmds
  co.bloom=globals.G_bloom
  co.rainbowIndex=globals.G_rainbowIndex
  co.pipe=globals.G_pipe
  co.pipeDebug=globals.G_pipeDebug
  co.savedStates=globals.G_savedStates
  co.autoYes=globals.G_auto_yes
  co.lastIP=globals.G_lastIP
  co.agentContext=globals.G_agentContext
  co.gui=globals.G_gui
  co.debug=globals.G_debug
  co.watchList=globals.G_watchList
  co.es=globals.G_es
  co.passwordCache=globals.G_passwordCache
end function
