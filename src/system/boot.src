  globals.G_bloom=co.bloom
  globals.G_rainbowIndex=co.rainbowIndex
  globals.G_pipe=co.pipe
  globals.G_pipeDebug=co.pipeDebug
  globals.G_savedStates=co.savedStates
  globals.G_auto_yes=co.autoYes
