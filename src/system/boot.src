  co=get_custom_object
  globals.G_main=co.main
  globals.G_hasPivoted=co.hasPivoted
  globals.G_proxy=co.proxy
  globals.G_piping=co.piping
  globals.G_pendingExit=co.pendingExit
  globals.G_clearAllSessions=co.clearAllSessions
  globals.G_settings=co.settings
  globals.G_errors=co.errors
  globals.G_CF=co.GF
  globals.G_sessions=co.sessions
  globals.G_netSessions=co.netSessions
  globals.G_rainbow=co.rainbow
  globals.G_names=co.names
  globals.G_virtualFiles=co.virtualFiles
  globals.G_cachePasswords=co.cachePasswords
  globals.G_shadow=co.shadow
  globals.G_server=co.server
  globals.G_libServer=co.libServer
  globals.G_xclip=co.xclip
