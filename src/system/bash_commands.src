  if globals.G_pipe.PIPE_MODE then return obj
  print green("_file: "+obj.user.name+"@"+obj.meta.public_ip+" ["+obj.user.raw+"] on port "+str(match.entry["port_number"]))
  return false
end function
  //_firewall - Disable firewall on target IP
  //Usage: _firewall <ip> [--port N]
_ef_firewall=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing firewall command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_firewall requires 1 argument: ip_address")
  targetIP=Net.lookup(cmd.args[0])
  if not targetIP then return Error.set("_firewall: invalid ip: "+cmd.args[0])
  if indexOf(targetIP,".")==null then return Error.set("_firewall: not a valid ip: "+targetIP)
  setup=Bash.exploitSetup(Obj,targetIP,"_firewall")
  if setup isa Error then return setup
  if public_ip(setup.router)!=targetIP and local_ip(setup.router)!=targetIP then return Error.set("_firewall: "+targetIP+" is not a router")
  flags=Bash.parseExploitArgs(cmd.args)
  matches=Bash.findBestExploit(setup.entries,"d","",flags.port)
  if len(matches)==0 then return Error.set("_firewall: no firewall exploit found for "+targetIP)
  result=null
  for m in matches
    result=Exploit.run(m.exploit,m.entry)
    if result and not (result isa Error) then break
    result=null
  end for
  if not result then return Error.set("_firewall: all firewall exploits failed for "+targetIP)
  if globals.G_pipe.PIPE_MODE then return result
  print green("_firewall: firewall disabled on "+targetIP)
  return false
end function
  //_rootpass - Change root password on target IP
