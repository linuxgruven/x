  end if
_ef_sys_whatami=function(cmd,Obj);if hasIndex(Obj,"type") and Obj.type then return Obj.type else return "unknown";end function
  //Check for _net_ping command
_ef_net_ping=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing _net_ping command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_net_ping requires 1 argument: ip_address")
  targetIP=cmd.args[0]
  if not hasIndex(Obj,"shell") or not Obj.shell then return Error.set("No shell access available")
  result=Obj.shell.ping(targetIP)
  if globals.G_pipe.PIPE_MODE then
    if typeof(result)=="string" then return 0
    return result
  end if
  if typeof(result)=="string" then
    print red("Invalid IP: "+result)
  else if result==1 then
    print green("Host "+targetIP+" is reachable")
  else
    print red("Host "+targetIP+" is not reachable")
  end if
  return false
end function
  //Check for _net_port command
_ef_net_port=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing net_port command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<2 then return Error.set("_net_port requires 2 arguments: ip_address port")
  targetIP=cmd.args[0]
  portNum=to_int(cmd.args[1])
  if not hasIndex(Obj,"computer") or not Obj.computer then
    if globals.G_pipe.PIPE_MODE then return 0
    return Error.set("No computer access available")
  end if
  router=get_router(targetIP)
  if not router then
    if globals.G_pipe.PIPE_MODE then return 0
    print red("Cannot reach "+targetIP)
    return false
  end if
  //Get all used ports and check if the specified port exists
  ports=router.used_ports
  portObj=null
  for p in ports
    if p.port_number==portNum then
      portObj=p
      break
    end if
  end for
  isOpen=0
  if portObj then
    if not portObj.is_closed then isOpen=1
  end if
  if globals.G_pipe.PIPE_MODE then return isOpen
  //Print mode
  if isOpen then
    print green("Port "+portNum+" is open on "+targetIP)
    serviceInfo=router.port_info(portNum)
    if serviceInfo then print "  Service: "+serviceInfo
  else
    print red("Port "+portNum+" is closed on "+targetIP)
  end if
  return false
end function
  //Check for _net_ports command (formatted output)
  //Check for _net_ports command (unified: prints or returns via PIPE_MODE)
_ef_net_ports=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing _net_ports command")
    print cyan("    Target IP: ")+white(cmd.args[0])
  end if
  if len(cmd.args)<1 then return Error.set("_net_ports requires 1 argument: ip_address")
  targetIP=cmd.args[0]
  if not hasIndex(Obj,"computer") or not Obj.computer then
    if globals.G_pipe.PIPE_MODE then return []
    return Error.set("No computer access available")
  end if
  router=get_router(targetIP)
  if not router then
    if globals.G_pipe.PIPE_MODE then return []
    print "Cannot reach "+targetIP
    return false
  end if
  //Get all used ports from the router
  usedPorts=used_ports(router)
  //Return mode: return list of port data maps (for _setvar capture and pipes)
  if globals.G_pipe.PIPE_MODE then
    openPorts=[]
    seenPorts=[]
    //Insert port 0 (router) for public IPs
    push(seenPorts,0)
    routerService="Kernel_router "+kernel_version(router)
    push(openPorts,{"port":0,"service":routerService})
    if usedPorts and typeof(usedPorts)=="list" then
      for port in usedPorts
        portNum=port.port_number
        if portNum!=null and seenPorts.indexOf(portNum)==null then
          push(seenPorts,portNum)
          result=router.port_info(port)
          portData={"port":portNum,"service":result}
          push(openPorts,portData)
        end if
      end for
    end if
    return openPorts
  end if
  //Print mode: formatted output (standalone)
  if usedPorts and typeof(usedPorts)=="list" then push(usedPorts,{"get_lan_ip":local_ip(router),"port_number":0,"is_closed":0,"version":kernel_version(router),"service":"Kernel_router","classID":"port"}) else usedPorts=[{"get_lan_ip":local_ip(router),"port_number":0,"is_closed":0,"version":kernel_version(router),"service":"Kernel_router","classID":"port"}]
  allPorts=[]
  output=[]
  for port in usedPorts
    portNum=port.port_number
    portLanIP=port.get_lan_ip
    if portNum!=null and allPorts.indexOf(portNum)==null then
      push(allPorts,portNum)
      if portNum==0 then
        result=port.service+" "+port.version
        push(output,"[OPEN] Port "+portNum+" - "+result+" -> "+portLanIP+":"+portNum)
      else
        result=router.port_info(port)
        if result then push(output,"[OPEN] Port "+portNum+" - "+result+" -> "+portLanIP+":"+portNum) else push(output,"[OPEN] Port "+portNum+" -> "+portLanIP+":"+portNum)
      end if
    end if
  end for
  commonPorts=Bash._commonPorts
  for scanPort in commonPorts
    if allPorts.indexOf(scanPort)==null then
      result=router.port_info(scanPort)
      if result then
        push(allPorts,scanPort)
        push(output,"[OPEN] Port "+scanPort+" - "+result)
      end if
    end if
  end for
  if len(allPorts)==0 then
    print "No open ports found on "+targetIP
  else
    lines=["Found "+len(allPorts)+" open port(s) on "+targetIP]
    for line in output;push(lines,"  "+line);end for
    print join(lines,char(10))
  end if
  return false
end function
  //Check for _net_devices command (unified: prints or returns via PIPE_MODE)
_ef_net_devices=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing net_devices command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_net_devices requires 1 argument: router_ip")
  routerIP=cmd.args[0]
  if not hasIndex(Obj,"computer") or not Obj.computer then
    if globals.G_pipe.PIPE_MODE then return []
    return Error.set("No computer access available")
  end if
  router=get_router(routerIP)
  if not router then
    if globals.G_pipe.PIPE_MODE then return []
    print "Cannot reach router "+routerIP
    return false
  end if
  devices=devices_lan_ip(router)
  if not devices then
    if globals.G_pipe.PIPE_MODE then return []
    print "No devices found on LAN"
    return false
  end if
  //Return mode
  if globals.G_pipe.PIPE_MODE then return devices
  //Print mode
  if len(devices)==0 then
    print "No devices found on LAN"
    return false
  end if
  lines=["Found "+len(devices)+" device(s) on LAN:"]
  for deviceIP in devices;push(lines,"  [DEVICE] "+deviceIP);end for
  print join(lines,char(10))
  return false
end function
  //Check for _net_router command (unified: prints or returns via PIPE_MODE)
_ef_net_router=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing net_router command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_net_router requires 1 argument: router_ip")
  routerIP=cmd.args[0]
  if not hasIndex(Obj,"computer") or not Obj.computer then
    if globals.G_pipe.PIPE_MODE then return {}
    return Error.set("No computer access available")
  end if
  router=get_router(routerIP)
  if not router then
    if globals.G_pipe.PIPE_MODE then return {}
    print red("Cannot reach router "+routerIP)
    return false
  end if
  //Return mode
  if globals.G_pipe.PIPE_MODE then
    routerData={}
    routerData["local_ip"]=local_ip(router)
    routerData["public_ip"]=public_ip(router)
    routerData["bssid"]=bssid_name(router)
    routerData["essid"]=essid_name(router)
    routerData["kernel_version"]=kernel_version(router)
    routerData["used_ports"]=used_ports(router)
    return routerData
  end if
  //Print mode
  resultStr="=== Router Information ==="
  resultStr=resultStr+char(10)+"Local IP: "+router.local_ip
  resultStr=resultStr+char(10)+"Public IP: "+router.public_ip
  resultStr=resultStr+char(10)+"BSSID: "+router.bssid_name
  resultStr=resultStr+char(10)+"ESSID: "+router.essid_name
  resultStr=resultStr+char(10)+"Kernel Version: "+router.kernel_version
  usedPorts=router.used_ports
  resultStr=resultStr+char(10)+"Used Ports: "+len(usedPorts)
  print resultStr
  return false
end function
  //Check for _net_devports command (unified: prints or returns via PIPE_MODE)
_ef_net_devports=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing net_devports command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<2 then return Error.set("_net_devports requires 2 arguments: router_ip device_ip")
  routerIP=cmd.args[0]
  deviceIP=cmd.args[1]
  if not hasIndex(Obj,"computer") or not Obj.computer then
    if globals.G_pipe.PIPE_MODE then return []
    return Error.set("No computer access available")
  end if
  router=get_router(routerIP)
  if not router then
    if globals.G_pipe.PIPE_MODE then return []
    print "Cannot reach router "+routerIP
    return false
  end if
  ports=device_ports(router,deviceIP)
  if not ports then
    if globals.G_pipe.PIPE_MODE then return []
    print "Cannot get ports for device "+deviceIP
    return false
  end if
  if typeof(ports)=="string" then
    if globals.G_pipe.PIPE_MODE then return []
    print ports
    return false
  end if
  openPorts=[]
  for port in ports;if not is_closed(port) then push(openPorts,port);end for
  //Return mode
  if globals.G_pipe.PIPE_MODE then
    portDataList=[]
    for port in openPorts
      portData={}
      portData["port_number"]=port_number(port)
      portData["service"]=port_info(router,port)
      portData["lan_ip"]=lan_ip(port)
      push(portDataList,portData)
    end for
    return portDataList
  end if
  //Print mode
  if len(openPorts)==0 then
    print "Device "+deviceIP+" has no open ports"
    return false
  end if
  resultStr="Device "+deviceIP+" has "+len(openPorts)+" open port(s):"
  for port in openPorts;portInfo=port_info(router,port);if portInfo then resultStr=resultStr+char(10)+"  [OPEN] Port "+port_number(port)+" - "+portInfo else resultStr=resultStr+char(10)+"  [OPEN] Port "+port_number(port);end for
  print resultStr
  return false
end function
