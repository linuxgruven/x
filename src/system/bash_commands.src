  print green("_computer: "+obj.user.name+"@"+obj.meta.public_ip+" ["+obj.user.raw+"] on port "+str(match.entry["port_number"]))
  return false
end function
  //_file - Find best file exploit for an IP and return headless FileObject
  //Usage: _file <ip> [--root|--user|--guest] [--port N]
  //Stores FileObject in FLAGS["hold"]; use _hold <cmd> to dispatch
_ef_file=function(cmd,Obj)
  if globals.G_bash.DEBUG then
