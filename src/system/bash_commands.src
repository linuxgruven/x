  //Check for _lan command - scan local LAN and return device list as a map
  //Usage: _setvar(result, _lan) or just _lan
  //Returns: [{ip,port_info:[{port,service,local_ip,public_ip},...],metalib:{port:lib,...}},...]
_ef_lan=function(cmd,Obj)
  //_lan [ip] - get shell on target, run Builder.packLan there; no ip=scan own LAN
  //Returns {ip, devices:[{ip, ports:[{port,service,public_ip}]}]} like _scan returns its map
  if globals.G_bash.DEBUG then
    print cyan("  Executing lan command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)>=1 then
    targetIP=Net.lookup(cmd.args[0])
    if not targetIP then return Error.set("_lan: invalid ip: "+cmd.args[0])
    if indexOf(targetIP,".")==null then return Error.set("_lan: not a valid ip: "+targetIP)
    setup=Bash.exploitSetup(Obj,targetIP,"_lan")
    if setup isa Error then return setup
    flags=Bash.parseExploitArgs(cmd.args)
    matches=Bash.findBestExploit(setup.entries,"s",flags.prefUser,flags.port)
    if len(matches)==0 then return Error.set("_lan: no shell exploit found for "+targetIP)
    shellObj=null
    for m in matches
      raw=Exploit.run(m.exploit,m.entry)
      if not raw or raw isa Error then continue
      shellObj=Exploit.getShell(raw,false,[],true)
      if not shellObj or shellObj isa Error then shellObj=null else break
    end for
    if not shellObj then return Error.set("_lan: could not get shell on "+targetIP)
    //Run LAN scan on target machine via Builder
    devices=Builder.packLan(shellObj)
    if devices isa Error then return devices
    if not devices then devices={}
    if not globals.G_pipe.PIPE_MODE then
      _ips=indexes(devices)
      print green("_lan: "+targetIP+" — "+len(_ips)+" device(s)")
      for _ip in _ips
        _ports=devices[_ip]
        if _ports and len(_ports)>0 then
          portStr=""
          for _p in _ports
            if portStr then portStr=portStr+","
            portStr=portStr+str(_p["port"])
          end for
          print "  "+_ip+" ["+portStr+"]"
        else
          print "  "+_ip
        end if
      end for
    end if
    return devices
  end if
  //No IP arg: scan own LAN via Builder (runs on current session)
  if not hasIndex(Obj,"computer") or not Obj.computer then return Error.set("_lan: no computer access")
  devices=Builder.packLan(Obj)
  if devices isa Error then return devices
  if not devices then devices={}
  if not globals.G_pipe.PIPE_MODE then
    _ips=indexes(devices)
    print green("_lan: "+len(_ips)+" device(s) on local LAN")
    for _ip in _ips
      _ports=devices[_ip]
      if _ports and len(_ports)>0 then
        portStr=""
        for _p in _ports
          if portStr then portStr=portStr+","
          portStr=portStr+str(_p["port"])
        end for
        print "  "+_ip+" ["+portStr+"]"
      else
        print "  "+_ip
      end if
    end for
  end if
  return devices
end function
  //Check for _wifi command - return visible wifi networks as a list of maps
  //Usage: _setvar(result, _wifi) or just _wifi
  //Returns: [{bssid,signal,essid},...]
_ef_wifi=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing wifi command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if not hasIndex(Obj,"net") or not Obj.net then
    if globals.G_pipe.PIPE_MODE then return []
    print red("_wifi: network not initialized")
    return false
  end if
  if not Obj.net.hasWifi then
    if globals.G_pipe.PIPE_MODE then return []
    print yellow("_wifi: wifi is not active")
    return false
  end if
  wlan=Obj.net.wlan
  if not wlan then
    if globals.G_pipe.PIPE_MODE then return []
    print "No wifi networks detected"
    return false
  end if
  result=[]
  _len=len(wlan)
  i=0
  while i<_len
    entry=wlan[i]
    wifiEntry={"bssid":entry[0],"signal":entry[1].replace("%",""),"essid":entry[2]}
    push(result,wifiEntry)
    i=i+1
  end while
  if globals.G_pipe.PIPE_MODE then return result
  print green("WiFi Networks: "+len(result))
  for w in result;print "  "+w["bssid"]+"  "+w["signal"]+"%  "+w["essid"];end for
  return false
end function
  //Check for _net_random command (generates random reachable router IP at runtime)
_ef_net_random=function(cmd,Obj)
  if globals.G_bash.DEBUG then print cyan("  Executing _net_random command")
  return Net.rip
end function
  //Check for _sys_procs command
_ef_sys_procs=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing sys_procs command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if not hasIndex(Obj,"computer") or not Obj.computer then return Error.set("No computer access available")
  processes=show_procs(Obj.computer)
  if processes then print processes else print "No processes found"
  return false
end function
  //_hold - Run a command on the held object (set by headless scan -- calls)
_ef_hold=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing hold command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  held=globals.G_bash.FLAGS["hold"]
  if not held then return Error.set("_hold: no held object (scan_ok was false or no -- flag was used)")
  if len(cmd.args)==0 then return false
  cmdName=lower(cmd.args[0])
  cmdArgs=cmd.args[1:]
  if cmdName=="home" or cmdName=="exit" then
    if hasIndex(held,"commands") and hasIndex(held.commands,"exit") then
      _fn=held.commands["exit"]
      _fn([])
    end if
    globals.G_bash.FLAGS["hold"]=null
    return false
  end if
  if not hasIndex(held,"commands") then return Error.set("_hold: held object has no commands")
  if not hasIndex(held.commands,cmdName) then return Error.set("_hold: unknown command '" + cmdName + "'")
  _fn=held.commands[cmdName]
  _fn(cmdArgs)
  return false
end function
_ef_holduser=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing holduser command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  held=globals.G_bash.FLAGS["hold"]
  if not held then return ""
  if hasIndex(held,"user") and hasIndex(held.user,"name") then return held.user.name
  return ""
end function
  //Check for _sys_kill command
_ef_sys_kill=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing sys_kill command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_sys_kill requires 1 argument: pid")
  pid=to_int(cmd.args[0])
  if not hasIndex(Obj,"computer") or not Obj.computer then return Error.set("No computer access available")
  result=close_program(Obj.computer,pid)
  if result then print green("Process "+pid+" terminated") else print red("Failed to terminate process "+pid)
  return false
end function
//Check for _fs_canwrite command
_ef_fs_canwrite=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing fs_canwrite command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_fs_canwrite requires 1 argument: path or file object")
  fileArg=cmd.args[0]
  if typeof(fileArg)=="file" then fileObj=fileArg else fileObj=Io._getFile(Obj,fileArg)
  if not fileObj or fileObj isa Error then
    print red("File not found: "+cmd.args[0])
    return false
  end if
  perms=fileObj.get_permissions
  if perms then print indexOf(perms,"w")!=null else print false
  return false
end function
//Check for _fs_canexec command
_ef_fs_canexec=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing fs_canexec command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_fs_canexec requires 1 argument: path or file object")
  fileArg=cmd.args[0]
  if typeof(fileArg)=="file" then fileObj=fileArg else fileObj=Io._getFile(Obj,fileArg)
  if not fileObj or fileObj isa Error then
    print red("File not found: "+cmd.args[0])
    return false
  end if
  perms=fileObj.get_permissions
  if perms then print indexOf(perms,"x")!=null else print false
  return false
end function
//Check for _fs_read command
_ef_fs_read=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing fs_read command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_fs_read requires 1 argument: filepath or file object")
  fileArg=cmd.args[0]
  if typeof(fileArg)=="file" then
    fileObj=fileArg
  else
    fileObj=Io._getFile(Obj,fileArg)
    if not fileObj or fileObj isa Error then return Info.error("File not found: "+fileArg)
  end if
  if is_binary(fileObj) then return Info.error("Cannot read binary file")
  if is_folder(fileObj) then return Info.error("Cannot read folder")
  content=get_content(fileObj)
  if content==null then return Info.error("Failed to read file")
  return content
end function
//Check for _fs_view command
_ef_fs_view=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing fs_view command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_fs_view requires 1 argument: filepath or file object")
  fileArg=cmd.args[0]
  if typeof(fileArg)=="file" then
    fileObj=fileArg
  else
    fileObj=Io._getFile(Obj,fileArg)
    if not fileObj or fileObj isa Error then return Info.error("File not found: "+fileArg)
  end if
  if is_binary(fileObj) then return Info.error("Cannot view binary file")
  if is_folder(fileObj) then return Info.error("Cannot view folder")
  content=get_content(fileObj)
  if content==null then return Info.error("Failed to read file")
  print content
  return false
end function
//Check for _fs_write command
_ef_fs_write=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing _fs_write command")
    if len(cmd.args)>0 then print cyan("    Path: ")+white(cmd.args[0])
  end if
  if len(cmd.args)<2 then return Error.set("_fs_write requires 2 arguments: filepath/file_object content")
  fileArg=cmd.args[0]
  content=join(cmd.args[1:]," ")
  if typeof(fileArg)=="file" then
    fileObj=fileArg
  else
    fileObj=Io._getFile(Obj,fileArg)
    if not fileObj or fileObj isa Error then
      //File doesn't exist — resolve absolute path and create it
      if not hasIndex(Obj,"computer") or not Obj.computer then return Error.set("No computer access available")
      absPath=Io._getPath(Obj,fileArg)
      if absPath isa Error then return absPath
      pathParts=absPath.split("/")
      fileName=pathParts[-1]
      dirPath=join(pathParts[:-1],"/")
      if len(dirPath)==0 then dirPath="/"
      parentDir=File(Obj.computer,dirPath)
      if not parentDir then return Info.error("Directory not found: "+dirPath)
      touchResult=touch(Obj.computer,dirPath,fileName)
      if touchResult isa string then return Info.error(touchResult)
      if touchResult!=1 then return Info.error("Failed to create file: "+fileArg)
      fileObj=Io._getFile(Obj,fileArg)
      if not fileObj or fileObj isa Error then return Info.error("Could not retrieve created file: "+fileArg)
    end if
  end if
  if is_binary(fileObj) then return Info.error("Cannot write to binary file")
  if is_folder(fileObj) then return Info.error("Cannot write to folder")
  result=set_content(fileObj,content)
  if result!=1 then
    if result isa string then return Info.error(result)
    return Info.error("Failed to write file: "+str(fileArg))
  end if
  return false
end function
  //Check for _fs_put command (upload to remote via scp)
_ef_fs_put=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing _fs_put command")
    print cyan("    Source: ")+white(cmd.args[0])
    if len(cmd.args)>1 then print cyan("    Dest: ")+white(cmd.args[1])
  end if
  //Requires both local shell (to read file) and remote shell (to write file)
  if not hasIndex(globals.G_main,"shell") or not globals.G_main.shell then return Error.set("No local shell available - _fs_put requires local shell access")
  if not hasIndex(Obj,"type") then return Error.set("Cannot determine object type")
  if Obj.type!="shell" then return Error.set("Unable to use "+Obj.type+" for this command - requires remote shell connection")
  if not hasIndex(Obj,"shell") or not Obj.shell then return Error.set("No remote shell connection available")
  if len(cmd.args)<1 then return Error.set("_fs_put requires at least 1 argument: source_file [dest_path]")
  sourcePath=cmd.args[0]
  //Default destination is remote current directory
  destPath="/"
  if len(cmd.args)>=2 then
    destPath=cmd.args[1]
  else if hasIndex(Obj,"dir") and Obj.dir and Obj.dir.current then
    destPath=path(Obj.dir.current)
  else if hasIndex(Obj,"root") and Obj.root then
    destPath=path(Obj.root)
  end if
  //Execute scp upload from local (G_main) to remote (Obj)
  result=scp(globals.G_main.shell,sourcePath,destPath,Obj.shell)
  if result isa string then return Info.error(result)
  if result==1 then print "File uploaded successfully".green
  return false
end function
  //Check for _fs_get command (download from remote via scp)
_ef_fs_get=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing _fs_get command")
    print cyan("    Source: ")+white(cmd.args[0])
    if len(cmd.args)>1 then print cyan("    Dest: ")+white(cmd.args[1])
  end if
  //Only works with shell objects
  if not hasIndex(Obj,"type") then return Error.set("Cannot determine object type")
  if Obj.type!="shell" then return Error.set("Unable to use "+Obj.type+" for this command")
  if not hasIndex(Obj,"shell") or not Obj.shell then return Error.set("No active shell connection")
  if len(cmd.args)<1 then return Error.set("_fs_get requires at least 1 argument: source_file [dest_path]")
  sourcePath=cmd.args[0]
  //Default destination is local current directory
  destPath="/"
  if len(cmd.args)>=2 then
    destPath=cmd.args[1]
  else if hasIndex(globals.G_main,"dir") and globals.G_main.dir and globals.G_main.dir.current then
    destPath=path(globals.G_main.dir.current)
  else if hasIndex(globals.G_main,"root") and globals.G_main.root then
    destPath=path(globals.G_main.root)
  end if
  //Execute scp download from remote (Obj) to local (G_main)
  result=scp(Obj.shell,sourcePath,destPath,globals.G_main.shell)
  if result isa string then return Info.error(result)
  if result==1 then print "File downloaded successfully".green
  return false
end function
//Check for _fs_find command
_ef_fs_find=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing fs_find command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_fs_find requires at least 1 argument: search_path [pattern] [-c|-e]")
  searchPath=cmd.args[0]
  searchPattern=""
  searchContent=false
  exactMatch=false
  //Parse arguments for pattern and flags
  _len=len(cmd.args)
  argIdx=1
  while argIdx<_len
    arg=cmd.args[argIdx]
    if arg=="-c" or arg=="--content" then
      searchContent=true
    else if arg=="-e" or arg=="--exact" then
      exactMatch=true
    else
      searchPattern=arg
    end if
    argIdx+=1
  end while
  //Get starting directory using Io._getFile for proper path resolution
  if searchPath=="." then startDir=Io._getFile(Obj,"./") else startDir=Io._getFile(Obj,searchPath)
  if not startDir or startDir isa Error then return Info.error("Directory not found: "+searchPath)
  if not is_folder(startDir) then return Info.error("Not a directory: "+searchPath)
  //Search by filename (default) or content (with -c flag)
  if searchContent then
    if searchPattern=="" then return Error.set("Pattern required for content search")
    allFiles=Io.getAll(startDir)
    if allFiles isa Error then return Info.error("Failed to search directory: "+searchPath)
    foundCount=0
    for f in allFiles
      if is_folder(f) then continue
      fileContent=get_content(f)
      if fileContent and indexOf(fileContent,searchPattern)!=null then
        print path(f)
        foundCount+=1
      end if
    end for
    if foundCount==0 then print yellow("No files containing '"+searchPattern+"' found in "+searchPath)
  else if exactMatch then
    if searchPattern=="" then return Error.set("Pattern required for exact match")
    result=Io.findFile(startDir,searchPattern)
    if result isa Error then
      print yellow("No file named '"+searchPattern+"' found in "+searchPath)
    else
      if is_folder(result) then print cyan(path(result)+"/") else print path(result)
    end if
  else
    allFiles=Io.getAll(startDir)
    if allFiles isa Error then return Info.error("Failed to search directory: "+searchPath)
    foundCount=0
    for f in allFiles
      fileName=name(f)
      filePath=path(f)
      if searchPattern!="" then
        if indexOf(fileName,searchPattern)==null then
          if indexOf(searchPattern,"*")!=null or indexOf(searchPattern,"?")!=null then
            if not Glob.match(fileName,searchPattern) then continue
          else
            continue
          end if
        end if
      end if
      if is_folder(f) then print cyan(filePath+"/") else print filePath
      foundCount+=1
    end for
    if foundCount==0 then
      if searchPattern!="" then print yellow("No files matching '"+searchPattern+"' found in "+searchPath) else print yellow("No files found in "+searchPath)
    end if
  end if
  return false
end function