  //_local - Attack current machine's /lib folder using a specific exploit type
  //Usage: _local [shell|computer|file|firewall|bounce|rootpass|userpass] [<password>]
  //Default type: shell. rootpass/userpass require a password argument.
  //Must be run from a computer context (after _bounce/_shell/_computer)
_ef_local=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing local command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if not hasIndex(Obj,"computer") or not Obj.computer then return Error.set("_local: no computer access")
  isShell=hasIndex(Obj,"packMetaxploit") and Obj.packMetaxploit!=null
  //Determine type from first arg; default to shell
  typeName="shell"
  newPass=""
  if len(cmd.args)>=1 then
    _a0=cmd.args[0]
    if _a0=="shell" or _a0=="computer" or _a0=="file" or _a0=="firewall" or _a0=="bounce" or _a0=="rootpass" or _a0=="userpass" then
      typeName=_a0
      if len(cmd.args)>=2 then newPass=cmd.args[1]
    end if
  end if
  //Parse optional --lib flag
  _libHint=""
  _li=0
  while _li<len(cmd.args)
    if cmd.args[_li]=="--lib" and _li+1<len(cmd.args) then
      _li=_li+1
      _libHint=cmd.args[_li]
      if _li==2 then newPass=""  //don't treat --lib value as password
    end if
    _li=_li+1
  end while
  //Map type name to exploit code
  if typeName=="shell" then
    _code="s"
  else if typeName=="computer" then
    _code="c"
  else if typeName=="file" then
    _code="f"
  else if typeName=="firewall" then
    _code="d"
  else if typeName=="bounce" then
    _code="l"
  else if typeName=="rootpass" then
    _code="p"
  else if typeName=="userpass" then
    _code="w"
  else
    _code="s"
  end if
  if (_code=="p" or _code=="w") and not newPass then return Error.set("_local: "+typeName+" requires a password argument")
  //Build argv for scanForExploit
  //  p/w: [code, password]   bounce: [code, lanIP?]   others: [code]
  _argv=[_code]
  if (_code=="p" or _code=="w") and newPass then push(_argv,newPass)
  if _code=="l" and newPass then push(_argv,newPass)
  if _libHint then push(_argv,"-l");push(_argv,_libHint)
  raw=Exploit.scanForExploit(Obj,_argv,isShell,true)
  if not raw or raw isa Error then return Error.set("_local: no "+typeName+" exploit found")
  //Get result object
  obj=null
  if _code=="s" then
    obj=Exploit.getShell(raw,false,[],true)
  else if _code=="c" or _code=="l" then
    obj=Exploit.getComputer(raw,true)
  else if _code=="f" then
    obj=Exploit.getFile(raw,null,true)
  else if _code=="d" then
    obj=true
  else if _code=="p" or _code=="w" then
    obj=true
  end if
  if not obj or (obj isa Error) then return Error.set("_local: "+typeName+" exploit failed")
  //Store in hold (non-boolean results only)
  if not (obj==true) then globals.G_bash.FLAGS["hold"]=obj
  if globals.G_pipe.PIPE_MODE then return obj
  //Print result
  if _code=="d" then
    print green("_local: firewall disabled on "+Obj.computer.public_ip)
  else if _code=="p" or _code=="w" then
    print green("_local: "+typeName+" changed to "+newPass+" on "+Obj.computer.public_ip)
  else
    print green("_local: "+typeName+" -> "+obj.user.name+" ["+obj.user.raw+"] on "+Obj.computer.public_ip)
  end if
  return false
end function
  //_bounce - LAN bounce; get a computer on the target router's local network
  //Usage: _bounce <ip> [<lan_ip>] [--port N]
  //Auto-detects LAN IP if not supplied. Stores ComputerObject in FLAGS["hold"].
_ef_bounce=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing bounce command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if not hasIndex(Obj,"computer") or not Obj.computer then return Error.set("_bounce: no computer access")
  _curIP=Obj.computer.public_ip
  _r=get_router(_curIP)
  if not _r or (public_ip(_r)!=_curIP and local_ip(_r)!=_curIP) then return Error.set("_bounce: must be run from a router")
  if len(cmd.args)<1 then return Error.set("_bounce requires 1 argument: ip_address")
  targetIP=Net.lookup(cmd.args[0])
  if not targetIP then return Error.set("_bounce: invalid ip: "+cmd.args[0])
  if indexOf(targetIP,".")==null then return Error.set("_bounce: not a valid ip: "+targetIP)
  setup=Bash.exploitSetup(Obj,targetIP,"_bounce")
  if setup isa Error then return setup
  if public_ip(setup.router)!=targetIP and local_ip(setup.router)!=targetIP then return Error.set("_bounce: "+targetIP+" is not a router")
  flags=Bash.parseExploitArgs(cmd.args)
  matches=Bash.findBestExploit(setup.entries,"l","",flags.port)
  if len(matches)==0 then return Error.set("_bounce: no bounce exploit found for "+targetIP)
  _argLanIP=null
  if len(cmd.args)>=2 and cmd.args[1]!="--port" and cmd.args[1]!="-p" then _argLanIP=cmd.args[1]
  obj=null;match=null
  for m in matches
    lanIP=_argLanIP
    if not lanIP then lanIP=Bash.findLanIP(m.entry)
    raw=Exploit.run(m.exploit,m.entry,lanIP)
    if not raw or raw isa Error then continue
    obj=Exploit.getComputer(raw,true)
    if not obj or obj isa Error then
      obj=null
    else
      match=m
      break
    end if
  end for
  if not obj then return Error.set("_bounce: all bounce exploits failed for "+targetIP)
  globals.G_bash.FLAGS["hold"]=obj
  if globals.G_pipe.PIPE_MODE then return obj
  print green("_bounce: "+obj.user.name+"@"+obj.meta.public_ip+" ["+obj.user.raw+"] (via "+targetIP+")")
  return false
end function
  //_netbounce - Internal LAN bounce; get a computer on the target's internal network
  //Usage: _netbounce <ip> [<lan_ip>] [--port N]
  //Auto-detects LAN IP if not supplied. Stores ComputerObject in FLAGS["hold"].
