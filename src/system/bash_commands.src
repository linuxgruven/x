  //Check for _scan command - scan a remote IP and return port/exploit data as a map
  //Usage: _setvar(result, _scan 1.2.3.4)
  //Returns: {"ip":..., "port_info":[{port,service,local_ip,public_ip},...], "metalib":{port:lib,...}}
_ef_scan=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing scan command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_scan requires 1 argument: ip_address")
  targetIP=Net.lookup(cmd.args[0])
  if not targetIP then return Error.set("_scan: invalid ip: "+cmd.args[0])
  if indexOf(targetIP,".")==null then return Error.set("_scan: not a valid ip: "+targetIP)
  if not hasIndex(Obj,"computer") or not Obj.computer then return Error.set("_scan: no computer access")
  _mx=Library.metaxploit
  if hasIndex(Obj,"metaxploit") and Obj.metaxploit then _mx=Obj.metaxploit
  if hasIndex(Obj,"packMetaxploit") and Obj.packMetaxploit then _mx=Obj.packMetaxploit
  if not _mx then return Error.set("_scan: metaxploit library not available")
  r=get_router(targetIP)
  if not r then
    if globals.G_pipe.PIPE_MODE then return {}
    print red("_scan: cannot reach "+targetIP)
    return false
  end if
  //Build port service lookup from router
  portServices={}
  portServices["0"]="kernel_router "+kernel_version(r)
  upList=used_ports(r)
  if upList then
    for _up in upList
      _pn=str(port_number(_up))
      _svc=port_info(r,_up)
      if not _svc then _svc=""
      portServices[_pn]=_svc
    end for
  end if
  entries=Exploit.extract(r,targetIP,_mx)
  if entries isa Error then
    if globals.G_pipe.PIPE_MODE then return {}
    print red("_scan: no attack vectors found for "+targetIP)
    return false
  end if
  portInfoList=[]
  metalibMap={}
  for entry in entries
    portNum=entry["port_number"]
    portEntry={}
    portEntry["port"]=portNum
    portEntry["service"]=portServices[str(portNum)]
    if not portEntry["service"] then portEntry["service"]=""
    portEntry["local_ip"]=entry["local_ip"]
    portEntry["public_ip"]=entry["public_ip"]
    _lib=entry["metaLib"]
    if not Exploit.haveAlready(_lib) then Exploit.headless(_lib)
    _exploitList=Exploit.get(_lib)
    _exploitNames=[]
    if _exploitList then
      for _ex in _exploitList
        if _ex.e=="?" or _ex.e=="t" then continue
        _exStr=Exploit.getItem[_ex.e]
        if _ex.u and _ex.u!="?" then _exStr=_exStr+" ("+Exploit.getItem[_ex.u]+")"
        push(_exploitNames,_exStr)
      end for
    end if
    portEntry["exploits"]=_exploitNames
    push(portInfoList,portEntry)
    metalibMap[str(portNum)]=entry["metaLib"]
  end for
  scanResult={"ip":targetIP,"port_info":portInfoList,"metalib":metalibMap}
  if not globals.G_pipe.PIPE_MODE then
    print green("Scan: "+targetIP+" — "+len(portInfoList)+" service(s)")
    for _pe in portInfoList
      _svc=_pe["service"]
      if not _svc then _svc="unknown"
      print "  ["+str(_pe["port"])+"] "+_svc+" ("+_pe["local_ip"]+")"
    end for
  end if
  return scanResult
end function
  //_shell - Find best shell exploit for an IP and return headless ShellObject
  //Usage: _shell <ip> [--root|--user|--guest] [--port N]
  //Stores ShellObject in FLAGS["hold"]; use _hold <cmd> to dispatch
_ef_shell=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing shell command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_shell requires 1 argument: ip_address")
  targetIP=Net.lookup(cmd.args[0])
  if not targetIP then return Error.set("_shell: invalid ip: "+cmd.args[0])
  if indexOf(targetIP,".")==null then return Error.set("_shell: not a valid ip: "+targetIP)
  setup=Bash.exploitSetup(Obj,targetIP,"_shell")
  if setup isa Error then return setup
  flags=Bash.parseExploitArgs(cmd.args)
  matches=Bash.findBestExploit(setup.entries,"s",flags.prefUser,flags.port)
  if len(matches)==0 then return Error.set("_shell: no shell exploit found for "+targetIP)
  obj=null;match=null
  for m in matches
    raw=Exploit.run(m.exploit,m.entry)
    if not raw or raw isa Error then continue
    obj=Exploit.getShell(raw,false,[],true)
    if not obj or obj isa Error then
      obj=null
    else
      match=m
      break
    end if
  end for
  if not obj then return Error.set("_shell: all shell exploits failed for "+targetIP)
  globals.G_bash.FLAGS["hold"]=obj
  if globals.G_pipe.PIPE_MODE then return obj
  print green("_shell: "+obj.user.name+"@"+obj.meta.public_ip+" ["+obj.user.raw+"] on port "+str(match.entry["port_number"]))
  return false
end function
  //_computer - Find best computer exploit for an IP and return headless ComputerObject
  //Usage: _computer <ip> [--root|--user|--guest] [--port N]
