// =============================================================================
// BASH_COMMANDS
// Command preprocessing, arithmetic evaluation, and built-in command execution.
// =============================================================================
// ARITHMETIC EXPRESSION EVALUATOR
//Evaluate arithmetic expressions with parentheses and operator precedence
Bash._evalArithmetic=function(expr,Obj=null)
  expr=trim(expr)
  if globals.G_bash.DEBUG then print cyan("[EVAL_ARITHMETIC] Input: ")+white(expr)
  //First, resolve any _getvar calls in the expression
  while indexOf(expr,"_getvar(")!=null
    startIdx=indexOf(expr,"_getvar(")
    parenDepth=0
    closeIdx=null
    _len=len(expr)
    i=startIdx+8
    while i<_len
      if expr[i]=="(" then parenDepth+=1
      if expr[i]==")" then
        if parenDepth==0 then
          closeIdx=i
          break
        else
          parenDepth-=1
        end if
      end if
      i+=1
    end while
    if closeIdx!=null then
      getVarCall=expr[startIdx:closeIdx+1]
      varName=expr[startIdx+8:closeIdx]
      varValue=self._getVar(varName)
      expr=expr[:startIdx]+str(varValue)+expr[closeIdx+1:]
    else
      break
    end if
  end while
  //Evaluate parentheses recursively (innermost first)
  while indexOf(expr,"(")!=null
    //Find innermost parenthesis
    openIdx=-1
    _len=len(expr)
    i=0
    while i<_len
      if expr[i]=="(" then openIdx=i
      if expr[i]==")" then
        if openIdx!=-1 then
          //Evaluate expression inside parentheses
          innerExpr=expr[openIdx+1:i]
          innerResult=self._evalArithmetic(innerExpr,Obj)
          expr=expr[:openIdx]+str(innerResult)+expr[i+1:]
          break
        end if
      end if
      i+=1
    end while
    //Safety check: if no closing paren found after opening, break
    if openIdx!=-1 and indexOf(expr,")")==null then break
    //Safety check: if we didn't find any parentheses this iteration, break
    if indexOf(expr,"(")==null then break
  end while
  //Now expr has no parentheses, evaluate with operator precedence
  //Precedence: ** > * / % > + -
  //Handle power operator (**) - highest precedence
  while indexOf(expr,"**")!=null
    opIdx=indexOf(expr,"**")
    //Find left operand - skip spaces before operator first
    leftEnd=opIdx-1
    while leftEnd>=0 and expr[leftEnd]==" ";leftEnd-=1;end while
    //Now scan backwards through digits
    leftStart=leftEnd
    while leftStart>0 and (expr[leftStart]>="0" and expr[leftStart]<="9" or expr[leftStart]==".");leftStart-=1;end while
    if leftStart<0 or not (expr[leftStart]>="0" and expr[leftStart]<="9" or expr[leftStart]==".") then leftStart+=1
    leftEnd+=1
    //Find right operand - skip spaces after operator
    rightStart=opIdx+2
    while rightStart<len(expr) and expr[rightStart]==" ";rightStart+=1;end while
    rightEnd=rightStart
    while rightEnd<len(expr) and (expr[rightEnd]>="0" and expr[rightEnd]<="9" or expr[rightEnd]==".");rightEnd+=1;end while
    leftStr=expr[leftStart:leftEnd]
    rightStr=expr[rightStart:rightEnd]
    if typeof(leftStr)=="string" then leftStr=leftStr.trim
    if typeof(rightStr)=="string" then rightStr=rightStr.trim
    left=val(leftStr)
    right=val(rightStr)
    result=left^right
    expr=expr[:leftStart]+str(result)+expr[rightEnd:]
  end while
  //Handle multiplication, division, modulo
  for op in ["*","/","%"]
    while indexOf(expr,op)!=null
      opIdx=indexOf(expr,op)
      //Find left operand - skip spaces before operator first
      leftEnd=opIdx-1
      while leftEnd>=0 and expr[leftEnd]==" ";leftEnd-=1;end while
      //Now scan backwards through digits
      leftStart=leftEnd
      while leftStart>0 and (expr[leftStart]>="0" and expr[leftStart]<="9" or expr[leftStart]==".");leftStart-=1;end while
      if leftStart<0 or not (expr[leftStart]>="0" and expr[leftStart]<="9" or expr[leftStart]==".") then leftStart+=1
      //Check for negative sign on left operand
      if leftStart>0 and expr[leftStart-1]=="-" then leftStart-=1
      leftEnd+=1
      //Find right operand (handle negative numbers) - skip spaces after operator
      rightStart=opIdx+1
      while rightStart<len(expr) and expr[rightStart]==" ";rightStart+=1;end while
      rightNeg=false
      if rightStart<len(expr) and expr[rightStart]=="-" then
        rightNeg=true
        rightStart+=1
      end if
      rightEnd=rightStart
      while rightEnd<len(expr) and (expr[rightEnd]>="0" and expr[rightEnd]<="9" or expr[rightEnd]==".");rightEnd+=1;end while
      leftStr=expr[leftStart:leftEnd]
      rightStr=expr[rightStart:rightEnd]
      if typeof(leftStr)=="string" then leftStr=leftStr.trim
      if typeof(rightStr)=="string" then rightStr=rightStr.trim
      left=val(leftStr)
      right=val(rightStr)
      if rightNeg then right=-right
      if op=="*" then
        result=left*right
      else if op=="/" then
        if right==0 then return 0
        result=left/right
      else if op=="%" then
        if right==0 then return 0
        result=left%right
      end if
      expr=expr[:leftStart]+str(result)+expr[rightEnd:]
    end while
  end for
  //Handle addition and subtraction
  arithSafetyAdd=0
  for op in ["+","-"]
    while indexOf(expr,op)!=null
      arithSafetyAdd+=1
      if arithSafetyAdd>50 then break
      opIdx=indexOf(expr,op)
      //Skip if this is a negative number at start or after another operator
      if opIdx==0 or (opIdx>0 and (expr[opIdx-1]=="+" or expr[opIdx-1]=="-" or expr[opIdx-1]=="*" or expr[opIdx-1]=="/" or expr[opIdx-1]=="%")) then
        //This is a sign, not an operator - skip it
        //Try to find next occurrence
        if opIdx+1<len(expr) then
          restExpr=expr[opIdx+1:]
          nextIdx=indexOf(restExpr,op)
          if nextIdx==null then break
          opIdx+=1+nextIdx
        else
          break
        end if
      end if
      //Find left operand - skip spaces before operator first
      leftEnd=opIdx-1
      while leftEnd>=0 and expr[leftEnd]==" ";leftEnd-=1;end while
      //Now scan backwards through digits
      leftStart=leftEnd
      while leftStart>0 and (expr[leftStart]>="0" and expr[leftStart]<="9" or expr[leftStart]==".");leftStart-=1;end while
      if leftStart<0 or not (expr[leftStart]>="0" and expr[leftStart]<="9" or expr[leftStart]==".") then leftStart+=1
      //Check for negative sign on left operand
      if leftStart>0 and expr[leftStart-1]=="-" then leftStart-=1
      leftEnd+=1
      //Find right operand (handle negative numbers) - skip spaces after operator
      rightStart=opIdx+1
      while rightStart<len(expr) and expr[rightStart]==" ";rightStart+=1;end while
      rightNeg=false
      if rightStart<len(expr) and expr[rightStart]=="-" then
        rightNeg=true
        rightStart+=1
      end if
      rightEnd=rightStart
      while rightEnd<len(expr) and (expr[rightEnd]>="0" and expr[rightEnd]<="9" or expr[rightEnd]==".");rightEnd+=1;end while
      leftStr=expr[leftStart:leftEnd]
      rightStr=expr[rightStart:rightEnd]
      if typeof(leftStr)=="string" then leftStr=leftStr.trim
      if typeof(rightStr)=="string" then rightStr=rightStr.trim
      left=val(leftStr)
      right=val(rightStr)
      if rightNeg then right=-right
      if op=="+" then
        result=left+right
      else if op=="-" then
        result=left-right
      end if
      expr=expr[:leftStart]+str(result)+expr[rightEnd:]
    end while
  end for
  //Return final result
  finalResult=val(expr)
  if globals.G_bash.DEBUG then print green("[EVAL_ARITHMETIC] Result: ")+yellow(finalResult)
  return finalResult
end function
//Evaluate string concatenation expressions (e.g., "a" + "." + "b" or _getvar(x)+.+_getvar(y))
Bash._evalStringConcat=function(expr,Obj=null)
  expr=trim(expr)
  if globals.G_bash.DEBUG then print cyan("[EVAL_STRING_CONCAT] Input: ")+white(expr)
  //First, resolve any _getvar calls in the expression
  while indexOf(expr,"_getvar(")!=null
    startIdx=indexOf(expr,"_getvar(")
    parenDepth=0
    closeIdx=null
    _len=len(expr)
    i=startIdx+8
    while i<_len
      if expr[i]=="(" then parenDepth+=1
      if expr[i]==")" then
        if parenDepth==0 then
          closeIdx=i
          break
        else
          parenDepth-=1
        end if
      end if
      i+=1
    end while
    if closeIdx!=null then
      getVarCall=expr[startIdx:closeIdx+1]
      varName=expr[startIdx+8:closeIdx]
      varValue=self._getVar(varName)
      //Convert to string if not already
      if typeof(varValue)!="string" then varValue=str(varValue)
      expr=expr[:startIdx]+varValue+expr[closeIdx+1:]
    else
      break
    end if
  end while
  //Now split by + operator and concatenate all parts
  //Handle both " + " and "+" patterns
  parts=[]
  currentPart=""
  _len=len(expr)
  i=0
  while i<_len
    if i<len(expr)-1 and expr[i]=="+" then
      //Check if it's surrounded by spaces or not
      isOperator=true
      //Skip spaces before +
      if len(currentPart)>0 then
        currentPart=currentPart.trim
        if currentPart then parts=parts+[currentPart]
        currentPart=""
      end if
      //Skip the + and any spaces after it
      i+=1
      _len=len(expr)
      while i<_len and expr[i]==" ";i+=1;end while
    else
      currentPart=currentPart+expr[i]
      i+=1
    end if
  end while
  //Add last part
  if currentPart then
    currentPart=currentPart.trim
    if currentPart then parts=parts+[currentPart]
  end if
  //Concatenate all parts
  result=""
  for part in parts;result=result+part;end for
  if globals.G_bash.DEBUG then print green("[EVAL_STRING_CONCAT] Result: ")+yellow(result)
  return result
end function
// COMMAND PREPROCESSING
//Preprocess command string with variable substitution and special commands
Bash.process=function(s,Obj=null)
  gb=globals.G_bash
  if gb.DEBUG then
    print blue("="*60)
    print blue("Function Call->process")
    print cyan("  Input Command: ")+white(s)
    print cyan("  Active Variables: ")+yellow(indexes(gb.VARS))
  end if
  //Handle _pause command (explicit pause - show Press [Enter] and return)
  if trim(s)=="_pause" or trim(s)=="pause" then
    self.pause
    return ""
  end if
  //Handle pause_ command (substring match for legacy/accidental triggers)
  if indexOf(s,"pause")!=null then
    s=s.replace("pause","")
    self.pause
  end if
  //Handle _getvar command - replace all occurrences
  //BUT skip _getvar when it's inside certain functions that need the actual type preserved
  preservedGetVars=[]
  preservedGetVarValues={} //Map of placeholder -> actual value
  maxGetVarIterations=20
  getVarIterations=0
  while indexOf(s,"_getvar(")!=null
    getVarIterations+=1
    if getVarIterations>maxGetVarIterations then
      if gb.DEBUG then print red("WARNING: Too many _getvar iterations, breaking")
      break
    end if
    startIdx=indexOf(s,"_getvar(")
    if startIdx==null then break
    if gb.DEBUG then print cyan("Processing _getvar at position ")+str(startIdx)+cyan(" in: ")+s
    //Check if this _getvar is inside a function that needs type preservation
    //Look backwards to see if we're inside len, _in, typeof_val, etc.
    skipSubstitution=false
    if startIdx>0 then
      //List of functions that need actual values, not strings
      funcNames=self._funcNamesP
      for funcPattern in funcNames
        //Look for the function name before this get_var
        searchPos=startIdx-len(funcPattern)
        if searchPos>=0 then
          checkStr=s[searchPos:startIdx]
          if gb.DEBUG then print yellow("  Checking for ")+funcPattern+yellow(" in: [")+checkStr+yellow("]")
          if indexOf(checkStr,funcPattern)!=null then
            skipSubstitution=true
            if gb.DEBUG then print green("  MATCHED! Will preserve type")
            break
          end if
        end if
      end for
    end if
    //If inside a type-preserving function, replace with placeholder
    //Also check if inside a user-defined function call (scan backward for enclosing open paren)
    if not skipSubstitution and startIdx>0 then
      scanDepth=0
      scanPos=startIdx-1
      while scanPos>=0
        if s[scanPos]==")" then scanDepth+=1
        if s[scanPos]=="(" then
          if scanDepth==0 then
            //Found unmatched open paren - extract function name before it
            funcEnd=scanPos
            funcStart=funcEnd-1
            while funcStart>=0;c=s[funcStart];if (c>="a" and c<="z") or (c>="A" and c<="Z") or (c>="0" and c<="9") or c=="_" then funcStart-=1 else break;end while
            funcStart+=1
            if funcStart<funcEnd then
              possibleFunc=s[funcStart:funcEnd]
              if hasIndex(gb.FUNCS,possibleFunc) or indexOf(self._funcNamesP,possibleFunc+"(")!=null then
                skipSubstitution=true
                if gb.DEBUG then print green("  Inside func "+possibleFunc+" - preserving _getvar type")
              end if
            end if
            break
          else
            scanDepth-=1
          end if
        end if
        scanPos-=1
      end while
    end if
    if skipSubstitution then
      parenEnd=indexOf(s[startIdx+8:],")")
      if parenEnd==null then break
      getVarEnd=startIdx+8+parenEnd+1
      getVarCall=s[startIdx:getVarEnd]
      //Extract variable name and get actual value
      varName=s[startIdx+8:startIdx+8+parenEnd]
      actualValue=self._getVar(varName)
      preservedGetVars.push(getVarCall)
      placeholder="__GVPRES"+str(len(preservedGetVars)-1)+"__"
      preservedGetVarValues[placeholder]=actualValue
      if gb.DEBUG then print green("  Created placeholder ")+placeholder+green(" for ")+varName+green(" = ")+typeof(actualValue)+green(" length=")+str(len(actualValue))
      s=s[:startIdx]+placeholder+s[getVarEnd:]
      continue
    end if
    parenStart=startIdx+8
    parenEnd=indexOf(s[parenStart:],")")
    if parenEnd==null then return Error.set("_getvar internal format is invalid")
    parenEnd=parenStart+parenEnd
    varName=s[parenStart:parenEnd]
    varValue=self._getVar(varName)
    //Check if there's property access after _getvar like _getvar(x).name
    propertyAccess=""
    checkIdx=parenEnd+1
    _len=len(s)
    if checkIdx<_len and s[checkIdx]=="." then
      //Found property access - extract the property path
      dotStart=checkIdx
      propertyEnd=checkIdx+1
      //Find end of property chain (stop at space, parenthesis, etc)
      while propertyEnd<_len
        char=s[propertyEnd]
        if char!="." and char!="_" and (char<"a" or char>"z") and (char<"A" or char>"Z") and (char<"0" or char>"9") then break
        propertyEnd+=1
      end while
      propertyAccess=s[dotStart+1:propertyEnd]
      //Access the properties
      if propertyAccess and (typeof(varValue)=="map" or typeof(varValue)=="file" or typeof(varValue)=="computer" or typeof(varValue)=="shell") then
        props=[]
        currentProp=""
        _len=len(propertyAccess)
        i=0
        while i<_len
          if propertyAccess[i]=="." then
            if currentProp then push(props,currentProp)
            currentProp=""
          else
            currentProp=currentProp+propertyAccess[i]
          end if
          i+=1
        end while
        if currentProp then push(props,currentProp)
        currentVal=varValue
        for prop in props
          prop=prop.trim
          if typeof(currentVal)=="map" and hasIndex(currentVal,prop) then
            currentVal=currentVal[prop]
          else if typeof(currentVal)=="file" then
            //File objects - manually call known methods
            if prop=="path" then
              currentVal=currentVal.path
            else if prop=="name" then
              currentVal=currentVal.name
            else if prop=="permissions" then
              currentVal=currentVal.permissions
            else if prop=="owner" then
              currentVal=currentVal.owner
            else if prop=="group" then
              currentVal=currentVal.group
            else if prop=="size" then
              currentVal=currentVal.size
            else if prop=="is_folder" then
              currentVal=currentVal.is_folder
            else if prop=="is_binary" then
              currentVal=currentVal.is_binary
            else if prop=="is_symlink" then
              currentVal=currentVal.is_symlink
            else if prop=="parent" then
              currentVal=currentVal.parent
            else if prop=="allow_import" then
              currentVal=currentVal.allow_import
            else if prop=="get_content" then
              currentVal=currentVal.get_content
            else if prop=="get_files" then
              currentVal=currentVal.get_files
            else if prop=="get_folders" then
              currentVal=currentVal.get_folders
            else if prop=="delete" then
              currentVal=currentVal.delete
            else
              currentVal=null
              break
            end if
          else if typeof(currentVal)=="computer" then
            //Computer objects - manually call known methods
            if prop=="local_ip" then
              currentVal=currentVal.local_ip
            else if prop=="public_ip" then
              currentVal=currentVal.public_ip
            else if prop=="active_net_card" then
              currentVal=currentVal.active_net_card
            else if prop=="get_name" then
              currentVal=currentVal.get_name
            else if prop=="get_ports" then
              currentVal=currentVal.get_ports
            else if prop=="is_network_active" then
              currentVal=currentVal.is_network_active
            else if prop=="network_devices" then
              currentVal=currentVal.network_devices
            else if prop=="network_gateway" then
              currentVal=currentVal.network_gateway
            else if prop=="show_procs" then
              currentVal=currentVal.show_procs
            else
              currentVal=null
              break
            end if
          else if typeof(currentVal)=="shell" then
            //Shell objects - manually call known methods
            if prop=="host_computer" then
              currentVal=currentVal.host_computer
            else
              currentVal=null
              break
            end if
          else
            currentVal=null
            break
          end if
        end for
        varValue=currentVal
      end if
      //Replace _getvar(x).property with the value
      if typeof(varValue)=="list" or typeof(varValue)=="map" then
        //Preserve typed result via placeholder so _setvar gets the actual object
        _ph="__PROP"+str(len(preservedGetVarValues))+"__"
        preservedGetVarValues[_ph]=varValue
        s=s[:startIdx]+_ph+s[propertyEnd:]
      else
        s=s[:startIdx]+str(varValue)+s[propertyEnd:]
      end if
    else
      //No property access - convert to string for substitution
      if typeof(varValue)=="string" then
        varValueStr=varValue
      else if typeof(varValue)=="number" then
        varValueStr=str(varValue)
      else
        varValueStr=str(varValue)
      end if
      s=s[:startIdx]+varValueStr+s[parenEnd+1:]
    end if
    if gb.DEBUG then print green("Command Bash->_getvar: ")+varName+" = "+str(varValue)
  end while
  //Store preserved _getvar values globally so _getVal can access them
  gb.PRESERVED_GETVAR_VALUES=preservedGetVarValues
  //DON'T restore preserved _getvar calls - keep them as placeholders
  //so that _getVal can look up the actual values and preserve types
  //The placeholders will be evaluated by _getVal when functions like len call it
  //Handle built-in function calls - evaluate them (but skip if this is a _setvar command)
  isSetVar=(indexOf(s,"_setvar")!=null)
  if not isSetVar and indexOf(s,"(")!=null then
    funcNames=self._funcNames
    for funcName in funcNames
      funcIterations=0
      maxFuncIterations=10
      while indexOf(s,funcName+"(")!=null
        funcIterations+=1
        if funcIterations>maxFuncIterations then
          if gb.DEBUG then print red("WARNING: Too many iterations for function "+funcName+", breaking")
          break
        end if
        startIdx=indexOf(s,funcName+"(")
        if startIdx==null then break
        //Skip if this match is part of a longer identifier (e.g. len( inside _len()
        if startIdx>0 then
          prevChar=s[startIdx-1]
          if (prevChar>="a" and prevChar<="z") or (prevChar>="A" and prevChar<="Z") or (prevChar>="0" and prevChar<="9") or prevChar=="_" then break
        end if
        //Find matching closing parenthesis
        parenStart=startIdx+len(funcName)
        _len=len(s)
        if parenStart>=_len then break
        depth=0
        closeIdx=null
        i=parenStart
        while i<_len
          if i>=_len then break
          if s[i]=="(" then depth+=1
          if s[i]==")" then
            depth-=1
            if depth==0 then
              closeIdx=i
              break
            end if
          end if
          i+=1
        end while
        if closeIdx!=null then
          //Extract full function call
          funcCall=s[startIdx:closeIdx+1]
          //Evaluate it
          result=self._evalFunc(funcCall,Obj)
          //Replace in string
          s=s[:startIdx]+str(result)+s[closeIdx+1:]
        else
          break
        end if
      end while
    end for
  end if
  //Handle _setvar command
  if indexOf(s,"_setvar")!=null then
    s=s.replace("_setvar","")
    if indexOf(s,"(")==null then return Error.set("_setvar internal format is invalid")
    p=s[indexOf(s,"("):]
    r=self.clean(p)
    //Smart split by comma that respects parentheses and brackets
    parts=[]
    currentPart=""
    parenDepth=0
    bracketDepth=0
    _len=len(r)
    i=0
    while i<_len
      if i>=len(r) then break
      char=r[i]
      if char=="," and parenDepth==0 and bracketDepth==0 then
        push(parts,currentPart)
        currentPart=""
      else
        if char=="(" then parenDepth+=1
        if char==")" then parenDepth-=1
        if char=="[" then bracketDepth+=1
        if char=="]" then bracketDepth-=1
        currentPart=currentPart+char
      end if
      i+=1
    end while
    push(parts,currentPart)
    if len(parts)<2 then return Error.set("Invalid _setvar parameters")
    varName=trim(parts[0])
    varValue=trim(parts[1])
    //DON'T evaluate varValue here - store the raw expression
    if gb.DEBUG then
      print cyan("  SET_VAR processing")
      print cyan("    varName: ")+white(varName)
      print cyan("    varValue (raw): ")+white(varValue)
    end if
    //Handle list literals
    isListLiteral=false
    builtinResolved=false
    //Resolve property-access placeholders from process() (preserves typed list/map results)
    _pvgv=gb.PRESERVED_GETVAR_VALUES
    if _pvgv and typeof(varValue)=="string" and hasIndex(_pvgv,varValue) then
      varValue=_pvgv[varValue]
      builtinResolved=true
      if typeof(varValue)=="list" then isListLiteral=true
    end if
    if varValue=="[]" then
      varValue=[]
      isListLiteral=true
    else if typeof(varValue)=="string" and len(varValue)>2 and varValue[0]=="[" and varValue[len(varValue)-1]=="]" then
      //Parse list literal [a,b,c]
      listContent=varValue[1:len(varValue)-1]
      varValue=split(listContent,",")
      //Trim each element
      trimmedList=[]
      for item in varValue;push(trimmedList,trim(item));end for
      varValue=trimmedList
      isListLiteral=true
      if gb.DEBUG then print green("  Created list literal with "+len(varValue)+" items: ")+yellow(varValue)
    end if
    //Check if varValue is a user-defined function call (skip if already converted to list)
    if not isListLiteral and typeof(varValue)=="string" and indexOf(varValue,"(")!=null then
      funcNameEnd=indexOf(varValue,"(")
      potentialFuncName=varValue[:funcNameEnd]
      if gb.DEBUG then
        print cyan("  Checking for user-defined function call")
        print cyan("    varValue: ")+white(varValue)
        print cyan("    potentialFuncName: ")+white(potentialFuncName)
        print cyan("    Available functions: ")+yellow(gb.FUNCS.indexes)
        print cyan("    Function exists? ")+yellow(hasIndex(gb.FUNCS,potentialFuncName))
      end if
      if hasIndex(gb.FUNCS,potentialFuncName) then
        //Extract function arguments
        funcArgs=[]
        argStart=funcNameEnd+1
        //Find matching closing paren (depth-aware, not just first ")")  
        argDepth=1
        argEnd=null
        _len=len(varValue)
        ai=argStart
        while ai<_len
          if varValue[ai]=="(" then argDepth+=1
          if varValue[ai]==")" then
            argDepth-=1
            if argDepth==0 then
              argEnd=ai
              break
            end if
          end if
          ai+=1
        end while
        if argEnd!=null and argEnd>argStart then
          argStr=varValue[argStart:argEnd]
          if argStr then
            //Smart split by comma respecting parentheses and brackets
            sfCurrent=""
            sfPDepth=0
            sfBDepth=0
            _len=len(argStr)
            sfI=0
            while sfI<_len
              if sfI>=len(argStr) then break
              sfC=argStr[sfI]
              if sfC=="(" then sfPDepth+=1
              if sfC==")" then sfPDepth-=1
              if sfC=="[" then sfBDepth+=1
              if sfC=="]" then sfBDepth-=1
              if sfC=="," and sfPDepth==0 and sfBDepth==0 then
                push(funcArgs,trim(sfCurrent))
                sfCurrent=""
              else
                sfCurrent=sfCurrent+sfC
              end if
              sfI+=1
            end while
            if sfCurrent then push(funcArgs,trim(sfCurrent))
          end if
        end if
        if gb.DEBUG then
          print green("  Calling user-defined function: ")+white(potentialFuncName)
          print green("    Arguments: ")+yellow(funcArgs)
        end if
        //Call the function with proper context
        varValue=self._callFunc(Obj,potentialFuncName,funcArgs)
        builtinResolved=true
        if gb.DEBUG then print green("  Function returned: ")+yellow(varValue)+" (type: "+typeof(varValue)+")"
      else
        //Check if it's a built-in function that should be evaluated
        //Resolve ALL builtin function calls in the expression (not just the first one)
        //Resolve ALL builtin function calls innermost-first (like arithmetic parens)
        bfMaxIter=20
        bfIter=0
        while typeof(varValue)=="string" and bfIter<bfMaxIter
          bfIter+=1
          //Find the innermost function call (one whose args have no other builtins)
          bfFound=false
          for bfName in self._funcNames
            bfPos=indexOf(varValue,bfName+"(")
            if bfPos==null then continue
            //Find matching close paren
            bfCallStart=bfPos+len(bfName)
            bfDepth=0
            bfClose=null
            _len=len(varValue)
            bfI=bfCallStart
            while bfI<_len
              if varValue[bfI]=="(" then bfDepth+=1
              if varValue[bfI]==")" then
                bfDepth-=1
                if bfDepth==0 then bfClose=bfI; break
              end if
              bfI+=1
            end while
            if bfClose==null then continue
            //Check if the args contain another builtin call - if so skip (not innermost)
            bfArgs=varValue[bfCallStart+1:bfClose]
            bfHasInner=false
            for bfInner in self._funcNames;if indexOf(bfArgs,bfInner+"(")!=null then bfHasInner=true; break;end for
            if bfHasInner then continue
            //This is an innermost call - evaluate it
            bfFullCall=varValue[bfPos:bfClose+1]
            bfResult=self._evalFunc(bfFullCall,Obj)
            if bfResult!=bfFullCall and str(bfResult)!=bfFullCall then
              //If this call is the ENTIRE expression, preserve typed result (lists, maps, etc.)
              if bfPos==0 and bfClose+1>=len(varValue) then
                varValue=bfResult
                builtinResolved=true
                bfFound=true
                if bfName=="join" then isListLiteral=true
                if typeof(varValue)=="list" then isListLiteral=true
              else
                varValue=varValue[:bfPos]+str(bfResult)+varValue[bfClose+1:]
                builtinResolved=true
                bfFound=true
                if bfName=="join" then isListLiteral=true
              end if
            end if
            break
          end for
          if not bfFound then break
        end while
        //If builtin resolved and result is a numeric arithmetic expression, evaluate it now
        if builtinResolved and typeof(varValue)=="string" then
          brHasOps=(indexOf(varValue,"+")!=null or indexOf(varValue,"-")!=null or indexOf(varValue,"*")!=null or indexOf(varValue,"/")!=null)
          if brHasOps then
            brNumeric=true
            brHasDigit=false
            _len=len(varValue)
            brCI=0
            while brCI<_len
              brC=varValue[brCI]
              if brC>="0" and brC<="9" then brHasDigit=true
              if (brC>="a" and brC<="z") or (brC>="A" and brC<="Z") or brC=="_" then
                brNumeric=false
                break
              end if
              brCI+=1
            end while
            if brNumeric and brHasDigit then varValue=self._evalArithmetic(varValue,Obj)
          end if
        end if
      end if
    end if
    //Dynamic get_any support - resolve prompts before arithmetic
    if indexOf(varValue,"get_any")!=null then
      msg=null
      startPos=indexOf(varValue,"get_any")+len("get_any")
      if startPos<len(varValue) and varValue[startPos]=="(" then
        restOfString=varValue[startPos:]
        closeIdx=indexOf(restOfString,")")
        if closeIdx!=null and closeIdx>1 then msg=varValue[startPos+1:startPos+closeIdx]
      end if
      varValue=self._getAny(msg)
    end if
    if indexOf(varValue,"get_string")!=null then
      msg=null
      startPos=indexOf(varValue,"get_string")+len("get_string")
      _len=len(varValue)
      if startPos<_len and varValue[startPos]=="(" then
        //Find matching closing parenthesis by tracking depth
        depth=0
        closeIdx=null
        i=startPos
        while i<_len
          if varValue[i]=="(" then depth+=1
          if varValue[i]==")" then
            depth-=1
            if depth==0 then
              closeIdx=i
              break
            end if
          end if
          i+=1
        end while
        if closeIdx!=null and closeIdx>startPos+1 then msg=varValue[startPos+1:closeIdx]
      end if
      varValue=self._getString(msg)
    end if
    if indexOf(varValue,"get_decimal")!=null then
      msg=null
      startPos=indexOf(varValue,"get_decimal")+len("get_decimal")
      _len=len(varValue)
      if startPos<_len and varValue[startPos]=="(" then
        //Find matching closing parenthesis by tracking depth
        depth=0
        closeIdx=null
        i=startPos
        while i<_len
          if varValue[i]=="(" then depth+=1
          if varValue[i]==")" then
            depth-=1
            if depth==0 then
              closeIdx=i
              break
            end if
          end if
          i+=1
        end while
        if closeIdx!=null and closeIdx>startPos+1 then msg=varValue[startPos+1:closeIdx]
      end if
      varValue=self._getDecimal(msg)
    end if
    if indexOf(varValue,"get_integer")!=null then
      msg=null
      startPos=indexOf(varValue,"get_integer")+len("get_integer")
      _len=len(varValue)
      if startPos<_len and varValue[startPos]=="(" then
        //Find matching closing parenthesis by tracking depth
        depth=0
        closeIdx=null
        i=startPos
        while i<_len
          if varValue[i]=="(" then depth+=1
          if varValue[i]==")" then
            depth-=1
            if depth==0 then
              closeIdx=i
              break
            end if
          end if
          i+=1
        end while
        if closeIdx!=null and closeIdx>startPos+1 then msg=varValue[startPos+1:closeIdx]
      end if
      varValue=self._getInteger(msg)
    end if
    if indexOf(varValue,"get_yesno")!=null then
      msg=null
      startPos=indexOf(varValue,"get_yesno")+len("get_yesno")
      _len=len(varValue)
      if startPos<_len and varValue[startPos]=="(" then
        //Find matching closing parenthesis by tracking depth
        depth=0
        closeIdx=null
        i=startPos
        while i<_len
          if varValue[i]=="(" then depth+=1
          if varValue[i]==")" then
            depth-=1
            if depth==0 then
              closeIdx=i
              break
            end if
          end if
          i+=1
        end while
        if closeIdx!=null and closeIdx>startPos+1 then msg=varValue[startPos+1:closeIdx]
      end if
      varValue=self._getYesNo(msg)
    end if
    //Special: _setvar(name, _hold) - store current held object into FLAGS.OBJ map
    if varValue=="_hold" then
      globals.G_bash.FLAGS["OBJ"][varName]=globals.G_bash.FLAGS["hold"]
      s=s[:indexOf(s,"(")]
      return s
    end if
    //Handle no-arg bash commands (_net_random, _fs_pwd, _sys_whoami, _sys_whatami)
    if typeof(varValue)=="string" then
      bashCmds=self._bashCmds
      for bashCmdName in bashCmds
        if varValue==bashCmdName then
          if gb.DEBUG then print cyan("  Detected bash command in _setvar: ")+white(bashCmdName)
          savedPipeMode2=globals.G_pipe.PIPE_MODE
          globals.G_pipe.PIPE_MODE=true
          bashCmd=self._prepareCommand(bashCmdName,true,Obj)
          if bashCmd and not (bashCmd isa Error) then
            bashResult=self._exec(Obj,bashCmd,true)
            if bashResult!=null and bashResult!=false and bashResult!=true then
              varValue=bashResult
              if gb.DEBUG then print green("  Bash command result: ")+white(varValue)
            end if
          end if
          globals.G_pipe.PIPE_MODE=savedPipeMode2
          break
        end if
      end for
    end if
    //Handle commands with arguments via PIPE_MODE capture
    //e.g. _setvar(ports, _net_ports 1.2.3.4) or _setvar(alive, _net_ping 1.2.3.4)
    if typeof(varValue)=="string" and not builtinResolved then
      tokens=split(varValue," ")
      if len(tokens)>=1 then
        cmdToken=tokens[0]
        //Check if first token is a known command name
        if self._cmdNames.indexOf(cmdToken)!=null then
          if gb.DEBUG then print cyan("  Detected command in _setvar: ")+white(varValue)
          //Enable PIPE_MODE so command returns data instead of printing
          savedPipeMode=globals.G_pipe.PIPE_MODE
          globals.G_pipe.PIPE_MODE=true
          cmdMap=self._prepareCommand(varValue,true,Obj)
          if cmdMap and not (cmdMap isa Error) then
            cmdResult=self._exec(Obj,cmdMap,true)
            //Use str() to distinguish boolean false/"true" from integer 0/1
            //In GreyScript typeof(false)=="number" and 0==false, so != comparisons fail for integers
            if cmdResult!=null and str(cmdResult)!="false" and not (cmdResult isa Error) then
              varValue=cmdResult
              builtinResolved=true
              if gb.DEBUG then print green("  Command capture result: ")+white(str(varValue))+" (type: "+typeof(varValue)+")"
            end if
          end if
          globals.G_pipe.PIPE_MODE=savedPipeMode
        end if
      end if
    end if
    //Handle expressions with operators AFTER resolving prompts (only for strings)
    //Skip arithmetic if value looks like a file path (starts with /)
    //Check if has parentheses but might still be arithmetic (e.g., (10+5)*2)
    hasArithmeticOps=(typeof(varValue)=="string" and (indexOf(varValue,"+")!=null or indexOf(varValue,"-")!=null or indexOf(varValue,"*")!=null or indexOf(varValue,"/")!=null or indexOf(varValue,"%")!=null))
    //Check for string concatenation patterns like: str + . + str or str+.+str
    isStringConcat=false
    if typeof(varValue)=="string" and indexOf(varValue,"+")!=null then
      //First check for explicit dot-based concatenation patterns
      if indexOf(varValue,".")!=null then
        if indexOf(varValue," + . + ")!=null or indexOf(varValue,"+.+")!=null or indexOf(varValue," + .")!=null or indexOf(varValue,". + ")!=null then
          isStringConcat=true
          if gb.DEBUG then print yellow("  Detected string concatenation pattern in: "+varValue)
        end if
      end if
      //BUT: Only if there are NO OTHER arithmetic operators (-, *, /, %, **)
      //This prevents detecting "100 / 10 + 5" as string concat (mixed operators = arithmetic)
      if not isStringConcat then
        hasOtherOps=(indexOf(varValue,"-")!=null or indexOf(varValue,"*")!=null or indexOf(varValue,"/")!=null or indexOf(varValue,"%")!=null)
        if not hasOtherOps then
          plusIdx=indexOf(varValue,"+")
          firstOperand=varValue[:plusIdx].trim
          //If first operand can't be converted to number, it's string concat
          //val returns 0 for non-numeric strings, so check if it's 0 AND not literally "0"
          testVal=val(firstOperand)
          if testVal==0 and firstOperand!="0" and firstOperand!="-0" and indexOf(firstOperand,"(")==null then
            isStringConcat=true
            if gb.DEBUG then print yellow("  Detected string concatenation (non-numeric operand): "+varValue)
          end if
        end if
      end if
    end if
    hasParens=(typeof(varValue)=="string" and indexOf(varValue,"(")!=null and indexOf(varValue,")")!=null)
    isFunctionCall=false
    isDateFormat=false
    if hasParens then
      //Check if it's a function call or arithmetic expression
      //Function calls have letters before the opening paren
      openIdx=indexOf(varValue,"(")
      if openIdx>0 then
        charBeforeParen=varValue[openIdx-1]
        //If character before paren is a letter, it's likely a function call
        if (charBeforeParen>="a" and charBeforeParen<="z") or (charBeforeParen>="A" and charBeforeParen<="Z") or charBeforeParen=="_" then isFunctionCall=true
      end if
    end if
    //Check if value looks like a date format: DD/MMM/YYYY - HH:MM or YYYY-MM-DD HH:MM:SS
    if typeof(varValue)=="string" and len(varValue)>=15 then
      //GreyScript format: "15/Jan/2000 - 07:50" (DD/MMM/YYYY - HH:MM)
      if indexOf(varValue,"/")!=null and indexOf(varValue," - ")!=null and indexOf(varValue,":")!=null then
        isDateFormat=true
      //Alternative format: "2000-01-22 06:38:00" (YYYY-MM-DD HH:MM:SS)
      else if indexOf(varValue,"-")!=null and indexOf(varValue,":")!=null then
        if len(varValue)>=19 and varValue[4]=="-" and varValue[7]=="-" and varValue[10]==" " and varValue[13]==":" and varValue[16]==":" then isDateFormat=true
      end if
    end if
    if typeof(varValue)=="string" and len(varValue)>0 and varValue[0]=="/" then
      //This is likely a file path, don't evaluate as arithmetic
      if gb.DEBUG then print yellow("  Skipping arithmetic - value looks like a path: "+varValue)
    else if builtinResolved then
      //Value already resolved by function call, skip further evaluation
      if gb.DEBUG then print yellow("  Skipping arithmetic - value resolved by function: "+str(varValue))
    else if isFunctionCall then
      //Try to evaluate as a GreyScript expression using call
      if gb.DEBUG then print yellow("  Attempting to evaluate function call: "+varValue)
      evalResult=self._evalGreyscriptCall(varValue,Obj)
      if evalResult!=null and evalResult!=varValue then
        varValue=evalResult
        if gb.DEBUG then print green("  Function call evaluated to: "+str(varValue))
      else
        //Couldn't evaluate, keep as string
        if gb.DEBUG then print yellow("  Could not evaluate function call, keeping as string")
      end if
    else if isDateFormat then
      //This is a date format, don't evaluate as arithmetic
      if gb.DEBUG then print yellow("  Skipping arithmetic - value looks like a date: "+varValue)
    else if isListLiteral then
      //This is a list literal or function result that should not be evaluated as arithmetic
      if gb.DEBUG then print yellow("  Skipping arithmetic - value is list literal or function result: "+varValue)
    else if isStringConcat then
      //Handle string concatenation with + operator
      if gb.DEBUG then print yellow("  Evaluating string concatenation: "+varValue)
      varValue=self._evalStringConcat(varValue,Obj)
      if gb.DEBUG then print yellow("  String concat result: "+str(varValue))
    else if hasArithmeticOps then
      //Check if it really looks numeric (digits, operators, spaces, dots, parens - no letters)
      arithSafe=true
      arithHasDigit=false
      _len=len(varValue)
      arI=0
      while arI<_len
        arC=varValue[arI]
        if arC>="0" and arC<="9" then arithHasDigit=true
        if (arC>="a" and arC<="z") or (arC>="A" and arC<="Z") or arC=="_" then
          arithSafe=false
          break
        end if
        arI+=1
      end while
      if arithSafe and arithHasDigit then
        //Use comprehensive arithmetic evaluator that handles parentheses and precedence
        if gb.DEBUG then print yellow("  Evaluating arithmetic expression: "+varValue)
        varValue=self._evalArithmetic(varValue,Obj)
        if gb.DEBUG then print yellow("  Arithmetic result: "+str(varValue))
      else
        if gb.DEBUG then print yellow("  Skipping arithmetic - value contains alphabetic chars: "+varValue)
      end if
    end if
    //Final evaluation with _getVal if not yet evaluated
    //Skip if a builtin function already resolved the value (e.g. substr returned "c")
    //because _getVal would incorrectly resolve it as a variable name
    if typeof(varValue)=="string" and not builtinResolved then
      evaluatedValue=self._getVal(varValue,Obj)
      //Only use evaluated value if it's different from the string
      if typeof(evaluatedValue)!="string" or evaluatedValue!=varValue then varValue=evaluatedValue
    end if
    //If _getVal returned an arithmetic expression (e.g., "5 - 1" from len resolution), evaluate it
    if typeof(varValue)=="string" and not builtinResolved then
      postHasOps=(indexOf(varValue,"+")!=null or indexOf(varValue,"-")!=null or indexOf(varValue,"*")!=null or indexOf(varValue,"/")!=null or indexOf(varValue,"%")!=null)
      if postHasOps then
        postNumeric=true
        postHasDigit=false
        _len=len(varValue)
        postCI=0
        while postCI<_len
          postC=varValue[postCI]
          if postC>="0" and postC<="9" then postHasDigit=true
          if (postC>="a" and postC<="z") or (postC>="A" and postC<="Z") or postC=="_" then
            postNumeric=false
            break
          end if
          postCI+=1
        end while
        if postNumeric and postHasDigit then varValue=self._evalArithmetic(varValue,Obj)
      end if
    end if
    self._setVar(varName,varValue)
    //Remove parameter using string slicing instead of replace
    s=s[:indexOf(s,"(")]
    if gb.DEBUG then print green("Command Bash->_setvar: ")+varName+" = "+str(varValue)+" (type: "+typeof(varValue)+")"
  end if
  //Note: get_string, get_integer, get_decimal, get_any, get_yesno are ONLY processed
  //inside _setvar commands above. Don't process them elsewhere to avoid
  //triggering prompts when these words appear in other contexts (like _print)
  return s
end function
//Prepare command string into parsed command map
Bash._prepareCommand=function(raw,skipProcess=false,Obj=null)
  if skipProcess then cmdStr=raw else cmdStr=self.process(raw,Obj)
  if cmdStr isa Error then return cmdStr
  cmdStr=trim(cmdStr)
  // Strip zero-width spaces (char 8203) used in man pages for display
  cmdStr=cmdStr.replace(char(8203),"")
  if not cmdStr then return null
  //Check for function-style syntax: command(arg1,arg2,...)
  parenIdx=indexOf(cmdStr,"(")
  if parenIdx!=null and parenIdx>0 then
    cmdName=cmdStr[:parenIdx]
    //Only parse as function syntax for known variable commands
    varCmds=self._varCmds
    if varCmds.indexOf(cmdName)!=null then
      //Extract arguments from parentheses
      closeParenIdx=cmdStr.lastIndexOf(")")
      if closeParenIdx!=null and closeParenIdx>parenIdx then
        argsStr=cmdStr[parenIdx+1:closeParenIdx]
        args=split(argsStr,",")
        //Trim each argument
        _len=len(args);i=0;while i<_len;args[i]=trim(args[i]);i+=1;end while
        return {
          "str":cmdStr,
          "name":lower(cmdName),
          "rawName":cmdName,
          "args":args
        }
      end if
    end if
  end if
  //Default space-separated parsing
  t=split(cmdStr," ")
  cmdName=lower(t[0])
  return {
    "str":cmdStr,
    "name":cmdName,
    "rawName":t[0],
    "args":t[1:]
  }
end function
// EXPLOIT HELPERS
// Shared helpers for _shell/_computer/_file/_firewall/_rootpass/_userpass/_bounce/_netbounce
//Get metaxploit library from current object context
Bash.getMx=function(Obj)
  if hasIndex(Obj,"packMetaxploit") and Obj.packMetaxploit then return Obj.packMetaxploit
  if hasIndex(Obj,"metaxploit") and Obj.metaxploit then return Obj.metaxploit
  return Library.metaxploit
end function
//Common setup for all exploit commands: validate access, get entries
//Returns {entries, router} map, or an Error
Bash.exploitSetup=function(Obj,targetIP,cmdName)
  if not hasIndex(Obj,"computer") or not Obj.computer then return Error.set(cmdName+": no computer access")
  mx=self.getMx(Obj)
  if not mx then return Error.set(cmdName+": metaxploit library not available")
  r=get_router(targetIP)
  if not r then return Error.set(cmdName+": cannot reach "+targetIP)
  entries=Exploit.extract(r,targetIP,mx)
  if entries isa Error then return Error.set(cmdName+": no attack vectors found for "+targetIP)
  return {"entries":entries,"router":r}
end function
//Parse exploit flags from cmd.args starting at startIdx
//Recognises: --root/-r  --user/-u  --guest/-g  --port/-p <N>
//Returns {prefUser, port}
Bash.parseExploitArgs=function(args,startIdx=1)
  prefUser=""
  port=null
  i=startIdx
  n=len(args)
  while i<n
    a=args[i]
    if a=="--root" or a=="-r" then prefUser="r"
    if a=="--user" or a=="-u" then prefUser="u"
    if a=="--guest" or a=="-g" then prefUser="g"
    if (a=="--port" or a=="-p") and i+1<n then
      i=i+1
      port=to_int(args[i])
    end if
    i=i+1
  end while
  return {"prefUser":prefUser,"port":port}
end function
//Find all exploit entry+exploit pairs matching type, user pref, and optional port
//Returns list of {entry, exploit, pri} sorted best-first, or empty list
Bash.findBestExploit=function(entries,exploitType,prefUser,port)
  matches=[]
  for entry in entries
    if port!=null and entry["port_number"]!=port then continue
    lib=entry["metaLib"]
    if not Exploit.haveAlready(lib) then Exploit.headless(lib)
    exList=Exploit.get(lib)
    if not exList then continue
    for ex in exList
      if ex.e!=exploitType then continue
      pri=0
      if ex.u=="r" then pri=3
      if ex.u=="u" then pri=2
      if ex.u=="g" then pri=1
      if prefUser!="" and ex.u!=prefUser then pri=pri-50
      if entry["port_number"]==0 then pri=pri-100
      push(matches,{"entry":entry,"exploit":ex,"pri":pri})
    end for
  end for
  if len(matches)==0 then return []
  //Sort descending by pri (bubble sort)
  _len=len(matches)
  i=0
  while i<_len-1
    j=0
    while j<_len-1-i
      if matches[j].pri<matches[j+1].pri then
        tmp=matches[j]
        matches[j]=matches[j+1]
        matches[j+1]=tmp
      end if
      j+=1
    end while
    i+=1
  end while
  return matches
end function
//Auto-detect a usable LAN IP from a bounce entry's network
//Prefers first real device (non-router, non-switch); falls back to entry.local_ip
Bash.findLanIP=function(entry)
  r=get_router(entry["public_ip"])
  if r then
    lan=devices_lan_ip(r)
    if lan then
      for dev in lan
        if get_switch(dev)==null and get_router(dev)==null then return dev
      end for
    end if
  end if
  return entry["local_ip"]
end function
// COMMAND EXECUTION
//Execute preprocessed command string
Bash._exec=function(Obj,c,skipProcess=false)
  gb=globals.G_bash
  //Check SIGSTOP first - if _home was called, exit immediately
  if gb.SIGSTOP then
    if gb.DEBUG then print cyan("  SIGSTOP detected in _exec - skipping command execution")
    return true
  end if
  if gb.DEBUG then
    print blue("="*60)
    print blue("Function Call->_exec")
    print cyan("  Input Type: ")+yellow(typeof(c))
    print cyan("  Calling Object: ")+yellow(typeof(Obj))
    if Obj then
      if hasIndex(Obj,"id") then print cyan("  Object ID: ")+yellow(Obj.id)
      if hasIndex(Obj,"name") then print cyan("  Object Name: ")+yellow(Obj.name)
      if hasIndex(Obj,"type") then print cyan("  Object Type: ")+yellow(Obj.type)
    end if
    if hasIndex(globals,"G_IPC") then
      print cyan("  G_IPC property exists: ")+yellow("true")
      print cyan("  G_IPC type: ")+yellow(typeof(globals.G_IPC))
      if typeof(globals.G_IPC)=="map" then
        print cyan("  G_IPC registered processes: ")+yellow(len(globals.G_IPC.indexes))
        if len(globals.G_IPC.indexes)==0 then print cyan("    ")+red("(no processes registered - empty map)") else print cyan("    Process IDs: ")+yellow(globals.G_IPC.indexes)
      end if
    else
      print cyan("  G_IPC property exists: ")+red("false - not initialized!")
    end if
    if globals.G_main then
      if hasIndex(globals.G_main,"computer") then
        comp=globals.G_main.computer
        if comp then
          if hasIndex(comp,"local_ip") then print cyan("  Local IP: ")+yellow(comp.local_ip)
          if hasIndex(comp,"public_ip") then print cyan("  Public IP: ")+yellow(comp.public_ip)
        end if
      end if
    end if
  end if
  //If input is a string with semicolons or &&, split and execute each command
  //Check this BEFORE pipes so that "a | b && c | d" is parsed as "(a | b) && (c | d)"
  //Uses lexer for quote-aware detection — operators inside strings are ignored
  //Skip for raw-text commands (_print/_printnow) — their args may contain | ; && literally
  _rawCmd=false
  if typeof(c)=="string" then
    _fw=c.split(" ")[0]
    if _fw=="_print" or _fw=="_printnow" then _rawCmd=true
  end if
  if not _rawCmd and typeof(c)=="string" and self._hasChain(c) then
    if gb.DEBUG then print cyan("  Detected command chain - executing commands")
    //Parse chain with both ; and && operators (quote-aware via lexer)
    chainParts=self._splitChain(c)
    //Execute command chain with conditional logic
    lastResult=null
    lastSuccess=true
    _len=len(chainParts)
    i=0
    while i<_len
      entry=chainParts[i]
      cmdStr=entry.cmd
      op=entry.op
      if not cmdStr or len(cmdStr)==0 then
        i+=1
        continue
      end if
      //For && operator, only execute if previous command succeeded
      if i>0 and chainParts[i-1].op=="&&" and not lastSuccess then
        if gb.DEBUG then print yellow("  Skipping command (previous failed): ")+white(cmdStr)
        i+=1
        continue
      end if
      if gb.DEBUG then print cyan("  Executing command: ")+white(cmdStr)+" "+yellow("["+op+"]")
      //Recursively execute command, always re-process for variable substitution
      //This allows variables set in earlier chain segments to be used in later segments
      result=self._exec(Obj,cmdStr,false)
      //Track success: command succeeded if result is not an Error
      lastSuccess=not (result isa Error)
      lastResult=result
      if gb.DEBUG then
        resultStatus=green("SUCCESS")
        if not lastSuccess then resultStatus=red("FAILED")
        print cyan("    Result: ")+resultStatus
      end if
      //Stop if SIGSTOP is set
      if gb.SIGSTOP then return result
      i+=1
    end while
    //Return the final result
    return lastResult
  end if
  //If input is a string with pipes, execute as pipeline using Pipe.run
  //Uses lexer for quote-aware detection — pipe chars inside strings are ignored
  if not _rawCmd and typeof(c)=="string" and self._hasPipe(c) then
    if gb.DEBUG then print cyan("  Detected pipes - delegating to Pipe.run")
    //Pre-tokenize so | is its own token — passing as [c] causes Pipe.run's re-quoting
    //loop to wrap the whole string (spaces + embedded |) in quotes, hiding the pipe separator
    argv=Pipe._parseArgs(c)
    //Enable Pipe debugging if bash debugging is on
    if gb.DEBUG and not globals.G_pipeDebug then globals.G_pipeDebug=true
    //Call Pipe.run to handle the entire pipeline
    result=Pipe.run(Obj,argv)
    //Restore Pipe debug state
    if not gb.DEBUG and globals.G_pipeDebug then globals.G_pipeDebug=false
    //Handle result display for bash context
    if result isa Error then
      //Don't print error object structure - error was already displayed by Error.set
      return []
    else if result isa list then
      if len(result)>0 then
        for line in result;print line;end for
      end if
    else if result isa string then
      if len(result)>0 then print result
    end if
    return result
  end if
  //Allow callers to pass either raw string or prepared command map
  if typeof(c)=="map" then
    cmd=c
    //Check if this is a deferred IF statement
    if hasIndex(cmd,"type") and cmd.type=="deferred_if" then
      if gb.DEBUG then
        print cyan("  Executing deferred IF statement")
        print cyan("    Condition: ")+white(cmd.cond)
      end if
      //Evaluate condition with current Obj context
      condResult=self._evalCond(cmd.cond,Obj)
      if gb.DEBUG then
        print cyan("    Result: ")+yellow(condResult)
        print cyan("    Then Block: ")+yellow(len(cmd.thenBlock)+" lines")
        print cyan("    Elif Branches: ")+yellow(len(cmd.elif))
        print cyan("    Else Block: ")+yellow(len(cmd.elseBlock)+" lines")
      end if
      if condResult then
        if gb.DEBUG then print cyan("    => Executing THEN block")
        //Parse and execute then block
        thenAst=self._parseScript(cmd.thenBlock)
        self._execBody(Obj,thenAst,false)
      else
        if gb.DEBUG then print cyan("    => Condition FALSE, checking elif/else")
        //Check elif branches
        executed=false
        elifCount=0
        for elifBranch in cmd.elif
          elifCount+=1
          if gb.DEBUG then
            print cyan("    Evaluating ELIF "+elifCount)
            print cyan("      Condition: ")+white(elifBranch.cond)
          end if
          elifResult=self._evalCond(elifBranch.cond,Obj)
          if gb.DEBUG then print cyan("      Result: ")+yellow(elifResult)
          if elifResult then
            if gb.DEBUG then print cyan("      => Executing ELIF "+elifCount+" block")
            elifAst=self._parseScript(elifBranch.body)
            self._execBody(Obj,elifAst,false)
            executed=true
            break
          end if
        end for
        if not executed and len(cmd.elseBlock)>0 then
          if gb.DEBUG then print cyan("    => No conditions matched, executing ELSE block")
          elseAst=self._parseScript(cmd.elseBlock)
          self._execBody(Obj,elseAst,false)
        else if not executed then
          if gb.DEBUG then print cyan("    => No conditions matched, no ELSE block")
        end if
      end if
      return false
    end if
    if gb.DEBUG then print cyan("  Using pre-parsed command map")
  else
    if gb.DEBUG then print cyan("  Parsing raw command string")
    //OBJ(name) cmdName [args...] - dispatch command to a named object in FLAGS.OBJ
    if typeof(c)=="string" and indexOf(c,"OBJ(")==0 then
      parenEnd=indexOf(c,")")
      if parenEnd!=null then
        varName=c[4:parenEnd]
        rest=trim(c[parenEnd+1:])
        if rest then
          objMap=globals.G_bash.FLAGS["OBJ"]
          if not hasIndex(objMap,varName) then return Error.set("OBJ: '"+varName+"' not found (use _setvar("+varName+", _hold) first)")
          storedObj=objMap[varName]
          if not storedObj then return Error.set("OBJ: '"+varName+"' is null")
          if not hasIndex(storedObj,"commands") then return Error.set("OBJ: '"+varName+"' has no commands")
          parts=split(rest," ")
          cmdName=lower(parts[0])
          cmdArgs=parts[1:]
          if cmdName=="home" or cmdName=="exit" then
            if hasIndex(storedObj.commands,"exit") then storedObj.commands["exit"]([])
            objMap[varName]=null
            return false
          end if
          if not hasIndex(storedObj.commands,cmdName) then return Error.set("OBJ: unknown command '"+cmdName+"'")
          _fn=storedObj.commands[cmdName] //split: obj.prop[key](args) fails at this nesting depth
          objResult=_fn(cmdArgs)
          //If the command returns a shell/object (e.g. su returning a root shell),
          //update the stored entry so subsequent OBJ(name) calls use the new object
          if objResult!=null and objResult!=false and hasIndex(objResult,"commands") then
            objMap[varName]=objResult
            globals.G_bash.FLAGS["hold"]=objResult
          end if
          return false
        end if
      end if
    end if
    cmd=self._prepareCommand(c,skipProcess,Obj)
  end if
  //Skip blank commands quietly
  if cmd==null then
    if gb.DEBUG then print yellow("  Command is blank - skipping")
    return gb.SIGSTOP
  end if
  //Processing failure clears bash state
  if cmd isa Error then
    if gb.DEBUG then print red("  ERROR during preprocessing - clearing state")
    return self.clear
  end if
  //Evaluate bash command arguments (_net_random, _sys_whoami, etc.) for all commands
  if cmd.args and len(cmd.args)>0 then
    evaluatedArgs=[]
    for arg in cmd.args
      argStr=str(arg)
      //Check if argument contains _getvar or other function-like syntax
      if indexOf(argStr,"_getvar(")!=null then
        //Extract variable name from _getvar(varname)
        startIdx=indexOf(argStr,"_getvar(")+8
        endIdx=indexOf(argStr,")",startIdx)
        if endIdx!=null then
          varName=argStr[startIdx:endIdx]
          varValue=self._getVar(varName)
          if varValue!=null then push(evaluatedArgs,str(varValue)) else push(evaluatedArgs,argStr)
          continue
        end if
      end if
      //Expand pipe variables ($VAR syntax)
      if indexOf(argStr,"$")!=null then argStr=Pipe._expandVars(argStr)
      //Check for other bash commands
      bashCmds=self._bashCmds
      //Check if argument is a bash command that needs evaluation
      if bashCmds.indexOf(argStr)!=null then
        bashCmd=self._prepareCommand(argStr,false,Obj)
        if bashCmd and bashCmd!=null and not (bashCmd isa Error) then
          bashResult=self._exec(Obj,bashCmd,false)
          if bashResult!=null and bashResult!=false and bashResult!=true then push(evaluatedArgs,str(bashResult)) else push(evaluatedArgs,argStr)
        else
          push(evaluatedArgs,argStr)
        end if
      else
        push(evaluatedArgs,argStr)
      end if
    end for
    cmd.args=evaluatedArgs
    //Glob expansion: expand wildcard patterns in args for filesystem commands
    //Commands that read/search existing files benefit from glob expansion
    globCmds=["_fs_read","_fs_view","_fs_find","_fs_ls","_fs_cd"]
    if indexOf(globCmds,cmd.name)!=null then
      globExpanded=[]
      for gArg in cmd.args
        if typeof(gArg)=="string" and indexOf(gArg,"*")!=null then
          expanded=Glob.expand(Obj,gArg)
          if expanded and typeof(expanded)=="list" then globExpanded=globExpanded+expanded else push(globExpanded,gArg)
        else
          push(globExpanded,gArg)
        end if
      end for
      cmd.args=globExpanded
    end if
  end if
  if gb.DEBUG then
    print green("  Final command build: ")+white(cmd.str)
    print green("  Command name: ")+white(cmd.name)
    print green("  Arguments: ")+yellow(cmd.args)
    print green("  Args count: ")+yellow(len(cmd.args))
  end if
  //Dispatch to handler — O(1) map lookup, built locally on first call then cached in gb.
  //IMPORTANT: map must be constructed inside this function (not at module level).
  //GreyScript invokes @refs in module-level maps at init time (no args -> crash).
  //Local construction stores references correctly; same pattern as _builtinMap in bash_builtins.src.
  if not hasIndex(gb,"_dc") then
    gb._dc={
      "_print":@_ef_print,
      "_printnow":@_ef_print,
      "_push":@_ef_push,
      "_pop":@_ef_pop,
      "_pull":@_ef_pull,
      "_len":@_ef_len,
      "_in":@_ef_in,
      "_sleep":@_ef_sleep,
      "sleep":@_ef_sleep,
      "_exit":@_ef_exit,
      "_throw":@_ef_throw,
      "_home":@_ef_home,
      "_fs_mkdir":@_ef_fs_mkdir,
      "_fs_cd":@_ef_fs_cd,
      "_fs_pwd":@_ef_fs_pwd,
      "_sys_whoami":@_ef_sys_whoami,
      "_sys_whatami":@_ef_sys_whatami,
      "_net_ping":@_ef_net_ping,
      "_net_port":@_ef_net_port,
      "_net_ports":@_ef_net_ports,
      "_net_devices":@_ef_net_devices,
      "_net_router":@_ef_net_router,
      "_net_devports":@_ef_net_devports,
      "_net_fwrules":@_ef_net_fwrules,
      "_scan":@_ef_scan,
      "_shell":@_ef_shell,
      "_computer":@_ef_computer,
      "_file":@_ef_file,
      "_firewall":@_ef_firewall,
      "_rootpass":@_ef_rootpass,
      "_userpass":@_ef_userpass,
      "_local":@_ef_local,
      "_bounce":@_ef_bounce,
      "_netbounce":@_ef_netbounce,
      "_lan":@_ef_lan,
      "_wifi":@_ef_wifi,
      "_net_random":@_ef_net_random,
      "_sys_procs":@_ef_sys_procs,
      "_hold":@_ef_hold,
      "_holduser":@_ef_holduser,
      "_sys_kill":@_ef_sys_kill,
      "_fs_canwrite":@_ef_fs_canwrite,
      "_fs_canexec":@_ef_fs_canexec,
      "_fs_read":@_ef_fs_read,
      "_fs_view":@_ef_fs_view,
      "_fs_write":@_ef_fs_write,
      "_fs_put":@_ef_fs_put,
      "_fs_get":@_ef_fs_get,
      "_fs_find":@_ef_fs_find
    }
  end if
  if hasIndex(gb._dc,cmd.name) then
    _ef=gb._dc[cmd.name]
    return _ef(cmd,Obj)
  end if
  //Check if it's a user-defined function call
  funcLookup=cmd.name
  if hasIndex(cmd,"rawName") and cmd.rawName then funcLookup=cmd.rawName
  if hasIndex(gb.FUNCS,funcLookup) then
    if gb.DEBUG then
      print cyan("  Command is user-defined function")
      print cyan("    Calling function: ")+white(funcLookup)
    end if
    self._callFunc(Obj,funcLookup)
    return false
  end if
  //Execute command from command table
  if hasIndex(Obj.commands,cmd.name) then
    if gb.DEBUG then
      print cyan("  Command found in command table")
      print cyan("    Executing: ")+white(cmd.name)
    end if
    _fn=Obj.commands[cmd.name]
    _cmdRet=_fn(cmd.args)
    if hasIndex(gb,"PENDING_OUTPUT") and gb.PENDING_OUTPUT then
      print gb.PENDING_OUTPUT
      gb.PENDING_OUTPUT=null
    end if
    if gb.SIGSTOP then return true
    return _cmdRet
  else
    if gb.DEBUG then
      print red("  WARNING: Command not found")
      print red("    Command: ")+white(cmd.name)
      print red("    Available functions: ")+yellow(gb.FUNCS.indexes)
    end if
  end if
  if gb.DEBUG then print blue("  _exec complete")
  //Check if there's pending output from network functions and print it immediately
  if hasIndex(gb,"PENDING_OUTPUT") and gb.PENDING_OUTPUT then
    print gb.PENDING_OUTPUT
    gb.PENDING_OUTPUT=null
  end if
  return gb.SIGSTOP
end function
  //Check for _print/_printnow command
_ef_print=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing _print command")
    print cyan("    Message: ")+white(join(cmd.args," "))
  end if
  //Evaluate any GreyScript function calls in arguments
  evaluatedArgs=[]
  argCount=len(cmd.args)
  argIdx=0
  for arg in cmd.args
    argStr=str(arg)
    //Check if argument is a bash command (_sys_whoami, _sys_whatami, etc.)
    //Only evaluate if it's the LAST argument to prevent mid-sentence evaluation
    bashCmds=Bash._bashCmds
    if bashCmds.indexOf(argStr)!=null and argIdx==argCount-1 then
      bashCmd=Bash._prepareCommand(argStr,false,Obj)
      if bashCmd and bashCmd!=null and not (bashCmd isa Error) then
        bashResult=Bash._exec(Obj,bashCmd,false)
        //All these commands should return a value (pwd now returns path string)
        if bashResult!=null and bashResult!=false and bashResult!=true then push(evaluatedArgs,str(bashResult)) else push(evaluatedArgs,argStr)
      else
        push(evaluatedArgs,argStr)
      end if
    else if indexOf(argStr,"(")!=null and indexOf(argStr,")")!=null then
      //Check if argument looks like a function call
      openIdx=indexOf(argStr,"(")
      if openIdx>0 then
        charBefore=argStr[openIdx-1]
        if (charBefore>="a" and charBefore<="z") or (charBefore>="A" and charBefore<="Z") or charBefore=="_" then
          //Try to evaluate it
          evalResult=Bash._evalGreyscriptCall(argStr,Obj)
          if evalResult!=null and evalResult!=argStr then push(evaluatedArgs,str(evalResult)) else push(evaluatedArgs,argStr)
        else
          push(evaluatedArgs,argStr)
        end if
      else
        push(evaluatedArgs,argStr)
      end if
    else
      push(evaluatedArgs,argStr)
    end if
    argIdx+=1
  end for
  msg=join(evaluatedArgs," ")
  //Process color functions: blue(text), red(text), etc.
  colorFuncs=Bash._colorFuncs
  for colorFunc in colorFuncs
    while indexOf(msg,colorFunc+"(")!=null
      startIdx=indexOf(msg,colorFunc+"(")
      if startIdx==null then break
      parenStart=startIdx+len(colorFunc)+1
      //Check if parenStart is within bounds
      _len=len(msg)
      if parenStart>=_len then break
      //Find matching closing paren
      depth=1
      closeIdx=null
      i=parenStart
      while i<_len
        if msg[i]=="(" then depth+=1
        if msg[i]==")" then
          depth-=1
          if depth==0 then
            closeIdx=i
            break
          end if
        end if
        i+=1
      end while
      if closeIdx!=null then
        //Extract text inside function call
        innerText=msg[parenStart:closeIdx]
        //Apply color function
        if colorFunc=="orange" then
          coloredText=innerText.orange
        else if colorFunc=="cyan" then
          coloredText=innerText.cyan
        else if colorFunc=="magenta" then
          coloredText=innerText.magenta
        else if colorFunc=="lime" then
          coloredText=innerText.lime
        else if colorFunc=="bred" then
          coloredText=innerText.bred
        else if colorFunc=="green" then
          coloredText=innerText.green
        else if colorFunc=="password" then
          coloredText=innerText.password
        else if colorFunc=="blue" then
          coloredText=innerText.blue
        else if colorFunc=="liteblue" then
          coloredText=innerText.liteblue
        else if colorFunc=="yellow" then
          coloredText=innerText.yellow
        else if colorFunc=="white" then
          coloredText=innerText.white
        else if colorFunc=="purple" then
          coloredText=innerText.purple
        else if colorFunc=="iyellow" then
          coloredText=innerText.iyellow
        else if colorFunc=="liteGrey" then
          coloredText=innerText.liteGrey
        else if colorFunc=="error" then
          coloredText=innerText.error
        else if colorFunc=="red" then
          coloredText=innerText.red
        else if colorFunc=="grey" then
          coloredText=innerText.grey
        else if colorFunc=="black" then
          coloredText=innerText.black
        else if colorFunc=="bold" then
          coloredText=innerText.bold
        end if
        //Replace function call with colored text
        msg=msg[:startIdx]+coloredText+msg[closeIdx+1:]
      else
        break
      end if
    end while
  end for
  print msg
  if cmd.name=="_printnow" then wait(0.01)
  return false
end function
  //Check for _push command
_ef_push=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing _push command")
    print cyan("    Variable: ")+white(cmd.args[0])
    if len(cmd.args)>1 then print cyan("    Value: ")+white(join(cmd.args[1:]," "))
  end if
  if len(cmd.args)<2 then return Error.set("_push requires 2 arguments: varname value")
  varName=cmd.args[0]
  value=join(cmd.args[1:]," ")
  if not hasIndex(globals.G_bash.VARS,varName) then globals.G_bash.VARS[varName]=[]
  if not (typeof(globals.G_bash.VARS[varName])=="list") then globals.G_bash.VARS[varName]=[globals.G_bash.VARS[varName]]
  push(globals.G_bash.VARS[varName],value)
  return false
end function
  //Check for _pop command
_ef_pop=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing pop command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_pop requires 1 argument: varname")
  varName=cmd.args[0]
  if not hasIndex(globals.G_bash.VARS,varName) then return Error.set("Variable not found: "+varName)
  if typeof(globals.G_bash.VARS[varName])!="list" then return Error.set("Variable is not a list: "+varName)
  if len(globals.G_bash.VARS[varName])==0 then return Error.set("Cannot pop from empty list: "+varName)
  pop(globals.G_bash.VARS[varName])
  return false
end function
  //Check for _pull command
_ef_pull=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing pull command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_pull requires 1 argument: varname")
  varName=cmd.args[0]
  if not hasIndex(globals.G_bash.VARS,varName) then return Error.set("Variable not found: "+varName)
  if typeof(globals.G_bash.VARS[varName])!="list" then return Error.set("Variable is not a list: "+varName)
  if len(globals.G_bash.VARS[varName])==0 then return Error.set("Cannot pull from empty list: "+varName)
  pull(globals.G_bash.VARS[varName])
  return false
end function
  //Check for _len command (get length of array or string)
_ef_len=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing len command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_len requires 1 argument: varname")
  varName=cmd.args[0]
  if not hasIndex(globals.G_bash.VARS,varName) then return Error.set("Variable not found: "+varName)
  varValue=globals.G_bash.VARS[varName]
  lenVal=0
  if typeof(varValue)=="list" or typeof(varValue)=="string" then lenVal=len(varValue)
  //Print to terminal only when not in pipe/capture context
  if not globals.G_pipe.PIPE_MODE then print lenVal
  return lenVal
end function
  //Check for _in command (check if value exists in array)
_ef_in=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing in command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<2 then return Error.set("_in requires 2 arguments: varname value")
  varName=cmd.args[0]
  searchValue=join(cmd.args[1:]," ")
  if not hasIndex(globals.G_bash.VARS,varName) then return Error.set("Variable not found: "+varName)
  if typeof(globals.G_bash.VARS[varName])!="list" then return Error.set("Variable is not a list: "+varName)
  print indexOf(globals.G_bash.VARS[varName],searchValue)!=null
  return false
end function
  //Check for _sleep command
_ef_sleep=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing sleep command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_sleep requires 1 argument: seconds")
  seconds=val(cmd.args[0])
  if seconds<0.01 then seconds=0.01
  if seconds>300 then seconds=300
  wait(seconds)
  return false
end function
  //Check for _exit command
_ef_exit=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing exit command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  exitCode=0
  if len(cmd.args)>=1 then exitCode=to_int(cmd.args[0])
  globals.G_bash.SIGSTOP=true
  if exitCode!=0 then print red("Exit with code "+exitCode)
  return true
end function
  //Throw error for try/catch - raises error and halts execution
_ef_throw=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing throw command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  msg="Script error"
  if len(cmd.args)>=1 then msg=join(cmd.args," ")
  globals.G_bash.LAST_ERROR=msg
  globals.G_bash.SIGSTOP=true
  print white(bold("["+error("!")+"] ")+msg)
  return true
end function
  //Check for _home command - safe version that works in bash scripts
_ef_home=function(cmd,Obj)
  if globals.G_bash.DEBUG then print cyan("  Executing _home - unwinding session stack")
  //Unwind all tracked sessions
  if hasIndex(globals.G_bash,"SESSION_STACK") and globals.G_bash.SESSION_STACK then
    sessionIds=globals.G_bash.SESSION_STACK.indexes
    sessionCount=len(sessionIds)
    if globals.G_bash.DEBUG then print cyan("    Tracked sessions: "+sessionCount)
    //Loop through all sessions and close them
    for sessionId in sessionIds
      sessionObj=globals.G_bash.SESSION_STACK[sessionId]
      if globals.G_bash.DEBUG then
        objType="unknown"
        if hasIndex(sessionObj,"type") then objType=sessionObj.type
        print cyan("      Closing session: "+objType+" ("+sessionId+")")
      end if
      //Call exit command on the session object to close it
      if hasIndex(sessionObj,"commands") and hasIndex(sessionObj.commands,"exit") then sessionObj.commands["exit"]([])
    end for
    //Clear the session stack
    globals.G_bash.SESSION_STACK={}
  end if
  //Clean up IPC safe list entry
  if hasIndex(globals.G_IPCSafe,Obj.id) then remove(globals.G_IPCSafe,Obj.id)
  //Clear the command queue to prevent nested continueMacro calls from processing stale commands
  if globals.G_bash.RUN then globals.G_bash.RUN=[]
  //Signal proxy/pivot to consume the back flag and stay running
  if globals.G_hasPivoted then globals.G_attributes.home=true
  //Stop bash execution - set both SIGSTOP and SIGBREAK to halt all processing
  globals.G_bash.SIGSTOP=true
  globals.G_bash.SIGBREAK=true
  return true
end function
//Check for _fs_mkdir command
_ef_fs_mkdir=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing fs_mkdir command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_fs_mkdir requires 1 argument: dirname")
  if not hasIndex(Obj,"computer") or not Obj.computer then return Error.set("No computer access available")
  absPath=Io._getPath(Obj,cmd.args[0])
  if absPath isa Error then return absPath
  pathParts=absPath.split("/")
  dirName=pathParts[-1]
  parentPath=join(pathParts[:-1],"/")
  if len(parentPath)==0 then parentPath="/"
  result=create_folder(Obj.computer,parentPath,dirName)
  if result!=1 then
    if result isa string then return Info.error(result)
    return Info.error("Failed to create directory: "+cmd.args[0])
  end if
  return false
end function
//Check for _fs_cd command
_ef_fs_cd=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing fs_cd command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  if len(cmd.args)<1 then return Error.set("_fs_cd requires 1 argument: path")
  targetPath=cmd.args[0]
  //Resolve to absolute path using get_abs_path — handles .., ../foo, ~, . and absolute paths
  curPath=""
  if hasIndex(Obj,"dir") and Obj.dir and Obj.dir.current then
    curPath=path(Obj.dir.current)
  else if hasIndex(Obj,"root") and Obj.root then
    curPath=path(Obj.root)
  end if
  absPath=get_abs_path(targetPath,curPath)
  //Detect "already at root" — going up from / stays at /
  if targetPath==".." and absPath==curPath then return Info.error("Already at root directory")
  targetDir=Io.getFileObj(Obj,absPath)
  if not targetDir or targetDir isa Error then return Info.error("Directory not found: "+targetPath)
  if not is_folder(targetDir) then return Info.error("Not a directory: "+targetPath)
  if hasIndex(Obj,"dir") and Obj.dir then Obj.dir.current=targetDir
  return false
end function
  //Check for _fs_pwd command
_ef_fs_pwd=function(cmd,Obj)
  if globals.G_bash.DEBUG then
    print cyan("  Executing fs_pwd command")
    if len(cmd.args)>0 then print cyan("    Args: ")+white(str(cmd.args))
  end if
  pathResult=""
  if hasIndex(Obj,"dir") and Obj.dir and Obj.dir.current then
    pathResult=path(Obj.dir.current)
  else if hasIndex(Obj,"root") and Obj.root then
    pathResult=path(Obj.root)
  else
    pathResult="/"
  end if
  if not globals.G_pipe.PIPE_MODE then print pathResult
  return pathResult
end function
  //Check for _sys_whoami command
_ef_sys_whoami=function(cmd,Obj);if hasIndex(Obj,"user") and Obj.user and hasIndex(Obj.user,"raw") then return Obj.user.raw else return "unknown";end function
  //Check for _sys_whatami command
  if globals.G_bash.DEBUG then
