// =============================================================================
// MAP / JSON BUILTIN HANDLERS
// =============================================================================
_bf_map=function(expr,Obj=null)
  gb=globals.G_bash
  argsStr=Bash.clean(expr)
  m={}
  if not argsStr or len(argsStr)==0 then return m
  args=[]
  currentArg=""
  depth=0
  inStr=false
  strChar=""
  _len=len(argsStr)
  i=0
  while i<_len
    c=argsStr[i]
    if not inStr and (c=="""" or c=="'") then
      inStr=true
      strChar=c
      currentArg=currentArg+c
    else if inStr and c==strChar then
      inStr=false
      currentArg=currentArg+c
    else if not inStr and c=="(" then
      depth+=1
      currentArg=currentArg+c
    else if not inStr and c==")" then
      depth-=1
      currentArg=currentArg+c
    else if not inStr and c=="," and depth==0 then
      push(args,trim(currentArg))
      currentArg=""
    else
      currentArg=currentArg+c
    end if
    i+=1
  end while
  if len(trim(currentArg))>0 then push(args,trim(currentArg))
  _len=len(args)
  if _len%2!=0 then
    if gb.DEBUG then print red("[map] Odd number of arguments - need key,value pairs")
    return m
  end if
  _len-=1
  i=0
  while i<_len
    k=Bash._getVal(args[i],Obj)
    v=Bash._getVal(args[i+1],Obj)
    m[str(k)]=v
    i=i+2
  end while
  if gb.DEBUG then print green("[map] Created map with ")+yellow(str(len(m)))+green(" entries")
  return m
end function
_bf_map_set=function(expr,Obj=null)
  gb=globals.G_bash
  argsStr=Bash.clean(expr)
  args=[]
  currentArg=""
  depth=0
  inStr=false
  strChar=""
  _len=len(argsStr)
  i=0
  while i<_len
    c=argsStr[i]
    if not inStr and (c=="""" or c=="'") then
      inStr=true
      strChar=c
      currentArg=currentArg+c
    else if inStr and c==strChar then
      inStr=false
      currentArg=currentArg+c
    else if not inStr and c=="(" then
      depth+=1
      currentArg=currentArg+c
    else if not inStr and c==")" then
      depth-=1
      currentArg=currentArg+c
    else if not inStr and c=="," and depth==0 then
      push(args,trim(currentArg))
      currentArg=""
    else
      currentArg=currentArg+c
    end if
    i+=1
  end while
  if len(trim(currentArg))>0 then push(args,trim(currentArg))
  if len(args)<3 then
    if gb.DEBUG then print red("[map_set] Need 3 args: map, key, value")
    return null
  end if
  m=Bash._getVal(args[0],Obj)
  if typeof(m)!="map" then
    if gb.DEBUG then print red("[map_set] First arg is not a map: ")+typeof(m)
    return null
  end if
  k=Bash._getVal(args[1],Obj)
  v=Bash._getVal(args[2],Obj)
  m[str(k)]=v
  if gb.DEBUG then print green("[map_set] Set ")+yellow(str(k))+green(" in map")
  return m
end function
_bf_map_get=function(expr,Obj=null)
  gb=globals.G_bash
  argsStr=Bash.clean(expr)
  args=[]
  currentArg=""
  depth=0
  inStr=false
  strChar=""
  _len=len(argsStr)
  i=0
  while i<_len
    c=argsStr[i]
    if not inStr and (c=="""" or c=="'") then
      inStr=true
      strChar=c
      currentArg=currentArg+c
    else if inStr and c==strChar then
      inStr=false
      currentArg=currentArg+c
    else if not inStr and c=="(" then
      depth+=1
      currentArg=currentArg+c
    else if not inStr and c==")" then
      depth-=1
      currentArg=currentArg+c
    else if not inStr and c=="," and depth==0 then
      push(args,trim(currentArg))
      currentArg=""
    else
      currentArg=currentArg+c
    end if
    i+=1
  end while
  if len(trim(currentArg))>0 then push(args,trim(currentArg))
  if len(args)<2 then
    if gb.DEBUG then print red("[map_get] Need 2 args: map, key")
    return null
  end if
  m=Bash._getVal(args[0],Obj)
  if typeof(m)!="map" then
    if gb.DEBUG then print red("[map_get] First arg is not a map: ")+typeof(m)
    return null
  end if
  k=Bash._getVal(args[1],Obj)
  if hasIndex(m,str(k)) then return m[str(k)]
  if gb.DEBUG then print yellow("[map_get] Key not found: ")+str(k)
  return null
end function
_bf_map_del=function(expr,Obj=null)
  gb=globals.G_bash
  argsStr=Bash.clean(expr)
  args=[]
  currentArg=""
  depth=0
  inStr=false
  strChar=""
  _len=len(argsStr)
  i=0
  while i<_len
    c=argsStr[i]
    if not inStr and (c=="""" or c=="'") then
      inStr=true
      strChar=c
      currentArg=currentArg+c
    else if inStr and c==strChar then
      inStr=false
      currentArg=currentArg+c
    else if not inStr and c=="(" then
      depth+=1
      currentArg=currentArg+c
    else if not inStr and c==")" then
      depth-=1
      currentArg=currentArg+c
    else if not inStr and c=="," and depth==0 then
      push(args,trim(currentArg))
      currentArg=""
    else
      currentArg=currentArg+c
    end if
    i+=1
  end while
  if len(trim(currentArg))>0 then push(args,trim(currentArg))
  if len(args)<2 then
    if gb.DEBUG then print red("[map_del] Need 2 args: map, key")
    return null
  end if
  m=Bash._getVal(args[0],Obj)
  if typeof(m)!="map" then
    if gb.DEBUG then print red("[map_del] First arg is not a map: ")+typeof(m)
    return null
  end if
  k=str(Bash._getVal(args[1],Obj))
  if hasIndex(m,k) then remove(m,k)
  if gb.DEBUG then print green("[map_del] Removed ")+yellow(k)+green(" from map")
  return m
end function
_bf_map_keys=function(expr,Obj=null)
  gb=globals.G_bash
  arg=Bash.clean(expr)
  m=Bash._getVal(arg,Obj)
  if typeof(m)!="map" then
    if gb.DEBUG then print red("[map_keys] Arg is not a map: ")+typeof(m)
    return []
  end if
  r=[]
  for k in indexes(m);push(r,k);end for
  return r
end function
_bf_map_values=function(expr,Obj=null)
  gb=globals.G_bash
  arg=Bash.clean(expr)
  m=Bash._getVal(arg,Obj)
  if typeof(m)!="map" then
    if gb.DEBUG then print red("[map_values] Arg is not a map: ")+typeof(m)
    return []
  end if
  r=[]
  for k in m;push(r,@k.value);end for
  return r
end function
_bf_map_has=function(expr,Obj=null)
  gb=globals.G_bash
  argsStr=Bash.clean(expr)
  args=[]
  currentArg=""
  depth=0
  inStr=false
  strChar=""
  _len=len(argsStr)
  i=0
  while i<_len
    c=argsStr[i]
    if not inStr and (c=="""" or c=="'") then
      inStr=true
      strChar=c
      currentArg=currentArg+c
    else if inStr and c==strChar then
      inStr=false
      currentArg=currentArg+c
    else if not inStr and c=="(" then
      depth+=1
      currentArg=currentArg+c
    else if not inStr and c==")" then
      depth-=1
      currentArg=currentArg+c
    else if not inStr and c=="," and depth==0 then
      push(args,trim(currentArg))
      currentArg=""
    else
      currentArg=currentArg+c
    end if
    i+=1
  end while
  if len(trim(currentArg))>0 then push(args,trim(currentArg))
  if len(args)<2 then
    if gb.DEBUG then print red("[map_has] Need 2 args: map, key")
    return 0
  end if
  m=Bash._getVal(args[0],Obj)
  if typeof(m)!="map" then return 0
  k=str(Bash._getVal(args[1],Obj))
  if hasIndex(m,k) then return 1
  return 0
end function
_bf_map_len=function(expr,Obj=null)
  gb=globals.G_bash
  arg=Bash.clean(expr)
  m=Bash._getVal(arg,Obj)
  if typeof(m)!="map" then
    if gb.DEBUG then print red("[map_len] Arg is not a map: ")+typeof(m)
