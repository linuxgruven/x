  if Obj and hasIndex(Obj,"meta") and Obj.meta then
    if returnObject then
      if gb.DEBUG then print green("  Returning meta object as fallback")
      return Obj.meta
    end if
    if gb.DEBUG then print green("  Falling back to Obj.meta.local_ip: ")+yellow(Obj.meta.local_ip)
    return Obj.meta.local_ip
  end if
  if gb.DEBUG then print red("  No computer or meta found, returning empty string or null")
  if returnObject then return null
