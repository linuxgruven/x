  return len(m)
end function
_bf_json=function(expr,Obj=null)
  arg=Bash.clean(expr)
  v=Bash._getVal(arg,Obj)
  return System.toJSON(v,1)
end function
_bf_json_parse=function(expr,Obj=null)
  gb=globals.G_bash
  arg=Bash.clean(expr)
  s=Bash._getVal(arg,Obj)
  if typeof(s)!="string" then
    if gb.DEBUG then print red("[json_parse] Arg is not a string: ")+typeof(s)
    return null
  end if
  return System.parse(s)
end function
_bf_map_save=function(expr,Obj=null)
  argsStr=Bash.clean(expr)
  args=[]
  currentArg=""
  depth=0
  _len=len(argsStr)
  i=0
  while i<_len
    c=argsStr[i]
    if c=="(" then depth+=1
    if c==")" then depth-=1
    if c=="," and depth==0 then
      push(args,trim(currentArg))
      currentArg=""
    else
      currentArg=currentArg+c
    end if
    i+=1
  end while
  if len(trim(currentArg))>0 then push(args,trim(currentArg))
  if len(args)<2 then return 0
  m=Bash._getVal(args[0],Obj)
  if typeof(m)!="map" then return 0
  filePath=str(Bash._getVal(args[1],Obj))
  if len(filePath)==0 then return 0
  jsonStr=System.toJSON(m,1)
  if not jsonStr then return 0
  if not Obj then return 0
  absPath=Io._getPath(Obj,filePath)
  if absPath isa Error then return 0
  fileObj=Io._getFile(Obj,filePath)
  if fileObj isa Error or not fileObj then
    if not hasIndex(Obj,"computer") or not Obj.computer then return 0
    parts=absPath.split("/")
    fileName=parts[-1]
    parentDir=parts[:-1].join("/")
    if not parentDir then parentDir="/"
    touchResult=touch(Obj.computer,parentDir,fileName)
    if touchResult isa string or touchResult!=1 then return 0
    fileObj=Io._getFile(Obj,filePath)
  end if
  if not fileObj or fileObj isa Error then return 0
  writeResult=set_content(fileObj,jsonStr)
  if writeResult!=1 then return 0
  return 1
end function
_bf_map_load=function(expr,Obj=null)
  arg=Bash.clean(expr)
  filePath=str(Bash._getVal(arg,Obj))
  if len(filePath)==0 then return ""
  if not Obj then return ""
  fileObj=Io._getFile(Obj,filePath)
  if fileObj isa Error or not fileObj then return ""
  content=get_content(fileObj)
  if content==null or len(content)==0 then return ""
  return System.parse(content)
end function
_bf__fs_read=function(expr,Obj=null)
  if not expr then return ""
  arg=Bash.clean(expr)
  filePath=Bash._getVal(arg,Obj)
  if typeof(filePath)!="string" or len(filePath)==0 then return ""
  if not Obj then return ""
  fileObj=Io._getFile(Obj,filePath)
  if fileObj isa Error or not fileObj then return ""
  if is_binary(fileObj) or is_folder(fileObj) then return ""
  content=get_content(fileObj)
  if content==null then return ""
  return content
end function
_bf_menu=function(expr,Obj=null)
  rawArgs=Bash.clean(expr)
  parts=[]
  currentArg=""
  parenD=0
  bracketD=0
  _len=len(rawArgs)
  mi=0
  while mi<_len
    ch=rawArgs[mi]
    if ch=="(" then parenD+=1
    if ch==")" then parenD-=1
    if ch=="[" then bracketD+=1
    if ch=="]" then bracketD-=1
    if ch=="," and parenD==0 and bracketD==0 then
      push(parts,currentArg)
      currentArg=""
    else
      currentArg=currentArg+ch
    end if
    mi+=1
  end while
  push(parts,currentArg)
  itemsArg=""
  styleArg="numbers"
  colorArg="cyan"
  caseModeArg="insensitive"
  if len(parts)>0 then itemsArg=trim(parts[0])
  if len(parts)>1 then styleArg=trim(parts[1])
  if len(parts)>2 then colorArg=trim(parts[2])
  if len(parts)>3 then caseModeArg=trim(parts[3])
  if len(styleArg)>1 and (styleArg[0]==char(34) or styleArg[0]==char(39)) then
    if styleArg[-1]==styleArg[0] then styleArg=styleArg[1:-1]
  end if
  if len(colorArg)>1 and (colorArg[0]==char(34) or colorArg[0]==char(39)) then
    if colorArg[-1]==colorArg[0] then colorArg=colorArg[1:-1]
  end if
  if len(caseModeArg)>1 and (caseModeArg[0]==char(34) or caseModeArg[0]==char(39)) then
    if caseModeArg[-1]==caseModeArg[0] then caseModeArg=caseModeArg[1:-1]
  end if
  items=Bash._getVal(itemsArg,Obj)
  if typeof(items)!="list" then return -1
  itemCount=len(items)
  if itemCount==0 then return -1
  if styleArg!="letters" and styleArg!="numbers" then styleArg="numbers"
  if caseModeArg!="insensitive" and caseModeArg!="strict" then caseModeArg="insensitive"
  i=0
  while i<itemCount
    if styleArg=="letters" then label=char(65+i) else label=str(i+1)
    itemStr=label+") "+str(items[i])
    isHexColor=false
    hexCode=colorArg
    if len(colorArg)>0 then
      if colorArg[0]=="#" then
        isHexColor=true
        hexCode=colorArg[1:]
      else if len(colorArg)==6 then
        allHex=true
        _len2=len(colorArg)
        ci=0
        while ci<_len2
          ch=colorArg[ci]
          if not ((ch>="0" and ch<="9") or (ch>="a" and ch<="f") or (ch>="A" and ch<="F")) then
            allHex=false
            break
          end if
          ci+=1
        end while
        if allHex then
          isHexColor=true
          hexCode=colorArg
        end if
      end if
    end if
    if isHexColor then
      print "<color=#"+hexCode+">"+itemStr+"</color>"
    else if colorArg=="green" then
      print green(itemStr)
    else if colorArg=="red" then
      print red(itemStr)
    else if colorArg=="yellow" then
      print yellow(itemStr)
    else if colorArg=="magenta" then
      print magenta(itemStr)
    else if colorArg=="orange" then
      print orange(itemStr)
    else if colorArg=="blue" then
      print blue(itemStr)
    else if colorArg=="lime" then
      print lime(itemStr)
    else if colorArg=="white" then
      print white(itemStr)
    else
      print cyan(itemStr)
    end if
    i+=1
  end while
  selectedIdx=-1
  valid=false
  while not valid
    if styleArg=="letters" then
      choice=trim(user_input(green("Select option: ")))
      if caseModeArg=="insensitive" then choice=upper(choice)
      if len(choice)>0 then
        selectedIdx=indexOf("ABCDEFGHIJKLMNOPQRSTUVWXYZ",choice[0])
        if selectedIdx>=0 and selectedIdx<itemCount then valid=true else selectedIdx=-1
      end if
    else
      choiceStr=user_input(green("Select option (1-"+str(itemCount)+"): "))
      choiceNum=to_int(choiceStr)
      if choiceNum>=1 and choiceNum<=itemCount then
        selectedIdx=choiceNum-1
        valid=true
      end if
    end if
    if not valid then print red("Invalid selection. Please try again.")
  end while
  return selectedIdx
end function
_bf__format_columns=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg,Obj)
  return format_columns(str(val))
end function
Bash._evalFunc=function(expr,Obj=null)
  gb=globals.G_bash
  expr=trim(expr)
  // =============================================================================
  // MAIN DISPATCH — len() handled specially; all others via _builtinMap
  // =============================================================================
  _builtinMap={
    "_in":@_bf__in,
    "file_read":@_bf__fs_read,
    "file_exists":@_bf_file_exists,
    "is_folder":@_bf_is_folder,
    "is_binary":@_bf_is_binary,
    "get_permissions":@_bf_get_permissions,
    "upper":@_bf_upper,
    "lower":@_bf_lower,
    "substr":@_bf_substr,
    "concat":@_bf_concat,
    "contains":@_bf_contains,
    "random":@_bf_random,
    "timestamp":@_bf_timestamp,
    "date":@_bf_date,
    "floor":@_bf_floor,
    "ceil":@_bf_ceil,
    "abs":@_bf_abs,
    "to_string":@_bf_to_string,
    "to_int":@_bf_to_int,
    "to_float":@_bf_to_float,
    "typeof":@_bf_typeof,
    "_fs_glob":@_bf__fs_glob,
    "_isValidIP":@_bf__isValidIP,
    "_isLanIP":@_bf__isLanIP,
    "_File":@_bf__File,
    "_Files":@_bf__Files,
    "_read":@_bf__read,
    "_write":@_bf__write,
    "file_ext":@_bf_file_ext,
    "get_cwd":@_bf_get_cwd,
    "round":@_bf_round,
    "min":@_bf_min,
    "max":@_bf_max,
    "clamp":@_bf_clamp,
    "pow":@_bf_pow,
    "replace":@_bf_replace,
    "split_str":@_bf_split_str,
    "trim_str":@_bf_trim_str,
    "starts_with":@_bf_starts_with,
    "ends_with":@_bf_ends_with,
    "str_count":@_bf_str_count,
    "join":@_bf_join,
    "typeof_val":@_bf_typeof_val,
    "_fs_canwrite":@_bf__fs_canwrite,
    "_fs_canexec":@_bf__fs_canexec,
    "get_user":@_bf_get_user,
    "get_home":@_bf_get_home,
    "get_shell_type":@_bf_get_shell_type,
    "get_computer_lan_ip":@_bf_get_computer_lan_ip,
    "get_computer_public_ip":@_bf_get_computer_public_ip,
    "get_type":@_bf_get_type,
    "get_layer":@_bf_get_layer,
    "to_yesno":@_bf_to_yesno,
    "to_truefalse":@_bf_to_truefalse,
    "get_root":@_bf_get_root,
    "get_lanIP":@_bf_get_lanIP,
    "get_publicIP":@_bf_get_publicIP,
    "map":@_bf_map,
    "map_set":@_bf_map_set,
    "map_get":@_bf_map_get,
    "map_del":@_bf_map_del,
    "map_keys":@_bf_map_keys,
    "map_values":@_bf_map_values,
    "map_has":@_bf_map_has,
    "map_len":@_bf_map_len,
    "json":@_bf_json,
    "json_parse":@_bf_json_parse,
    "map_save":@_bf_map_save,
    "map_load":@_bf_map_load,
    "_fs_read":@_bf__fs_read,
    "menu":@_bf_menu,
    "_format_columns":@_bf__format_columns
  }
  //String functions
  if indexOf(expr,"len(")==0 then
    //Find matching closing paren to handle trailing expressions like len(x) - 1
    lenStart=indexOf(expr,"(")
    lenDepth=0
    lenEnd=null
    _len=len(expr)
    lenI=lenStart
    while lenI<_len
      if expr[lenI]=="(" then lenDepth+=1
      if expr[lenI]==")" then
        lenDepth-=1
        if lenDepth==0 then lenEnd=lenI; break
      end if
      lenI+=1
    end while
    arg=expr[lenStart+1:lenEnd]
    val=Bash._getVal(arg)
    lenResult=0
    if typeof(val)=="number" then lenResult=len(str(val))
    if typeof(val)=="string" or typeof(val)=="list" then lenResult=len(val)
    //If there's remaining expression after len(...), return as string for arithmetic evaluation
    if lenEnd!=null and lenEnd+1<len(expr) then return str(lenResult)+expr[lenEnd+1:]
    return lenResult
  end if
  //O(1) map dispatch for all other builtins
  parenIdx=indexOf(expr,"(")
  if parenIdx==null then return expr
  funcName=expr[:parenIdx]
  if hasIndex(_builtinMap,funcName) then
    _bfn=_builtinMap[funcName]
    return _bfn(expr,Obj)
  end if
  return expr
end function
// Evaluate GreyScript function calls
Bash._evalGreyscriptCall=function(expr,Obj)
  gb=globals.G_bash
  if gb.DEBUG then print yellow("[_evalGreyscriptCall] Called with: "+str(expr))
  if typeof(expr)!="string" then return expr
  expr=trim(expr)
  //Extract function name and arguments
  openParenPos=indexOf(expr,"(")
  if openParenPos==-1 then return expr
  funcName=expr[:openParenPos]
  argsStr=expr[openParenPos+1:]
  if argsStr[-1]!=")" then return expr
  argsStr=argsStr[:-1]
  //Try to call through Obj.commands if available
  if gb.DEBUG then print yellow("[_evalGreyscriptCall] funcName: "+funcName+" argsStr: "+argsStr)
  if not Obj then
    if gb.DEBUG then print red("[_evalGreyscriptCall] No Obj provided for: "+expr)
    return expr
  end if
  if gb.DEBUG then print yellow("[_evalGreyscriptCall] Obj exists")
  if not Obj.hasIndex("commands") then
    if gb.DEBUG then print red("[_evalGreyscriptCall] Obj has no commands for: "+expr)
    return expr
  end if
  if gb.DEBUG then print yellow("[_evalGreyscriptCall] Obj.commands exists, checking for: "+funcName)
  if not Obj.commands.hasIndex(funcName) then
    if gb.DEBUG then print red("[_evalGreyscriptCall] Function not found: "+funcName)
    if gb.DEBUG then print red("[_evalGreyscriptCall] Available: "+Obj.commands.indexes)
    return expr
  end if
  if gb.DEBUG then print green("[_evalGreyscriptCall] Function found! Calling: "+funcName)
  args=[]
  if len(argsStr)>0 then
    //Handle true/false/null literals
    if argsStr=="true" then
      args.push(true)
    else if argsStr=="false" then
      args.push(false)
    else if argsStr=="null" then
      args.push(null)
    else
      //For now, treat as string or number
      if argsStr[0]==char(34) or argsStr[0]=="'" then
        args.push(argsStr[1:-1])
      else
        numVal=argsStr.to_int
        if str(numVal)==argsStr then args.push(numVal) else args.push(argsStr)
      end if
    end if
  end if
  //Call the command function
  cmd=Obj.commands[funcName]
  result=null
  if len(args)==0 then
    result=cmd
  else if len(args)==1 then
    result=cmd(args[0])
  else if len(args)==2 then
    result=cmd(args[0],args[1])
  else if len(args)==3 then
    result=cmd(args[0],args[1],args[2])
  end if
  if gb.DEBUG then print green("[_evalGreyscriptCall] Result: "+str(result)+" (type: "+typeof(result)+")")
  if result==null then
    if gb.DEBUG then print yellow("[_evalGreyscriptCall] Result was null (command probably printed output), returning empty string")
    return ""
  end if
  return result
end function