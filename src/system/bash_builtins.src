    if arg[0]==char(39) and arg[-1]==char(39) then arg=arg[1:-1]
  end if
  returnObject=(arg=="object" or lower(arg)=="object")
  if gb.DEBUG then
    print cyan("[DEBUG] get_computer_lan_ip called")
    print cyan("  arg: ")+white(arg)+" (returnObject: "+str(returnObject)+")"
  end if
  if Obj and hasIndex(Obj,"computer") and Obj.computer then
    if returnObject then
      if gb.DEBUG then print green("  Returning computer object")
      return Obj.computer
    end if
    if gb.DEBUG then print green("  Returning from Obj.computer.local_ip: ")+yellow(Obj.computer.local_ip)
    return Obj.computer.local_ip
