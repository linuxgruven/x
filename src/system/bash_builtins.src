// =============================================================================
// BASH_BUILTINS
// Built-in function evaluation for the Bash scripting engine.
// =============================================================================
//Evaluate built-in function calls in expressions
// =============================================================================
// BUILTIN HANDLERS — one function per builtin, called via _builtinMap
// =============================================================================
_bf_upper=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg)
  return upper(str(val))
end function
_bf_lower=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg)
  return lower(str(val))
end function
_bf_substr=function(expr,Obj=null)
  args=split(Bash.clean(expr),",")
  if len(args)>=2 then
    trimA0=trim(args[0])
    if indexOf(trimA0,"(")!=null or indexOf(trimA0,"__GVPRES")!=null then str_val=Bash._getVal(trimA0,Obj) else str_val=trimA0
    start_idx=Bash._getVal(trim(args[1]),Obj)
    if len(args)>=3 then
      end_idx=Bash._getVal(trim(args[2]),Obj)
      full=str(str_val)
      return full[start_idx:end_idx]
    else
      return str(str_val)[start_idx:]
    end if
  end if
  return ""
end function
_bf_concat=function(expr,Obj=null)
  argsStr=Bash.clean(expr)
  if not argsStr or len(argsStr)==0 then return ""
  args=[]
  currentArg=""
  depth=0
  safetyCounter=0
  maxIterations=200
  _len=len(argsStr)
  i=0
  while i<_len
    safetyCounter+=1
    if safetyCounter>maxIterations then break
    char=argsStr[i]
    if char=="(" then
      depth+=1
      currentArg=currentArg+char
    else if char==")" then
      depth-=1
      currentArg=currentArg+char
    else if char=="," and depth==0 then
      if currentArg!=null then push(args,currentArg)
      currentArg=""
    else
      currentArg=currentArg+char
    end if
    i+=1
  end while
  if currentArg!=null then push(args,currentArg)
  result=""
  for arg in args
    trimmedArg=trim(arg)
    if trimmedArg=="" and len(arg)>0 then
      result=result+arg
    else
      val=Bash._getVal(trimmedArg,Obj)
      if val==null then val=trimmedArg
      result=result+str(val)
    end if
  end for
  return result
end function
_bf_contains=function(expr,Obj=null)
  cRaw=Bash.clean(expr)
  cHaystack=""
  cNeedle=""
  cSplitFound=false
  cPD=0
  cBD=0
  _len=len(cRaw)
  cI=0
  while cI<_len
    cCh=cRaw[cI]
    if cCh=="(" then cPD+=1
    if cCh==")" then cPD-=1
    if cCh=="[" then cBD+=1
    if cCh=="]" then cBD-=1
    if cCh=="," and cPD==0 and cBD==0 and not cSplitFound then
      cHaystack=cRaw[:cI]
      cNeedle=cRaw[cI+1:]
      cSplitFound=true
      break
    end if
    cI+=1
  end while
  if cSplitFound then
    haystack=str(Bash._getVal(trim(cHaystack)))
    while len(cNeedle)>0 and cNeedle[0]==" ";cNeedle=cNeedle[1:];end while
    needle=str(Bash._getVal(cNeedle))
    return indexOf(haystack,needle)!=null
  end if
  return false
end function
_bf__in=function(expr,Obj=null)
  ivRaw=Bash.clean(expr)
  ivListArg=""
  ivNeedle=""
  ivSplitFound=false
  ivPD=0
  ivBD=0
  _len=len(ivRaw)
  ivI=0
  while ivI<_len
    ivCh=ivRaw[ivI]
    if ivCh=="(" then ivPD+=1
    if ivCh==")" then ivPD-=1
    if ivCh=="[" then ivBD+=1
    if ivCh=="]" then ivBD-=1
    if ivCh=="," and ivPD==0 and ivBD==0 and not ivSplitFound then
      ivListArg=ivRaw[:ivI]
      ivNeedle=ivRaw[ivI+1:]
      ivSplitFound=true
      break
    end if
    ivI+=1
  end while
  if ivSplitFound then
    varNameOrPlaceholder=trim(ivListArg)
    while len(ivNeedle)>0 and ivNeedle[0]==" ";ivNeedle=ivNeedle[1:];end while
    needle=str(Bash._getVal(ivNeedle))
    varValue=Bash._getVal(varNameOrPlaceholder)
    if typeof(varValue)=="list" then
      for item in varValue;if str(item)==needle then return 1;end for
      return 0
    end if
  end if
  return 0
end function
_bf_random=function(expr,Obj=null)
  args=split(Bash.clean(expr),",")
  if len(args)==2 then
    min_val=Bash._getVal(trim(args[0]),Obj)
    max_val=Bash._getVal(trim(args[1]),Obj)
    return floor(min_val+rnd*(max_val-min_val+1))
  end if
  return 0
end function
_bf_timestamp=function(expr,Obj=null);return Bash.unixTime;end function
_bf_date=function(expr,Obj=null);return current_date;end function
_bf_floor=function(expr,Obj=null)
  arg=Bash.clean(expr)
  argVal=Bash._getVal(arg)
  if typeof(argVal)=="string" then argVal=val(argVal)
  return floor(argVal)
end function
_bf_ceil=function(expr,Obj=null)
  arg=Bash.clean(expr)
  argVal=Bash._getVal(arg)
  if typeof(argVal)=="string" then argVal=val(argVal)
  return ceil(argVal)
end function
_bf_abs=function(expr,Obj=null)
  arg=Bash.clean(expr)
  argVal=Bash._getVal(arg)
  if typeof(argVal)=="string" then argVal=val(argVal)
  return abs(argVal)
end function
_bf_to_string=function(expr,Obj=null)
  arg=Bash.clean(expr)
  argVal=Bash._getVal(arg)
  return str(argVal)
end function
_bf_to_int=function(expr,Obj=null)
  arg=Bash.clean(expr)
  argVal=Bash._getVal(arg)
  if typeof(argVal)=="number" then return floor(argVal)
  if typeof(argVal)=="string" then return to_int(argVal)
  return 0
end function
_bf_to_float=function(expr,Obj=null)
  arg=Bash.clean(expr)
  argVal=Bash._getVal(arg)
  if typeof(argVal)=="number" then return argVal
  if typeof(argVal)=="string" then return val(argVal)
  return 0.0
end function
_bf_typeof=function(expr,Obj=null)
  arg=Bash.clean(expr)
  argVal=Bash._getVal(arg)
  return typeof(argVal)
end function
_bf__fs_glob=function(expr,Obj=null)
  arg=Bash.clean(expr)
  pattern=str(Bash._getVal(arg,Obj))
  return Glob.expand(Obj,pattern)
end function
_bf__isValidIP=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg,Obj)
  if typeof(val)!="string" then return 0
  if is_valid_ip(val) then return 1
  return 0
end function
_bf__isLanIP=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg,Obj)
  if typeof(val)!="string" then return 0
  if is_lan_ip(val) then return 1
  return 0
end function
_bf__File=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg,Obj)
  if typeof(val)!="string" or len(val)==0 then return null
  fileObj=Io._getFile(Obj,val)
  if fileObj isa Error or typeof(fileObj)!="file" then return null
  return fileObj
end function
_bf__Files=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg,Obj)
  if typeof(val)!="string" or len(val)==0 then return null
  dirObj=Io._getFile(Obj,val)
  if dirObj isa Error or not dirObj then return null
  return get_files(dirObj)+get_folders(dirObj)
end function
_bf__read=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg,Obj)
  if typeof(val)!="string" or len(val)==0 then return ""
  fileObj=Io._getFile(Obj,val)
  if fileObj isa Error or typeof(fileObj)!="file" then return ""
  content=get_content(fileObj)
  if content==null then return ""
  return content
end function
_bf__write=function(expr,Obj=null)
  rawArgs=Bash.clean(expr)
  wPathArg=""
  wContentArg=""
  wSplitFound=false
  wPD=0
  wBD=0
  _len=len(rawArgs)
  wi=0
  while wi<_len
    wCh=rawArgs[wi]
    if wCh=="(" then wPD+=1
    if wCh==")" then wPD-=1
    if wCh=="[" then wBD+=1
    if wCh=="]" then wBD-=1
    if wCh=="," and wPD==0 and wBD==0 and not wSplitFound then
      wPathArg=rawArgs[:wi]
      wContentArg=rawArgs[wi+1:]
      wSplitFound=true
      break
    end if
    wi+=1
  end while
  if not wSplitFound then return 0
  filePath=str(Bash._getVal(trim(wPathArg),Obj))
  content=str(Bash._getVal(trim(wContentArg),Obj))
  if len(filePath)==0 then return 0
  absPath=Io._getPath(Obj,filePath)
  if absPath isa Error then return 0
  fileObj=Io._getFile(Obj,filePath)
  if fileObj isa Error or not fileObj then
    if not hasIndex(Obj,"computer") then return 0
    parts=absPath.split("/")
    fileName=parts[-1]
    parentDir=parts[:-1].join("/")
    if not parentDir then parentDir="/"
    touchResult=touch(Obj.computer,parentDir,fileName)
    if touchResult isa string or touchResult!=1 then return 0
    fileObj=Io._getFile(Obj,filePath)
  end if
  if not fileObj or fileObj isa Error then return 0
  result=set_content(fileObj,content)
  if result==1 then return 1
  return 0
end function
_bf_file_exists=function(expr,Obj=null)
  arg=Bash.clean(expr)
  filePath=str(Bash._getVal(arg,Obj))
  if len(filePath)==0 then return 0
  if len(filePath)>=2 and filePath[0]==char(34) and filePath[-1]==char(34) then filePath=filePath[1:-1]
  if not Obj then return 0
  fileObj=Io._getFile(Obj,filePath)
  if fileObj isa Error or not fileObj then return 0
  return 1
end function
_bf_is_folder=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg,Obj)
  if typeof(val)=="file" then
    if is_folder(val) then return 1 else return 0
  end if
  pathStr=str(val)
  if len(pathStr)>=2 and pathStr[0]==char(34) and pathStr[-1]==char(34) then pathStr=pathStr[1:-1]
  if len(pathStr)==0 or not Obj then return 0
  fileObj=Io._getFile(Obj,pathStr)
  if fileObj isa Error or not fileObj then return 0
  if is_folder(fileObj) then return 1 else return 0
end function
_bf_is_binary=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg,Obj)
  if typeof(val)=="file" then
    if is_binary(val) then return 1 else return 0
  end if
  pathStr=str(val)
  if len(pathStr)>=2 and pathStr[0]==char(34) and pathStr[-1]==char(34) then pathStr=pathStr[1:-1]
  if len(pathStr)==0 or not Obj then return 0
  fileObj=Io._getFile(Obj,pathStr)
  if fileObj isa Error or not fileObj then return 0
  if is_binary(fileObj) then return 1 else return 0
end function
_bf_get_permissions=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg,Obj)
  if typeof(val)=="file" then return str(permissions(val))
  pathStr=str(val)
  if len(pathStr)>=2 and pathStr[0]==char(34) and pathStr[-1]==char(34) then pathStr=pathStr[1:-1]
  if len(pathStr)==0 or not Obj then return ""
  fileObj=Io._getFile(Obj,pathStr)
  if fileObj isa Error or not fileObj then return ""
  return str(permissions(fileObj))
end function
_bf_file_ext=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=str(Bash._getVal(arg,Obj))
  slashIdx=null
  _len=len(val)
  i=_len-1
  while i>=0
    if val[i]=="/" then slashIdx=i; break
    i=i-1
  end while
  name=val
  if slashIdx!=null then name=val[slashIdx+1:]
  dotIdx=null
  _len=len(name)
  i=_len-1
  while i>=0
    if name[i]=="." then dotIdx=i; break
    i=i-1
  end while
  if dotIdx==null or dotIdx==0 then return ""
  return name[dotIdx:]
end function
_bf_get_cwd=function(expr,Obj=null)
  gb=globals.G_bash
  if Obj and hasIndex(Obj,"dir") and hasIndex(Obj.dir,"current") then
    if typeof(Obj.dir.current)=="file" then return path(Obj.dir.current)
  end if
  if hasIndex(gb,"PWD") and gb.PWD then return gb.PWD
  return current_path
end function
_bf_round=function(expr,Obj=null)
  arg=Bash.clean(expr)
  argVal=Bash._getVal(arg)
  return round(argVal)
end function
_bf_min=function(expr,Obj=null)
  args=split(Bash.clean(expr),",")
  if len(args)>=2 then
    val1=Bash._getVal(trim(args[0]),Obj)
    val2=Bash._getVal(trim(args[1]),Obj)
    if val1<val2 then return val1 else return val2
  end if
  return 0
end function
_bf_max=function(expr,Obj=null)
  args=split(Bash.clean(expr),",")
  if len(args)>=2 then
    val1=Bash._getVal(trim(args[0]),Obj)
    val2=Bash._getVal(trim(args[1]),Obj)
    if val1>val2 then return val1 else return val2
  end if
  return 0
end function
_bf_clamp=function(expr,Obj=null)
  args=split(Bash.clean(expr),",")
  if len(args)>=3 then
    v=Bash._getVal(trim(args[0]),Obj)
    mn=Bash._getVal(trim(args[1]),Obj)
    mx=Bash._getVal(trim(args[2]),Obj)
    if typeof(v)=="string" then v=val(v)
    if typeof(mn)=="string" then mn=val(mn)
    if typeof(mx)=="string" then mx=val(mx)
    if v<mn then return mn
    if v>mx then return mx
    return v
  end if
  return 0
end function
_bf_pow=function(expr,Obj=null)
  args=split(Bash.clean(expr),",")
  if len(args)>=2 then
    b=Bash._getVal(trim(args[0]),Obj)
    e=Bash._getVal(trim(args[1]),Obj)
    if typeof(b)=="string" then b=val(b)
    if typeof(e)=="string" then e=val(e)
    if e==0 then return 1
    neg=e<0
    eAbs=floor(abs(e))
    result=1
    i=0
    while i<eAbs
      result=result*b
      i+=1
    end while
    if neg then return 1/result
    return result
  end if
  return 0
end function
_bf_replace=function(expr,Obj=null)
  rawArgs=Bash.clean(expr)
  rParts=[]
  rCurrent=""
  rParenD=0
  rBracketD=0
  _len=len(rawArgs)
  ri=0
  while ri<_len
    rCh=rawArgs[ri]
    if rCh=="(" then rParenD+=1
    if rCh==")" then rParenD-=1
    if rCh=="[" then rBracketD+=1
    if rCh=="]" then rBracketD-=1
    if rCh=="," and rParenD==0 and rBracketD==0 and len(rParts)<2 then
      push(rParts,rCurrent)
      rCurrent=""
    else
      rCurrent=rCurrent+rCh
    end if
    ri+=1
  end while
  push(rParts,rCurrent)
  if len(rParts)>=3 then
    str_val=str(Bash._getVal(trim(rParts[0]),Obj))
    search_str=str(Bash._getVal(trim(rParts[1]),Obj))
    replace_str=str(Bash._getVal(trim(rParts[2]),Obj))
    return str_val.replace(search_str,replace_str)
  end if
  return ""
end function
_bf_split_str=function(expr,Obj=null)
  rawArgs=Bash.clean(expr)
  strArg=""
  delimArg=""
  splitFound=false
  spParenD=0
  spBracketD=0
  _len=len(rawArgs)
  spi=0
  while spi<_len
    spCh=rawArgs[spi]
    if spCh=="(" then spParenD+=1
    if spCh==")" then spParenD-=1
    if spCh=="[" then spBracketD+=1
    if spCh=="]" then spBracketD-=1
    if spCh=="," and spParenD==0 and spBracketD==0 and not splitFound then
      strArg=rawArgs[:spi]
      delimArg=rawArgs[spi+1:]
      splitFound=true
      break
    end if
    spi+=1
  end while
  if not splitFound then strArg=rawArgs
  strArg=trim(strArg)
  while len(delimArg)>0 and delimArg[0]==" ";delimArg=delimArg[1:];end while
  if splitFound then
    str_val=str(Bash._getVal(strArg,Obj))
    delim=delimArg
    return str_val.split(delim)
  end if
  return []
end function
_bf_trim_str=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg,Obj)
  return trim(str(val))
end function
_bf_starts_with=function(expr,Obj=null)
  swRaw=Bash.clean(expr)
  swStr=""
  swPfx=""
  swFound=false
  swPD=0
  swBD=0
  _len=len(swRaw)
  swI=0
  while swI<_len
    swCh=swRaw[swI]
    if swCh=="(" then swPD+=1
    if swCh==")" then swPD-=1
    if swCh=="[" then swBD+=1
    if swCh=="]" then swBD-=1
    if swCh=="," and swPD==0 and swBD==0 and not swFound then
      swStr=swRaw[:swI]
      swPfx=swRaw[swI+1:]
      swFound=true
      break
    end if
    swI+=1
  end while
  if not swFound then return 0
  s=str(Bash._getVal(trim(swStr),Obj))
  p=str(Bash._getVal(trim(swPfx),Obj))
  if len(p)==0 then return 1
  if len(s)<len(p) then return 0
  if s[:len(p)]==p then return 1
  return 0
end function
_bf_ends_with=function(expr,Obj=null)
  ewRaw=Bash.clean(expr)
  ewStr=""
  ewSfx=""
  ewFound=false
  ewPD=0
  ewBD=0
  _len=len(ewRaw)
  ewI=0
  while ewI<_len
    ewCh=ewRaw[ewI]
    if ewCh=="(" then ewPD+=1
    if ewCh==")" then ewPD-=1
    if ewCh=="[" then ewBD+=1
    if ewCh=="]" then ewBD-=1
    if ewCh=="," and ewPD==0 and ewBD==0 and not ewFound then
      ewStr=ewRaw[:ewI]
      ewSfx=ewRaw[ewI+1:]
      ewFound=true
      break
    end if
    ewI+=1
  end while
  if not ewFound then return 0
  s=str(Bash._getVal(trim(ewStr),Obj))
  sfx=str(Bash._getVal(trim(ewSfx),Obj))
  if len(sfx)==0 then return 1
  if len(s)<len(sfx) then return 0
  if s[len(s)-len(sfx):]==sfx then return 1
  return 0
end function
_bf_str_count=function(expr,Obj=null)
  scRaw=Bash.clean(expr)
  scStr=""
  scSub=""
  scFound=false
  scPD=0
  scBD=0
  _len=len(scRaw)
  scI=0
  while scI<_len
    scCh=scRaw[scI]
    if scCh=="(" then scPD+=1
    if scCh==")" then scPD-=1
    if scCh=="[" then scBD+=1
    if scCh=="]" then scBD-=1
    if scCh=="," and scPD==0 and scBD==0 and not scFound then
      scStr=scRaw[:scI]
      scSub=scRaw[scI+1:]
      scFound=true
      break
    end if
    scI+=1
  end while
  if not scFound then return 0
  s=str(Bash._getVal(trim(scStr),Obj))
  sub=str(Bash._getVal(trim(scSub),Obj))
  if len(sub)==0 then return 0
  count=0
  pos=0
  _lenS=len(s)
  _lenSub=len(sub)
  while pos<=_lenS-_lenSub
    if s[pos:pos+_lenSub]==sub then
      count+=1
      pos=pos+_lenSub
    else
      pos+=1
    end if
  end while
  return count
end function
_bf_join=function(expr,Obj=null)
  gb=globals.G_bash
  rawArgs=Bash.clean(expr)
  listArg=""
  delimiterArg=""
  splitFound=false
  parenD=0
  bracketD=0
  _len=len(rawArgs)
  ci=0
  while ci<_len
    ch=rawArgs[ci]
    if ch=="(" then parenD+=1
    if ch==")" then parenD-=1
    if ch=="[" then bracketD+=1
    if ch=="]" then bracketD-=1
    if ch=="," and parenD==0 and bracketD==0 and not splitFound then
      listArg=rawArgs[:ci]
      delimiterArg=rawArgs[ci+1:]
      splitFound=true
      break
    end if
    ci+=1
  end while
  if not splitFound then listArg=rawArgs
  listArg=trim(listArg)
  while len(delimiterArg)>0 and delimiterArg[0]==" ";delimiterArg=delimiterArg[1:];end while
  if gb.DEBUG then
    print cyan("[DEBUG] join called")
    print cyan("  listArg: ")+white(listArg)
    print cyan("  delimiterArg: ")+white(delimiterArg)
  end if
  if splitFound then
    list_val=Bash._getVal(listArg,Obj)
    if indexOf(delimiterArg,"_getvar(")==null and indexOf(delimiterArg,"__GVPRES")==null then delimiter=delimiterArg else delimiter=str(Bash._getVal(delimiterArg,Obj))
    if gb.DEBUG then
      print cyan("  list_val type: ")+yellow(typeof(list_val))
      print cyan("  list_val: ")+yellow(list_val)
      print cyan("  delimiter: ")+yellow(delimiter)
    end if
    if typeof(list_val)=="list" then
      _len=len(list_val)
      if _len==0 then return ""
      if gb.DEBUG then print green("  Processing list with "+_len+" items")
      result=""
      i=0;while i<_len;if i>0 then result=result+delimiter;result=result+str(list_val[i]);i+=1;end while
      if gb.DEBUG then print green("  join result: ")+yellow(result)
      return result
    else
      if gb.DEBUG then print red("  list_val is not a list, returning empty")
    end if
  else
    if gb.DEBUG then print red("  Not enough arguments, returning empty")
  end if
  return ""
end function
_bf_typeof_val=function(expr,Obj=null)
  arg=Bash.clean(expr)
  val=Bash._getVal(arg)
  return typeof(val)
end function
_bf__fs_canwrite=function(expr,Obj=null)
  arg=Bash.clean(expr)
  args=arg.split(",")
  val=Bash._getVal(trim(args[0]),Obj)
  returnFile=false
  if len(args)>1 then
    secondArg=trim(args[1])
    if len(secondArg)>=2 then
      if secondArg[0]==char(34) and secondArg[-1]==char(34) then secondArg=secondArg[1:-1]
      if secondArg[0]==char(39) and secondArg[-1]==char(39) then secondArg=secondArg[1:-1]
    end if
    if secondArg=="file" then returnFile=true
  end if
  fileObj=null
  if typeof(val)=="file" then
    fileObj=val
  else if typeof(val)=="string" and len(val)>0 and Obj then
    fileObj=Io._getFile(Obj,val)
    if fileObj isa Error then fileObj=null
  end if
  if not fileObj then
    if returnFile then return null
    return 0
  end if
  if not has_permission(fileObj,"w") then
    if returnFile then return null
    return 0
  end if
  if returnFile then return fileObj
  return 1
end function
_bf__fs_canexec=function(expr,Obj=null)
  arg=Bash.clean(expr)
  args=arg.split(",")
  val=Bash._getVal(trim(args[0]),Obj)
  returnFile=false
  if len(args)>1 then
    secondArg=trim(args[1])
    if len(secondArg)>=2 then
      if secondArg[0]==char(34) and secondArg[-1]==char(34) then secondArg=secondArg[1:-1]
      if secondArg[0]==char(39) and secondArg[-1]==char(39) then secondArg=secondArg[1:-1]
    end if
    if secondArg=="file" then returnFile=true
  end if
  fileObj=null
  if typeof(val)=="file" then
    fileObj=val
  else if typeof(val)=="string" and len(val)>0 and Obj then
    fileObj=Io._getFile(Obj,val)
    if fileObj isa Error then fileObj=null
  end if
  if not fileObj then
    if returnFile then return null
    return 0
  end if
  if not has_permission(fileObj,"x") then
    if returnFile then return null
    return 0
  end if
  if returnFile then return fileObj
  return 1
end function
_bf_get_user=function(expr,Obj=null)
  gb=globals.G_bash
  arg=Bash.clean(expr)
  if typeof(arg)=="string" then arg=arg.trim
  if typeof(arg)=="string" and len(arg)>=2 then
    if arg[0]==char(34) and arg[-1]==char(34) then arg=arg[1:-1]
    if arg[0]==char(39) and arg[-1]==char(39) then arg=arg[1:-1]
  end if
  returnObject=(arg=="object" or lower(arg)=="object")
  if gb.DEBUG then
    print cyan("[DEBUG] get_user called")
    print cyan("  arg: ")+white(arg)+" (returnObject: "+str(returnObject)+")"
  end if
  if Obj and hasIndex(Obj,"user") and Obj.user then
    if returnObject then
      if gb.DEBUG then print green("  Returning full user object")
      return Obj.user
    end if
    if gb.DEBUG then print green("  Returning user name: ")+yellow(Obj.user.name)
    return Obj.user.name
  end if
  if gb.DEBUG then print red("  No user found, returning empty string or null")
  if returnObject then return null
  return ""
end function
_bf_get_home=function(expr,Obj=null)
  gb=globals.G_bash
  arg=Bash.clean(expr)
  if typeof(arg)=="string" then arg=arg.trim
  if typeof(arg)=="string" and len(arg)>=2 then
    if arg[0]==char(34) and arg[-1]==char(34) then arg=arg[1:-1]
    if arg[0]==char(39) and arg[-1]==char(39) then arg=arg[1:-1]
  end if
  returnFile=(arg=="file" or lower(arg)=="file")
  if gb.DEBUG then
    print cyan("[DEBUG] get_home called")
    print cyan("  arg: ")+white(arg)+" (returnFile: "+str(returnFile)+")"
  end if
  if Obj and hasIndex(Obj,"user") and Obj.user then
    home=Obj.user.home
    if typeof(home)=="file" then
      if returnFile then
        if gb.DEBUG then print green("  Returning home file object")
        return home
      end if
      if gb.DEBUG then print green("  Returning home path from file: ")+yellow(home.path)
      return home.path
    end if
    if gb.DEBUG then print green("  Returning home: ")+yellow(home)
    return home
  end if
  if gb.DEBUG then print red("  No user/home found, returning empty string")
  return ""
end function
