// =============================================================================
// UTILITY_RAT
// Remote Access Tool: file editor on remote server via SSH.
// =============================================================================
// Function: rat
// Purpose: Remote Access Tool file editor on remote server via SSH
// Args:
//   argv - Arguments array [ip, port, password] (prompts for anything missing)
// Returns: null (interactive loop until user exits)
Utility.rat=function(argv)
	if not argv then argv=[]
	i=null
	p=null
	w=null
	if len(argv)>=1 then i=argv[0]
	if len(argv)>=2 then
		p=to_int(argv[1])
		if not p isa number then return Error.set("Malformed port")
	end if
	if len(argv)>=3 then w=argv[2]
	if i==null then
		i=Gui.inputIP({"text":"Rat server ip"})
		if i==null then return Error.set("Missing rat server ip")
	end if
	if p==null then
		p=Gui.inputInt({"text":"Rat server port","default":22})
		if not p isa number then return Error.set("Missing rat server port")
	end if
	if w==null then w=Gui.inputPassNS("Root password")
	if not w then return Error.set("Missing root password")
	s=connect_service(globals.G_main.shell,i,p,"root",w)
	if typeof(s)!="shell" then return Error.set("Unable to connect to rat server")
	Info.info("Server connection verified")
	c=host_computer(s)
	r=File(c,"/root/rat")
	F=true
	writeRat=function
		set_content(r,trim(join(y,char(10))))
	end function
	isEmpty=function
		return not len(y) or (len(y)==1 and y[0]=="")
	end function
	while true
		m={
			"n":"New item...",
			"a":"Append to line...",
			"e":"Edit a line...",
			"r":"Remove a line...",
			"d":"Dump rat data to :"+path(globals.G_main.dir.current),
			"c":"Clear all",
			"f":"Un|Format",
			"x":"--- Done editing rat ---"
		}
		if not r then
			touch(c,"/root","rat")
			r=File(c,"/root/rat")
			if not r then return Error.set("Failed to create /root/rat")
		end if
		content=get_content(r)
		if not content then content=""
		y=split(content,char(10))
		CH=[green("What would you like to do with the rat file?")]
		if not content then
			print red("Add something...")
		else
			if not F then
				disp=uncolorString(content).replace("\\n","\<b></b>n")
				pLines=split(disp,char(10))
			else
				disp=parseSyntax(uncolorString(content),false).replace("\\n","\<b></b>n")
				pLines=split(disp,char(10))
			end if
			_len=len(pLines)
			l=0
			while l<_len
				_num=yellow(str(l+1)+") ")
				if not F then push(CH,_num+green(pLines[l])) else push(CH,_num+pLines[l])
				l+=1
			end while
			print blue("Line Item Count:")+yellow(str(len(y)))
		end if
		UCH=lower(Gui.choiceAlpha(CH,m,"x"))
		if UCH=="x" then break
		if UCH=="n" then
			a=Gui.input({"text":"Add What?"})
			if a==null then continue
			push(y,a)
			writeRat
		else if UCH=="a" then
			if isEmpty then continue
			n=Gui.inputInt({"text":"What line to append?"})-1
			if not n isa number then continue
			if n>=0 and n<len(y) then
				t=y[n]
				d=Gui.input({"text":"What would you like to append?"})
				if d==null then continue
				if d==t then continue
				y[n]=y[n]+" "+trim(d)
				writeRat
			end if
		else if UCH=="e" then
			if isEmpty then continue
			n=Gui.inputInt({"text":"What line to edit?"})-1
			if not n isa number then continue
			if n>=0 and n<len(y) then
				t=y[n]
				print orange(t)
				j=Gui.input({"text":"What changes do you want to make?"})
				if j==null then continue
				if j==t then continue
				y[n]=trim(j)
				writeRat
			end if
		else if UCH=="r" then
			if isEmpty then continue
			n=Gui.inputInt({"text":"What line do you want to remove?"})-1
			if not n isa number then continue
			if n>=0 and n<len(y) then
				remove(y,n)
				writeRat
			end if
		else if UCH=="c" then
			if isEmpty then continue
			set_content(r,"")
		else if UCH=="d" then
			if isEmpty then continue
			dumpPath=path(globals.G_main.dir.current)+"/rat"
			localFile=File(globals.G_main.computer,dumpPath)
			if localFile then
				set_content(localFile,get_content(localFile)+char(10)+join(y,char(10)))
				Info.info("Rat appended to "+dumpPath)
			else
				localFile=Command.touch(globals.G_main,[dumpPath])
				if not localFile isa Error and localFile then
					set_content(localFile,join(y,char(10)))
					Info.info("Rat written out to "+dumpPath)
				end if
			end if
		else if UCH=="f" then
			F=not F
		end if
	end while
end function
