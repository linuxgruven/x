  formatData=function
		y=[]
		push(y,"/"*45)
		push(y,"/"*45)
		push(y,"/"*45)
		push(y,"-"*45)
		push(y,"COMPANY:")
		push(y,"-"*45)
    push(y,"COMPANY PUBLIC IP - : "+PIP)
    if hasIndex(C,"BSSID") then push(y,"BSSID ------------- : "+C.BSSID)
    if hasIndex(C,"ESSID") then push(y,"ESSID ------------- : "+C.ESSID)
    if hasIndex(C,"company") then push(y,"COMPANY NAME ------ : "+C.company)
    if hasIndex(C,"web") then push(y,"COMPANY WEBSITE --- : "+C.web)
    if hasIndex(C,"domain") then push(y,"COMPANY DOMAIN ---- : "+C.domain)
    if hasIndex(C,"admin") then push(y,"ADMIN NAME -------- : "+C.admin)
    if hasIndex(C,"email") then push(y,"ADMIN EMAIL ------- : "+C.email)
    if hasIndex(C,"emailPass") then push(y,"ADMIN EMAIL PASS -- : "+C.emailPass)
    if U then
      push(y,"-"*45)
      push(y,"USER DATASET:")
      for i in U
        push(y,"-"*45)
        push(y,"USER ------------- : "+i.key)
        if hasIndex(i.value,"passwd") then push(y,"PASSWORD --------- : "+i.value.passwd)
        if hasIndex(i.value,"email") then push(y,"EMAIL ------------ : "+i.value.email)
        if hasIndex(i.value,"emailPass") then push(y,"EMAIL PASSWORD --- : "+i.value.emailPass)
        if hasIndex(i.value,"bank") then push(y,"BANK ACCOUNT ----- : "+i.value.bank)
        if hasIndex(i.value,"bankPass") then push(y,"BANK PASSWORD ---- : "+i.value.bankPass)
        if hasIndex(i.value,"ip") then push(y,"LOCAL IP --------- : "+i.value.ip)
        if hasIndex(i.value,"type") then push(y,"OBJECT USED ------ : "+i.value.type)
        if hasIndex(i.value,"bins") then
          push(y,"FILES FOUND ------ :")
          for b in i.value.bins;push(y,"  "+b);end for
        end if
      end for
      push(y,"-"*45)
    end if
		return y
  end function
  saveData=function
    d=formatData
		f=File(globals.G_main.computer,path(globals.G_main.dir.current)+"/reconData.txt")
		if not f then f=Command.touch(globals.G_main,[path(globals.G_main.dir.current)+"/reconData.txt"])
		if f isa Error then return
		_ct=get_content(f);if not _ct then set_content(f,join(d,char(10))) else set_content(f,_ct+char(10)+join(d,char(10)))
		Info.info("Save complete")
  end function
  fillCompany(ex)
  if argv.s then
    trySearch(ex)
  else if argv.r then
    tryReverse(ex)
  else if argv.g then
    if tryBounce(ex) then
      printGrabData
    else
      Info.warning("No bounces found, trying exploits...")
      getExploits(ex)
      printGrabData
    end if
  else
    if tryBounce(ex) then
      if argv.subjects then _fetchSubjects
      if argv.filter and not argv.u then printSearchData else printData
    else
      Info.warning("No bounces found, trying exploits...")
      getExploits(ex)
      if argv.subjects then _fetchSubjects
      if argv.filter and not argv.u then printSearchData else printData
    end if
  end if
end function
Attack.script=function(Obj,argv)
  _p=ArgumentParser.init
  _p.addArgument("f",false,"store")
  _p.addArgument("w",false,"flag")
  _p.addArgument("p",false,"store")
  _p.addArgument("n",false,"store")
  argv=_p.parseArgs("sk",argv)
  if argv isa Error then return
  if argv.w then
    if not argv.n then argv.n="sk"
    if not argv.p then argv.p=path(globals.G_main.dir.bash)
    f=Command.touch(globals.G_main,["-x",argv.p+"/"+argv.n])
    if f isa Error then return
    _sys=System.getSystem
    _sf=File(_sys.computer,path(_sys.dir.srcWeb)+"/store")
    if not _sf then return Error.set("Missing store source")
    r=set_content(f,get_content(_sf))
    if r==1 then return Info.info(argv.n+" written") else return Error.set(x)
  end if
	if Obj.type=="computer" or indexOf(Obj.type,"shell")!=null then
		e=Obj.computer
		y=File(e,"/Public/htdocs/website.html")
		if y then
			if not has_permission(y,"w") then return Error.set("You do not have write permissions to [ website.html ]")
			Info.info("Defacing the web site...")
      if argv.f then
        f=File(globals.G_main.computer,argv.f)
        if not f then return Error.set("File not found: "+argv.f)
        x=set_content(y,get_content(f))
        if x==1 then return Info.info("Defacing complete") else return Error.set(x)
      else
        _sys=System.getSystem
        _sf=File(_sys.computer,path(_sys.dir.srcWeb)+"/website")
        if not _sf then return Error.set("Missing website source")
        x=set_content(y,get_content(_sf))
        if x==1 then return Info.info("Defacing complete") else return Error.set(x)
      end if
		else
			Info.warning("Missing website.html")
		end if
	else
		for f in get_folders(Obj.root)
			if name(f)!="Public" then continue
			for j in get_folders(f)
				if name(j)!="htdocs" then continue
				for h in get_files(j)
					if name(h)!="website.html" then continue
					if not has_permission(h,"w") then return Error.set("You do not have write permissions to [ website.html ]")
					Info.info("Defacing the web site...")
					_sys=System.getSystem
					_sf=File(_sys.computer,path(_sys.dir.srcWeb)+"/website")
					if not _sf then return Error.set("Missing website source")
					x=set_content(h,get_content(_sf))
					if x==1 then return Info.info("Defacing complete") else return Error.set(x)
				end for
			end for
			Info.warning("Missing website.html")
		end for
	end if
end function
Attack.scanCustom=function(argv,returnEx=false,Obj=null)
  routerFlag=false
  pos=[]
  for arg in argv;if arg=="--router" then routerFlag=true else push(pos,arg);end for
  _findMode=len(pos)>=2 and lower(pos[1])=="find"
  if len(pos)<2 or (not _findMode and len(pos)<3) then return Error.set("Missing ip|library|target params")
  // Resolve metaxploit: prefer shell's packMetaxploit, then pivot/proxy metaxploit, then global
  _mx=Library.metaxploit
  if Obj!=null then
    if hasIndex(Obj,"packMetaxploit") and Obj.packMetaxploit then
      _mx=Obj.packMetaxploit
    else if hasIndex(Obj,"metaxploit") and Obj.metaxploit then
      _mx=Obj.metaxploit
    end if
  end if
	y=0
	while y!=16
		y+=1
    i=pos[0]
		if not i then return Error.set("No ip specified")
		if i=="-r" then i=Net.rip
    i=Net.nslookup(i)
		if is_lan_ip(i) then r=get_router else r=get_router(i)
		if not r then
      if pos[0]=="-r" then
				Info.warning("Router not found")
				continue
			else
				return Warning.set("IP down")
			end if
		end if
    L=pos[1]
		if not L then return Error.set("No library specified")
    L=lower(L)
    T=null
    if len(pos)>=3 then T=pos[2]
    if L!="find" then
      if not T then return Error.set("No target object specified")
      T=Exploit.convertToCode(T)
      // Validate object type is one of the expected values
      validTypes=["s","c","f","l","i","d","p","w"]
      if validTypes.indexOf(T)==null then return Error.set("Invalid object type '"+T+"'. Expected: s|c|f|l|i|d|p|w")
    else if T then
      T=Exploit.convertToCode(T)
    end if
		if globals.G_settings.monitorDirtyips then Dirty.add(i)
		z=Exploit.extract(r,i,_mx)
    if z isa Error then return
		if not z then
			Info.error("No attack vectors found")
			continue
		end if
    if L=="find" then
      findArgs=[]
      if T=="s" then push(findArgs,"--shell")
      if T=="c" then push(findArgs,"--computer")
      if T=="f" then push(findArgs,"--file")
      if T=="l" then push(findArgs,"--bounce")
      if routerFlag then push(findArgs,"--router")
      if len(pos)>3 then
        for arg in pos[3:];push(findArgs,arg);end for
      end if
      _prevActive=globals.G_bash.ACTIVE
      globals.G_bash.ACTIVE=true
      if len(findArgs) then
        _r=Exploit.fetchExploit(z,findArgs,returnEx)
        globals.G_bash.ACTIVE=_prevActive
        return _r
      end if
      // No type specified: find best object in priority order shell -> computer -> file
      _r=Exploit.fetchExploit(z,["--shell"],returnEx)
      if not (_r isa Error) then globals.G_bash.ACTIVE=_prevActive;return _r
      _r=Exploit.fetchExploit(z,["--computer"],returnEx)
      if not (_r isa Error) then globals.G_bash.ACTIVE=_prevActive;return _r
      _r=Exploit.fetchExploit(z,["--file"],returnEx)
      globals.G_bash.ACTIVE=_prevActive
      return _r
    end if
		m=null
		for e in z
			if indexOf(lib_name(e.metaLib),L)!=null then
				m=e
				break
			end if
		end for
		if not m then return Error.set("No library was found with the name: "+L)
		x=null
		if not hasIndex(globals.G_exploitCache,lib_name(m.metaLib)+"_"+version(m.metaLib)) then
			Info.warning("Database is out of date, updateing database...")
			Exploit.headless(m.metaLib)
			continue
		end if
		x=Exploit._ex(Exploit.getCacheKey(m.metaLib))
		matches=[]
		for j in x;if indexOf(j.e,T)!=null then push(matches,j);end for
		if not matches then return Error.set("No matching exploit found for target: "+Exploit.getItem[T])
		// Sort: root first, then user, then guest
		_rm=[];_um=[];_gm=[];_om=[]
		for j in matches
			if not hasIndex(j,"u") then
				push(_om,j)
			else if j.u=="r" then
				push(_rm,j)
			else if j.u=="u" then
				push(_um,j)
			else if j.u=="g" then
				push(_gm,j)
			else
				push(_om,j)
			end if
		end for
		matches=_rm+_um+_gm+_om
    if len(pos)>=4 then A=pos[3] else A=null
		ex=null
		e=null
		for j in matches
			if not A then ex=Exploit.overflow(m.metaLib,j.m,j.s,null,"attack_recon") else ex=Exploit.overflow(m.metaLib,j.m,j.s,A,"attack_recon")
			if not ex or ex isa string then continue
			if ex isa number and ex==1 then
				if hasIndex(m,"port_number") then
					if m.port_number==0 or j.e=="d" then return Info.info(Text.buffer.SF)
				else
					return Info.info(Text.buffer.SP)
				end if
			end if
			if ex isa number and ex==0 then
				if hasIndex(m,"port_number") then
					if m.port_number==0 or j.e=="d" then return Warning.set(Text.buffer.FF)
				else
					return Warning.set(Text.buffer.FP)
				end if
			end if
			if ex isa number then continue
			e=j
			break
		end for
		if not e then return Error.set("No matching exploit found: "+Exploit.getItem[T])
		//Continuation commands already stored in globals by agent, will be picked up by session
		if returnEx then return ex else return self.getObject(typeof(ex),ex,m)
	end while
	globals.G_bash.SIGSTOP=true
end function
Attack.lanCustom=function(Obj,argv)
  if not len(argv.rest)>=2 then return Error.set("Missing library|object params")
	b=argv.rest[0]
	if not b then return Error.set("No library specified")
	if b=="router" then b="http"
	t=argv.rest[1]
  t=Exploit.convertToCode(t)
	if not t then return Error.set("No object specified")
	if len(argv.rest)>=3 then extra=argv.rest[2] else extra=null
	genLan=function(r)
		a={}
		for d in sort(devices_lan_ip(r));p=device_ports(r,d);if not p then a[d]=[] else a[d]=p;end for
		return a
	end function
	r=null
	h=null
	if Obj.layer=="shell" then
    h=Obj.packMetaxploit
    r=Obj.packRouter
	else
		h=Library.metaxploit
		// CONTEXT ROUTING: Get router for LAN bounce attack
		// Must use Builder.packRouter when pivoted to avoid getting proxy's router
		if not globals.G_hasPivoted then r=get_router else r=Builder.packRouter(this)
	end if
	if not r then return Error.set("Failed to get router")
	if not h then return Error.set("Failed to get metaxploit")
	a=genLan(r)
	for l in a
		if l.value then
			if argv.r and argv.r!=l.key then continue
			for p in l.value
				if argv.r and argv.r!=p.get_lan_ip then continue
				if indexOf(port_info(r,p),b)!=null then
					if argv.r then
            z=Exploit.extract(r,argv.r,h,true)
            if z isa Error then continue
          else
            z=Exploit.extract(r,l.key,h)
            if z isa Error then continue
          end if
					if not z then
						Info.error("No attack vectors found")
						continue
					end if
					m=null
					for e in z
						if b=="http" and lib_name(e.metaLib)=="kernel_router.so" then
							m=e
							break
						end if
						if indexOf(lib_name(e.metaLib),b)!=null then
							m=e
							break
						end if
					end for
					if not m then
						Info.error("No exploit found for: "+b)
						continue
					end if
					x=null
					if not hasIndex(globals.G_exploitCache,lib_name(m.metaLib)+"_"+version(m.metaLib)) then
						Info.warning("Database is out of date, updateing database...")
						Exploit.headless(m.metaLib)
						continue
					end if
					x=Exploit._ex(Exploit.getCacheKey(m.metaLib))
					e=null
					for j in x
						if indexOf(lower(j.e),t)!=null then
							e=j
							break
						end if
					end for
					if not e then
						Info.error("Object not found: "+t)
						continue
					end if
					if not extra then ex=Exploit.overflow(m.metaLib,e.m,e.s,null,"attack_recon") else ex=Exploit.overflow(m.metaLib,e.m,e.s,extra,"attack_recon")
					if not ex then
						Info.error("Returned null")
						continue
					else if ex isa string then
						Info.error(ex)
						continue
					else if ex isa number and ex==1 then
            if hasIndex(m,"port_number") then
              if m.port_number==0 or e.e=="d" then return Info.info(Text.buffer.SF)
            else
              return Info.info(Text.buffer.SP)
            end if
					else if ex isa number and ex==0 then
            if hasIndex(m,"port_number") then
              if m.port_number==0 or e.e=="d" then return Warning.set(Text.buffer.FF)
            else
              return Warning.set(Text.buffer.FP)
            end if
					end if
					return self.getObject(typeof(ex),ex,m)
				end if
			end for
		end if
	end for
	if globals.G_bash.ACTIVE then globals.G_bash.SIGBREAK=true
end function
Attack.map=function(j,r,argv)
  if not j then return "Not enough attack vectors to use this option at this time"
  _p=ArgumentParser.init
  _p.addArgument("extreme",true,"flag")
  argv=_p.parseArgs("map",argv)
  if argv isa Error then return
  if not argv.extreme then argv.extreme=50 else argv.extreme=255
  if not argv.rest then argv.rest=Net.getRouters(r)
  l=[]
  y=["#### Public IP : "+j[0].public_ip]
  h=false
  mapped={}
  c=0
  z=0
  for m in j
    if h then break
    q=null
    if not hasIndex(globals.G_exploitCache,lib_name(m.metaLib)+"_"+version(m.metaLib)) then
      Info.warning("Database is out of date, updateing database...")
      Exploit.headless(m.metaLib)
    end if
    q=Exploit._ex(Exploit.getCacheKey(m.metaLib))
    if not q isa list then continue
    for e in q
      if h then break
      if e.e!="l" then continue
      for i in argv.rest
        if hasIndex(mapped,i) then continue
        mapped[i]=1
        push(l,yellow("Lan Map for the following subnet [ "+green(i)+" ]"))
        push(y,"Lan Map for the following subnet [ "+i+" ]")
        z+=1
        v=split(i,"\.")
        x=join(v[:-1],".")+"."
        b=0
        a=0
        while a<=argv.extreme
          if not argv.extreme then
            if b>20 then break
          end if
          t=x+a
          if t==i then
            a+=1
            continue
          end if
          ex=Exploit.overflow(m.metaLib,e.m,e.s,t,"attack_recon")
          if ex==null or ex isa number or ex isa string then
            b+=1
            a+=1
            continue
          end if
          //Computer exploits on non-routers ignore the LAN IP and always return
          //the same machine - only count when the obtained host is actually t
          if typeof(ex)=="computer" then
            gotIp=ex.local_ip
            if gotIp!=t then
              b+=1
              a+=1
              continue
            end if
            push(l,green("[------> ")+blue("Device at ")+" "+yellow(gotIp))
            push(y,"[------> Device at "+gotIp)
            c+=1
          end if
          a+=1
        end while
      end for
      h=true
    end for
  end for
  if c==0 then return Warning.set("No devices found on this network, Possible Cause: No Lan Bounce from the router")
  print join(l,char(10))
  print yellow("There are "+white(str(c))+" device(s) and "+white(str(z))+" router(s) on this network")
  if Gui.yesNoNon("Save this data for future use?",false) then
    saveName="map.txt"
    if j[0] and hasIndex(j[0],"public_ip") and j[0].public_ip then saveName=j[0].public_ip+"_map.txt"
    savePath=path(globals.G_main.dir.current)+"/"+saveName
    f=File(globals.G_main.computer,savePath)
    if not f then f=Command.touch(globals.G_main,[savePath])
    if f isa Error then return
    _ct=get_content(f)
    if not _ct then set_content(f,join(y,char(10))) else set_content(f,_ct+char(10)+join(y,char(10)))
  end if
end function
// Extract system logs from remote target
// Args: Obj (context), argv (IP and options: -p port, -w watch)
Attack.grabLog=function(Obj,argv)
  if not argv then return Man.help(["grab"])
  if not Library.haveMetaxploit then return
  // Resolve target IP
  i=Net.lookup(pull(argv))
  if not i then return Error.set("Invalid ip: "+i)
  _p=ArgumentParser.init
  _p.addArgument("p",false,"storeNumber")
  _p.addArgument("w",false,"flag")
  argv=_p.parseArgs("grab",argv)
  if argv isa Error then return
  if not argv.p then argv.p=0
  // Get metaxploit library
  if globals.G_metaxploit then z=globals.G_metaxploit else z=Library.metaxploit
  S=null
  // Get router and extract exploits
  r=get_router(i)
  if not r then return Warning.set("IP down")
  m=Exploit.extract(r,i)
  if m isa Error then return Warning.set("No attack vectors found")
  // Find shell exploit for target port
  for e in m
    if not e.port_number==argv.p then continue
    // Update exploit cache if needed
    if not hasIndex(globals.G_exploitCache,lib_name(e.metaLib)+"_"+version(e.metaLib)) then
      Info.warning("Database is out of date, updateing database...")
			Exploit.headless(e.metaLib)
		end if
    // Try shell exploits
    for y in Exploit._ex(Exploit.getCacheKey(e.metaLib))
			if y.e!="s" then continue
      ex=Exploit.overflow(e.metaLib,y.m,y.s,null,"attack_recon")
      if not ex then continue
      if ex isa number or ex isa string then continue
      // Get or escalate to root shell
      if Utility.getUserEX(ex).user=="root" then
        S=ex
      else
        S=Exploit.tryShellEX(ex,true)
        if not S then
          Error.set("Failed to escalate permissions to root")
          continue
        end if
      end if
      // Check log file permissions
      if not has_permission(File(host_computer(S),"/var/system.log"),"r") then continue
      // Copy log file to local system
      x=scp(S,"var/system.log",path(globals.G_main.user.home)+"/Downloads",globals.G_main.shell)
      if x isa string then return Error.set(x)
      // Optionally log shell access
      if argv.w then Log.shellLog(S)
      // Move log to current directory with IP and port in name
      f=File(globals.G_main.computer,path(globals.G_main.user.home)+"/Downloads/system.log")
      if move(f,path(globals.G_main.dir.current),"system"+i+"_"+argv.p+".log")!=1 then return Error.set("Failed to move "+path(globals.G_main.user.home)+"/Downloads/system.log") else return Info.info("Log file saved to: "+path(globals.G_main.dir.current)+"/system"+i+"_"+argv.p+".log")
    end for
  end for
  // Report failure if no shell found
  if not S then Info.warning("Unable to find a shell to "+i+":"+argv.p) else Info.warning("Unable to retrieve logs from "+i+":"+argv.p)
end function
// Automated bounce attack - connect to router, pivot to LAN computer, get root
// Args: Obj (context), argv (command arguments with -p public IP, -l LAN IP)
// Returns: Root computer object on success, null on failure
Attack.bounce=function(argv,headless=false)
  // Check for vulnerable library configuration
  if not globals.G_settings.vulnerableLib or globals.G_settings.vulnerableLibIndex==-1 then return Error.set("No vulnerable library set for bounce attack")
  // Extract -p and -l values; everything else becomes trailing commands
  publicIP=null
  lanIP=null
  trailing=[]
  i=0
  while i<len(argv)
    a=argv[i]
    if a=="-p" and i+1<len(argv) then
      publicIP=argv[i+1]
      i+=2
    else if a=="-l" and i+1<len(argv) then
      lanIP=argv[i+1]
      i+=2
    else
      push(trailing,a)
      i+=1
    end if
  end while
  if not publicIP or not lanIP then return Error.set("Missing required parameters: -p <public IP> -l <LAN IP>")
  // Resolve public IP to router
  publicIP=Net.lookup(publicIP)
  // Use Mission.getRootBounce to handle the attack
  result=Mission.getRootBounce(publicIP,lanIP,{})
  // Error result: ["error", message]
  if result isa list then return Error.set(result[1])
  // If inside a bash script, set FLAGS directly
  if globals.G_bash.ACTIVE then
    co=Exploit.getComputer(result,true)
    if co isa Error then
      globals.G_bash.FLAGS["scan_ok"]=false
      globals.G_bash.FLAGS["hold"]=null
      return co
    end if
    globals.G_bash.FLAGS["scan_ok"]=true
    if trailing then
      globals.G_bash.FLAGS["hold"]=null
      cmdGroups=join(trailing," ").split(" then ")
      for cmd in cmdGroups
        parts=split(trim(cmd)," ")
        if not parts then continue
        cmdName=lower(parts[0])
        if hasIndex(co.commands,cmdName) then co.commands[cmdName](parts[1:])
      end for
    else
      globals.G_bash.FLAGS["hold"]=co
    end if
    return co
  end if
  // Interactive (non-script) mode
  if trailing then
    co=Exploit.getComputer(result,true)
    if co isa Error then return co
    cmdGroups=join(trailing," ").split(" then ")
    for cmd in cmdGroups
      parts=split(trim(cmd)," ")
      if not parts then continue
      cmdName=lower(parts[0])
      if hasIndex(co.commands,cmdName) then co.commands[cmdName](parts[1:])
    end for
  else
    Exploit.getComputer(result,headless)
  end if
end function
// Attack.shellBounce - Like scan --c but executes commands on the resulting shell
// Usage: scan --s IP LIBRARY s [-S] [cmd [then cmd ...]]
// -S = su to root after getting shell
// Everything before first "then" token (minus -S) is passed to scanCustom
Attack.shellBounce=function(argv,Obj=null)
  doSu=false
  scanArgs=[]
  trailing=[]
  positionalCount=0
  i=0
  _len=len(argv)
  while i<_len
    a=argv[i]
    if a=="-S" then
      doSu=true
    else if lower(a)=="then" then
      // explicit separator — everything after is trailing
      trailing=argv[i+1:]
      break
    else if positionalCount<3 or a[:2]=="--" then
      // still collecting scan args: first 3 positionals + any --flags (e.g. --router)
      push(scanArgs,a)
      if a[:2]!="--" then positionalCount+=1
    else
      // 3 positionals done and not a -- flag — rest is trailing
      trailing=argv[i:]
      break
    end if
    i+=1
  end while
  // LAN IP auto-detection: if first positional is a LAN IP, scan it directly
  // and select the best shell by privilege (root -> user -> guest)
  if len(scanArgs)>=1 and is_lan_ip(scanArgs[0]) and len(scanArgs)<3 then
    lanIP=scanArgs[0]
    // Any extra positionals captured beyond the IP become trailing commands
    if len(scanArgs)>1 then
      if trailing then trailing=scanArgs[1:]+["then"]+trailing else trailing=scanArgs[1:]
    end if
    if not globals.G_hasPivoted then r=get_router else r=Builder.packRouter(Obj)
    if not r then return Error.set("Failed to get router for LAN scan")
    z=Exploit.extract(r,lanIP)
    if z isa Error then return z
    if not z then return Error.set("No attack vectors found for "+lanIP)
    // Filter to entries targeting lanIP; fall back to full z if none match
    zTarget=[]
    for _ze in z;if _ze.local_ip==lanIP then push(zTarget,_ze);end for
    if not zTarget then zTarget=z
    _prevActive=globals.G_bash.ACTIVE
    globals.G_bash.ACTIVE=true
    ex=Exploit.fetchExploit(zTarget,["--shell"],true)
    globals.G_bash.ACTIVE=_prevActive
  else
    if len(scanArgs)<3 then return Error.set("Usage: scan --s IP LIBRARY TYPE [-S] [cmd then cmd ...]")
    // Get raw object via scanCustom
    ex=Attack.scanCustom(scanArgs,true)
  end if
  if not ex then return
  if ex isa Error then return ex
  if typeof(ex)!="shell" then return Error.set("--s requires a shell-type exploit (got "+typeof(ex)+")")
  // Wrap headless
  shellObj=Exploit.getShell(ex,false,[],true)
  if shellObj isa Error then return shellObj
  // Optionally escalate to root
  if doSu then
    suResult=ShellObject.headlessSu(shellObj)
    if not (suResult isa Error) then shellObj=suResult
  end if
  // Run trailing commands or drop into interactive shell
  // If inside a bash script, set FLAGS directly
  if globals.G_bash.ACTIVE then
    globals.G_bash.FLAGS["scan_ok"]=true
    if trailing then
      globals.G_bash.FLAGS["hold"]=null
      cmdGroups=join(trailing," ").split(" then ")
      for cmd in cmdGroups
        parts=split(trim(cmd)," ")
        if not parts then continue
        cmdName=lower(parts[0])
        if hasIndex(shellObj.commands,cmdName) then shellObj.commands[cmdName](parts[1:])
      end for
    else
      globals.G_bash.FLAGS["hold"]=shellObj
    end if
    return shellObj
  end if
  // Interactive (non-script) mode
  if trailing then
    cmdGroups=join(trailing," ").split(" then ")
    for cmd in cmdGroups
      parts=split(trim(cmd)," ")
      if not parts then continue
      cmdName=lower(parts[0])
      if hasIndex(shellObj.commands,cmdName) then shellObj.commands[cmdName](parts[1:])
    end for
  else
    Exploit.getShell(ex)
  end if
end function