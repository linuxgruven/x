// =============================================================================
// ATTACK_RECON
// Reconnaissance, bouncing, network mapping, and advanced attack operations.
// =============================================================================
// Find LAN bounce exploits for pivoting through router
// Args: o (options object with exploit/router info)
// Returns: bounce exploit data or null
Attack.getBounces=function(o)
	k={}
	d={}
  // Handle object-based bounce discovery
  if hasIndex(o,"Obj") then
    b=false
    // Get LAN IP for bounce target
    i=devices_lan_ip(o.c.router)[0]
    if not i then i=o.c.router.local_ip
		// Search for LAN bounce exploits in libraries
		for l in get_files(File(o.Obj.computer,"/lib"))
			if b then break
			z=load(o.c.metaxploit,path(l))
      if not z then continue
			n=z.lib_name+"_"+z.version
			if not hasIndex(globals.G_exploitCache,n) then Exploit.headless(z)
			x=Exploit._ex(n)
			if not len(x) then continue
			for eType in ["l","c"]
				if b then break
				if eType=="c" and k then continue
				for e in x
					if e.e!=eType then continue
					ex=Exploit.overflow(z,e.m,e.s,i,"attack_recon")
					if typeof(ex)!="computer" then continue
					u=Utility.getUserEX(ex)
					if u.user=="root" then
						k["root"]={"memory":Exploit.getmtree(e.m),"unsec":Exploit.getstree(e.s),"lib":z}
						b=true
						break
					else if u.user=="user" then
						if hasIndex(k,"user") then continue
						k["user"]={"memory":Exploit.getmtree(e.m),"unsec":Exploit.getstree(e.s),"lib":z}
					else if u.user=="guest" then
						if hasIndex(k,"guest") then continue
						k["guest"]={"memory":Exploit.getmtree(e.m),"unsec":Exploit.getstree(e.s),"lib":z}
					end if
				end for
			end for
		end for
  else
    j=Net.getRouters(get_router(o.ex[0].public_ip))
    if not j then return
    d["j"]=j
    x=devices_lan_ip(get_router(o.ex[0].public_ip))[0]
    if not x then x=o.ex[0].local_ip
    for eType in ["l","c"]
      if k then break
      for e in o.q
        if e.e!=eType then continue
        if eType=="l" then
          if typeof(Exploit.overflow(o.m,e.m,e.s,x,"attack_recon"))!="computer" then continue
          uKey=e.u
        else
          ex=Exploit.overflow(o.m,e.m,e.s,x,"attack_recon")
          if typeof(ex)!="computer" then continue
          uKey=Utility.getUserEX(ex).user
        end if
        if uKey=="r" or uKey=="root" then
          k["root"]={"memory":Exploit.getmtree(e.m),"unsec":Exploit.getstree(e.s),"lib":o.m}
          break
        else if uKey=="u" or uKey=="user" then
          if hasIndex(k,"user") then continue
          k["user"]={"memory":Exploit.getmtree(e.m),"unsec":Exploit.getstree(e.s),"lib":o.m}
        else if uKey=="g" or uKey=="guest" then
          if hasIndex(k,"guest") then continue
          k["guest"]={"memory":Exploit.getmtree(e.m),"unsec":Exploit.getstree(e.s),"lib":o.m}
        end if
      end for
    end for
  end if
  if not k then return Info.info("Failed to find a lan bounce exploit","i",null)
  for p in ["root","user","guest"]
    if hasIndex(k,p) then
      pn={"root":"Root","user":"User","guest":"Guest"}
      Info.info("Using "+pn[p])
      d["memory"]=k[p]["memory"]
      d["unsec"]=k[p]["unsec"]
      d["lib"]=k[p]["lib"]
      d["user"]=p
      break
    end if
  end for
	return d
end function
// Deep reconnaissance with OSINT data gathering
// Args: rt (router), ex (exploits), argv (options including -a for email attack)
// Returns: comprehensive recon data
Attack.recon=function(rt,ex,argv)
  if not ex then return Warning.set("Not enough attack vectors to use this option at this time")
  _PIPE=hasIndex(globals.G_pipe,"PIPE_MODE") and globals.G_pipe.PIPE_MODE
  // Initialize recon data structures
  C={}
  U={}
  E={}
  SUBJ={}
  G=[]
  S={}
  F=[]
  PIP=public_ip(rt)
  // Gather company/target information from whois
  fillCompany=function(e)
    C["ip"]=PIP
    C["BSSID"]=bssid_name(rt)
    C["ESSID"]=essid_name(rt)
    // Parse whois data
    a=split(whois(PIP).replace("Domain name: ","").replace("Administrative contact: ","").replace("Email address: ","").replace("Phone: ",""),char(10))
    C["web"]=a[0]
		C["domain"]=a[0].replace("www.","")
    C["admin"]=a[1]
		C["email"]=a[2]
		C["company"]=split(C["web"],"\.")[1]
    // Optionally attack admin email
    if argv.a then
      Info.info("Attacking the admin email account...")
      y=Crack.dictEmail({"start":0,"stop":null,"rest":[a[2]]},true)
      if not y isa Warning then
        C["emailPass"]=y
      else
        Info.warning("Email attack failed, disabling email attack")
        argv.a=false
      end if
		end if
  end function
  getExploits=function(q,r=false)
    trySort=function(x,m,i)
      for uFilter in ["r","u",null]
        for e in x
          if not (e.e=="s" or e.e=="c" or e.e=="f") then continue
          if uFilter and e.u!=uFilter then continue
          _=Exploit.overflow(m,e.m,e.s,null,"attack_recon")
          if not _ then continue
          if _ isa number or _ isa string then continue
          o=typeof(_)
          if indexOf(o,"shell")==null and o!="computer" and o!="file" then continue
          Info.info("Found a "+Exploit.getItem[e.u]+" "+o+" exploit")
          return {"type":o,"user":Exploit.getItem[e.u],"ip":i,"object":_}
        end for
      end for
    end function
    for m in q
      if __m_idx==0 then continue
      if not hasIndex(globals.G_exploitCache,lib_name(m.metaLib)+"_"+version(m.metaLib)) then
        Info.warning("Database is out of date, updateing database...")
				Exploit.headless(m.metaLib)
			end if
      if argv.i and not m.local_ip==argv.i then continue
      w=Exploit._ex(Exploit.getCacheKey(m.metaLib))
      if r then return trySort(w,m.metaLib,m.local_ip) else populateUser(trySort(w,m.metaLib,m.local_ip))
    end for
  end function
  tryBounce=function(e)
    m=e[0].metaLib
    if not hasIndex(globals.G_exploitCache,lib_name(m)+"_"+version(m)) then
      Info.warning("Database is out of date, updateing database...")
      Exploit.headless(m)
    end if
    key=Exploit.getCacheKey(m)
    q=Exploit._ex(key)
    if not q then
      Exploit.headless(m)
      q=Exploit._ex(key)
    end if
    d=Attack.getBounces({"m":m,"q":q,"ex":e})
    if not d then return
    seen={}
		for i in d.j
			v=split(i,"\.")
			x=join(v[:-1],".")+"."
			r=0
      if argv.extreme then
        a=0;while a<=255
          t=x+a
          if argv.i and t!=argv.i then
            a+=1
            continue
          end if
          _=overflow(d.lib,d.memory,d.unsec,t)
          if _==null then
            r+=1
            a+=1;continue
          end if
          if _==null or _ isa number or _ isa string then
            a+=1
            continue
          end if
          if _ then
            lip=_.local_ip
            if hasIndex(seen,lip) then
              a+=1
              continue
            end if
            seen[lip]=1
            if (argv.s or argv.r or argv.filter) and not argv.u then getEmail({"type":"Lan Bounce","user":d.user,"ip":lip,"object":_}) else populateUser({"type":"Lan Bounce","user":d.user,"ip":lip,"object":_})
          end if
        a+=1;end while
      else
        a=0;while a<=50
          t=x+a
          if argv.i and t!=argv.i then
            a+=1
            continue
          end if
          _=overflow(d.lib,d.memory,d.unsec,t)
          if _==null then
            if r>=10 then break
            r+=1
          end if
          if _==null or _ isa number or _ isa string then
            a+=1
            continue
          end if
          if _ then
            lip=_.local_ip
            if hasIndex(seen,lip) then
              a+=1
              continue
            end if
            seen[lip]=1
            if (argv.s or argv.r or argv.filter) and not argv.u then getEmail({"type":"Lan Bounce","user":d.user,"ip":lip,"object":_}) else populateUser({"type":"Lan Bounce","user":d.user,"ip":lip,"object":_})
          end if
        a+=1;end while
      end if
		end for
    return len(U)
  end function
  getFile=function(e,o,f)
    if o=="computer" then return File(e,f)
    if o=="Lan Bounce" then return File(e,f)
    if indexOf(o,"shell")!=null then return File(host_computer(e),f)
  end function
  getFileData=function(z)
    if argv.s then
      f=Io.getAll(FileHelper.toRootEx(z.object))
      if f isa Error then return
      for w in f
        if name(w)!=argv.f or indexOf(name(w),argv.f)==null then
          continue
        else
          Info.info("Found: "+name(w)+" on "+z.object.local_ip)
          return getFileEmail(z)
        end if
      end for
      return
    end if
    for d in get_folders(FileHelper.toRootEx(z.object))
      if name(d)!="etc" then continue
      for h in get_files(d)
        if name(h)!="passwd" then continue
        if has_permission(h,"r") then
          for q in split(get_content(h),char(10))
            if not q then continue
            q=split(trim(q),":")
            if not len(q)==2 then continue
            t=q[0]
            if not hasIndex(U,t) then
              U[t]={
                "type":z.type,
                "ip":z.ip,
                "passwd":Crack.hash(q[1])
              }
            else if not hasIndex(U[t],"passwd") then
              U[t]+={
                "passwd":Crack.hash(q[1])
              }
            end if
          end for
        end if
      end for
    end for
    for d in get_folders(FileHelper.toRootEx(z.object))
      if name(d)!="home" then continue
      for h in get_folders(d)
        if name(h)=="guest" then continue
        if not hasIndex(U,name(h)) then U[name(h)]={
          "type":z.type,
          "ip":z.ip
        }
        if hasIndex(U[name(h)],"bank") and hasIndex(U[name(h)],"email") then
          if not z.user=="root" then continue
        end if
        uname=name(h)
        for c in get_folders(h)
          if name(c)!="Config" then continue
          for f in get_files(c)
            fname=name(f)
            if fname!="Mail.txt" and fname!="Bank.txt" then continue
            if not has_permission(f,"r") then
              if fname=="Mail.txt" then
                U[uname]+={
                  "email":"Permission Denied"
                }
                U[uname]+={
                  "emailPass":"Permission Denied"
                }
              else
                U[uname]+={
                  "bank":"Permission Denied"
                }
                U[uname]+={
                  "bankPass":"Permission Denied"
                }
              end if
            else
              content=get_content(f)
              if not content then content=""
              s=split(content,":")
              if not len(s)==2 then
                if fname=="Mail.txt" then
                  U[uname]+={
                    "email":"Bad MD5"
                  }
                  U[uname]+={
                    "emailPass":"Bad MD5"
                  }
                else
                  U[uname]+={
                    "bank":"Bad MD5"
                  }
                  U[uname]+={
                    "bankPass":"Bad MD5"
                  }
                end if
              else
                t=Crack.hash(s[1])
                if fname=="Mail.txt" then
                  U[uname]+={
                    "email":s[0]
                  }
                  if t then U[uname]+={
                    "emailPass":t
                  } else U[uname]+={
                    "emailPass":"Bad MD5"
                  }
                else
                  U[uname]+={
                    "bank":s[0]
                  }
                  if t then U[uname]+={
                    "bankPass":t
                  } else U[uname]+={
                    "bankPass":"Bad MD5"
                  }
                end if
              end if
            end if
          end for
        end for
      end for
    end for
  end function
  getFileEmail=function(z)
    e=FileHelper.toRootEx(z.object)
    home=null
    for d in get_folders(e)
      if name(d)=="home" then
        home=d
        break
      end if
    end for
    if not home then return
    for h in get_folders(home)
      uname=name(h)
      if uname=="guest" then continue
      if not hasIndex(U,uname) then U[uname]={
        "type":z.type,
        "ip":z.ip
      }
      if not hasIndex(E,uname) then E[uname]={"type":z.type,"ip":z.ip}
      if hasIndex(E[uname],"email") then continue
      //One Config listing for Mail.txt
      mailF=null
      for c in get_folders(h)
        if name(c)!="Config" then continue
        for f in get_files(c)
          if name(f)=="Mail.txt" then
            mailF=f
            break
          end if
        end for
        break
      end for
      if not mailF then continue
      if not has_permission(mailF,"r") then
        E[uname]+={
          "email":"Permission Denied"
        }
        E[uname]+={
          "emailPass":"Permission Denied"
        }
        continue
      end if
      content=get_content(mailF)
      if not content then content=""
      s=split(content,":")
      if not len(s)==2 then
        E[uname]+={
          "email":"Bad MD5"
        }
        E[uname]+={
          "emailPass":"Bad MD5"
        }
        continue
      end if
      t=Crack.hash(s[1])
      E[uname]+={
        "email":s[0]
      }
      if t then E[uname]+={
        "emailPass":t
      } else E[uname]+={
        "emailPass":"Bad MD5"
      }
    end for
  end function
  getFileSearch=function(z)
    if argv.r then return getFileEmail(z)
    e=Io.getAll(FileHelper.toRootEx(z.object))
    for f in e
      if name(f)==argv.f then
        Info.info("Found: "+name(f)+" on "+z.ip)
        return getFileEmail(z)
      end if
    end for
    if e==null then return
  end function
  getData=function(z)
    if argv.r then
      if z.type=="file" then return getFileEmail(z)
      return getEmail(z)
    end if
    if argv.s then
      f=Io.getAll(File(z.object,argv.p))
      if f isa Error then return
      for w in f
        if name(w)!=argv.f or indexOf(name(w),argv.f)==null then
          continue
        else
          Info.info("Found: "+name(w)+" on "+z.object.local_ip)
          return getEmail(z)
        end if
      end for
      return Info.info("File not found: "+argv.f)
    end if
		x=getFile(z.object,z.type,"/etc/passwd")
		if x then
      if has_permission(x,"r") then
        for q in split(get_content(x),char(10))
          if not q then continue
          q=split(trim(q),":")
          if len(q)==2 then
            t=q[0]
            if not hasIndex(U,t) then
              U[t]={
                "type":z.type,
                "ip":z.ip,
                "passwd":Crack.hash(q[1])
              }
            else if not hasIndex(U[t],"passwd") then
              U[t]+={
                "passwd":Crack.hash(q[1])
              }
            end if
          else
            Info.warning("Bad /etc/passwd MD5")
          end if
        end for
      else
        Info.warning("Permission Denied for /etc/passwd")
      end if
    else
      Info.warning("No /etc/passwd file found")
    end if
		x=get_folders(getFile(z.object,z.type,"/home"))
		if not x then return
		if not len(x) then return
		for h in x
      uname=name(h)
      if uname=="guest" then continue
      if not hasIndex(U,uname) then U[uname]={
        "type":z.type,
        "ip":z.ip
      }
      if hasIndex(U[uname],"bank") and hasIndex(U[uname],"email") then
        if not z.user=="root" then continue
      end if
      //One Config listing for Mail.txt + Bank.txt (same idea as dig)
      mailF=null
      bankF=null
      configDir=getFile(z.object,z.type,"/home/"+uname+"/Config")
      if configDir then
        for cf in get_files(configDir)
          cn=name(cf)
          if cn=="Mail.txt" then
            mailF=cf
          else if cn=="Bank.txt" then
            bankF=cf
          end if
        end for
      end if
      if mailF then
        if not has_permission(mailF,"r") then
          U[uname]+={
            "email":"Permission Denied"
          }
          U[uname]+={
            "emailPass":"Permission Denied"
          }
        else
          content=get_content(mailF)
          if not content then content=""
          s=split(content,":")
          if len(s)==2 then
            U[uname]+={
              "email":s[0]
            }
            t=Crack.hash(s[1])
            if t then U[uname]+={
              "emailPass":t
            } else U[uname]+={
              "emailPass":"Bad MD5"
            }
          end if
        end if
      else
        U[uname]+={
          "email":"Missing"
        }
        U[uname]+={
          "emailPass":"Missing"
        }
      end if
      if bankF then
        if not has_permission(bankF,"r") then
            U[uname]+={
              "bank":"Permission Denied"
            }
            U[uname]+={
              "bankPass":"Permission Denied"
            }
        else
          content=get_content(bankF)
          if not content then content=""
          s=split(content,":")
          if len(s)==2 then
            U[uname]+={
              "bank":s[0]
            }
            t=Crack.hash(s[1])
            if t then U[uname]+={
              "bankPass":t
            } else U[uname]+={
              "bankPass":"Bad MD5"
            }
          end if
        end if
      else
        U[uname]+={
          "bank":"Missing"
        }
        U[uname]+={
          "bankPass":"Missing"
        }
      end if
      bins=[]
      binContents={}
      for hf in get_files(h)
        n=name(hf)
        if is_binary(hf) then
          push(bins,n)
        else if n!="Bank.txt" and n!="Mail.txt" then
          push(bins,n)
          if argv.view then
            c=get_content(hf)
            if c then binContents[n]=c
          end if
        end if
      end for
      if bins then U[uname]+={"bins":bins}
      if len(binContents) then U[uname]+={"binContents":binContents}
		end for
    if argv.g then _extractGrab(z)
  end function
  getEmail=function(z)
		x=get_folders(getFile(z.object,z.type,"/home"))
		if not x then return
		for h in x
      if name(h)=="guest" then continue
      if not hasIndex(E,name(h)) then E[name(h)]={"type":z.type}
      if hasIndex(E[name(h)],"email") then continue
			f=getFile(z.object,z.type,"/home/"+name(h)+"/Config/Mail.txt")
      if not f then
        E[name(h)]+={
          "user":name(h)
        }
        E[name(h)]+={
          "email":"Missing"
        }
        E[name(h)]+={
          "emailPass":"Missing"
        }
        E[name(h)]+={
          "ip":z.ip
        }
        Info.warning("No Mail.txt found for "+name(h))
        continue
      end if
			if not has_permission(f,"r") then
        E[name(h)]+={
          "user":name(h)
        }
        E[name(h)]+={
          "email":"Permission Denied"
        }
        E[name(h)]+={
          "emailPass":"Permission Denied"
        }
        E[name(h)]+={
          "ip":z.ip
        }
      else
        content=get_content(f)
        if not content then content=""
        s=split(content,":")
        if not len(s)==2 then
          E[name(h)]+={
            "user":name(h)
          }
          E[name(h)]+={
            "email":"Bad MD5"
          }
          E[name(h)]+={
            "emailPass":"Bad MD5"
          }
          E[name(h)]+={
            "ip":z.ip
          }
          Info.warning("Bad Mail.txt MD5 for "+name(h))
        else
          E[name(h)]+={
            "user":name(h)
          }
          E[name(h)]+={
            "email":s[0]
          }
          E[name(h)]+={
            "ip":z.ip
          }
          t=Crack.hash(s[1])
          if t then E[name(h)]+={
            "emailPass":t
          } else E[name(h)]+={
            "emailPass":"Bad MD5"
          }
        end if
      end if
      bins=[]
      binContents={}
      for hf in get_files(h)
        n=name(hf)
        if is_binary(hf) then
          push(bins,n)
        else if n!="Bank.txt" and n!="Mail.txt" then
          push(bins,n)
          if argv.view then
            c=get_content(hf)
            if c then binContents[n]=c
          end if
        end if
      end for
      if bins then E[name(h)]+={"bins":bins}
      if len(binContents) then E[name(h)]+={"binContents":binContents}
    end for
  end function
  _fetchSubjects=function
    Info.info("Reading emails...")
    // XFIX1.0: MetaMail 2s cooldown; packMailLogin not needed (use mail_login).
    // XFIX1.0: _firstLogin=true
    _src=E
    if not _src then _src=U
    for i in _src
      _addr=i.value["email"]
      _pass=i.value["emailPass"]
      if not _addr or _addr=="MISSING" or _addr=="Missing" or _addr=="Permission Denied" or _addr=="Bad MD5" then continue
      if not _pass or _pass=="MISSING" or _pass=="Missing" or _pass=="Permission Denied" or _pass=="Bad MD5" then continue
      // XFIX1.0: if not _firstLogin then System.tryWait(2)
      // XFIX1.0: _firstLogin=false
      // XFIX1.0: mm=mail_login(_addr,_pass)
      mm=Builder.packMailLogin(Obj,_addr,_pass)
      if not mm or mm isa Error then continue
      // XFIX1.0: System.tryWait(2)
      mails=fetch(mm)
      if not mails isa list then continue
      _subjects=[]
      for mail in mails
        segs=split(mail,char(10))
        if len(segs)>=5 then push(_subjects,segs[4][9:])
      end for
      if len(_subjects)>0 then SUBJ[i.key]=_subjects
    end for
  end function
  _extractGrab=function(z)
    _userHomes={}
    _userFiles={}
    _sysFiles=[]
    _homeRoot=getFile(z.object,z.type,"/home")
    if not _homeRoot then return
    for h in get_folders(_homeRoot)
      uname=name(h)
      if uname=="guest" then continue
      _userHomes[path(h)]=uname
    end for
    allFiles=Io.getAll(getFile(z.object,z.type,"/"))
    if allFiles isa Error then return
    for w in allFiles
      if is_folder(w) then continue
      _wpath=path(w)
      _owner=null
      for hPath in _userHomes.indexes
        if indexOf(_wpath,hPath)==0 then
          _owner=_userHomes[hPath]
          break
        end if
      end for
      ct=get_content(w)
      if not ct or matches(ct,"Binary file\.") then
        if _owner then
          if not hasIndex(_userFiles,_owner) then _userFiles[_owner]=[]
          push(_userFiles[_owner],_wpath)
        else
          push(_sysFiles,_wpath)
        end if
        continue
      end if
      if matches(ct,"Permission denied\.") then ct="Permission denied."
      if _owner then
        if not hasIndex(_userFiles,_owner) then _userFiles[_owner]=[]
        push(_userFiles[_owner],_wpath)
        push(outer.G,{"name":name(w),"ip":z.ip,"path":_wpath,"content":ct,"user":_owner})
      else
        push(_sysFiles,_wpath)
        outer.S[z.ip+":"+_wpath]={"name":name(w),"ip":z.ip,"path":_wpath,"content":ct}
      end if
    end for
    for uname in _userFiles.indexes
      _flist=_userFiles[uname]
      if len(_flist)>0 then push(outer.F,{"ip":z.ip,"user":uname,"files":_flist})
    end for
    if len(_sysFiles)>0 then push(outer.F,{"ip":z.ip,"user":"[system]","files":_sysFiles})
  end function
  populateUser=function(z)
    if not z then return
    if z.type=="file" then return getFileData(z)
    if z.type=="computer" or z.type=="shell" or z.type=="Lan Bounce" then return getData(z)
  end function
  trySearch=function(e)
		tryBounce(e)
    if E then
      if argv.subjects then _fetchSubjects
      printSearchData
      return
    end if
    z=getExploits(e,true)
    if not z then return Info.warning("No exploits found")
    if z.type=="file" then getFileSearch(z) else getData(z)
    if E then
      if argv.subjects then _fetchSubjects
      printSearchData
    end if
  end function
  tryReverse=function(e)
		tryBounce(e)
    if E then
      if argv.subjects then _fetchSubjects
      printSearchData
      return
    end if
    z=getExploits(e,true)
    if not z then return Info.warning("No exploits found")
    if z.type=="file" then getFileSearch(z) else getData(z)
    if E then
      if argv.subjects then _fetchSubjects
      printSearchData
    end if
  end function
  formatSearchData=function
    y=[]
    push(y,"-"*45)
    push(y,"COMPANY:")
    push(y,"-"*45)
    push(y,"COMPANY PUBLIC IP - : "+PIP)
    if hasIndex(C,"BSSID") then push(y,"BSSID ------------- : "+C.BSSID)
    if hasIndex(C,"ESSID") then push(y,"ESSID ------------- : "+C.ESSID)
    if hasIndex(C,"company") then push(y,"COMPANY NAME ------ : "+C.company)
    if hasIndex(C,"web") then push(y,"COMPANY WEBSITE --- : "+C.web)
    if hasIndex(C,"domain") then push(y,"COMPANY DOMAIN ---- : "+C.domain)
    if hasIndex(C,"admin") then push(y,"ADMIN NAME -------- : "+C.admin)
    if hasIndex(C,"email") then push(y,"ADMIN EMAIL ------- : "+C.email)
    if hasIndex(C,"emailPass") then push(y,"ADMIN EMAIL PASS -- : "+C.emailPass)
    if E then
      push(y,"-"*45)
      push(y,"EMAIL DATASET:")
      for i in E
        push(y,"-"*45)
        push(y,"USER ------------- : "+i.key)
        if hasIndex(i.value,"email") then push(y,"EMAIL ------------ : "+i.value.email)
        if hasIndex(i.value,"emailPass") then push(y,"EMAIL PASSWORD --- : "+i.value.emailPass)
        if hasIndex(i.value,"ip") then push(y,"LOCAL IP --------- : "+i.value.ip)
        if hasIndex(i.value,"bins") then
          push(y,"FILES FOUND ------ :")
          for b in i.value.bins;push(y,"  "+b);end for
        end if
      end for
      push(y,"-"*45)
    end if
    return y
  end function
  printGrabData=function
    _f=null
    if argv.grep and len(argv.grep)>0 then _f=argv.grep[0]
    while true
      if not U then
        print red("No data found.")
      else
        print white("-"*45)
        print orange("GRAB RESULTS:")
        _anyPrinted=false
        for i in U
          uname=i.key
          _cip=i.value["ip"]
          if _f then
            _hit=false
            _chk=uname+" "+str(i.value["passwd"])+" "+str(i.value["email"])+" "+_cip
            if indexOf(_chk,_f)!=null then _hit=true
            if not _hit then
              for gRec in G
                if gRec["ip"]!=_cip then continue
                if gRec["user"]!=uname then continue
                if indexOf(gRec["name"],_f)!=null then _hit=true
                if not _hit then
                  for line in split(gRec["content"],char(10));if indexOf(line,_f)!=null then _hit=true;end for
                end if
              end for
            end if
            if not _hit then continue
          end if
          if _anyPrinted then print white("="*45)
          _anyPrinted=true
          print green("USER NAME -------- : "+uname)
          if hasIndex(i.value,"passwd") then print yellow("USER PASSWD ------ : "+i.value.passwd)
          if hasIndex(i.value,"email") then print yellow("USER EMAIL ------- : "+i.value.email)
          if hasIndex(i.value,"emailPass") then print yellow("USER EMAIL PASSWD  : "+i.value.emailPass)
          if hasIndex(i.value,"bank") then print blue("USER BANK # ------ : "+i.value.bank)
          if hasIndex(i.value,"bankPass") then print blue("USER BANK PASSWD   : "+i.value.bankPass)
          print cyan("LAN IP ----------- : "+_cip)
          for gRec in G
            if gRec["ip"]!=_cip then continue
            if gRec["user"]!=uname then continue
            if _f then
              _fhit=false
              if indexOf(gRec["name"],_f)!=null then _fhit=true
              if not _fhit then
                for line in split(gRec["content"],char(10));if indexOf(line,_f)!=null then _fhit=true;end for
              end if
              if not _fhit then continue
            end if
            print blue("  FILE: "+gRec["path"])
            print white("  CONTENT:")
            if _f then
              for line in split(gRec["content"],char(10));if indexOf(line,_f)!=null then print cyan("    "+line);end for
            else
              for line in split(gRec["content"],char(10));print white("    "+line);end for
            end if
          end for
          print green("-"*45)
        end for
        if S then
          for sRec in S
            if _f then
              _fhit=false
              if indexOf(sRec.value["name"],_f)!=null then _fhit=true
              if not _fhit then
                for line in split(sRec.value["content"],char(10));if indexOf(line,_f)!=null then _fhit=true;end for
              end if
              if not _fhit then continue
            end if
            if _anyPrinted then print white("="*45)
            _anyPrinted=true
            print orange("SYSTEM FILE ("+sRec.value["ip"]+"):")
            print blue("  FILE: "+sRec.value["path"])
            print white("  CONTENT:")
            if _f then
              for line in split(sRec.value["content"],char(10));if indexOf(line,_f)!=null then print cyan("    "+line);end for
            else
              for line in split(sRec.value["content"],char(10));print white("    "+line);end for
            end if
          end for
        end if
      end if
      if not argv.filter then break
      _f=Gui.input({"text":"Enter some filter data (type '!' to stop filtering)"})
      if _f==null then break
    end while
  end function
  printSearchData=function
    if _PIPE then
