      end while
    else
      if not E then return Info.info("No email data found")
      print orange("EMAIL DATASET:")
      if globals.G_Zday["rshell"] then print blue("RSHELL SERVER IP - : "+globals.G_Zday["rshell"])
      for i in E
        print white("-"*45)
        print blue("USER ------------- : ")+yellow(i.key)
        if hasIndex(i.value,"email") then print blue("EMAIL ------------ : ")+yellow(i.value.email)
        if hasIndex(i.value,"emailPass") then print blue("EMAIL PASSWORD --- : ")+yellow(i.value.emailPass)
        if hasIndex(SUBJ,i.key) then
          print blue("EMAIL SUBJECTS --- :")
          for _subj in SUBJ[i.key]
            if indexOf(lower(_subj),"re:")!=null then print yellow("  ~ ")+blue(_subj) else print blue("  "+_subj)
          end for
        end if
        if hasIndex(i.value,"ip") then print blue("LOCAL IP --------- : ")+green(i.value.ip)
        if hasIndex(i.value,"bins") then
          print blue("FILES FOUND ------ :")
          for b in i.value.bins;print blue("  ")+yellow(b);end for
