// =============================================================================
// BUILDER
// Builder library; packages GreyScript code into custom objects for remote deployment.
// =============================================================================
Builder={}
// Check write permissions for build directory
// Falls back to home directory if current directory not writable
// Returns: writable directory path or Error
Builder.checkPerms=function(Obj)
  C=Obj.dir.current
  // Check if current directory is writable
  if not has_permission(C,"w") then
    H=Obj.user.home
    // Can't fall back if already in home directory
    if path(C)==path(H) then return Error.set("No write permission to : "+path(C))
    // Check if home directory is writable
    if not has_permission(H,"w") then return Error.set("No write permission to : "+path(C)+" or "+path(H)) else C=H // Fall back to home directory
  end if
  return C
end function
// Clean up temp build files and optionally an uploaded library from path(C)
Builder._cleanup=function(Obj,C,m=null,n=".x_x")
  f=File(Obj.computer,path(C)+"/"+n+".src")
  if f then Crack.qrm(Obj.computer,path(C),f)
  f=File(Obj.computer,path(C)+"/"+n)
  if f then Crack.qrm(Obj.computer,path(C),f)
  if m then Crack.qrm(Obj.computer,path(C),m)
end function
// Pack libtrafficnet.so into get_custom_object for network operations
// Args: Obj (context)
// Returns: packed library object or Error
Builder.packTraffic=function(Obj)
  co=get_custom_object
  // Check write permissions
  C=self.checkPerms(Obj)
  if C isa Error then return C
  // Clear existing packed object
  if hasIndex(co,"packTraffic") then co.packTraffic=null
  F=true
  // Look for library on target system
  m=Io.findFile(Obj.root,"libtrafficnet.so")
  if m isa Error then
    // Library not found, upload from local system
    m=File(globals.G_main.computer,path(globals.G_main.dir.data)+"/libtrafficnet.so")
    if not m then return Error.set("","",true)
    x=scp(globals.G_main.shell,path(m),path(C),Obj.shell)
    if x isa string then return Error.set(x)
    m=File(Obj.computer,path(C)+"/libtrafficnet.so")
    if not m then return Error.set("Failed to upload libtrafficnet")
  else
    // Library already exists, don't delete it later
    F=false
  end if
	// Create code to pack library into get_custom_object
	c="get_custom_object[""packTraffic""]=include_lib("""+path(m)+""")"
	// Create temporary source file
	_n=Io.tmpName
	f=Command.touch(Obj,["-x",path(C)+"/"+_n+".src"])
	if f isa Error then return Error.set("","",true)
	set_content(f,c)
	// Build and launch to execute packing code
	if build(Obj.shell,path(f),path(C))=="" then launch(Obj.shell,path(C)+"/"+_n)
	// Clean up temporary files
	_m=null
	if F then _m=m
	self._cleanup(Obj,C,_m,_n)
  return co.packTraffic
end function
// Pack libsmartappliance.so into get_custom_object for smart appliance operations
// Args: Obj (context)
// Returns: packed library object or Error
Builder.packAppliance=function(Obj)
