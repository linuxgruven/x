    if x isa string then return Error.set(x)
    m=File(Obj.computer,path(C)+"/libsmartappliance.so")
    if not m then return Error.set("Failed to upload libsmartappliance")
  else
    // Library already exists
    F=false
  end if
	// Create packing code
