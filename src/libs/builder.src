	f=Command.touch(Obj,["-x",path(C)+"/"+_n+".src"])
	if f isa Error then return Error.set("","",true)
	set_content(f,c)
	// Build and launch to execute packing
	if build(Obj.shell,path(f),path(C))=="" then launch(Obj.shell,path(C)+"/"+_n)
	// Clean up temporary files
	_m=null
	if F then _m=m
	self._cleanup(Obj,C,_m,_n)
  return co.packAppliance
end function
// Pack crypto.so into get_custom_object for encryption operations
// Args: Obj (context), L (leave flag - don't delete library if true)
// Returns: packed library object or Error
Builder.packCrypto=function(Obj,L=false)
  co=get_custom_object
  // Check write permissions
  C=self.checkPerms(Obj)
  if C isa Error then return C
  // Clear existing packed object
  if hasIndex(co,"packCrypto") then co.packCrypto=null
  F=true
  // Look for library on target system
  m=Io.findFile(Obj.root,"crypto.so")
  if m isa Error then
    // Upload library from local system
    m=File(globals.G_main.computer,path(globals.G_main.dir.data)+"/crypto.so")
    if not m then return Error.set("","",true)
    x=scp(globals.G_main.shell,path(m),path(C),Obj.shell)
    if x isa string then return Error.set(x)
    m=File(Obj.computer,path(C)+"/crypto.so")
    if not m then return Error.set("Failed to upload crypto")
  else
    // Library already exists
    F=false
  end if
	// Create packing code
	c="get_custom_object[""packCrypto""]=include_lib("""+path(m)+""")"
	// Create and build temporary source file
	_n=Io.tmpName
	f=Command.touch(Obj,["-x",path(C)+"/"+_n+".src"])
	if f isa Error then return Error.set("","",true)
	set_content(f,c)
	if build(Obj.shell,path(f),path(C))=="" then launch(Obj.shell,path(C)+"/"+_n)
	// Clean up temporary files
	_m=null
	if not L and F then _m=m
	self._cleanup(Obj,C,_m,_n)
  return co.packCrypto
end function
