// Pack router object into get_custom_object
// Args: Obj (context), i (optional IP address for specific router)
// Returns: packed router object or Error
Builder.packRouter=function(Obj,i=null)
  co=get_custom_object
  // Check write permissions
  C=self.checkPerms(Obj)
  if C isa Error then return C
  // Clear existing packed object
  if hasIndex(co,"packRouter") then co.packRouter=null
	// Create code for router packing (with or without IP)
	if i then c="get_custom_object[""packRouter""]=get_router("""+i+""")" else c="get_custom_object[""packRouter""]=get_router"
  // Create and build temporary source file
  _n=Io.tmpName
  f=Command.touch(Obj,["-x",path(C)+"/"+_n+".src"])
	if f isa Error then return Error.set("","",true)
	set_content(f,c)
	if build(Obj.shell,path(f),path(C))=="" then launch(Obj.shell,path(C)+"/"+_n)
	// Clean up temporary files
	self._cleanup(Obj,C,null,_n)
  return co.packRouter
end function
