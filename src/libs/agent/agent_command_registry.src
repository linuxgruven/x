// =============================================================================
// AGENT_COMMAND_REGISTRY
// Agent command registry; dynamic command knowledge wrapper and lookup system.
// =============================================================================
AgentCommandRegistry={}
//Get command knowledge from cache (populated by man page parsing)
AgentCommandRegistry.get=function(cmdName)
  outLvl=globals.G_agent.config.outputLevel
  if not hasIndex(globals.G_agent,"commandKnowledgeCache") then globals.G_agent.commandKnowledgeCache={}
  //Load knowledge if empty
  if len(globals.G_agent.commandKnowledgeCache.indexes)==0 then
    savedLevel=outLvl
    outLvl=0
    globals.G_agent.loadKnowledge
    outLvl=savedLevel
  end if
  normalizedName=trim(lower(cmdName))
  //Check cache
  if hasIndex(globals.G_agent.commandKnowledgeCache,normalizedName) then return globals.G_agent.commandKnowledgeCache[normalizedName]
  //Try to learn from man page
  return globals.G_agent.getCommandInfo(cmdName)
end function
AgentCommandRegistry.has=function(cmdName);knowledge=self.get(cmdName);return knowledge!=null;end function
//Match natural language query to best command using man page knowledge
AgentCommandRegistry.matchQuery=function(queryWords)
  outLvl=globals.G_agent.config.outputLevel
  if not hasIndex(globals.G_agent,"commandKnowledgeCache") then globals.G_agent.commandKnowledgeCache={}
  //Load knowledge if empty
  if len(globals.G_agent.commandKnowledgeCache.indexes)==0 then
    savedLevel=outLvl
    outLvl=0
    globals.G_agent.loadKnowledge
    outLvl=savedLevel
  end if
  //Filter stop words (using shared map for O(1) lookup)
  sw=AgentCore._STOP_WORDS
  meaningfulWords=[]
  for word in queryWords;if len(word)>2 and not hasIndex(sw,word) then push(meaningfulWords,lower(word));end for
  //Score each command by matching query words against purpose/description
  bestCommand=null
  bestScore=0
  for cmdName in globals.G_agent.commandKnowledgeCache.indexes
    knowledge=globals.G_agent.commandKnowledgeCache[cmdName]
    score=0
    //Command name in query = strong signal
    if meaningfulWords.indexOf(cmdName)!=null then score=score+10
    //Check purpose (cached lower)
    if hasIndex(knowledge,"purpose") then
      if hasIndex(knowledge,"purposeLower") then purposeLower=knowledge.purposeLower else purposeLower=lower(knowledge.purpose);knowledge.purposeLower=purposeLower
      for word in meaningfulWords;if indexOf(purposeLower,word)!=null then score=score+2;end for
    end if
    //Check raw description (cached lower)
    if hasIndex(knowledge,"raw") then
      if hasIndex(knowledge,"rawLower") then rawLower=knowledge.rawLower else rawLower=lower(knowledge.raw);knowledge.rawLower=rawLower
      for word in meaningfulWords;if indexOf(rawLower,word)!=null then score+=1;end for
    end if
    if score>bestScore then
      bestScore=score
      bestCommand=cmdName
    end if
  end for
  return {"command":bestCommand,"score":bestScore}
end function
//Map parsed flag->description into semantic keys used by the executor (_FLAG_KEYWORDS)
//Keys: randomIP, localhost, publicIP, recursive, force, verbose, quiet, all, port, pattern, count
//Plus scan -- intents: bounce, exploitSearch, customLocal, customRemote, lanNetwork (full flag strings)
AgentCommandRegistry._mapSemanticFlags=function(flagsMap)
  if not flagsMap then return {}
  semanticMap={}
  for flag in indexes(flagsMap)
    desc=lower(flagsMap[flag])
    if not len(flag) then continue
    //Keep full --flag for double-dash; single-letter for short flags
    flagToken=flag
    if len(flag)>=2 and flag[:2]=="--" then
      flagToken=flag
    else if flag[0]=="-" then
      flagToken=flag[1:]
    end if
    if not len(flagToken) then continue
    if indexOf(desc,"random")!=null then semanticMap.randomIP=flagToken
    //Localhost: only single-dash -l style "local ports", not --l custom local exploit
    if indexOf(desc,"localhost")!=null then
      semanticMap.localhost=flagToken
    else if indexOf(desc,"local")!=null and indexOf(desc,"port")!=null and indexOf(desc,"exploit")==null then
      semanticMap.localhost=flagToken
    end if
    if indexOf(desc,"public")!=null and indexOf(desc,"bounce")==null then semanticMap.publicIP=flagToken
    if indexOf(desc,"recursive")!=null or indexOf(desc,"recurse")!=null then semanticMap.recursive=flagToken
    if indexOf(desc,"force")!=null then semanticMap.force=flagToken
    if indexOf(desc,"verbose")!=null then semanticMap.verbose=flagToken
    if indexOf(desc,"quiet")!=null or indexOf(desc,"silent")!=null then semanticMap.quiet=flagToken
    if indexOf(desc,"all")!=null or indexOf(desc,"everything")!=null then semanticMap.all=flagToken
    if indexOf(desc,"port")!=null then semanticMap.port=flagToken
    if indexOf(desc,"pattern")!=null then semanticMap.pattern=flagToken
    if indexOf(desc,"count")!=null or indexOf(desc,"number")!=null then semanticMap.count=flagToken
    //scan bash autos: only store -- flags (scriptable $scan_ok / $hold path)
    isDashDash=len(flag)>=2 and flag[:2]=="--"
    if not isDashDash then
      //skip single-dash for scan intents below
    else
      if indexOf(desc,"bounce")!=null then semanticMap.bounce=flag
      if indexOf(desc,"search")!=null and indexOf(desc,"libraries")!=null then semanticMap.exploitSearch=flag
      if indexOf(desc,"custom")!=null and indexOf(desc,"local")!=null and indexOf(desc,"index")!=null then semanticMap.customLocal=flag
      if indexOf(desc,"custom")!=null and (indexOf(desc,"public")!=null or indexOf(desc,"remote")!=null) then semanticMap.customRemote=flag
      if indexOf(desc,"smart")!=null and indexOf(desc,"lan")!=null then semanticMap.lanNetwork=flag
      if indexOf(desc,"shell")!=null and indexOf(desc,"bounce")!=null then semanticMap.shellBounce=flag
    end if
  end for
  return semanticMap
end function
//Extract semantic flag meanings from cached command knowledge
AgentCommandRegistry.getSemanticFlags=function(cmdName)
  knowledge=self.get(cmdName)
  if not knowledge then return {}
  if hasIndex(knowledge,"flagMappings") and knowledge.flagMappings then return knowledge.flagMappings
  if not hasIndex(knowledge,"flags") then return {}
  return self._mapSemanticFlags(knowledge.flags)
end function
//Parse OPTIONS from man-page text and learn semantic flagMappings for a command.
//Returns {"flags":{-x:"desc",...},"flagMappings":{randomIP:"r",...}} or null
AgentCommandRegistry.learnFlagsFromManPage=function(cmd,helpText)
  if not helpText or not len(helpText) then return null
  flags={}
  openBold=char(60)+"b"+char(62)
  closeBold=char(60)+"/b"+char(62)
  optionsMarker=openBold+"OPTIONS"+closeBold
  optionsIdx=indexOf(helpText,optionsMarker)
  if optionsIdx==null then
    //Plain-text fallback
    optionsIdx=indexOf(upper(helpText),"OPTIONS")
    if optionsIdx==null then return {"flags":flags,"flagMappings":{}}
  end if
  optionsSection=helpText[optionsIdx:]
  examplesIdx=indexOf(optionsSection,openBold+"EXAMPLE")
  if examplesIdx==null then examplesIdx=indexOf(optionsSection,"EXAMPLE")
  seeAlsoIdx=indexOf(optionsSection,openBold+"SEE ALSO"+closeBold)
  if seeAlsoIdx==null then seeAlsoIdx=indexOf(optionsSection,"SEE ALSO")
  endIdx=null
  if examplesIdx!=null then endIdx=examplesIdx
  if seeAlsoIdx!=null and (endIdx==null or seeAlsoIdx<endIdx) then endIdx=seeAlsoIdx
  if endIdx!=null then optionsSection=optionsSection[:endIdx]
  lines=split(optionsSection,char(10))
  currentFlag=null
  _len=len(lines);i=0;while i<_len
    line=lines[i]
    if len(line)==0 then
      i+=1
      continue
    end if
    if len(line)>=4 and line[:4]=="    " and indexOf(line,openBold)!=null then
      boldStart=indexOf(line,openBold)
      boldEnd=indexOf(line,closeBold)
      if boldStart!=null and boldEnd!=null and boldEnd>boldStart then
        flagContent=line[boldStart+3:boldEnd]
        spaceIdx=indexOf(flagContent," ")
        bracketIdx=indexOf(flagContent,"[")
        cutIdx=null
        if spaceIdx!=null then cutIdx=spaceIdx
        if bracketIdx!=null and (cutIdx==null or bracketIdx<cutIdx) then cutIdx=bracketIdx
        if cutIdx!=null then currentFlag=trim(flagContent[:cutIdx]) else currentFlag=trim(flagContent)
        if len(currentFlag)>=2 and currentFlag[0]=="-" then
          flags[currentFlag]=""
          remainingLine=trim(line[boldEnd+4:])
          if len(remainingLine)>0 and remainingLine[0]=="-" then remainingLine=trim(remainingLine[1:])
          if len(remainingLine)>0 then
            if hasIndex(globals,"G_agent") and hasIndex(globals.G_agent,"_stripColorTags") then flags[currentFlag]=globals.G_agent._stripColorTags(remainingLine) else flags[currentFlag]=remainingLine
          end if
        else
          currentFlag=null
        end if
      end if
    else if currentFlag and len(line)>=8 and line[:8]=="        " then
      desc=trim(line)
      if len(desc)>0 then
        if hasIndex(globals,"G_agent") and hasIndex(globals.G_agent,"_stripColorTags") then desc=globals.G_agent._stripColorTags(desc)
        if len(flags[currentFlag])>0 then flags[currentFlag]+=" "+desc else flags[currentFlag]=desc
        if len(flags[currentFlag])>200 then
          flags[currentFlag]=flags[currentFlag][:200]
          currentFlag=null
        end if
      end if
    else
      currentFlag=null
    end if
    i+=1
  end while
  mappings=self._mapSemanticFlags(flags)
  //Persist onto cache entry when present
  normalizedName=trim(lower(cmd))
  if hasIndex(globals,"G_agent") and hasIndex(globals.G_agent,"commandKnowledgeCache") and hasIndex(globals.G_agent.commandKnowledgeCache,normalizedName) then
    entry=globals.G_agent.commandKnowledgeCache[normalizedName]
    entry.flags=flags
    entry.flagMappings=mappings
  end if
  return {"flags":flags,"flagMappings":mappings}
end function
//Legacy compatibility - hardcoded commands structure (kept minimal for backward compat)
//This is ONLY used for commands that have special parsing needs not in man pages
AgentCommandRegistry.commands={
  //Special case: scan has structured port shortcuts and object types in man page
  "scan":{"expectsObj":true},
  //Special case: crack doesn't use shell object
  "crack":{"expectsObj":false}
}