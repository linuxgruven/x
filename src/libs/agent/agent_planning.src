// =============================================================================
// AGENT_PLANNING
// AI agent planning; plan creation, strategy generation, and goal decomposition.
// =============================================================================
AgentPlanning={}
AgentPlanning._LOCAL_OPS=["directCommand","navigation","fileOp","fileContent","permissions"]
AgentPlanning._DANGEROUS_OPS=["wipe","bomb","ddos","0day","encrypt"]
AgentPlanning._MODERATE_OPS=["tux","exploit","crack","escalate"]
AgentPlanning._COMPLEX_OPS=["escalate","backdoor","0day"]
AgentPlanning._COMMAND_MAPPING={"fetch":"scan","scan":"scan","exploit":"exploit","crack":"crack","escalate":"su","proxy":"proxy","pivot":"pivot","nmap":"nmap","dig":"deepscan","decipher":"decipher","tux":"adduser","backdoor":"backdoor","encrypt":"encrypt","decrypt":"decrypt","build":"build","sniffer":"sniffer"}
AgentPlanning._SYNONYM_GROUPS=[["space","free","available","capacity","remaining","left"],["find","search","locate","discover"],["list","show","display","print"],["delete","remove","erase"],["copy","duplicate"],["move","relocate"],["create","make","new"]]
AgentPlanning._expandSubnet=function(subnet)
  debug=globals.G_agent.config.debug
  //Parse CIDR notation: 192.168.1.0/24
  if indexOf(subnet,"/")==null then return [subnet]  //Not a subnet, return as-is
  parts=split(subnet,"\/")
  if len(parts)!=2 then return [subnet]
  baseIP=parts[0]
  mask=parts[1].val
  if not mask or mask<1 or mask>32 then return [subnet]
  //Calculate how many IPs will be scanned (prompt user if configured)
  ipCount=0
  if mask==24 then
    ipCount=254
  else if mask>=25 and mask<=30 then
    ipCount=2^(32-mask)-2
  end if
  if ipCount>0 and globals.G_agent.config.promptOnSlow then
    shouldExpand=globals.G_agent.promptUser("This will scan "+ipCount+" IP addresses. Continue?",{"type":"subnet_expansion","details":"Subnet: "+subnet+" ("+ipCount+" IPs)"},true)
    if not shouldExpand then
      if debug then print green("[DEBUG] Agent: Subnet expansion cancelled by user")
      return [subnet]
    end if
  end if
  //For /24, generate all IPs in range
  if mask==24 then
    octets=split(baseIP,".")
    if len(octets)!=4 then return [subnet]
    base=octets[0]+"."+octets[1]+"."+octets[2]+"."
    ips=[]
    i=1;while i<=254;push(ips,base+i);i+=1;end while
    if debug then print green("[DEBUG] Agent: Expanded /24 subnet to "+len(ips)+" IPs")
    return ips
  end if
  //For /25-/30, calculate smaller ranges
  if mask>=25 and mask<=30 then
    octets=split(baseIP,".")
    if len(octets)!=4 then return [subnet]
    base=octets[0]+"."+octets[1]+"."+octets[2]+"."
    lastOctet=octets[3].val
    rangeSize=2^(32-mask)
    ips=[]
    _len=rangeSize-2;i=1;while i<=_len;push(ips,base+(lastOctet+i));i+=1;end while
    if debug then print green("[DEBUG] Agent: Expanded /"+mask+" subnet to "+len(ips)+" IPs")
    return ips
  end if
  return [subnet]  //Unsupported mask, return as-is
end function
AgentPlanning._extractIps=function(text)
  ips=[]
  //Simple pattern matching for IPs (not perfect but functional)
  parts=split(text," ")
  for part in parts
    //Remove trailing punctuation (comma, period, etc)
    part=part.replace(",","").replace(";","")
    //Skip empty strings after cleanup
    if len(part)==0 then continue
    //Handle CIDR notation (e.g., 192.168.1.0/24)
    cidrPart=part
    if indexOf(part,"/")!=null then
      cidrPart=split(part,"\/")[0]
      //Keep the full CIDR notation as well
      //Check if it looks like an IP by counting dots
      dotCount=0
      _len=len(part);i=0;while i<_len;if part[i]=="." then dotCount+=1;i+=1;end while
      if dotCount==3 then
        //This is likely a CIDR notation IP, keep it as-is
        push(ips,part)
        continue
      end if
    end if
    //Check if it looks like an IP by counting dots
    //Skip if cidrPart is empty
    _len=len(cidrPart)
    if _len==0 then continue
    dotCount=0
    i=0;while i<_len;if cidrPart[i]=="." then dotCount+=1;i+=1;end while
    if dotCount==3 then
      segments=split(cidrPart,"\.")
      valid=true
      if len(segments)==4 then
        for seg in segments
          if to_int(seg)<0 or to_int(seg)>255 then
            valid=false
            break
          end if
        end for
        if valid then push(ips,cidrPart)
      end if
    end if
  end for
  return ips
end function
//Classify IP as public or private
AgentPlanning._isPrivateIp=function(ip)
  if not ip or typeof(ip)!="string" then return false
  parts=split(ip,"\.")
  if len(parts)!=4 then return false
  //Verify we have enough elements (defensive programming)
  if len(parts)<2 then return false
  //Safely convert with bounds checking
  if len(parts)>=1 then first=to_int(parts[0]) else return false
  if len(parts)>=2 then second=to_int(parts[1]) else return false
  if first==10 then return true
  if first==172 and second>=16 and second<=31 then return true
  if first==192 and second==168 then return true
  if first==127 then return true
  return false
end function
//Prompt user with yes/no question
AgentPlanning._promptUser=function(question,defaultYes=true)
  outLvl=globals.G_agent.config.outputLevel
  if outLvl==0 then return defaultYes
  if typeof(Gui)!="map" or not hasIndex(Gui,"yesNo") then return defaultYes
  response=Gui.yesNo(question,defaultYes)
  if response==null then return defaultYes
  return response
end function
//Ask user a question and get response
AgentPlanning._askUser=function(question, options=null)
  outLvl=globals.G_agent.config.outputLevel
  if outLvl==0 then return null
  if typeof(Gui)!="map" or not hasIndex(Gui,"input") then return null
  if options then
    //Multiple choice (index 0 is a non-selectable header)
    if hasIndex(Gui,"choiceHybrid") then
      choices=[yellow(question)]
      for opt in options;push(choices,opt);end for
      result=Gui.choiceHybrid(choices,{},1,false,true)
      if result>=1 and result<=len(options) then return options[result-1]
      return null
    end if
  end if
  //Free text input
  inputConfig={}
  inputConfig.text=question
  result=Gui.input(inputConfig)
  return result
end function
//Generic command executor helper
AgentPlanning._execCommand=function(Obj,cmdName,argv,context)
  result={"success":false}
  if hasIndex(Obj.commands,cmdName) then
    f=Obj.commands[cmdName]
    cmdResult=f(argv)
    result.success=true
    result.data=cmdResult
    if context then context[cmdName+"_data"]=cmdResult
  else
    result.error=cmdName+" command not available"
  end if
  return result
end function
//AI risk assessment for operations
AgentPlanning._assessRisk=function(operation, context)
  outLvl=globals.G_agent.config.outputLevel
  risk={"level":"low","score":0,"factors":[]}
  //Skip risk assessment for local/simple commands
  localOps=self._LOCAL_OPS
  for op in localOps;if operation==op then return risk;end for
  if outLvl>=2 then print yellow("[!] AI: Risk analysis for operation '"+operation+"'...")
  //High-risk operations
  dangerousOps=self._DANGEROUS_OPS
  for op in dangerousOps
    if operation==op then
      risk.level="critical"
      risk.score+=50
      push(risk.factors,"Destructive operation")
      if outLvl>=2 then print yellow("  * Destructive operation detected (+50 pts)")
      break
    end if
  end for
  //Medium-risk operations
  moderateOps=self._MODERATE_OPS
  for op in moderateOps
    if indexOf(lower(operation),op)!=null then
      risk.score+=25
      push(risk.factors,"Security-sensitive operation")
      if outLvl>=2 then print yellow("  * Security-sensitive operation (+25 pts)")
      break
    end if
  end for
  //Context-based risk factors
  if hasIndex(context,"target") then
    if not globals.G_agent._isPrivateIp(context.target) then
      risk.score+=20
      push(risk.factors,"Public IP target")
      if outLvl>=2 then print yellow("  * Public IP target (+20 pts)")
    end if
  end if
  //Check if we have a fallback
  if not hasIndex(context,"shell") and not hasIndex(context,"backupShell") then
    risk.score+=15
    push(risk.factors,"No fallback shell")
    if outLvl>=2 then print yellow("  * No fallback shell (+15 pts)")
  end if
  //Determine risk level by score
  if risk.score>=50 then
    risk.level="critical"
  else if risk.score>=25 then
    risk.level="high"
  else if risk.score>=10 then
    risk.level="medium"
  else
    risk.level="low"
  end if
  if outLvl>=2 then print yellow("  -> Total risk: "+risk.score+" pts ("+upper(risk.level)+")")
  return risk
end function
//AI success prediction based on context
AgentPlanning._predictSuccess=function(stepType, context)
  outLvl=globals.G_agent.config.outputLevel
  prediction={"confidence":0.5,"factors":[]}
  if outLvl>=2 then print yellow("[AI] Predicting success for '"+stepType+"'...")
  //Higher confidence if we've succeeded before
  successCount=0
  totalCount=0
  for entry in globals.G_agent.history
    if hasIndex(entry,"result") and hasIndex(entry.result,"stepsCompleted") then
      totalCount+=1
      if entry.result.success then successCount+=1
    end if
  end for
  if totalCount>0 then
    baseConfidence=successCount/totalCount
    prediction.confidence=baseConfidence
    push(prediction.factors,"Historical success rate: "+round(baseConfidence*100)+"%")
    if outLvl>=2 then print yellow("  * Historical rate: "+round(baseConfidence*100)+"% ("+successCount+"/"+totalCount+" succeeded)")
  end if
  //Boost confidence if we have necessary tools
  if stepType=="scan" or stepType=="exploit" or stepType=="crack" then
    if hasIndex(context,"availableExploits") and len(context.availableExploits)>0 then
      prediction.confidence+=0.2
      push(prediction.factors,"Multiple exploits available")
      if outLvl>=2 then print yellow("  * Multiple exploits available (+0.2 confidence)")
    end if
  end if
  //Reduce confidence for complex operations without prep
  complexOps=self._COMPLEX_OPS
  for op in complexOps
    if stepType==op then
      if not hasIndex(context,"scanData") then
        prediction.confidence-=0.2
        push(prediction.factors,"Insufficient reconnaissance")
        if outLvl>=2 then print yellow("  * Missing scan data (-0.2 confidence)")
      end if
      break
    end if
  end for
  //Cap confidence
  if prediction.confidence>0.95 then prediction.confidence=0.95
  if prediction.confidence<0.1 then prediction.confidence=0.1
  if outLvl>=2 then print green("  -> Predicted confidence: "+round(prediction.confidence*100)+"%")
  return prediction
end function
//Create alternative plan when critical step fails
AgentPlanning._createAlternativePlan=function(Obj,failedStep,context)
  debug=globals.G_agent.config.debug
  outLvl=globals.G_agent.config.outputLevel
  plan={"steps":[]}
  if outLvl>=2 then print yellow("[AI] Analyzing alternatives for failed '"+failedStep.type+"'...")
  if debug then print skyblue("Agent: Creating alternative plan for failed "+failedStep.type)
  //Alternative strategies based on failure type
  if failedStep.type=="scan" then
    //Try different scan tool
    if hasIndex(failedStep,"tool") and failedStep.tool=="scan" then
      push(plan.steps,{"type":"scan","tool":"nmap","target":failedStep.target,"description":"Retry scan with nmap"})
      if outLvl>=2 then print yellow("  * Alternative 1: Retry with nmap")
    else if hasIndex(failedStep,"tool") and failedStep.tool=="nmap" then
      push(plan.steps,{"type":"recon","target":failedStep.target,"description":"Switch to reconnaissance approach"})
      if outLvl>=2 then print yellow("  * Alternative 1: Switch to reconnaissance")
    end if
  else if failedStep.type=="exploit" then
    //Try different exploit or manual approach
    if hasIndex(context,"availableExploits") and len(context.availableExploits)>1 then
      push(plan.steps,{"type":"exploit","description":"Retry with next best exploit","retryCount":1})
      if outLvl>=2 then print yellow("  * Alternative 1: Try next exploit from list")
    else
      push(plan.steps,{"type":"crack","description":"Attempt credential cracking instead"})
      if outLvl>=2 then print yellow("  * Alternative 1: Switch to credential cracking")
    end if
  else if failedStep.type=="escalate" then
    //Try alternative escalation methods
    push(plan.steps,{"type":"findEscalation","description":"Search for alternative escalation vectors"})
    push(plan.steps,{"type":"crack","crackType":"password","description":"Attempt password cracking for privilege escalation"})
    if outLvl>=2 then
      print yellow("  * Alternative 1: Search for escalation vectors")
      print yellow("  * Alternative 2: Password cracking for privesc")
    end if
  else if failedStep.type=="crackPassword" or failedStep.type=="crackShell" then
    //Try different cracking approach
    push(plan.steps,{"type":"recon","description":"Gather more intelligence for targeted attack"})
    if outLvl>=2 then print yellow("  * Alternative 1: Gather more intelligence")
  end if
  if len(plan.steps)==0 then
    if outLvl>=2 then print yellow("  [X] No alternative strategy available")
  else
    if outLvl>=2 then print green("  -> Injecting "+len(plan.steps)+" alternative step(s) into plan")
  end if
  return plan
end function
//AI adaptive strategy based on failures
AgentPlanning._adaptStrategy=function(context)
  outLvl=globals.G_agent.config.outputLevel
  if len(globals.G_agent.history)==0 then return {"adjusted":false}
  //Check recent failures
  recentFailures=0
  recentOps=3  //Look at last 3 operations
  startIdx=len(globals.G_agent.history)-recentOps
  if startIdx<0 then startIdx=0
  _len=len(globals.G_agent.history);i=startIdx;while i<_len
    entry=globals.G_agent.history[i]
    if hasIndex(entry,"result") and hasIndex(entry.result,"success") then
      if not entry.result.success then recentFailures+=1
    end if
  i+=1;end while
  adaptation={"adjusted":false,"changes":[]}
  //If multiple failures, become more aggressive
  if recentFailures>=2 then
    if outLvl>=2 then print yellow("[AI] Strategy adaptation triggered ("+recentFailures+" recent failures)...")
    if not globals.G_agent.config.aggressive then
      globals.G_agent.config.aggressive=true
      adaptation.adjusted=true
      push(adaptation.changes,"Switched to aggressive mode")
      if outLvl>=2 then print yellow("  * Switching aggressive mode: OFF -> ON")
    end if
    //Reduce stealth if failing
    if globals.G_agent.config.stealth then
      globals.G_agent.config.stealth=false
      adaptation.adjusted=true
      push(adaptation.changes,"Disabled stealth mode")
      if outLvl>=2 then print yellow("  * Disabling stealth for better success rate")
    end if
  end if
  if adaptation.adjusted and outLvl>=2 then print green("  -> Strategy adapted: "+join(adaptation.changes,", "))
  return adaptation
end function
