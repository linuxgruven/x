  //Removed cd/ls/pwd - let them use universal parameter extraction instead
  globals.G_agent._planBuilders.promptIpAction=@globals.G_agent._buildPromptPlan
  globals.G_agent._planBuilders.multiTarget=@globals.G_agent._buildMultiTargetPlan
  globals.G_agent._planBuilders.test=@globals.G_agent._buildTestPlan
  globals.G_agent._planBuilders.showHistory=@globals.G_agent._buildShowHistoryPlan
end function
//Create execution plan based on parsed command
AgentPlanning._createPlan=function(Obj,parsed,headless=false)
  debug=globals.G_agent.config.debug
  outLvl=globals.G_agent.config.outputLevel
  if debug then
    print green("[DEBUG] Planning: _createPlan called with action='"+parsed.action+"'")
    if hasIndex(parsed,"source") then print green("[DEBUG] Planning: parsed has source='"+parsed.source+"'")
    if hasIndex(parsed,"destination") then print green("[DEBUG] Planning: parsed has destination='"+parsed.destination+"'")
  end if
  plan={}
  if hasIndex(parsed,"action") then plan.action=parsed.action else plan.action="unknown"
  if hasIndex(parsed,"target") then plan.target=parsed.target else plan.target=null
  if hasIndex(parsed,"goal") then plan.goal=parsed.goal else plan.goal="shell"
  //Store headless flag in parsed for builders to use
  parsed.headless=headless
  plan.steps=[]
  //Initialize plan builders before template recall (builders take priority)
  if not hasIndex(self,"_planBuilders") then globals.G_agent._initPlanBuilders
  hasPlanBuilder=hasIndex(parsed,"action") and hasIndex(globals.G_agent._planBuilders,parsed.action)
  //AI: Check learned templates only when no dedicated plan builder exists
  //Otherwise dialog-resume noise (exploit->exploit->exploit) hijacks real plans
  if not hasPlanBuilder and hasIndex(globals.G_agent.sessionContext,"templates") and typeof(globals.G_agent.sessionContext.templates)=="list" then
    bestTemplate=null
    bestTemplateScore=0
    for tmpl in globals.G_agent.sessionContext.templates
      if tmpl.successCount>=2 and hasIndex(tmpl,"signature") and hasIndex(tmpl,"steps") then
        if globals.G_agent._isDegenerateTemplate(tmpl) then continue
        score=globals.G_agent._scoreFuzzyTemplate(parsed.action,tmpl)
        if score>bestTemplateScore then
          bestTemplateScore=score
          bestTemplate=tmpl
        end if
      end if
    end for
    //Use template if score is above threshold (0.4 = at least partial match)
    if bestTemplate and bestTemplateScore>=0.4 then
      if debug then print green("[DEBUG] Planning: Fuzzy template match '"+bestTemplate.signature+"' (score="+round(bestTemplateScore*100)+"%  success="+bestTemplate.successCount+")")
      for stepCmd in bestTemplate.steps
        push(plan.steps,{"type":"directCommand","command":stepCmd,"description":stepCmd})
      end for
      plan.fromTemplate=true
      plan.templateScore=bestTemplateScore
      if outLvl>=1 then print skyblue("Agent: Using learned template '"+bestTemplate.signature+"' ("+round(bestTemplateScore*100)+"% match)")
      return plan
    end if
  end if
  //AI: Consult man pages to understand commands we'll be using
  if hasIndex(parsed,"action") and parsed.action!="directCommand" then
    //Map actions to actual commands that will be executed
    commandMapping=self._COMMAND_MAPPING
    if hasIndex(commandMapping,parsed.action) then
      cmdToLearn=commandMapping[parsed.action]
      learnedKnowledge=globals.G_agent.getCommandInfo(cmdToLearn)
      //Store in plan context for handlers to use
      if learnedKnowledge then plan.commandKnowledge=learnedKnowledge
    end if
  end if
  //Dispatch to appropriate plan builder
  if hasIndex(parsed,"action") and hasIndex(globals.G_agent._planBuilders,parsed.action) then
    if debug then print green("[DEBUG] Planning: Using plan builder for action='"+parsed.action+"'")
    builder=globals.G_agent._planBuilders[parsed.action]
    plan=builder(Obj,parsed,plan)
  else
    if debug then print green("[DEBUG] Planning: No plan builder for action='"+parsed.action+"', checking man pages...")
    //Unknown action - check if we have man page knowledge for it
    if hasIndex(parsed,"action") and hasIndex(globals.G_agent,"commandKnowledgeCache") then
      cmdName=parsed.action
      if debug then print green("[DEBUG] Planning: Checking if '"+cmdName+"' is in commandKnowledgeCache...")
      if hasIndex(globals.G_agent.commandKnowledgeCache,cmdName) then
        if debug then print green("[DEBUG] Planning: Found '"+cmdName+"' in commandKnowledgeCache!")
        //We have man page knowledge - determine appropriate flags
        knowledge=globals.G_agent.commandKnowledgeCache[cmdName]
        cmdString=cmdName
        //Universal parameter extraction - works for any command
        if debug then print green("[DEBUG] Planning: About to extract params from parsed.raw='"+parsed.raw+"'")
        extractedParams=globals.G_agent._extractParameters(parsed.raw,cmdName,knowledge)
        if len(extractedParams)>0 then
          cmdString=cmdName+" "+extractedParams
          if debug then print green("[DEBUG] Planning: Extracted parameters '"+extractedParams+"'")
        else
          if debug then print green("[DEBUG] Planning: No parameters extracted")
        end if
        //Match query words to flag descriptions or flag names
        if hasIndex(knowledge,"flags") and len(knowledge.flags)>0 and hasIndex(parsed,"raw") then
          queryLower=lower(parsed.raw)
          //Extract meaningful words from query
            sw=AgentCore._STOP_WORDS
            queryWords=split(queryLower," ")
            meaningfulWords=[]
            for word in queryWords;if len(word)>2 and not hasIndex(sw,word) then push(meaningfulWords,word);end for
            //Common synonyms for semantic expansion
            synonymGroups=self._SYNONYM_GROUPS
            expandedWords=[]
            for word in meaningfulWords
              push(expandedWords,word)
              //Add synonyms from matching group
              for group in synonymGroups
                if group.indexOf(word)!=null then
                  for synonym in group;if expandedWords.indexOf(synonym)==null then push(expandedWords,synonym);end for
                  break
                end if
              end for
            end for
            bestFlag=null
            bestFlagScore=0
            for flag in knowledge.flags.indexes
              score=0
              //Try matching against flag description first
              flagDesc=lower(knowledge.flags[flag])
              if len(flagDesc)>0 then
                //Score based on how many meaningful words appear in description
                for word in meaningfulWords;if indexOf(flagDesc,word)!=null then score=score+20;end for
                //Bonus for synonym matches (lower score)
                for word in expandedWords;if meaningfulWords.indexOf(word)==null and indexOf(flagDesc,word)!=null then score=score+3;end for
                //Context-aware boost for crack commands
                if indexOf(queryLower,"crack")!=null then
                  //Boost rainbow table/dictionary flags for "crack"
                  if indexOf(flagDesc,"rainbow")!=null or indexOf(flagDesc,"dictionary")!=null or indexOf(flagDesc,"table")!=null then score=score+15
                  //Penalize decipher/computational for "crack" (user wants fast rainbow tables)
                  if indexOf(flagDesc,"decipher")!=null or indexOf(flagDesc,"computational")!=null then score=score-10
                end if
                //Detect hash values in extracted parameters (32 hex chars = MD5)
                _len=len(extractedParams)
                if _len==32 then
                  isHash=true
                  i=0;while i<_len
                    c=extractedParams[i]
                    if "0123456789abcdef".indexOf(c)==null then
                      isHash=false
                      break
                    end if
                  i+=1;end while
                  //If we have a hash value, penalize file flags
                  if isHash then
                    if indexOf(flagDesc,"file")!=null then score=score-30  //Strong penalty for file flags when hash provided
                    //Boost flags that take hash directly
                    if indexOf(flag,"-h")!=null or indexOf(flag,"-d")!=null then score=score+25  //Boost hash/decipher flags
                  end if
                end if
                //Penalty for contradictory terms
                if indexOf(queryLower,"how much")!=null or indexOf(queryLower,"summary")!=null or indexOf(queryLower,"total")!=null then
                  //User wants summary, penalize flags about listing all items
                  if indexOf(flagDesc,"all")!=null or indexOf(flagDesc,"each")!=null or indexOf(flagDesc,"every")!=null then score=score-5
                end if
              else
                //No flag description - try matching flag name itself to query words
                //Strip dashes from flag name for matching
                flagName=flag.replace("-","").replace("--","")
                flagNameLower=lower(flagName)
                //Check if any query words match the flag name
                for word in meaningfulWords
                  if flagNameLower==word then score=score+10  //Exact match
                  if indexOf(flagNameLower,word)!=null then score=score+5  //Partial match
                  if indexOf(word,flagNameLower)!=null then score=score+5  //Word contains flag name
                end for
              end if
              if score>bestFlagScore then
                bestFlag=flag
                bestFlagScore=score
              end if
            end for
            if bestFlag and bestFlagScore>=5 then
              cmdString=cmdName+" "+bestFlag
              //Don't append extracted parameters when using knowledge-matched flags
              //The flag itself represents the complete intent from the query
              if debug then print green("[DEBUG] Planning: Matched flag '"+bestFlag+"' for query (score: "+bestFlagScore+")")
              //Verbose output explaining AI reasoning
              if outLvl>=2 then
                flagDesc=knowledge.flags[bestFlag]
                if flagDesc then
                  print yellow("[VERBOSE] Agent reasoning: Selected '"+bestFlag+"' flag (score: "+bestFlagScore+")")
                  print yellow("[VERBOSE] Learned from 'man "+cmdName+"': "+flagDesc)
                else
                  print yellow("[VERBOSE] Agent reasoning: Selected '"+bestFlag+"' flag from "+cmdName+" knowledge (score: "+bestFlagScore+")")
                end if
              end if
            end if
        end if
        summaryText="Execute "+cmdString
        if hasIndex(parsed,"summary") then summaryText=parsed.summary
        step={"type":"directCommand","command":cmdString,"description":summaryText}
        //Copy parsed fields to step for executor
        if hasIndex(parsed,"source") then
          step.source=parsed.source
          if debug then print green("[DEBUG] Planning: Copying source='"+parsed.source+"' to step")
        end if
        if hasIndex(parsed,"destination") then
          step.destination=parsed.destination
          if debug then print green("[DEBUG] Planning: Copying destination='"+parsed.destination+"' to step")
        end if
        if hasIndex(parsed,"content") then step.content=parsed.content
        if hasIndex(parsed,"target") then step.target=parsed.target
        if hasIndex(parsed,"permValue") then step.permValue=parsed.permValue
        push(plan.steps,step)
        if debug then print green("[DEBUG] Planning: Using man page knowledge to execute '"+cmdString+"'")
      else
        //No knowledge - generic fallback
        if debug then print green("[DEBUG] Planning: No man page knowledge for '"+cmdName+"', using generic fallback")
        step={"type":"directCommand","command":cmdName,"description":"Execute command"}
        //Copy parsed fields to step for executor
        if hasIndex(parsed,"source") then
          step.source=parsed.source
          if debug then print green("[DEBUG] Planning: (Fallback) Copying source='"+parsed.source+"' to step")
        end if
        if hasIndex(parsed,"destination") then
          step.destination=parsed.destination
          if debug then print green("[DEBUG] Planning: (Fallback) Copying destination='"+parsed.destination+"' to step")
        end if
        if hasIndex(parsed,"content") then step.content=parsed.content
        if hasIndex(parsed,"target") then step.target=parsed.target
        if hasIndex(parsed,"permValue") then step.permValue=parsed.permValue
        push(plan.steps,step)
      end if
    else
      //No action at all
      actionCmd="unknown"
      if hasIndex(parsed,"action") then actionCmd=parsed.action
      summaryText="execute command"
      if hasIndex(parsed,"summary") then summaryText=parsed.summary
      step={"type":"directCommand","command":actionCmd,"description":summaryText}
      //Copy parsed fields to step for executor
      if hasIndex(parsed,"source") then step.source=parsed.source
      if hasIndex(parsed,"destination") then step.destination=parsed.destination
      if hasIndex(parsed,"content") then step.content=parsed.content
      if hasIndex(parsed,"target") then step.target=parsed.target
      if hasIndex(parsed,"permValue") then step.permValue=parsed.permValue
      push(plan.steps,step)
    end if
  end if
  return plan
end function