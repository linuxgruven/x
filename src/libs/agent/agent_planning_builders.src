//Build launch plan - find and execute file
AgentPlanning._buildLaunchPlan=function(Obj,parsed,plan)
  step={"type":"launch","description":"Launch executable"}
  //Extract filename from parsed object
  if hasIndex(parsed,"path") then
    step.filename=parsed.path
  else if hasIndex(parsed,"target") then
    step.filename=parsed.target
  end if
  if not hasIndex(step,"filename") then step.error="No file specified to launch"
  push(plan.steps,step)
  return plan
end function
//Build hunt plan - network service/resource discovery
AgentPlanning._buildHuntPlan=function(Obj,parsed,plan)
  step={"type":"hunt","description":"Hunt for services"}
  //Copy all hunt parameters from parsed
  if hasIndex(parsed,"huntType") then step.huntType=parsed.huntType
  if hasIndex(parsed,"version") then step.version=parsed.version
  if hasIndex(parsed,"count") then step.count=parsed.count
  if hasIndex(parsed,"save") then step.save=parsed.save
  if hasIndex(parsed,"download") then step.download=parsed.download
  if hasIndex(parsed,"kill") then step.kill=parsed.kill
  if hasIndex(parsed,"port") then step.port=parsed.port
  if hasIndex(parsed,"huntName") then step.huntName=parsed.huntName
  if hasIndex(parsed,"bssid") then step.bssid=parsed.bssid
  if hasIndex(parsed,"essid") then step.essid=parsed.essid
  //Build detailed description
  descParts=["Hunt for"]
  if hasIndex(step,"count") and step.count>1 then push(descParts,str(step.count))
  if hasIndex(step,"huntType") then push(descParts,step.huntType)
  if hasIndex(step,"version") then push(descParts,"version "+step.version)
  if hasIndex(step,"huntName") then push(descParts,"named "+step.huntName)
  if hasIndex(step,"save") and step.save then push(descParts,"(save results)")
  if hasIndex(step,"download") and step.download then push(descParts,"(download)")
  step.description=join(descParts," ")
  push(plan.steps,step)
  return plan
end function
//Build test plan - run AI test suite
AgentPlanning._buildTestPlan=function(Obj,parsed,plan)
  step={"type":"test","description":"Run AI improvements test suite"}
  step.suite="all"
  //Check if a specific test was requested
  if hasIndex(parsed,"raw") then
    rawLower=lower(parsed.raw)
    if indexOf(rawLower,"synonym")!=null then
      step.suite="synonyms"
    else if indexOf(rawLower,"compound")!=null then
      step.suite="compound"
    else if indexOf(rawLower,"learn")!=null or indexOf(rawLower,"persist")!=null or indexOf(rawLower,"save")!=null then
      step.suite="persistence"
    else if indexOf(rawLower,"template")!=null or indexOf(rawLower,"planner")!=null then
      step.suite="template"
    else if indexOf(rawLower,"dialog")!=null then
      step.suite="dialog"
    else if indexOf(rawLower,"undo")!=null or indexOf(rawLower,"snapshot")!=null then
      step.suite="undo"
    else if indexOf(rawLower,"escalat")!=null then
      step.suite="escalate"
    else if indexOf(rawLower,"history")!=null then
      step.suite="history"
    end if
  end if
  push(plan.steps,step)
  return plan
end function
//Build show/search history plan
AgentPlanning._buildShowHistoryPlan=function(Obj,parsed,plan)
  step={"type":"showHistory","description":"Show command history"}
  if hasIndex(parsed,"historyQuery") and parsed.historyQuery then
    step.historyQuery=parsed.historyQuery
    step.description="Search history for '"+parsed.historyQuery+"'"
  end if
  if hasIndex(parsed,"historyLimit") then step.historyLimit=parsed.historyLimit
  push(plan.steps,step)
  return plan
end function