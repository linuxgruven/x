// =============================================================================
// AGENT_PLANNING_BUILDERS
// Plan builder functions (_build*Plan) and template helpers.
// Companion: agent_planning.src (createPlan, risk, strategy)
// =============================================================================
//Plan builder functions - each handles one action type
//Autonomous decision-making
AgentPlanning._buildAutonomousPlan=function(Obj,parsed,plan)
  debug=globals.G_agent.config.debug
  outLvl=globals.G_agent.config.outputLevel
  target=parsed.target
  if not target then
    push(plan.steps,{"type":"error","description":"Need target for autonomous decision-making"})
    return plan
  end if
  //Handle network-scope targets
  if target=="network" then
    //Try to resolve to router
    routerIP=Obj.getRouter
    if routerIP then
      target=routerIP
      parsed.target=routerIP
    else
      push(plan.steps,{"type":"error","description":"Network scope requires router access. Connect to a network first."})
      return plan
    end if
  end if
  //Determine scan target: use publicIP (router) if available, otherwise use target
  scanTarget=target
  if hasIndex(parsed,"publicIP") and parsed.publicIP then scanTarget=parsed.publicIP
  goal="compromise"
  if hasIndex(parsed,"goal") then goal=parsed.goal
  //Extract requirements if present
  requirements=null
  if hasIndex(parsed,"requirements") then requirements=parsed.requirements
  context={}
  context.target=target
  if hasIndex(parsed,"publicIP") then context.publicIP=parsed.publicIP
  if hasIndex(parsed,"lanIP") then context.lanIP=parsed.lanIP
  context.originalCommand=parsed.originalInput  // Store for knowledge recording
  if requirements then context.requirements=requirements
  if hasIndex(parsed,"shouldStore") then
    context.shouldStore=parsed.shouldStore  //Pass store flag to context
    if debug then print green("[DEBUG] Planning: Set context.shouldStore = "+str(context.shouldStore))
  end if
  //Store context in plan for later execution
  plan.context=context
  //Debug: verify context storage
  if debug then
    if debug then print green("[DEBUG] Stored context in plan")
    if debug then print green("[DEBUG] context.originalCommand = "+context.originalCommand)
    if debug then print green("[DEBUG] plan.context exists: "+hasIndex(plan,"context"))
    if hasIndex(parsed,"publicIP") and debug then print green("[DEBUG] Using publicIP "+parsed.publicIP+" for scanning")
  end if
  //LAN computer/shell via public router: use man-learned scan bounce flag (ai learn scan -> --b)
  if requirements and hasIndex(requirements,"targetIP") and is_lan_ip(requirements.targetIP) then
    lanIP=requirements.targetIP
    publicIP=null
    if hasIndex(parsed,"publicIP") and parsed.publicIP and not is_lan_ip(parsed.publicIP) then publicIP=parsed.publicIP
    if not publicIP and scanTarget and not is_lan_ip(scanTarget) then publicIP=scanTarget
    objectType="computer"
    if hasIndex(requirements,"objectType") then objectType=requirements.objectType
    if publicIP and (objectType=="computer" or objectType=="shell") then
      needRoot=false
      if hasIndex(requirements,"privilege") and requirements.privilege=="root" then needRoot=true
      //Consult learned man page for the bounce -- flag
      bounceFlag="--b"
      if hasIndex(globals.G_agent,"_getScanFlagForIntent") then bounceFlag=globals.G_agent._getScanFlagForIntent("bounce")
      if not bounceFlag then bounceFlag="--b"
      descStr="scan "+bounceFlag+" -p "+publicIP+" -l "+lanIP
      if needRoot then descStr="Get root "+objectType+" via "+descStr else descStr="Get "+objectType+" via "+descStr
      step={"type":"getObject","publicIP":publicIP,"lanIP":lanIP,"objectType":objectType,"isHeadless":false,"needRoot":needRoot,"description":descStr,"tool":"scan","flag":bounceFlag}
      //Attach scan man knowledge for the handler
      if hasIndex(plan,"commandKnowledge") then step.commandKnowledge=plan.commandKnowledge
      if hasIndex(parsed,"continuationCommands") then step.continuationCommands=parsed.continuationCommands
      if hasIndex(parsed,"needsInteractiveShell") and parsed.needsInteractiveShell then step.needsInteractiveShell=true
      if outLvl>=1 then print skyblue("Agent: Using man scan flag "+bounceFlag+" for LAN bounce")
      push(plan.steps,step)
      return plan
    end if
  end if
  //Public router shell (e.g. "root router shell on 1.2.3.4"): use scanCustom fetch, not scan+exploit.
  //Generic exploit hard-filters root-only and often returns nothing; fetchShell gets any shell then su.
  if requirements and hasIndex(requirements,"libraryType") and requirements.libraryType=="router" then
    wantShell=true
    if hasIndex(requirements,"objectType") and requirements.objectType!="shell" then wantShell=false
    lanOnly=hasIndex(requirements,"targetIP") and is_lan_ip(requirements.targetIP)
    pubTarget=target
    if hasIndex(parsed,"publicIP") and parsed.publicIP and not is_lan_ip(parsed.publicIP) then
      pubTarget=parsed.publicIP
    else if scanTarget and not is_lan_ip(scanTarget) then
      pubTarget=scanTarget
    end if
    if wantShell and not lanOnly and pubTarget and not is_lan_ip(pubTarget) then
      needRoot=false
      if hasIndex(requirements,"privilege") and requirements.privilege=="root" then needRoot=true
      descStr="Fetch router shell on "+pubTarget
      if needRoot then descStr="Fetch root router shell on "+pubTarget
      step={"type":"fetchShell","target":pubTarget,"service":"router","objectType":"s","needRoot":needRoot,"isHeadless":false,"description":descStr}
      if hasIndex(plan,"commandKnowledge") then step.commandKnowledge=plan.commandKnowledge
      if hasIndex(parsed,"continuationCommands") then step.continuationCommands=parsed.continuationCommands
      if hasIndex(parsed,"needsInteractiveShell") and parsed.needsInteractiveShell then step.needsInteractiveShell=true
      if requirements then step.requirements=requirements
      if outLvl>=1 then print skyblue("Agent: Using scanCustom router shell fetch for "+pubTarget)
      push(plan.steps,step)
      return plan
    end if
  end if
  //If we have specific requirements (especially LAN targets), skip command selection and go straight to exploit
  if requirements and (hasIndex(requirements,"targetIP") or hasIndex(requirements,"privilege") or hasIndex(requirements,"objectType")) then
    //Build scan + exploit steps for requirement-based attacks
    step1={"type":"scan","target":scanTarget,"flag":"-n","autonomous":true,"description":"Scan "+scanTarget}
    step2={"type":"exploit","target":target,"autonomous":true,"description":"Exploit "+target}
    //Keep router/public IP on steps - target alone is often the LAN goal
    if hasIndex(parsed,"publicIP") and parsed.publicIP then
      step1.publicIP=parsed.publicIP
      step2.publicIP=parsed.publicIP
    else if scanTarget and not is_lan_ip(scanTarget) then
      step1.publicIP=scanTarget
      step2.publicIP=scanTarget
    end if
    if hasIndex(parsed,"lanIP") and parsed.lanIP then step2.lanIP=parsed.lanIP
    if requirements then
      step1.requirements=requirements
      step2.requirements=requirements
    end if
    //Pass continuation commands if present
    if hasIndex(parsed,"continuationCommands") then step2.continuationCommands=parsed.continuationCommands
    push(plan.steps,step1)
    push(plan.steps,step2)
    return plan
  end if
  //Scan/recon goals: scan only (no auto-exploit)
  if goal=="scan" or goal=="recon" then
    step={"type":"scan","target":scanTarget,"flag":"-n","autonomous":true,"description":"Scan "+scanTarget}
    if requirements then step.requirements=requirements
    push(plan.steps,step)
    return plan
  end if
  //Default autonomous attack/compromise: scan then exploit
  if not goal or goal=="compromise" or goal=="attack" then
    step1={"type":"scan","target":scanTarget,"flag":"-n","autonomous":true,"description":"Scan "+scanTarget}
    step2={"type":"exploit","target":target,"autonomous":true,"description":"Exploit "+target}
    if hasIndex(parsed,"publicIP") and parsed.publicIP then
      step1.publicIP=parsed.publicIP
      step2.publicIP=parsed.publicIP
    else if scanTarget and not is_lan_ip(scanTarget) then
      step1.publicIP=scanTarget
      step2.publicIP=scanTarget
    end if
    if hasIndex(parsed,"lanIP") and parsed.lanIP then step2.lanIP=parsed.lanIP
    if requirements then
      step1.requirements=requirements
      step2.requirements=requirements
    end if
    if hasIndex(parsed,"continuationCommands") then step2.continuationCommands=parsed.continuationCommands
    if hasIndex(parsed,"needsInteractiveShell") and parsed.needsInteractiveShell then
      step2.needsInteractiveShell=true
      if debug then print green("[DEBUG] Step 2 will open interactive shell (not headless)")
    end if
    push(plan.steps,step1)
    push(plan.steps,step2)
    return plan
  end if
  chosenCommand=globals.G_agent._chooseBestCommand(goal,context)
  if chosenCommand then
    if chosenCommand=="scan" or chosenCommand=="nmap" then
      step={"type":"scan","target":target,"flag":"-n","autonomous":true,"description":"Autonomously scan "+target}
      if requirements then step.requirements=requirements
      push(plan.steps,step)
    else if chosenCommand=="crack" then
      step={"type":"crackPassword","target":target,"autonomous":true,"description":"Autonomously crack "+target}
      if requirements then step.requirements=requirements
      push(plan.steps,step)
    else if chosenCommand=="exploit" then
      step={"type":"exploit","target":target,"autonomous":true,"description":"Autonomously exploit "+target}
      if requirements then step.requirements=requirements
      push(plan.steps,step)
    else
      step={"type":"directCommand","command":chosenCommand+" "+target,"autonomous":true,"description":"Autonomously execute "+chosenCommand}
      if requirements then step.requirements=requirements
      push(plan.steps,step)
    end if
  else
    if goal=="scan" or goal=="recon" then
      step={"type":"scan","target":target,"flag":"-n","autonomous":true,"description":"Scan "+target}
      if requirements then step.requirements=requirements
      push(plan.steps,step)
    else if goal=="password" then
      step={"type":"crackPassword","target":target,"autonomous":true,"description":"Crack passwords on "+target}
      if requirements then step.requirements=requirements
      push(plan.steps,step)
    else if goal=="root" then
      step1={"type":"scan","target":target,"flag":"-n","autonomous":true,"description":"Scan "+target}
      step2={"type":"exploit","target":target,"autonomous":true,"description":"Exploit "+target}
      step3={"type":"escalate","target":target,"autonomous":true,"description":"Escalate to root on "+target}
      if requirements then
        step1.requirements=requirements
        step2.requirements=requirements
        step3.requirements=requirements
      end if
      push(plan.steps,step1)
      push(plan.steps,step2)
      push(plan.steps,step3)
    else
      step1={"type":"scan","target":target,"flag":"-n","autonomous":true,"description":"Scan "+target}
      step2={"type":"exploit","target":target,"autonomous":true,"description":"Exploit "+target}
      if requirements then
        step1.requirements=requirements
        step2.requirements=requirements
      end if
      push(plan.steps,step1)
      push(plan.steps,step2)
    end if
  end if
  return plan
end function
AgentPlanning._buildKnowledgePlan=function(Obj,parsed,plan);push(plan.steps,{"type":"knowledge","command":parsed.knowledgeCommand,"description":"Get information about "+parsed.knowledgeCommand});return plan;end function
AgentPlanning._buildGetObjectPlan=function(Obj,parsed,plan)
  debug=globals.G_agent.config.debug
  outLvl=globals.G_agent.config.outputLevel
  objectType="computer"
  if hasIndex(parsed,"objectType") then objectType=parsed.objectType
  isHeadless=false
  if hasIndex(parsed,"isHeadless") then isHeadless=parsed.isHeadless
  //Check if headless flag was set by multi-step handler
  if hasIndex(parsed,"headless") and parsed.headless then isHeadless=true
  needRoot=false
  if hasIndex(parsed,"needRoot") then needRoot=parsed.needRoot
  //Check if interactive shell is needed
  needsInteractiveShell=false
  if hasIndex(parsed,"needsInteractiveShell") then needsInteractiveShell=parsed.needsInteractiveShell
  //Create context and pass shouldStore flag if present
  context={}
  if hasIndex(parsed,"shouldStore") then
    context.shouldStore=parsed.shouldStore
    if debug then print green("[DEBUG] Planning: Set context.shouldStore = "+str(context.shouldStore))
  end if
  if hasIndex(parsed,"originalInput") then context.originalCommand=parsed.originalInput
  plan.context=context
  //Check if we have both IPs
  if hasIndex(parsed,"publicIP") and hasIndex(parsed,"lanIP") then
    //Have both - bounce via man-learned scan flag (ai learn scan -> --b)
    bounceFlag="--b"
    if hasIndex(globals.G_agent,"_getScanFlagForIntent") then bounceFlag=globals.G_agent._getScanFlagForIntent("bounce")
    if not bounceFlag then bounceFlag="--b"
    descStr="scan "+bounceFlag+" -p "+parsed.publicIP+" -l "+parsed.lanIP
    if needRoot then descStr="Get root "+objectType+" via "+descStr else descStr="Get "+objectType+" via "+descStr
    step={"type":"getObject","publicIP":parsed.publicIP,"lanIP":parsed.lanIP,"objectType":objectType,"isHeadless":isHeadless,"needRoot":needRoot,"description":descStr,"tool":"scan","flag":bounceFlag}
    if hasIndex(plan,"commandKnowledge") then step.commandKnowledge=plan.commandKnowledge
    if needsInteractiveShell then step.needsInteractiveShell=needsInteractiveShell
    if outLvl>=1 then print skyblue("Agent: Using man scan flag "+bounceFlag+" for LAN bounce")
    push(plan.steps,step)
  else if hasIndex(parsed,"lanIP") and not hasIndex(parsed,"publicIP") then
    //Only have LAN IP - need to scan for routers first
    descStr="Find router and get "+objectType+" on "+parsed.lanIP
    if needRoot then descStr="Find router and get root "+objectType+" on "+parsed.lanIP
    //Step 1: LAN scan to find routers
    push(plan.steps,{"type":"scan","flag":"-l","description":"Scan LAN for routers"})
    //Step 2: Get object via router bounce (handler will use found router)
    step={"type":"getObject","lanIP":parsed.lanIP,"objectType":objectType,"isHeadless":isHeadless,"needRoot":needRoot,"autoFindRouter":true,"description":descStr}
    if needsInteractiveShell then step.needsInteractiveShell=needsInteractiveShell
    push(plan.steps,step)
  else
    //Missing required IPs
    push(plan.steps,{"type":"error","description":"Need LAN IP for object access"})
  end if
  return plan
end function
AgentPlanning._buildExtractDataPlan=function(Obj,parsed,plan)
  debug=globals.G_agent.config.debug
  target=null
  if hasIndex(parsed,"target") then target=parsed.target
  //Check if this is a shorthand command without a target
  if not target and hasIndex(parsed,"shorthand") and parsed.shorthand then
    push(plan.steps,{"type":"error","description":"No target specified. Use 'ai <command> <target>' first, or specify a target: 'ai "+parsed.dataType+" <IP>'"})
    return plan
  end if
  //Map dataType to dig flag
  flag=null
  if hasIndex(parsed,"dataType") then
    if debug then print green("[DEBUG PLANNING] parsed.dataType="+parsed.dataType)
    if parsed.dataType=="email" then
      flag="-e"
    else if parsed.dataType=="bank" then
      flag="-b"
    else if parsed.dataType=="user" then
      flag="-u"
    else if parsed.dataType=="rshell" then
      flag="-r"
    else if parsed.dataType=="all" then
      flag="-a"
    end if
    if debug then print green("[DEBUG PLANNING] Mapped to flag="+str(flag))
  end if
  step={"type":"dataExtraction","target":target,"dataType":parsed.dataType,"description":"Extract "+parsed.dataType+" data"}
  if flag then step.flag=flag
  if debug then
    flagStatus="<not set>"
    if hasIndex(step,"flag") then flagStatus=str(step.flag)
    if debug then print green("[DEBUG PLANNING] step.flag set to "+flagStatus)
  end if
  if hasIndex(parsed,"useFilter") then step.useFilter=parsed.useFilter
  if hasIndex(parsed,"saveResults") then step.saveResults=parsed.saveResults
  //Pass extracted IPs for multi-IP commands ("via" syntax)
  if hasIndex(parsed,"extractedIps") then step.extractedIps=parsed.extractedIps
  //Wire dig fallbackDataType into in-plan hasFallback / isFallback skip path
  if hasIndex(parsed,"fallbackDataType") and parsed.fallbackDataType then
    step.hasFallback=true
    push(plan.steps,step)
    fbFlag=null
    fbType=parsed.fallbackDataType
    if fbType=="email" then
      fbFlag="-e"
    else if fbType=="bank" then
      fbFlag="-b"
    else if fbType=="user" then
      fbFlag="-u"
    else if fbType=="rshell" then
      fbFlag="-r"
    else if fbType=="all" then
      fbFlag="-a"
    end if
    fbStep={"type":"dataExtractionFallback","target":target,"dataType":fbType,"description":"Fallback: extract "+fbType+" data","isFallback":true}
    if fbFlag then fbStep.flag=fbFlag
    if hasIndex(parsed,"useFilter") then fbStep.useFilter=parsed.useFilter
    if hasIndex(parsed,"saveResults") then fbStep.saveResults=parsed.saveResults
    if hasIndex(parsed,"extractedIps") then fbStep.extractedIps=parsed.extractedIps
    push(plan.steps,fbStep)
    return plan
  end if
  push(plan.steps,step)
  return plan
end function
AgentPlanning._buildScanPlan=function(Obj,parsed,plan)
  outLvl=globals.G_agent.config.outputLevel
  //Check if we have a flag that doesn't require a target (like -r for random or -l for localhost)
  if hasIndex(parsed,"flag") and (parsed.flag=="-r" or parsed.flag=="-l") then
    //Flag-only scan - no target needed
    description="Scan random network"
    if parsed.flag=="-l" then description="Scan localhost"
    scanStep={"type":"scan","flag":parsed.flag,"description":description}
    if hasIndex(parsed,"headless") and parsed.headless then scanStep.autonomous=true
    push(plan.steps,scanStep)
    return plan
  end if
  if not hasIndex(parsed,"target") or not parsed.target then
    //Check if this is a shorthand command
    if hasIndex(parsed,"shorthand") and parsed.shorthand then push(plan.steps,{"type":"error","description":"No target specified. Use 'ai scan <target>' first to set a target, or specify one: 'ai scan <IP>'"}) else push(plan.steps,{"type":"error","description":"No target specified for scan"})
    return plan
  end if
  target=parsed.target
  scanMode="lan"
  if indexOf(target,".")!=-1 and len(split(target,"\."))==4 then
    parts=split(target,"\.")
    if parts[0]=="192" or parts[0]=="10" or parts[0]=="172" then scanMode="lan" else scanMode="external"
  end if
  scanFlag="-n"
  if scanMode=="external" then scanFlag="-l"
  if hasIndex(parsed,"flag") then scanFlag=parsed.flag
  reason="external target"
  if scanMode=="lan" then reason="LAN target"
  if outLvl>=2 then print yellow("[VERBOSE] Agent: Chose scan flag "+scanFlag+" because "+reason)
  //Mark as autonomous if in headless mode to prevent interactive prompts
  scanStep={"type":"scan","target":target,"flag":scanFlag,"description":"Scan "+target}
  if hasIndex(parsed,"headless") and parsed.headless then scanStep.autonomous=true
  push(plan.steps,scanStep)
  return plan
end function
AgentPlanning._buildCrackAllPlan=function(Obj,parsed,plan)
  //Crack all accounts on target system
  //Use AI to discover the right commands dynamically - no transformations
  target=null
  if hasIndex(parsed,"target") then target=parsed.target
  //Step 1: Extract subject from query and discover how to list it
  //Remove action words and let system figure out the best command
  queryLower=lower(parsed.raw)
  actionWords=["crack","break","get","fetch","find","attack","exploit"]
  discoveryQuery=queryLower
  for action in actionWords;discoveryQuery=discoveryQuery.replace(action+" ","");discoveryQuery=discoveryQuery.replace(action,"");end for
  //Add "list" or "show" prefix to help system understand we want to discover/enumerate
  if indexOf(discoveryQuery,"list")==null and indexOf(discoveryQuery,"show")==null then discoveryQuery="list "+trim(discoveryQuery)
  listCmd=globals.G_agent._discoverCommand(Obj,discoveryQuery)
  if listCmd then push(plan.steps,{"type":"directCommand","command":listCmd,"description":"Discover accounts"})
  //Step 2: Crack root password
  push(plan.steps,{"type":"crackPassword","target":target,"user":"root","description":"Crack root password"})
  return plan
end function
AgentPlanning._buildExploitPlan=function(Obj,parsed,plan)
  if not hasIndex(parsed,"target") then
    push(plan.steps,{"type":"error","description":"No target specified for exploit"})
    return plan
  end if
  push(plan.steps,{"type":"exploit","target":parsed.target,"description":"Exploit "+parsed.target})
  return plan
end function
AgentPlanning._buildAttackPlan=function(Obj,parsed,plan)
  if not hasIndex(parsed,"target") then
    push(plan.steps,{"type":"error","description":"No target specified for attack"})
    return plan
  end if
  push(plan.steps,{"type":"attack","target":parsed.target,"description":"Attack "+parsed.target})
  return plan
end function
AgentPlanning._buildEscalatePlan=function(Obj,parsed,plan);push(plan.steps,{"type":"escalate","description":"Escalate privileges"});return plan;end function
AgentPlanning._buildReconPlan=function(Obj,parsed,plan)
  if not hasIndex(parsed,"target") then
    push(plan.steps,{"type":"error","description":"No target specified for recon"})
    return plan
  end if
  push(plan.steps,{"type":"recon","target":parsed.target,"description":"Recon "+parsed.target})
  return plan
end function
AgentPlanning._buildBackdoorPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"backdoor","description":"Install backdoor"});return plan;end function
AgentPlanning._buildDirectCommandPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"directCommand","command":parsed.command,"description":"Execute: "+parsed.command});return plan;end function
AgentPlanning._buildViewPlan=function(Obj,parsed,plan)
  step={"type":"view"}
  //Check if we have a file path or an application flag
  if hasIndex(parsed,"path") then
    step.path=parsed.path
    step.description="View "+parsed.path
  else if hasIndex(parsed,"openFlag") then
    step.openFlag=parsed.openFlag
    if hasIndex(parsed,"summary") then step.description=parsed.summary else step.description="Open application"
  else if hasIndex(parsed,"searchLocation") then
    step.searchLocation=parsed.searchLocation
    step.description="Search and open file"
  else
    step.description="Open file"
  end if
  push(plan.steps,step)
  return plan
end function
AgentPlanning._buildBrowserPlan=function(Obj,parsed,plan)
  if not hasIndex(parsed,"url") then
    push(plan.steps,{"type":"error","description":"Browser action requires URL"})
    return plan
  end if
  push(plan.steps,{"type":"browser","url":parsed.url,"description":"Open "+parsed.url})
  return plan
end function
AgentPlanning._buildFetchPlan=function(Obj,parsed,plan)
  debug=globals.G_agent.config.debug
  if not hasIndex(parsed,"url") then
    //No URL means this is a fetch shell command
    //Check if we have a target
    if not hasIndex(parsed,"target") then
      push(plan.steps,{"type":"error","description":"No target specified for fetch"})
      return plan
    end if
    //Build fetchShell step with all the parsed parameters
    step={"type":"fetchShell","target":parsed.target,"description":parsed.summary}
    if hasIndex(parsed,"service") then step.service=parsed.service
    if hasIndex(parsed,"objectType") then step.objectType=parsed.objectType
    if hasIndex(parsed,"needRoot") then step.needRoot=parsed.needRoot
    if hasIndex(parsed,"isHeadless") then step.isHeadless=parsed.isHeadless
    //If shouldStore is set, force headless mode
    if hasIndex(parsed,"shouldStore") and parsed.shouldStore then step.isHeadless=true
    if hasIndex(parsed,"libsToInstall") then step.libsToInstall=parsed.libsToInstall
    if hasIndex(parsed,"autoSu") then step.autoSu=parsed.autoSu
    if hasIndex(parsed,"extractedIps") then step.extractedIps=parsed.extractedIps
    if hasIndex(plan,"commandKnowledge") then step.commandKnowledge=plan.commandKnowledge
    push(plan.steps,step)
    //Create context and pass shouldStore flag if present
    context={}
    if hasIndex(parsed,"shouldStore") then
      context.shouldStore=parsed.shouldStore
      if debug then print green("[DEBUG] Planning (fetch): Set context.shouldStore = "+str(context.shouldStore))
    end if
    plan.context=context
    //Add continuation commands if present
    if hasIndex(parsed,"continuationCommands") and len(parsed.continuationCommands)>0 then
      for contCmd in parsed.continuationCommands;push(plan.steps,{"type":"directCommand","command":contCmd,"description":"Execute: "+contCmd});end for
    end if
    return plan
  end if
  push(plan.steps,{"type":"fetch","url":parsed.url,"description":"Fetch "+parsed.url})
  return plan
end function
AgentPlanning._buildProxyPlan=function(Obj,parsed,plan)
  target=null
  if hasIndex(parsed,"target") then target=parsed.target
  step={"type":"proxy","quiet":true,"description":"Create proxy session"}
  if target then
    step.target=target
    step.description="Use proxy "+target
  end if
  push(plan.steps,step)
  return plan
end function
AgentPlanning._buildSuPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"su","user":parsed.user,"description":"Switch to user "+parsed.user});return plan;end function
AgentPlanning._buildNetworkToolPlan=function(Obj,parsed,plan)
  target=""
  if hasIndex(parsed,"target") then target=parsed.target
  desc=parsed.action
  if target then desc=parsed.action+" "+target
  push(plan.steps,{"type":"networkTool","tool":parsed.action,"target":target,"description":desc})
  return plan
end function
AgentPlanning._buildBuildExecPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"buildExec","command":parsed.action,"description":"Build/execute"});return plan;end function
AgentPlanning._buildFileOpPlan=function(Obj,parsed,plan)
  step={"type":"fileOp","command":parsed.action,"description":"File operation"}
  if hasIndex(parsed,"source") then step.source=parsed.source
  if hasIndex(parsed,"target") then step.target=parsed.target
  if hasIndex(parsed,"destination") then step.destination=parsed.destination
  if hasIndex(parsed,"permValue") then step.permValue=parsed.permValue
  push(plan.steps,step)
  return plan
end function
AgentPlanning._buildFileContentPlan=function(Obj,parsed,plan)
  step={"type":"fileContent","command":parsed.action,"description":"File content operation"}
  if hasIndex(parsed,"target") then step.target=parsed.target
  if hasIndex(parsed,"content") then step.content=parsed.content
  if hasIndex(parsed,"pattern") then step.pattern=parsed.pattern
  push(plan.steps,step)
  return plan
end function
AgentPlanning._buildEncryptPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"encrypt","command":parsed.action,"description":"Encryption operation"});return plan;end function
AgentPlanning._buildUserMgmtPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"userMgmt","command":parsed.action,"description":"User management"});return plan;end function
AgentPlanning._buildWifiAttackPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"wifiAttack","command":parsed.action,"description":"WiFi attack"});return plan;end function
AgentPlanning._buildNetworkCmdPlan=function(Obj,parsed,plan)
  step={"type":"networkCmd","command":parsed.action,"description":"Network command"}
  if hasIndex(parsed,"flags") then step.flags=parsed.flags
  if hasIndex(parsed,"target") then step.target=parsed.target
  push(plan.steps,step)
  return plan
end function
AgentPlanning._buildPushPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"push","description":"Deploy/push"});return plan;end function
AgentPlanning._buildTuxPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"tux","description":"Tux operation"});return plan;end function
AgentPlanning._buildAdvancedAttackPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"advancedAttack","command":parsed.action,"description":"Advanced attack"});return plan;end function
AgentPlanning._buildTransferPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"transfer","command":parsed.action,"description":"File transfer"});return plan;end function
AgentPlanning._buildProcessPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"process","command":parsed.action,"description":"Process management"});return plan;end function
AgentPlanning._buildMailPlan=function(Obj,parsed,plan)
  target=null
  if hasIndex(parsed,"target") then target=parsed.target
  push(plan.steps,{"type":"email","target":target,"description":"Mail operation"})
  return plan
end function
AgentPlanning._buildDecipherPlan=function(Obj,parsed,plan)
  step={"type":"decipher","description":"Decipher"}
  //Extract hash or target from parsed command
  if hasIndex(parsed,"hash") then
    step.target=parsed.hash
  else if hasIndex(parsed,"target") then
    step.target=parsed.target
  else if hasIndex(parsed,"args") and len(parsed.args)>0 then
    step.target=parsed.args[0]
  else
    //Ask via typed dialog on execute (avoids blocking user_input mid-plan)
    plan.needsHash=true
    plan.hashResumeCommand="decipher"
    return plan
  end if
  push(plan.steps,step)
  return plan
end function
AgentPlanning._buildLogsPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"logs","command":parsed.action,"description":"Logs operation"});return plan;end function
AgentPlanning._buildNetConfigPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"netConfig","command":parsed.action,"description":"Network config"});return plan;end function
AgentPlanning._buildCompressionPlan=function(Obj,parsed,plan);push(plan.steps,{"type":"compression","command":parsed.action,"description":"Compression"});return plan;end function
AgentPlanning._buildPermissionsPlan=function(Obj,parsed,plan)
  debug=globals.G_agent.config.debug
  step={"type":"permissions","command":parsed.action,"description":"Change permissions"}
  if hasIndex(parsed,"target") then step.target=parsed.target
  if hasIndex(parsed,"permValue") then step.permValue=parsed.permValue
  if hasIndex(parsed,"user") then 
    step.user=parsed.user
    if debug then print green("[DEBUG] Planning: Copied user='"+parsed.user+"' to step")
  end if
  if hasIndex(parsed,"group") then 
    step.group=parsed.group
    if debug then print green("[DEBUG] Planning: Copied group='"+parsed.group+"' to step")
  end if
  push(plan.steps,step)
  return plan
end function
AgentPlanning._buildEsPlan=function(Obj,parsed,plan)
  step={"type":"permissions","command":"es","description":"Discrete exploit scan"}
  //Check if we have IP + port or library
  if hasIndex(parsed,"target") and hasIndex(parsed,"port") then
    step.target=parsed.target
    step.port=parsed.port
    step.description="Scan "+parsed.target+":"+parsed.port
  else if hasIndex(parsed,"library") then
    step.library=parsed.library
    step.description="Scan "+parsed.library+" library"
  end if
  push(plan.steps,step)
  return plan
end function
AgentPlanning._buildWifiPlan=function(Obj,parsed,plan)
  step={"type":"permissions","command":"iwlist","description":"List WiFi networks"}
  if hasIndex(parsed,"flag") then
    step.flag=parsed.flag
    if parsed.flag=="-l" then step.description="List WiFi networks"
  end if
  push(plan.steps,step)
  return plan
end function
AgentPlanning._buildPromptPlan=function(Obj,parsed,plan)
  plan.needsPrompt=true
  plan.promptMessage=parsed.summary
  plan.options=parsed.options
  return plan
end function
//Multi-target plan builder: apply same action to multiple IPs
//True if template is a repeated single action (e.g. exploit->exploit->exploit)
AgentPlanning._isDegenerateTemplate=function(tmpl)
  if not tmpl or not hasIndex(tmpl,"signature") or not tmpl.signature then return true
  sigParts=split(tmpl.signature,"->")
  if len(sigParts)<2 then return true
  first=sigParts[0]
  if not first or first=="unknown" then return true
  for part in sigParts;if part!=first then return false;end for
  return true
end function
//AI: Fuzzy template matching - score how well a parsed action matches a template
AgentPlanning._scoreFuzzyTemplate=function(action,tmpl)
  if not action or not hasIndex(tmpl,"signature") then return 0
  if globals.G_agent._isDegenerateTemplate(tmpl) then return 0
  sigParts=split(tmpl.signature,"->")
  //Exact match: action appears directly in signature
  if indexOf(sigParts,action)!=null then return 1.0
  //Similarity groups: related actions that should partially match
  groups=[]
  push(groups,["exploit","attack","hack","pwn","compromise","break"])
  push(groups,["scan","probe","recon","enumerate","discover","check"])
  push(groups,["crack","brute","bruteforce","decrypt","password"])
  push(groups,["fetch","get","grab","pull","retrieve","extract","dump"])
  push(groups,["find","search","locate","look","list"])
  push(groups,["connect","ssh","shell","rshell","access","login"])
  push(groups,["install","deploy","setup","upload","push"])
  push(groups,["delete","remove","wipe","clean","purge"])
  //Find which group the action belongs to
  actionGroup=null
  for g in groups
    if indexOf(g,action)!=null then
      actionGroup=g
      break
    end if
  end for
  if actionGroup==null then return 0
  //Check if any signature part is in the same group
  bestPartScore=0
  for part in sigParts
    if indexOf(actionGroup,part)!=null then
      bestPartScore=0.8
      break
    end if
  end for
  if bestPartScore==0 then return 0
  //Bonus for higher success counts (diminishing returns)
  successBonus=0
  if tmpl.successCount>2 then successBonus=0.05
  if tmpl.successCount>5 then successBonus=0.1
  score=bestPartScore+successBonus
  if score>1.0 then score=1.0
  return score
end function
AgentPlanning._buildMultiTargetPlan=function(Obj,parsed,plan)
  outLvl=globals.G_agent.config.outputLevel
  if not hasIndex(parsed,"targets") or len(parsed.targets)==0 then
    push(plan.steps,{"type":"error","description":"No targets specified for multi-target operation"})
    return plan
  end if
  targetAction=parsed.targetAction
  if not targetAction then targetAction="scan"
  if outLvl>=1 then print skyblue("Agent: Batching "+targetAction+" on "+len(parsed.targets)+" targets (headless, continue-on-fail)")
  plan.context={"multiTarget":true,"targetAction":targetAction,"targetResults":[],"aggregate":true}
  for ip in parsed.targets
    step={}
    step.type="multiTargetStep"
    step.target=ip
    step.targetAction=targetAction
    step.description=targetAction+" "+ip
    step.continueOnFail=true
    step.critical=false
    push(plan.steps,step)
  end for
  return plan
end function
