// =============================================================================
// AGENT_HANDLERS_ATTACK
// Scan / exploit step handlers and autonomous exploit scoring/selection.
// Companion: agent_handlers_access.src (getObject, escalate, crack, fetch, ...)
// =============================================================================
//True when the active session is already on a router (proxy / router shell)
AgentHandlers._isRouterSession=function(Obj)
  if not Obj or typeof(Obj)!="map" then return false
  if hasIndex(Obj,"layer") and Obj.layer=="proxy" then return true
  if hasIndex(Obj,"machineType") then
    mt=lower(str(Obj.machineType))
    if indexOf(mt,"router")!=null or mt=="switch" then return true
  end if
  return false
end function
//Public IP for the active session, if known
AgentHandlers._sessionPublicIP=function(Obj)
  if not Obj then return null
  if hasIndex(Obj,"meta") and typeof(Obj.meta)=="map" and hasIndex(Obj.meta,"public_ip") and Obj.meta.public_ip then return Obj.meta.public_ip
  if hasIndex(Obj,"computer") and Obj.computer and hasIndex(Obj.computer,"public_ip") and Obj.computer.public_ip then return Obj.computer.public_ip
  return null
end function
//True if lanIP appears on the current session router's device list
AgentHandlers._lanReachableFromSession=function(Obj,lanIP)
  if not lanIP or not is_lan_ip(lanIP) then return false
  pub=AgentHandlers._sessionPublicIP(Obj)
  r=null
  if pub then r=get_router(pub)
  if not r then r=get_router
  if not r then return false
  devices=devices_lan_ip(r)
  if not devices then return false
  for d in devices;if d==lanIP then return true;end for
  return false
end function
//Autonomous scan helper - Obj required so extract uses proxy/session metaxploit (OPSEC)
AgentHandlers._scanAutonomous=function(targetIp,Obj=null)
  outLvl=globals.G_agent.config.outputLevel
  if not targetIp then return []
  if typeof(Exploit)!="map" then return []
  //Get router at target (same as scan command)
  r=get_router(targetIp)
  if not r then return []
  //Extract via session/proxy metaxploit - never bare Library.metaxploit while proxied
  _mx=Library.mxFor(Obj)
  libraries=Exploit.extract(r,targetIp,_mx)
  if not libraries or libraries isa Error then return []
  if outLvl>=2 then print skyblue("Agent: Autonomous scan found "+len(libraries)+" exploitable libraries")
  //Process each library - check database first, only scan if needed
  attackVectors=[]
  for lib in libraries
    if not hasIndex(lib,"metaLib") then continue
    metaLib=lib.metaLib
    if not metaLib then continue
    libName=lib_name(metaLib)
    if not libName then continue
    libVersion=version(metaLib)
    cacheKey=libName+"_"+libVersion
    exploitCount=0
    //Check if library already exists in database using haveAlready
    if typeof(Exploit)=="map" and hasIndex(Exploit,"haveAlready") then
      if not Exploit.haveAlready(metaLib) then
        //Library not in database - add it by calling headless once
        if hasIndex(Exploit,"headless") then
          if outLvl>=2 then print skyblue("Agent: Adding "+libName+" to database...")
          Exploit.headless(metaLib)
        end if
      else
        if outLvl>=2 then print green("Agent: Using cached data for "+libName)
      end if
    end if
    //Get exploit count from cache (should be there now)
    if typeof(globals.G_exploitCache)=="map" and hasIndex(globals.G_exploitCache,cacheKey) then
      cache=globals.G_exploitCache[cacheKey]
      if hasIndex(cache,"checksum") then exploitCount=cache.checksum else exploitCount=len(Exploit.ensureExploits(cache))
    end if
    //Build attack vector with all data for next step (same structure as scan output)
    vector={}
    vector.library=libName
    vector.version=libVersion
    vector.metaLib=metaLib //Keep metaLib for exploit step
    vector.exploitCount=exploitCount
    //Get target IP:port from library
    if hasIndex(lib,"local_ip") then
      vector.ip=lib.local_ip
      if hasIndex(lib,"port_number") then
        vector.port=lib.port_number
        vector.target=lib.local_ip+":"+lib.port_number
      else
        vector.port=0
        vector.target=lib.local_ip+":0"
      end if
    else
      vector.ip=targetIp
      vector.port=0
      vector.target=targetIp
    end if
    //Build description matching scan output format
    vector.description=libName
    if vector.version then vector.description=vector.description+" (Version: "+vector.version+")"
    vector.description=vector.description+" -> "+vector.target
    if exploitCount>0 then vector.description=vector.description+" ["+exploitCount+" exploits]"
    //Dedup identical library@target entries (extract can return duplicates)
    dedupeKey=libName+"@"+vector.target
    already=false
    for existing in attackVectors
      if existing.library+"@"+existing.target==dedupeKey then
        already=true
        break
      end if
    end for
    if not already then push(attackVectors,vector)
  end for
  if outLvl>=2 then print skyblue("Agent: Returning "+len(attackVectors)+" attack vectors for next step")
  return attackVectors
end function
//Priority: shell > computer > file (primary), then root > user > guest (secondary)
AgentHandlers._exploitObjectScore=function(objType)
  if objType=="shell" then return 300
  if objType=="computer" then return 200
  if objType=="file" then return 100
  if objType=="lan" then return 180
  if objType=="firewall" then return 40
  if objType=="password" then return 40
  if objType=="router" then return 20
  if objType=="unknown" then return 10
  return 0
end function
AgentHandlers._exploitPrivScore=function(userPriv)
  if userPriv=="root" then return 30
  if userPriv=="user" then return 20
  if userPriv=="guest" then return 10
  return 0
end function
AgentHandlers._classifyExploit=function(exploit)
  //Map cache e/u codes to display type, privilege, and whether it yields a session object
  info={"objType":"unknown","userPriv":"guest","canCapture":false,"typeCode":"?"}
  if not exploit or not hasIndex(exploit,"e") then return info
  exploitType=exploit.e
  info.typeCode=exploitType
  if exploitType=="s" then
    info.objType="shell";info.canCapture=true
  else if exploitType=="c" then
    info.objType="computer";info.canCapture=true
  else if exploitType=="f" then
    info.objType="file";info.canCapture=true
  else if exploitType=="l" or exploitType=="i" then
    info.objType="lan";info.canCapture=true
  else if exploitType=="d" then
    info.objType="firewall"
  else if exploitType=="p" or exploitType=="w" or exploitType=="n" then
    info.objType="password"
  else if exploitType=="t" then
    info.objType="router"
  else
    info.objType="unknown"
  end if
  if hasIndex(exploit,"u") then
    if exploit.u=="r" then info.userPriv="root"
    if exploit.u=="u" then info.userPriv="user"
    if exploit.u=="g" then info.userPriv="guest"
    if exploit.u=="?" then info.userPriv="unknown"
  end if
  return info
end function
AgentHandlers._exploitLabel=function(info)
  //Prefer Exploit.getItem names when available
  typeName=info.objType
  if typeof(Exploit)=="map" and hasIndex(Exploit,"getItem") and hasIndex(Exploit.getItem,info.typeCode) then typeName=lower(Exploit.getItem[info.typeCode])
  if info.userPriv and info.userPriv!="unknown" then return typeName+" ("+info.userPriv+")"
  return typeName
end function
AgentHandlers._sortScoredExploitsDesc=function(items)
  //Insertion sort by .score descending (don't rely on list.sort key form)
  n=len(items)
  i=1
  while i<n
    j=i
    while j>0 and items[j].score>items[j-1].score
      tmp=items[j]
      items[j]=items[j-1]
      items[j-1]=tmp
      j=j-1
    end while
    i=i+1
  end while
  return items
end function
AgentHandlers._loadVectorExploits=function(vector)
  //Resolve exploit list for a vector via Exploit.get / cache
  if not vector or not hasIndex(vector,"metaLib") or not vector.metaLib then return []
  if typeof(Exploit)!="map" then return []
  metaLib=vector.metaLib
  if hasIndex(Exploit,"haveAlready") and not Exploit.haveAlready(metaLib) and hasIndex(Exploit,"headless") then Exploit.headless(metaLib)
  if hasIndex(Exploit,"get") then
    exploits=Exploit.get(metaLib)
    if exploits and len(exploits)>0 then return exploits
  end if
  libName=null
  libVersion=null
  if hasIndex(vector,"library") then libName=vector.library
  if hasIndex(vector,"version") then libVersion=vector.version
  if not libName then libName=lib_name(metaLib)
  if not libVersion then libVersion=version(metaLib)
  if not libName or not libVersion then return []
  cacheKey=libName+"_"+libVersion
  if not hasIndex(globals.G_exploitCache,cacheKey) then return []
  return Exploit.ensureExploits(globals.G_exploitCache[cacheKey])
end function
//Build scored exploit candidates from attack vectors (no execution).
//Includes all typed exploits (shell/file/password/firewall/...) so the picker matches "N exploits on file".
AgentHandlers._buildScoredExploits=function(attackVectors,requirements)
  debug=globals.G_agent.config.debug
  scoredExploits=[]
  if not attackVectors or len(attackVectors)==0 then return scoredExploits
  for vector in attackVectors
    if not hasIndex(vector,"metaLib") or not vector.metaLib then continue
    libName=null
    if hasIndex(vector,"library") then libName=vector.library else libName=lib_name(vector.metaLib)
    if not libName then continue
    metaLib=vector.metaLib
    if requirements and hasIndex(requirements,"targetIP") then
      reqIP=requirements.targetIP
      if hasIndex(vector,"ip") and vector.ip!=reqIP then continue
    end if
    if requirements and hasIndex(requirements,"libraryType") then
      reqType=requirements.libraryType
      matchesType=false
      if reqType=="router" and indexOf(libName,"kernel_router")!=null then matchesType=true
      if reqType=="http" and indexOf(libName,"libhttp")!=null then matchesType=true
      if reqType=="ssh" and indexOf(libName,"libssh")!=null then matchesType=true
      if reqType=="ftp" and indexOf(libName,"libftp")!=null then matchesType=true
      if reqType=="sql" and indexOf(libName,"libsql")!=null then matchesType=true
      if not matchesType then continue
    end if
    if requirements and hasIndex(requirements,"excludeLibraryTypes") then
      isExcluded=false
      for excludeType in requirements.excludeLibraryTypes
        if excludeType=="router" and indexOf(libName,"kernel_router")!=null then isExcluded=true
        if excludeType=="http" and indexOf(libName,"libhttp")!=null then isExcluded=true
        if excludeType=="ssh" and indexOf(libName,"libssh")!=null then isExcluded=true
        if excludeType=="ftp" and indexOf(libName,"libftp")!=null then isExcluded=true
        if excludeType=="sql" and indexOf(libName,"libsql")!=null then isExcluded=true
        if isExcluded then break
      end for
      if isExcluded then
        if debug then print yellow("  Skipping "+libName+" (excluded type)")
        continue
      end if
    end if
    exploits=AgentHandlers._loadVectorExploits(vector)
    if not exploits or len(exploits)==0 then continue
    for exploit in exploits
      if not hasIndex(exploit,"m") or not hasIndex(exploit,"s") then continue
      if not hasIndex(exploit,"e") then continue
      info=AgentHandlers._classifyExploit(exploit)
      //Requirement filters only apply to capturable session objects
      if requirements and hasIndex(requirements,"objectType") and info.canCapture then
        if info.objType!=requirements.objectType then continue
      end if
      //Privilege: prefer exact match via score, but when root is required still allow
      //guest/user shells (su later). Hard-filter only for user/guest-only goals.
      if requirements and hasIndex(requirements,"privilege") and info.canCapture then
        if info.userPriv!=requirements.privilege then
          if requirements.privilege=="root" and (info.userPriv=="guest" or info.userPriv=="user") then
            //keep - escalate after capture
          else
            continue
          end if
        end if
      end if
      score=AgentHandlers._exploitObjectScore(info.objType)+AgentHandlers._exploitPrivScore(info.userPriv)
      if info.canCapture then score=score+50
      if requirements then
        if hasIndex(requirements,"libraryType") then score=score+5
        if hasIndex(requirements,"privilege") and info.userPriv==requirements.privilege then score=score+15
        if hasIndex(requirements,"objectType") and info.objType==requirements.objectType then score=score+5
        if hasIndex(requirements,"targetIP") then score=score+5
      end if
      //Skip exact cache duplicates (same library + memory + string indices)
      dedupeKey=libName+"|"+str(exploit.m)+"|"+str(exploit.s)
      already=false
      for existing in scoredExploits
        if hasIndex(existing,"dedupeKey") and existing.dedupeKey==dedupeKey then
          already=true
          break
        end if
      end for
      if already then continue
      scoredEx={}
      scoredEx.exploit=exploit
      scoredEx.metaLib=metaLib
      scoredEx.library=libName
      scoredEx.type=info.objType
      scoredEx.user=info.userPriv
      scoredEx.canCapture=info.canCapture
      scoredEx.typeCode=info.typeCode
      scoredEx.score=score
      scoredEx.dedupeKey=dedupeKey
      scoredEx.label=AgentHandlers._exploitLabel(info)
      //Memory + short string so same-mem / different-payload rows stay distinct
      mt="";st=""
      if typeof(Exploit)=="map" then
        if hasIndex(Exploit,"getmtree") then
          rawMt=Exploit.getmtree(exploit.m)
          if typeof(rawMt)=="string" and len(rawMt)>0 then
            if len(rawMt)>10 then mt=rawMt[:10] else mt=rawMt
          end if
        end if
        if hasIndex(Exploit,"getstree") then
          rawSt=Exploit.getstree(exploit.s)
          if typeof(rawSt)=="string" and len(rawSt)>0 then
            if len(rawSt)>8 then st=rawSt[:8] else st=rawSt
          end if
        end if
      end if
      hint=""
      if mt then hint=mt
      if st then
        if hint then hint=hint+"/"+st else hint=st
      end if
      if hint then
        scoredEx.label=scoredEx.label+" ["+hint+"]"
        scoredEx.mem=hint
      end if
      if hasIndex(vector,"ip") then scoredEx.ip=vector.ip
      if hasIndex(vector,"port") then scoredEx.port=vector.port
      if hasIndex(vector,"target") then scoredEx.target=vector.target
      push(scoredExploits,scoredEx)
    end for
  end for
  return AgentHandlers._sortScoredExploitsDesc(scoredExploits)
end function
//Picker list: capturable session objects only (hide password/unknown clutter)
AgentHandlers._pickerExploits=function(scoredExploits)
  picker=[]
  if not scoredExploits then return picker
  for scoredEx in scoredExploits
    if hasIndex(scoredEx,"canCapture") and scoredEx.canCapture then push(picker,scoredEx)
  end for
  if len(picker)>0 then return picker
  return scoredExploits
end function
//Autonomous attack function - uses cached exploits from database
//Returns captured objects with scoring: shells > computers > files, root > user > guest
//Filters by requirements if provided (e.g., libraryType="router", privilege="root")
AgentHandlers._attackAutonomous=function(attackVectors,requirements)
  debug=globals.G_agent.config.debug
  outLvl=globals.G_agent.config.outputLevel
  if not attackVectors or len(attackVectors)==0 then return []
  if outLvl>=2 then print skyblue("Agent: Using "+len(attackVectors)+" cached attack vectors from database")
  if requirements and outLvl>=2 then
    reqStr="Requirements:"
    if hasIndex(requirements,"libraryType") then reqStr=reqStr+" "+requirements.libraryType
    if hasIndex(requirements,"excludeLibraryTypes") then reqStr=reqStr+" (excluding: "+join(requirements.excludeLibraryTypes,", ")+")"
    if hasIndex(requirements,"privilege") then reqStr=reqStr+" "+requirements.privilege
    if hasIndex(requirements,"objectType") then reqStr=reqStr+" "+requirements.objectType
    if hasIndex(requirements,"targetIP") then reqStr=reqStr+" on "+requirements.targetIP
    print yellow(reqStr)
  end if
  scoredExploits=AgentHandlers._buildScoredExploits(attackVectors,requirements)
  forcedSingle=false
  //User picked a specific exploit via typed dialog
  if globals.G_agentContext and hasIndex(globals.G_agentContext,"selectedAttackExploit") and globals.G_agentContext.selectedAttackExploit then
    scoredExploits=[globals.G_agentContext.selectedAttackExploit]
    globals.G_agentContext.selectedAttackExploit=null
    forcedSingle=true
  else
    //Auto mode: only try exploits that can yield shell/computer/file
    capturable=[]
    for scoredEx in scoredExploits
      if hasIndex(scoredEx,"canCapture") and scoredEx.canCapture then push(capturable,scoredEx)
    end for
    scoredExploits=capturable
  end if
  if not forcedSingle and len(scoredExploits)>0 and outLvl>=1 then
    print skyblue("Agent: Auto-trying "+str(len(scoredExploits))+" exploits (shell>computer>file, root>user>guest)...")
  end if
  //Try exploits in priority order until we get a valid object
  bestCapture=null
  tried=0
  failed=0
  for scoredEx in scoredExploits
    exploit=scoredEx.exploit
    metaLib=scoredEx.metaLib
    memAddr=null
    unsafeVal=null
    if typeof(Exploit)=="map" then
      if hasIndex(Exploit,"getmtree") then memAddr=Exploit.getmtree(exploit.m)
      if hasIndex(Exploit,"getstree") then unsafeVal=Exploit.getstree(exploit.s)
    end if
    if not memAddr or not unsafeVal then continue
    tried+=1
    //Per-attempt detail only when verbose, or when user picked a specific exploit
    if forcedSingle or outLvl>=2 then print skyblue("Agent: Trying "+scoredEx.label+" from "+scoredEx.library)
    result=null
    if typeof(Exploit)=="map" and hasIndex(Exploit,"overflow") then result=Exploit.overflow(metaLib,exploit.m,exploit.s,null,"agent "+scoredEx.label) else result=overflow(metaLib,memAddr,unsafeVal)
    //Non-capture exploits (password/firewall): report and stop when user picked specifically
    if forcedSingle and hasIndex(scoredEx,"canCapture") and not scoredEx.canCapture then
      if result isa number or result==1 or result==0 then
        if outLvl>=1 then print green("Agent: Ran "+scoredEx.label+" on "+scoredEx.library+" (result: "+str(result)+")")
        return []
      end if
    end if
    if not result or result isa number or result isa string then
      failed+=1
      if outLvl>=2 then
        why="no object"
        if result isa string then
          why=result
        else if result isa number then
          why="code "+str(result)
        end if
        print yellow("Agent: Failed "+scoredEx.label+" ("+why+")")
      end if
      continue
    end if
    objType=typeof(result)
    if indexOf(objType,"shell")!=null then objType="shell"
    if objType!="shell" and objType!="computer" and objType!="file" then
      failed+=1
      continue
    end if
    bestCapture={}
    bestCapture.object=result
    bestCapture.type=objType
    bestCapture.user=scoredEx.user
    bestCapture.score=scoredEx.score
    bestCapture.library=scoredEx.library
    if hasIndex(scoredEx,"ip") then bestCapture.ip=scoredEx.ip
    if hasIndex(scoredEx,"port") then bestCapture.port=scoredEx.port
    if outLvl>=1 then
      if failed>0 and not forcedSingle then print white("Agent: "+str(failed)+" failed, then captured "+objType+" ("+scoredEx.user+")") else print green("Agent: Captured "+objType+" ("+scoredEx.user+") from "+scoredEx.library)
    end if
    break
  end for
  if bestCapture then return [bestCapture]
  if tried>0 and outLvl>=1 and not forcedSingle then print yellow("Agent: All "+str(tried)+" capturable exploits failed")
  if requirements and hasIndex(requirements,"targetIP") then
    targetIP=requirements.targetIP
    if is_lan_ip(targetIP) then
      if outLvl>=2 then
        print yellow("Agent: Target "+targetIP+" requires LAN bounce attack via router")
        print yellow("Agent: Direct exploitation not available - returning empty to trigger getObject")
      end if
      return []
    end if
  end if
  return []
end function
//LAN Setup - Prepare for bounce attacks when vulnerable library not configured
//Returns shell object in headless mode with metaxploit packed, ready for LAN attacks
AgentHandlers._setupLanBounce=function(Obj,requirements)
  outLvl=globals.G_agent.config.outputLevel
  if outLvl>=2 then print skyblue("Agent: Checking LAN bounce setup...")
  //Check if vulnerable library is already configured
  if hasIndex(globals,"G_settings") and hasIndex(globals.G_settings,"vulnerableLib") and hasIndex(globals.G_settings,"vulnerableLibIndex") then
    if globals.G_settings.vulnerableLib and globals.G_settings.vulnerableLibIndex then
      if outLvl>=2 then print green("Agent: Vulnerable library already configured - no setup needed")
      return {"success":true,"alreadyConfigured":true}
    end if
  end if
  //Already on a router/proxy shell - use current session (skip remote shell hunt)
  if AgentHandlers._isRouterSession(Obj) then
    sessionIP=AgentHandlers._sessionPublicIP(Obj)
    if outLvl>=2 then
      if sessionIP then print green("Agent: Already on router session "+sessionIP+" - using current shell") else print green("Agent: Already on router session - using current shell")
    end if
    if typeof(ShellObject)=="map" and hasIndex(ShellObject,"packMeta") then
      if not (hasIndex(Obj,"packMetaxploit") and Obj.packMetaxploit) then
        if outLvl>=2 then print skyblue("Agent: Packing metaxploit on current router session...")
        ShellObject.packMeta(Obj)
      end if
    end if
    userLevel="root"
    if hasIndex(Obj,"user") and typeof(Obj.user)=="map" and hasIndex(Obj.user,"raw") then userLevel=Obj.user.raw
    return {"success":true,"shell":Obj,"user":userLevel,"library":"current router","usedCurrentSession":true,"publicIP":sessionIP}
  end if
  //Need to set up LAN bounce capability
  if outLvl>=2 then print yellow("Agent: Vulnerable library not configured - initiating LAN setup...")
  //Step 1: Disable root requirements if user requested them (since we can't guarantee root without vuln lib)
  if requirements then
    if hasIndex(requirements,"requiresRoot") and requirements.requiresRoot then
      requirements.requiresRoot=false
      if outLvl>=2 then print yellow("Agent: Disabled requiresRoot (no vulnerable library)")
    end if
    if hasIndex(requirements,"needRoot") and requirements.needRoot then
      requirements.needRoot=false
      if outLvl>=2 then print yellow("Agent: Disabled needRoot (no vulnerable library)")
    end if
  end if
  //Step 2: Scan for router shell (scanCustom requires ip|library|target)
  if outLvl>=2 then print skyblue("Agent: Scanning network for router shells...")
  shell=null
  scanIP="-r"
  if requirements and hasIndex(requirements,"publicIP") and requirements.publicIP then scanIP=requirements.publicIP
  if typeof(Attack)=="map" and hasIndex(Attack,"scanCustom") then
    shell=Attack.scanCustom([scanIP,"router","s"],true, Obj)
    if (not shell or typeof(shell)!="shell") and scanIP!="-r" then shell=Attack.scanCustom(["-r","router","s"],true, Obj)
    if not shell or typeof(shell)!="shell" then shell=Attack.scanCustom([scanIP,"http","s"],true, Obj)
  end if
  //If no router shell found, try to get ANY shell on the network
  if not shell or typeof(shell)!="shell" then
    if outLvl>=2 then print yellow("Agent: No direct router shells - scanning for any available shell...")
    //Scan network for any exploitable service
    if hasIndex(Obj,"commands") and hasIndex(Obj.commands,"scan") then
      scanResult=Obj.commands.scan(["--n"])
      //Parse scan results to find exploitable services
      if scanResult and typeof(scanResult)=="string" then
        attackVectors=globals.G_agent._parseAttackVectors(scanResult)
        if attackVectors and len(attackVectors)>0 then
          //Try to capture any shell using autonomous attack
          capturedObjects=globals.G_agent._attackAutonomous(attackVectors,null)
          if capturedObjects and len(capturedObjects)>0 then
            shell=capturedObjects[0].object
            if outLvl>=2 then print green("Agent: Captured "+capturedObjects[0].user+" shell from "+capturedObjects[0].library)
          end if
        end if
      end if
    end if
  end if
  //Check if we found any shell
  if not shell or typeof(shell)!="shell" then
    if outLvl>=2 then print red("Agent: No shells available on network")
    return {"success":false,"error":"No shells available for LAN bounce setup"}
  end if
  if outLvl>=2 then print green("Agent: Found shell on network")
  //Step 3: Get shell in headless mode so we can execute commands
  if outLvl>=2 then print skyblue("Agent: Converting to headless mode...")
  headlessShell=Exploit.getShell(shell,false,[],true)
  if not headlessShell or headlessShell isa Error then
    if outLvl>=2 then print red("Agent: Failed to get headless shell")
    return {"success":false,"error":"Could not create headless shell"}
  end if
  //Determine user level from shell
  userLevel="guest"
  if hasIndex(headlessShell,"user") and hasIndex(headlessShell.user,"raw") then userLevel=headlessShell.user.raw
  if outLvl>=2 then print green("Agent: Got "+userLevel+" shell in headless mode")
  //Step 4 (optional): scan via ShellObject.commands - native shell has no .run
  if outLvl>=2 then print skyblue("Agent: Using shell to scan network for routers...")
  if hasIndex(headlessShell,"commands") and typeof(headlessShell.commands)=="map" and hasIndex(headlessShell.commands,"scan") then
    scanOutput=headlessShell.commands.scan(["--n","router","s"])
    if scanOutput and typeof(scanOutput)=="string" and (indexOf(scanOutput,"exploit")!=null or indexOf(scanOutput,"vulnerab")!=null) then
      if outLvl>=2 then print green("Agent: Found routers on network from shell scan")
    end if
    scanOutput2=headlessShell.commands.scan(["--n","http","s"])
    if scanOutput2 and typeof(scanOutput2)=="string" and (indexOf(scanOutput2,"exploit")!=null or indexOf(scanOutput2,"vulnerab")!=null) then
      if outLvl>=2 then print green("Agent: Found HTTP routers on network from shell scan")
    end if
  end if
  //Step 5: Pack custom objects using ShellObject.packMeta
  if outLvl>=2 then print skyblue("Agent: Packing metaxploit for LAN attacks...")
  if typeof(ShellObject)!="map" or not hasIndex(ShellObject,"packMeta") then
    if outLvl>=2 then print red("Agent: ShellObject.packMeta not available")
    return {"success":false,"error":"ShellObject.packMeta not available"}
  end if
  packResult=ShellObject.packMeta(headlessShell)
  if not packResult then
    if outLvl>=2 then print red("Agent: Failed to pack metaxploit")
    return {"success":false,"error":"Failed to pack custom objects"}
  end if
  if outLvl>=2 then print green("Agent: Successfully packed metaxploit - ready for LAN attacks")
  //Return the prepared shell
  return {"success":true,"shell":headlessShell,"user":userLevel,"library":"http router"}
end function
//Handler: Scan
AgentHandlers._handleScan=function(Obj,step,context)
  debug=globals.G_agent.config.debug
  outLvl=globals.G_agent.config.outputLevel
  result={"success":false,"step":"scan"}
  //Check if we need a target (not for local/lan scans or flag-based scans like -r)
  needsTarget=true
  if hasIndex(step,"scanMode") then
    if step.scanMode=="local" or step.scanMode=="lan" then needsTarget=false
  end if
  //Flag-based scans (like -r for random) don't need a target
  if hasIndex(step,"flag") and (step.flag=="-r" or step.flag=="-l" or step.flag=="-n") then needsTarget=false
  if needsTarget and not hasIndex(step,"target") then
    result.error="No target specified"
    result.critical=true
    return result
  end if
  //Build argv based on scan mode and service
  argv=[]
  //Check if we have a flag that doesn't need a target (like -r for random)
  if hasIndex(step,"flag") and not hasIndex(step,"target") then
    //Flag-only scan (like scan -r for random)
    argv=[step.flag]
    if debug then print green("[DEBUG] Built argv with flag='"+step.flag+"' for flag-only scan")
  else
    //Check if target is a subnet (contains CIDR notation)
    isSubnet=false
    if hasIndex(step,"target") and indexOf(step.target,"/")!=null then isSubnet=true
    //Check if specific service requested (but not for subnets - use network scan for those)
    if hasIndex(step,"service") and hasIndex(step,"target") and not isSubnet then
      //Service-specific scan: scan --c <ip> <service> <type>
      serviceType="s"  //default to shelluserLevel,"library":"http router"
      //Detect what type of access is needed from the command context
      if hasIndex(context,"goal") then
        if context.goal=="rootShell" or context.goal=="shell" then serviceType="s"
      end if
      //Check parsed command for explicit type keywords
      if hasIndex(step,"accessType") then
        if step.accessType=="shell" then
          serviceType="s"
        else if step.accessType=="file" then
          serviceType="f"
        else if step.accessType=="computer" then
          serviceType="c"
        end if
      end if
      //Use cached port knowledge if available
      port=globals.G_agent._getPortForService(step.service)
      if port!=null then
        if outLvl>=2 then print skyblue("Agent: Using learned port "+port+" for "+step.service)
        argv=["--c",step.target,port,serviceType]
      else
        argv=["--c",step.target,step.service,serviceType]
      end if
    else if isSubnet then
      //Subnet scan: use network scan mode
      //For subnets, we need to iterate through each IP in the range
      //For now, just pass the subnet directly and let the scan command handle it
      argv=["-n",step.target]
    else if hasIndex(step,"scanMode") then
      if step.scanMode=="local" then
        //Local mode: scan --l
        argv=["--l"]
      else if step.scanMode=="lan" then
        //Network scan: scan --n
        argv=["--n"]
      else if step.scanMode=="ip" and hasIndex(step,"target") then
        //Specific IP without service - general scan
        if globals.G_agent._isPrivateIp(step.target) then argv=["-n",step.target] else argv=[step.target]
      else if hasIndex(step,"target") then
        argv=[step.target]
      end if
    else if hasIndex(step,"target") then
      argv=[step.target]
    end if
  end if
  scanResult=null
  //Check if this is an autonomous scan - use non-interactive method
  isAutonomous=false
  if hasIndex(step,"autonomous") and step.autonomous then isAutonomous=true
  //For autonomous mode, use dedicated non-interactive scan
  if isAutonomous and hasIndex(step,"target") then
    if outLvl>=2 then print skyblue("Agent: Running autonomous scan on "+step.target)
    attackVectors=AgentHandlers._scanAutonomous(step.target,Obj)
    if attackVectors and len(attackVectors)>0 then
      context.availableExploits=attackVectors
      context.target=step.target
      result.success=true
      result.data="Found "+len(attackVectors)+" attack vectors"
      if outLvl>=2 then
        print skyblue("Agent: Attack vectors available:")
        for vec in attackVectors;print skyblue("  - "+vec.description);end for
      end if
      return result
    else
      result.error="No exploitable libraries found"
      result.critical=true
      return result
    end if
  end if
  //Interactive scan mode - use command
  //Use the specified tool if provided, otherwise try defaults
  if hasIndex(step,"tool") and hasIndex(Obj.commands,step.tool) then
    f=Obj.commands[step.tool]
    if globals.G_agent.config.trainer then print orange("Command you need to run: "+step.tool+" "+join(argv," "))
    //For autonomous mode, try to get libraries without interactive prompt
    if typeof(Exploit)=="map" and hasIndex(Exploit,"extract") and hasIndex(step,"target") then
      r=get_router(step.target)
      if r then
        scanLibraries=Exploit.extract(r,step.target,Library.mxFor(Obj))
        if scanLibraries and not (scanLibraries isa Error) then
          if outLvl>=2 then print skyblue("Agent: Extracted "+len(scanLibraries)+" libraries from scan")
          //Parse attack vectors from library list
          attackVectors=[]
          for lib in scanLibraries
            if not hasIndex(lib,"metaLib") then continue
            if not lib_name(lib.metaLib) then continue
            vector={}
            vector.library=lib_name(lib.metaLib)
            if hasIndex(lib,"local_ip") then
              if hasIndex(lib,"port_number") then vector.target=lib.local_ip+":"+lib.port_number else vector.target=lib.local_ip+":0"
            else
              vector.target=step.target
            end if
            vector.description=vector.library+" at "+vector.target
            vector.metaLib=lib.metaLib
            push(attackVectors,vector)
          end for
          if len(attackVectors)>0 then
            context.availableExploits=attackVectors
            context.scanLibraries=scanLibraries
            if outLvl>=2 then print skyblue("Agent: Found "+len(attackVectors)+" attack vectors")
          end if
        end if
      end if
    end if
    scanResult=f(argv)
    //Command executed - consider it successful even if return value is null
    result.success=true
    result.data=scanResult
    if hasIndex(step,"target") then context.target=step.target
    if scanResult!=null then
      context.scanData=scanResult
      //Parse attack vectors from scan output for autonomous exploitation (fallback if extract didn't work)
      if not hasIndex(context,"availableExploits") or len(context.availableExploits)==0 then
        attackVectors=globals.G_agent._parseAttackVectors(scanResult)
        if attackVectors and len(attackVectors)>0 then
          context.availableExploits=attackVectors
          if outLvl>=2 then print skyblue("Agent: Parsed "+len(attackVectors)+" attack vectors from scan output")
        end if
      end if
      //Check if this was a LAN scan - look for routers
      if hasIndex(step,"flag") and (step.flag=="-l" or step.flag=="--n") then
        //Try to find a router from the scan (for auto-bounce attacks)
        router=get_router
        if router and typeof(router)=="router" then
          routerIp=router.local_ip
          if routerIp then
            context.lastRouter=routerIp
            if outLvl>=2 then print skyblue("Agent: Found router at "+routerIp+" for future bounce attacks")
          end if
        end if
      end if
    end if
  else if hasIndex(Obj,"commands") then
    //Try default commands
    for cmd in ["scan","nmap"]
      if hasIndex(Obj.commands,cmd) then
        f=Obj.commands[cmd]
        if globals.G_agent.config.trainer then print orange("Command you need to run: "+cmd+" "+join(argv," "))
        scanResult=f(argv)
        //Command executed - consider it successful
        result.success=true
        result.data=scanResult
        if hasIndex(step,"target") then context.target=step.target
        if scanResult!=null then context.scanData=scanResult
        break
      end if
    end for
    //If no command was found, try fallback
    if not result.success then
      if typeof(Attack)=="map" and hasIndex(Attack,"scan") then
        scanResult=Attack.scan(Obj,step.target)
        result.success=true
        result.data=scanResult
        context.scanData=scanResult
        context.target=step.target
      else
        result.error="Scan command not available"
        result.critical=true
      end if
    end if
  else
    //No commands available, try Attack library
    if typeof(Attack)=="map" and hasIndex(Attack,"scan") then
      scanResult=Attack.scan(Obj,step.target)
      result.success=true
      result.data=scanResult
      context.scanData=scanResult
      context.target=step.target
    else
      result.error="Scan command not available"
      result.critical=true
    end if
  end if
  return result
end function
//Handler: Find exploits
AgentHandlers._handleFindExploits=function(Obj,step,context)
  result={"success":false,"step":"findExploits"}
  //Use Obj to get available exploits
  if hasIndex(context,"target") then
    //Check for exploit command
    if hasIndex(Obj.commands,"exploit") then
      argv=["list",context.target]
      exploits=Obj.commands.exploit(Obj,argv)
      result.success=true
      result.exploits=exploits
      context.availableExploits=exploits
    else
      //Fallback to Attack library
      if typeof(Attack)=="map" and hasIndex(Attack,"getExploit") then
        exploit=Attack.getExploit(Obj)
        result.success=true
        result.exploits=[exploit]
        context.availableExploits=[exploit]
      else
        result.error="No exploit discovery available"
      end if
    end if
  else
    result.error="No target available"
  end if
  return result
end function
//Handler: Exploit
AgentHandlers._handleExploit=function(Obj,step,context)
  debug=globals.G_agent.config.debug
  outLvl=globals.G_agent.config.outputLevel
  result={"success":false,"step":"exploit"}
  //Resume path: user already picked a vector via typed dialog
  if globals.G_agentContext and hasIndex(globals.G_agentContext,"selectedAttackVector") and globals.G_agentContext.selectedAttackVector then
    context.availableExploits=[globals.G_agentContext.selectedAttackVector]
    globals.G_agentContext.selectedAttackVector=null
  end if
  //If no exploits available and we have a target, scan first (always non-interactive)
  if not (hasIndex(context,"availableExploits") and len(context.availableExploits)>0) then
    if hasIndex(step,"target") then
      if outLvl>=2 then print skyblue("Agent: No exploits in context - scanning target first...")
      //Create a scan step for the target - autonomous avoids Gui NEED RESPONSE
      scanStep={}
      scanStep.action="scan"
      scanStep.target=step.target
      scanStep.autonomous=true
      //Copy any requirements from the exploit step
      if hasIndex(step,"requirements") then scanStep.requirements=step.requirements
      //Execute the scan to populate exploits
      scanResult=AgentHandlers._handleScan(Obj,scanStep,context)
      if not scanResult.success then
        result.error="Failed to scan target before exploitation"
        result.critical=true
        return result
      end if
      //After scan, exploits should now be in context
      if not (hasIndex(context,"availableExploits") and len(context.availableExploits)>0) then
        result.error="No exploits found for target after scan"
        result.critical=true
        return result
      end if
    else
      result.error="No exploits available and no target specified"
      result.critical=true
      return result
    end if
  end if
  //Dedup identical library@target entries before counting / prompting
  if hasIndex(context,"availableExploits") and len(context.availableExploits)>0 then
    uniqueVectors=[]
    seenKeys={}
    for vec in context.availableExploits
      tkey=vec.library
      if hasIndex(vec,"target") then tkey=tkey+"@"+vec.target
      if hasIndex(seenKeys,tkey) then continue
      seenKeys[tkey]=true
      push(uniqueVectors,vec)
    end for
    context.availableExploits=uniqueVectors
  end if
  //Multiple vectors: ask via typed dialog (skip in autonomous mode - agent picks)
  isAutonomousStep=hasIndex(step,"autonomous") and step.autonomous
  if not isAutonomousStep and hasIndex(context,"availableExploits") and len(context.availableExploits)>1 and globals.G_agent.config.promptOnAmbiguous then
    //Skip prompt if a single vector was already forced
    if not (hasIndex(step,"selectedVector") and step.selectedVector) then
      vectors=context.availableExploits
      labels=[]
      for vec in vectors
        label=vec.library
        if hasIndex(vec,"target") then
          label=label+" @ "+vec.target
        else if hasIndex(vec,"description") then
          label=vec.description
        end if
        if hasIndex(vec,"exploitCount") then label=label+" ["+vec.exploitCount+"]"
        push(labels,label)
      end for
      if outLvl>=1 then
        Info.info("Found the following attack vectors:")
        vi=0;while vi<len(vectors)
          vec=vectors[vi]
          print purple("["+str(vi+1)+"] ")+orange(vec.library)+white(" -> ")+yellow(vec.target)
          if hasIndex(vec,"exploitCount") then print "    "+green(str(vec.exploitCount))+white(" exploits on file")
          vi+=1
        end while
      end if
      resumeCmd="exploit"
      if hasIndex(step,"target") then resumeCmd="exploit "+step.target
      globals.G_agent.startDialog("pickVector","Which attack vector?",labels,{
        "mode":"resumeExploit",
        "resumeCommand":resumeCmd,
        "target":step.target,
        "vectors":vectors,
        "suggested":labels[0]
      })
      result.success=true
      result.awaitDialog=true
      result.message="Awaiting vector selection"
      return result
    end if
  end if
  //Multiple exploits on the selected vector: let user pick (shell>file, root>guest)
  requirements=null
  if hasIndex(step,"requirements") then requirements=step.requirements
  exploitPromptDone=globals.G_agentContext and hasIndex(globals.G_agentContext,"exploitPromptResolved") and globals.G_agentContext.exploitPromptResolved
  alreadyPickedExploit=globals.G_agentContext and hasIndex(globals.G_agentContext,"selectedAttackExploit") and globals.G_agentContext.selectedAttackExploit
  if exploitPromptDone then globals.G_agentContext.exploitPromptResolved=false
  if not isAutonomousStep and not exploitPromptDone and not alreadyPickedExploit and hasIndex(context,"availableExploits") and len(context.availableExploits)>0 and globals.G_agent.config.promptOnAmbiguous then
    scoredExploits=AgentHandlers._buildScoredExploits(context.availableExploits,requirements)
    pickerExploits=AgentHandlers._pickerExploits(scoredExploits)
    //Prompt when multiple capturable exploits (password/unknown hidden from list)
    shouldPick=len(pickerExploits)>1
    if shouldPick then
      labels=["auto"]
      for scoredEx in pickerExploits;push(labels,scoredEx.label);end for
      if outLvl>=1 then
        hidden=len(scoredExploits)-len(pickerExploits)
        Info.info("Exploits (priority: shell > computer > file, then root > user > guest):")
        print purple("[1] ")+green("auto")+white(" - try capturable exploits in priority order")
        si=0;while si<len(pickerExploits)
          se=pickerExploits[si]
          hint=""
          if hasIndex(se,"mem") and se.mem then hint=white(" ["+se.mem+"]")
          print purple("["+str(si+2)+"] ")+orange(se.type)+white(" / ")+yellow(se.user)+hint
          si+=1
        end while
        if hidden>0 then print white("  ("+str(hidden)+" password/unknown exploits hidden - use scan UI for those)")
      end if
      resumeCmd="exploit"
      if hasIndex(step,"target") then resumeCmd="exploit "+step.target
      globals.G_agent.startDialog("pickExploit","Which exploit?",labels,{
        "mode":"resumeExploit",
        "resumeCommand":resumeCmd,
        "target":step.target,
        "vector":context.availableExploits[0],
        "scoredExploits":pickerExploits,
        "suggested":labels[0]
      })
      result.success=true
      result.awaitDialog=true
      result.message="Awaiting exploit selection"
      return result
    else if outLvl>=2 and len(scoredExploits)==0 then
      print yellow("Agent: No exploits loaded from cache for selected vector - check scan database")
    end if
  end if
  //Check if we have attack vectors from autonomous scan
  if hasIndex(context,"availableExploits") and len(context.availableExploits)>0 then
    //For autonomous mode, use cached exploits from database
    if outLvl>=2 then print skyblue("Agent: Running autonomous exploitation...")
    //Pass attack vectors and requirements to autonomous attack function
    capturedObjects=AgentHandlers._attackAutonomous(context.availableExploits,requirements)
    if capturedObjects and len(capturedObjects)>0 then
      //We got the best object already (only one returned)
      bestObj=capturedObjects[0]
      //LAN computer goal: router shell is only a bounce point - never open it as the final session
      lanGoal=null
      if requirements and hasIndex(requirements,"targetIP") and is_lan_ip(requirements.targetIP) then lanGoal=requirements.targetIP
      if not lanGoal and hasIndex(step,"lanIP") and step.lanIP and is_lan_ip(step.lanIP) then lanGoal=step.lanIP
      if not lanGoal and context and hasIndex(context,"lanIP") and context.lanIP and is_lan_ip(context.lanIP) then lanGoal=context.lanIP
      if not lanGoal and hasIndex(step,"target") and step.target and is_lan_ip(step.target) then lanGoal=step.target
      wantLanComputer=lanGoal!=null and ((not requirements) or (not hasIndex(requirements,"objectType")) or requirements.objectType=="computer" or requirements.objectType=="shell")
      if wantLanComputer and bestObj.type=="shell" then
        //Resolve router/public IP (step.target/context.target are often the LAN goal)
        publicIP=null
        if hasIndex(step,"publicIP") and step.publicIP and not is_lan_ip(step.publicIP) then publicIP=step.publicIP
        if not publicIP and hasIndex(context,"publicIP") and context.publicIP and not is_lan_ip(context.publicIP) then publicIP=context.publicIP
        if not publicIP and hasIndex(step,"extractedIps") and step.extractedIps then
          for ip in step.extractedIps
            if not is_lan_ip(ip) then
              publicIP=ip
              break
            end if
          end for
        end if
        if not publicIP and hasIndex(context,"target") and context.target and not is_lan_ip(context.target) then publicIP=context.target
        if not publicIP and hasIndex(step,"target") and step.target and not is_lan_ip(step.target) then publicIP=step.target
        if not publicIP and hasIndex(bestObj,"ip") and bestObj.ip and not is_lan_ip(bestObj.ip) then publicIP=bestObj.ip
        if not publicIP then
          result.error="LAN target "+lanGoal+" needs a public router IP - none found in plan context"
          result.critical=true
          if outLvl>=1 then print yellow("Agent: "+result.error)
          return result
        end if
        //scan --b: --e root bounce on router libs, else config -v/-x + --l (never open guest shell)
        if outLvl>=1 then print skyblue("Agent: Router shell captured - scan --b to "+lanGoal+" (not opening guest shell)")
        context.bounceShell=bestObj.object
        needRoot=true
        if requirements and hasIndex(requirements,"privilege") and requirements.privilege!="root" then needRoot=false
        if typeof(Mission)=="map" and hasIndex(Mission,"getRootBounce") then
          if outLvl>=1 then print skyblue("Agent: scan --b -p "+publicIP+" -l "+lanGoal+" (via Mission.getRootBounce)")
          bounceComputer=Mission.getRootBounce(publicIP,lanGoal,{"shell":bestObj.object,"Obj":Obj})
          if typeof(bounceComputer)=="computer" then
            isHeadless=false
            if hasIndex(step,"continuationCommands") and len(step.continuationCommands)>0 then isHeadless=true
            wrappedObj=null
            if typeof(Exploit)=="map" and hasIndex(Exploit,"getComputer") then wrappedObj=Exploit.getComputer(bounceComputer,isHeadless)
            result.success=true
            result.exploitUsed="scan --b root bounce"
            result.publicIP=publicIP
            result.lanIP=lanGoal
            result.baseType="computer"
            result.rawObject=bounceComputer
            result.wrappedObj=wrappedObj
            context.computer=wrappedObj
            context.rootComputer=wrappedObj
            if isHeadless and hasIndex(step,"continuationCommands") then AgentHandlers._runContinuation(wrappedObj,step.continuationCommands,lanGoal)
            return result
          end if
          errMsg="bounce failed"
          if typeof(bounceComputer)=="list" and len(bounceComputer)>=2 then errMsg=str(bounceComputer[1]) else if bounceComputer then errMsg=str(bounceComputer)
          //Firewall never blocks LAN bounce - don't surface that as the cause
          if indexOf(lower(errMsg),"firewall")!=null or indexOf(lower(errMsg),"connection refused")!=null then errMsg="bounce failed (not firewall) - try scan --e on router or config -v/-x"
          result.error="scan --b failed: "+errMsg
          result.critical=true
          if outLvl>=1 then print yellow("Agent: "+result.error)
          return result
        end if
        getObjectStep={"action":"getObject","publicIP":publicIP,"lanIP":lanGoal,"needRoot":needRoot,"isHeadless":false,"objectType":"computer"}
        if requirements and hasIndex(requirements,"objectType") then getObjectStep.objectType=requirements.objectType
        if hasIndex(step,"continuationCommands") then getObjectStep.continuationCommands=step.continuationCommands
        if hasIndex(context,"bounceShell") then getObjectStep.routerShell=context.bounceShell
        return globals.G_agent._handleGetObject(Obj,getObjectStep,context)
      end if
      //Never open a captured router guest shell when the goal was a LAN machine
      if lanGoal!=null and bestObj.type=="shell" then
        result.error="Refusing to open router shell - goal is LAN target "+lanGoal
        result.critical=true
        if outLvl>=1 then print yellow("Agent: "+result.error)
        return result
      end if
      //Check if we need escalation (got object but wrong privilege)
      needsEscalation=false
      if requirements and hasIndex(requirements,"privilege") then
        if bestObj.user!=requirements.privilege then
          needsEscalation=true
          if outLvl>=2 then print yellow("Agent: Captured "+bestObj.user+" "+bestObj.type+", need "+requirements.privilege+" - will escalate")
        end if
      end if
      result.success=true
      result.exploitUsed="Autonomous ("+bestObj.library+")"
      result.data=bestObj.object
      context.shell=bestObj.object
      if needsEscalation then
        context.needsEscalation=true
        result.needsEscalation=true
      end if
      if outLvl>=2 then
        locationInfo=""
        if hasIndex(bestObj,"ip") and hasIndex(bestObj,"port") then
          locationInfo=" from "+bestObj.ip+":"+bestObj.port
        else if hasIndex(bestObj,"ip") then
          locationInfo=" from "+bestObj.ip
        end if
        print green("Agent: Best capture - "+bestObj.type+" ("+bestObj.user+")"+locationInfo)
        print green("Agent: Score: "+bestObj.score)
      end if
      //Activate the captured object using Exploit library
      if typeof(Exploit)=="map" then
        //Check if we have continuation commands - if so, activate headless
        isHeadless=false
        if hasIndex(step,"continuationCommands") and len(step.continuationCommands)>0 then isHeadless=true
        //getShell(shell, pivoting, args, headless) - headless is 4th arg, not 2nd
        if bestObj.type=="shell" and hasIndex(Exploit,"getShell") then
          Exploit.getShell(bestObj.object,false,[],isHeadless)
        else if bestObj.type=="computer" and hasIndex(Exploit,"getComputer") then
          Exploit.getComputer(bestObj.object,isHeadless)
          //Execute continuation commands if present and headless
          if isHeadless and hasIndex(step,"continuationCommands") then
            compObj=Mission.getHeadless(bestObj.object)
            for cmd in step.continuationCommands
              //Parse command and arguments
              parts=split(cmd," ")
              cmdName=parts[0]
              cmdArgs=[]
              if len(parts)>1 then cmdArgs=parts[1:]
              //Execute command if it exists
              if hasIndex(compObj.commands,cmdName) then
                compObj.commands[cmdName](cmdArgs)
                //Record successful execution in knowledge
                if debug then
                  print green("Debug: Knowledge type: "+typeof(Knowledge))
                  if typeof(Knowledge)=="map" then print green("Debug: Knowledge.loaded: "+Knowledge.loaded)
                  print green("Debug: context has originalCommand: "+hasIndex(context,"originalCommand"))
                  if hasIndex(context,"originalCommand") then print green("Debug: originalCommand: "+context.originalCommand)
                end if
                if typeof(Knowledge)=="map" and Knowledge.loaded and hasIndex(context,"originalCommand") then
                  recordResult=Knowledge.record(context.originalCommand,cmd,"success",0.8)
                  if debug then print green("Debug: Knowledge.record result: "+recordResult)
                end if
              else
                result.error="Command not found: "+cmdName
                result.critical=true
                Info.info("Agent: Command not found: "+cmdName)
                //Record failure in knowledge
                if typeof(Knowledge)=="map" and Knowledge.loaded and hasIndex(context,"originalCommand") then Knowledge.record(context.originalCommand,cmd,"failure",0.3)
                compObj.commands.home
                return result
              end if
            end for
            compObj.commands.home
          end if
        else if bestObj.type=="file" and hasIndex(Exploit,"getFile") then
          meta={"public_ip":"","local_ip":""}
          if hasIndex(bestObj,"ip") and bestObj.ip then meta.local_ip=bestObj.ip
          if hasIndex(step,"target") and step.target then
            if is_lan_ip(step.target) then
              if not meta.local_ip then meta.local_ip=step.target
            else
              meta.public_ip=step.target
            end if
          end if
          if not meta.public_ip and hasIndex(Obj,"meta") and hasIndex(Obj.meta,"public_ip") then meta.public_ip=Obj.meta.public_ip
          if not meta.local_ip and hasIndex(Obj,"meta") and hasIndex(Obj.meta,"local_ip") then meta.local_ip=Obj.meta.local_ip
          Exploit.getFile(bestObj.object,meta)
        end if
      end if
      return result
    else
      //Check if we need LAN bounce instead of direct exploitation
      if requirements and hasIndex(requirements,"targetIP") then
        targetIP=requirements.targetIP
        if is_lan_ip(targetIP) then
          //This is a LAN target - need router bounce
          if outLvl>=2 then print yellow("Agent: LAN target "+targetIP+" requires router bounce")
          //Resolve intended public/router IP from step/context (target is often the LAN goal)
          publicIP=null
          if hasIndex(step,"publicIP") and step.publicIP and not is_lan_ip(step.publicIP) then publicIP=step.publicIP
          if not publicIP and hasIndex(context,"publicIP") and context.publicIP and not is_lan_ip(context.publicIP) then publicIP=context.publicIP
          if not publicIP and hasIndex(step,"extractedIps") and step.extractedIps then
            for ip in step.extractedIps
              if not is_lan_ip(ip) then
                publicIP=ip
                break
              end if
            end for
          end if
          if not publicIP and hasIndex(context,"target") and context.target!=targetIP and not is_lan_ip(context.target) then publicIP=context.target
          if not publicIP and hasIndex(step,"target") and step.target!=targetIP and not is_lan_ip(step.target) then publicIP=step.target
          currentRouter=AgentHandlers._isRouterSession(Obj)
          currentPub=AgentHandlers._sessionPublicIP(Obj)
          useCurrentRouter=false
          //Prefer live router/proxy session when target is on this LAN, or specified router has no shell
          if currentRouter and currentPub then
            if AgentHandlers._lanReachableFromSession(Obj,targetIP) then
              useCurrentRouter=true
              if outLvl>=2 then print green("Agent: Target "+targetIP+" reachable from current router "+currentPub)
            else if not publicIP or publicIP==currentPub then
              useCurrentRouter=true
            else
              routerShell=null
              if typeof(Attack)=="map" and hasIndex(Attack,"scanCustom") then routerShell=Attack.scanCustom([publicIP,"router","s"],true, Obj)
              if not routerShell or typeof(routerShell)!="shell" then
                useCurrentRouter=true
                if outLvl>=2 then print yellow("Agent: No shell on "+publicIP+" - falling back to current router "+currentPub)
              end if
            end if
          end if
          if useCurrentRouter then publicIP=currentPub
          //Only use LAN setup when we are NOT already on a usable router session
          needsLanSetup=false
          routerShellAvailable=false
          if useCurrentRouter then
            routerShellAvailable=true
            needsLanSetup=false
          else
            if not hasIndex(globals,"G_settings") or not hasIndex(globals.G_settings,"vulnerableLib") or not hasIndex(globals.G_settings,"vulnerableLibIndex") then
              needsLanSetup=true
            else if not globals.G_settings.vulnerableLib or not globals.G_settings.vulnerableLibIndex then
              needsLanSetup=true
            end if
            if not needsLanSetup and publicIP and publicIP!=targetIP and not is_lan_ip(publicIP) then
              if outLvl>=2 then print skyblue("Agent: Checking router "+publicIP+" for available shells...")
              routerShell=null
              if typeof(Attack)=="map" and hasIndex(Attack,"scanCustom") then routerShell=Attack.scanCustom([publicIP,"router","s"],true, Obj)
              if routerShell and typeof(routerShell)=="shell" then
                routerShellAvailable=true
                if outLvl>=2 then print green("Agent: Router shell available - no LAN setup needed")
              else
                needsLanSetup=true
                if outLvl>=2 then print yellow("Agent: No router shell available - will need LAN setup")
              end if
            else if not publicIP then
              needsLanSetup=true
            end if
          end if
          bounceShell=null
          lanSetupResult=null
          if needsLanSetup then
            if outLvl>=2 then print skyblue("Agent: Initiating LAN setup approach...")
            //Pass known public IP into setup for correct scanCustom args
            if publicIP and requirements then requirements.publicIP=publicIP
            //Autonomous / current-router: never pause for shell-scan confirm - just proceed
            if not isAutonomousStep and not currentRouter and globals.G_agent.config.promptOnSlow then
              resumeCmd=globals.G_agent._resumeCommand(context)
              confirm=globals.G_agent._beginConfirm("No router shell available. Scan network for any available shell?",resumeCmd,"skipLanShellScanPrompt","yes",true)
              if confirm then return confirm
            end if
            lanSetupResult=AgentHandlers._setupLanBounce(Obj,requirements)
            if not lanSetupResult or not lanSetupResult.success then
              errMsg="unknown"
              if lanSetupResult and hasIndex(lanSetupResult,"error") then errMsg=lanSetupResult.error
              result.error="Failed to set up LAN bounce: "+errMsg
              result.critical=true
              return result
            end if
            if hasIndex(lanSetupResult,"shell") then
              bounceShell=lanSetupResult.shell
              context.bounceShell=bounceShell
              if outLvl>=2 then print green("Agent: Using "+lanSetupResult.user+" shell from "+lanSetupResult.library+" as bounce point")
            end if
            //If setup used current session, prefer that public IP for bounce
            if hasIndex(lanSetupResult,"usedCurrentSession") and lanSetupResult.usedCurrentSession and hasIndex(lanSetupResult,"publicIP") and lanSetupResult.publicIP then publicIP=lanSetupResult.publicIP
          end if
          //If still no public IP, derive from bounce shell meta / host_computer (native shell has no .run)
          if not publicIP or is_lan_ip(publicIP) then
            if outLvl>=2 then print yellow("Agent: No router IP specified - auto-detecting on network...")
            if bounceShell then
              if hasIndex(bounceShell,"meta") and typeof(bounceShell.meta)=="map" and hasIndex(bounceShell.meta,"public_ip") and bounceShell.meta.public_ip then
                publicIP=bounceShell.meta.public_ip
              else if hasIndex(bounceShell,"computer") and bounceShell.computer and hasIndex(bounceShell.computer,"public_ip") then
                publicIP=bounceShell.computer.public_ip
              else if hasIndex(bounceShell,"shell") and bounceShell.shell then
                hc=host_computer(bounceShell.shell)
                if hc and hasIndex(hc,"public_ip") then publicIP=hc.public_ip else if hc and hasIndex(hc,"local_ip") then publicIP=hc.local_ip
              end if
            end if
            if not publicIP and currentPub then publicIP=currentPub
            if not publicIP and typeof(Attack)=="map" and hasIndex(Attack,"scanCustom") then
              if outLvl>=2 then print yellow("Agent: Scanning for router on network...")
              routerShell=Attack.scanCustom(["-r","router","s"],true, Obj)
              if routerShell and typeof(routerShell)=="shell" then
                hc=host_computer(routerShell)
                if hc and hasIndex(hc,"public_ip") then publicIP=hc.public_ip else if hc and hasIndex(hc,"local_ip") then publicIP=hc.local_ip
              end if
            end if
          end if
          if not publicIP then
            result.error="Cannot determine router IP for LAN bounce to "+targetIP+" - try specifying router IP explicitly"
            result.critical=true
            return result
          end if
          if outLvl>=2 then print green("Agent: Bounce router="+publicIP+" target="+targetIP)
          //Determine if we need root (keep root when hack lib is configured)
          needRoot=false
          if hasIndex(requirements,"privilege") and requirements.privilege=="root" then needRoot=true
          hasHackLib=hasIndex(globals,"G_settings") and hasIndex(globals.G_settings,"vulnerableLib") and hasIndex(globals.G_settings,"vulnerableLibIndex") and globals.G_settings.vulnerableLib and globals.G_settings.vulnerableLibIndex
          if needRoot and not hasHackLib then
            needRoot=false
            if outLvl>=2 then print yellow("Agent: Root access not guaranteed without vulnerable library - will accept guest/user")
          end if
          //Determine headless mode
          isHeadless=true
          //If continuation commands present, force headless mode for autonomous execution
          if hasIndex(step,"continuationCommands") and len(step.continuationCommands)>0 then
            isHeadless=true
          else if hasIndex(requirements,"objectType") and requirements.objectType=="computer" then
            //User explicitly requested computer object - final object should be interactive
            isHeadless=false
          else
            //For LAN bounce setup without continuation commands, final object should be interactive
            isHeadless=false
          end if
          //Build getObject step
          getObjectStep={}
          getObjectStep.action="getObject"
          getObjectStep.publicIP=publicIP
          getObjectStep.lanIP=targetIP
          getObjectStep.needRoot=needRoot
          getObjectStep.isHeadless=isHeadless
          if hasIndex(requirements,"objectType") then getObjectStep.objectType=requirements.objectType else getObjectStep.objectType="computer"  //default
          //Pass continuation commands if present
          if hasIndex(step,"continuationCommands") then getObjectStep.continuationCommands=step.continuationCommands
          //Execute getObject immediately
          //NOTE: Final object will be INTERACTIVE (not headless) unless continuation commands are present
          //This ensures user gets a usable terminal even if we only captured guest access
          if outLvl>=2 then print skyblue("Agent: Executing LAN bounce: router="+publicIP+", target="+targetIP+", root="+needRoot+", headless="+isHeadless)
          return globals.G_agent._handleGetObject(Obj,getObjectStep,context)
        end if
      end if
      result.error="No objects captured from autonomous exploitation"
      result.critical=true
      return result
    end if
  else if hasIndex(step,"target") then
    //Fallback: Evaluate all attack vectors to find the best route manually
    //Priority: shell > computer > file, root > user > guest
    //First check if we have exploits available
    if not hasIndex(context,"availableExploits") or len(context.availableExploits)==0 then
      result.error="No exploits available in context for target"
      result.critical=true
      return result
    end if
    bestVector=null
    bestScore=0
    if outLvl>=2 then print skyblue("Agent: Evaluating "+len(context.availableExploits)+" attack vectors...")
    for vec in context.availableExploits
      if not hasIndex(vec,"exploitCount") or vec.exploitCount==0 then continue
      if not hasIndex(vec,"metaLib") then continue
      //Get exploits from cache for this vector
      if not (typeof(G_exploitCache)=="map" and hasIndex(G_exploitCache,vec.library)) then continue
      exploits=G_exploitCache[vec.library]
      if not exploits or len(exploits)==0 then continue
      //Score all exploits in this vector (shell>computer>file, then root>user>guest)
      for exploit in exploits
        objType=null
        if hasIndex(exploit,"e") then
          if exploit.e=="s" then objType="shell"
          if exploit.e=="c" then objType="computer"
          if exploit.e=="f" then objType="file"
        end if
        if not objType then continue
        userPriv="guest"
        if hasIndex(exploit,"u") then
          if exploit.u=="r" then userPriv="root"
          if exploit.u=="u" then userPriv="user"
          if exploit.u=="g" then userPriv="guest"
        end if
        score=AgentHandlers._exploitObjectScore(objType)+AgentHandlers._exploitPrivScore(userPriv)
        //Prefer exploits without additional requirements (key is Cyrillic scha via char() for ASCII-safe source)
        if not hasIndex(exploit,char(1097)) then score=score+5
        //Track best scoring exploit
        if score>bestScore then
          bestScore=score
          bestVector=vec
          bestVector.selectedExploit=exploit
        end if
      end for
    end for
    if not bestVector then
      //No exploits with score - just use first vector with exploits
      for vec in context.availableExploits
        if hasIndex(vec,"exploitCount") and vec.exploitCount>0 then
          bestVector=vec
          break
        end if
      end for
    end if
    if not bestVector then bestVector=context.availableExploits[0]
    if outLvl>=2 then
      print skyblue("Agent: Auto-selected attack vector: "+bestVector.description+" (score: "+bestScore+")")
    end if
    //Use Exploit.run to execute the exploit
    if typeof(Exploit)=="map" and hasIndex(Exploit,"run") and hasIndex(bestVector,"metaLib") then
      //Get exploit from cache
      if typeof(G_exploitCache)=="map" and hasIndex(G_exploitCache,bestVector.library) then
        exploits=G_exploitCache[bestVector.library]
        if exploits and len(exploits)>0 then
          //Use selected exploit or first one
          exploit=exploits[0]
          if hasIndex(bestVector,"selectedExploit") then exploit=bestVector.selectedExploit
          metaInfo={}
          metaInfo.metaLib=bestVector.metaLib
          metaInfo.public_ip=bestVector.ip
          metaInfo.local_ip=bestVector.ip
          if hasIndex(bestVector,"port") then metaInfo.port_number=bestVector.port
          if outLvl>=2 then
            exploitType="unknown"
            exploitUser="unknown"
            if hasIndex(exploit,"e") then exploitType=exploit.e
            if hasIndex(exploit,"u") then exploitUser=exploit.u
            print yellow("Agent: Running exploit (type: "+exploitType+", user: "+exploitUser+") on "+bestVector.target)
          end if
          //Execute exploit
          exploitResult=Exploit.run(exploit,metaInfo,bestVector.ip)
          result.success=true
          result.exploitUsed=bestVector.library
          result.data=exploitResult
          if exploitResult and not (exploitResult isa Error) then
            context.shell=exploitResult
            if outLvl>=2 then print green("Agent: Exploit successful - obtained "+typeof(exploitResult))
          else if exploitResult isa Error then
            result.error="Exploit failed: "+exploitResult
          end if
        else
          result.error="No exploits in cache for "+bestVector.library
        end if
      else
        result.error="Exploit cache not available"
      end if
    else if hasIndex(Obj.commands,"exploit") then
      //Fallback to registered exploit command
      argv=[bestVector.target,bestVector.library]
      if outLvl>=2 then print yellow("Agent: exploit "+join(argv," "))
      exploitResult=Obj.commands.exploit(Obj,argv)
      result.success=true
      result.exploitUsed=bestVector.library
      result.data=exploitResult
      if exploitResult then context.shell=exploitResult
    else
      result.error="Exploit execution not available"
    end if
  else if hasIndex(step,"target") then
    //Fallback: try generic exploit with target
    if hasIndex(Obj.commands,"exploit") then
      argv=[step.target]
      exploitResult=Obj.commands.exploit(Obj,argv)
      result.success=true
      result.data=exploitResult
      if exploitResult then context.shell=exploitResult
    else if typeof(Attack)=="map" and hasIndex(Attack,"scan") then
      targetIp=""
      if hasIndex(context,"target") then targetIp=context.target
      exploitResult=Attack.scan(Obj,targetIp)
      result.success=true
      context.shell=exploitResult
    else
      result.error="Cannot launch exploit"
    end if
  else
    result.error="No attack vectors or target available"
  end if
  return result
end function