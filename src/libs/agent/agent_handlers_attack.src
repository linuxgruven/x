//Handler: Find escalation
AgentHandlers._handleFindEscalation=function(Obj,step,context)
  result={"success":false,"step":"findEscalation"}
  //Find escalation path
  result.success=true
  result.methods=["kernelExploit","suidBinary","weakService"]
  return result
end function
//Handler: Direct command
AgentHandlers._handleDirectCommand=function(Obj,step,context)
  result={"success":false,"step":"directCommand"}
  //Execute direct command
  if not hasIndex(step,"command") then
    result.error="No command specified"
    return result
  end if
  cmdParts=split(step.command," ")
  if len(cmdParts)==0 then
    result.error="Empty command"
    return result
  end if
  cmdName=cmdParts[0]
  cmdArgs=cmdParts[1:]
  //Check if command ends with a flag that expects a parameter but doesn't have one
  if len(cmdArgs)>0 then
    lastArg=cmdArgs[len(cmdArgs)-1]
    if lastArg[0]=="-" then
      //Last argument is a flag with no value after it - might need a parameter
      //Check for hash-cracking commands that need a hash
      if (cmdName=="decipher" or cmdName=="hc" or cmdName=="hashcat") and (lastArg=="-d" or lastArg=="-h" or lastArg=="-c") then
        //Prompt for hash
        hashInput=user_input("Enter hash to crack: ")
        if hashInput and len(hashInput)==32 then
          cmdArgs.push(lower(hashInput))
        else
          result.error="Invalid or no hash provided"
          return result
        end if
      end if
    end if
  end if
  //Try to find command in Obj.commands
  if hasIndex(Obj.commands,cmdName) then
    f=Obj.commands[cmdName]
    if globals.G_agent.config.trainer then print orange("Command you need to run: "+step.command)
    cmdResult=f(cmdArgs)
    result.success=true
    result.data=cmdResult
  else
    result.error="Command not found: "+cmdName
  end if
  return result
end function
//Handler: Open file
AgentHandlers._handleOpenFile=function(Obj,step,context)
  result={"success":false,"step":"openFile"}
  //Open file with appropriate flags
  //Check if we have a shell with open command, otherwise use local open
  openCmd=null
  if hasIndex(Obj,"commands") and hasIndex(Obj.commands,"open") then
    openCmd=Obj.commands["open"]
  else if typeof(open)=="function" then
    //Use local open command
    openCmd=@open
  else
    result.error="Open command not available"
    return result
  end if
  //Handle log file search
  if hasIndex(step,"searchLocation") and step.searchLocation=="home" then
    //Search for .log file in home
    homePath=Obj.homeDir
    if not homePath then homePath="/home/"+Obj.user
    //Try to find log files
    if hasIndex(Obj,"computer") and hasIndex(Obj.computer,"File") then
      homeFolder=Obj.computer.File(homePath)
      if homeFolder then
        files=homeFolder.getFiles
        logFile=null
        for f in files
          if indexOf(f.name,".log")!=null then
            logFile=f.path
            break
          end if
        end for
        if logFile then
          openResult=openCmd(["-l",logFile])
          result.success=true
          result.data=openResult
        else
          result.error="No log file found in home"
        end if
      else
        result.error="Cannot access home directory"
      end if
    else
      result.error="File system not accessible"
    end if
  else if hasIndex(step,"openFlag") then
    //Use specified flag
    openResult=openCmd([step.openFlag])
    result.success=true
    result.data=openResult
  else if hasIndex(step,"path") then
    //Open specific file by path
    //The open command doesn't take arbitrary filenames, only flags
    //Try to open with code editor if it looks like a file
    if indexOf(step.path,".")!=null or step.path[0]=="/" then
      //Has extension or absolute path - try code editor
      openResult=openCmd(["-c","--code",step.path])
      result.success=true
      result.data=openResult
    else
      //No extension, might be an app name we don't recognize
      result.error="Unknown application '"+step.path+"'. Use 'man open' to see available applications."
      result.success=false
    end if
  else
    result.error="No file or flag specified"
  end if
  return result
end function
//Handler: Open browser
AgentHandlers._handleOpenBrowser=function(Obj,step,context)
  result={"success":false,"step":"openBrowser"}
  //Open browser
  if not hasIndex(Obj,"commands") or not hasIndex(Obj.commands,"open") then
    result.error="Open command not available"
    return result
  end if
  openCmd=Obj.commands["open"]
  if hasIndex(step,"openFlag") then
    //Parse flag string into array
    flagParts=split(step.openFlag," ")
    openResult=openCmd(flagParts)
    result.success=true
    result.data=openResult
  else
    openResult=openCmd(["-b"])
    result.success=true
    result.data=openResult
  end if
  return result
end function
//Handler: Fetch shell
AgentHandlers._handleFetchShell=function(Obj,step,context)
  debug=globals.G_agent.config.debug
  outLvl=globals.G_agent.config.outputLevel
  result={"success":false,"step":"fetchShell"}
  //Fetch shell from target
  if not hasIndex(step,"target") then
    result.error="No target specified for fetch"
    result.critical=true
    return result
  end if
  //Check if target is a LAN IP - if so, this needs to be a bounce attack
  targetIp=step.target
  if is_lan_ip(targetIp) then
    if outLvl>=2 then print yellow("Agent: Target "+targetIp+" is a LAN IP - converting to bounce attack")
    //Find public router IP - check if multiple IPs were extracted
    publicIP=null
    //First check if we have extracted IPs stored in step
    if hasIndex(step,"extractedIps") and len(step.extractedIps)>1 then
      //Look for a non-LAN IP in the extracted list
      for ip in step.extractedIps
        if ip!=targetIp and not is_lan_ip(ip) then
          publicIP=ip
          if outLvl>=2 then print green("Agent: Using router IP "+publicIP+" from command")
          break
        end if
      end for
    end if
    //Fallback to context target if different from LAN target
    if not publicIP and hasIndex(context,"target") and context.target!=targetIp and not is_lan_ip(context.target) then
      publicIP=context.target
      if outLvl>=2 then print green("Agent: Using router IP "+publicIP+" from context")
    end if
    //Auto-detect router if still not found
    if not publicIP then
      if outLvl>=2 then print yellow("Agent: No router IP specified - scanning network for router...")
      //Use network scan to find routers
      if typeof(Attack)=="map" and hasIndex(Attack,"scanCustom") then
        routerShell=Attack.scanCustom(["router","s"],true)
        if routerShell and typeof(routerShell)=="shell" then
          if hasIndex(routerShell,"host_computer") then
            routerComp=routerShell.host_computer
            if hasIndex(routerComp,"public_ip") then
              publicIP=routerComp.public_ip
            else if hasIndex(routerComp,"local_ip") then
              publicIP=routerComp.local_ip
            end if
          end if
          if publicIP and outLvl>=2 then print green("Agent: Auto-detected router at "+publicIP)
        end if
      end if
    end if
    if not publicIP then
      result.error="LAN target requires router IP - cannot auto-detect router"
      result.critical=true
      return result
    end if
    //Build getObject step for LAN bounce
    getObjectStep={}
    getObjectStep.action="getObject"
    getObjectStep.publicIP=publicIP
    getObjectStep.lanIP=targetIp
    getObjectStep.needRoot=false
    if hasIndex(step,"needRoot") then getObjectStep.needRoot=step.needRoot
    getObjectStep.isHeadless=false
    if hasIndex(step,"isHeadless") then getObjectStep.isHeadless=step.isHeadless
    getObjectStep.objectType="computer"
    if hasIndex(step,"objectType") then getObjectStep.objectType=step.objectType
    if hasIndex(step,"continuationCommands") then getObjectStep.continuationCommands=step.continuationCommands
    if outLvl>=2 then print skyblue("Agent: Redirecting to LAN bounce handler")
    return globals.G_agent._handleGetObject(Obj,getObjectStep,context)
  end if
  //Check if we have learned knowledge about scan command
  learnedPorts=null
  learnedTypes=null
  if hasIndex(step,"commandKnowledge") then
    if hasIndex(step.commandKnowledge,"ports") then learnedPorts=step.commandKnowledge.ports
    if hasIndex(step.commandKnowledge,"objectTypes") then learnedTypes=step.commandKnowledge.objectTypes
  end if
  //Use scan command with service-specific options
  //Format: scan --c <ip> <service> <type>
  //Build argv array directly
  serviceName="router"
  if hasIndex(step,"service") then serviceName=step.service
  objectType="s"
  if hasIndex(step,"objectType") then objectType=step.objectType
  //Check if headless mode requested
  isHeadless=false
  if hasIndex(step,"isHeadless") and step.isHeadless then isHeadless=true
  if debug then print green("Debug: After step check: isHeadless="+isHeadless+", step.isHeadless type="+typeof(step.isHeadless)+", value="+step.isHeadless)
  if hasIndex(context,"shouldStore") and context.shouldStore then
    isHeadless=true  //Force headless when storing
    if debug then print green("Debug: Forcing isHeadless=true because shouldStore=true")
  end if
  if debug then print green("Debug: Final isHeadless="+isHeadless)
  //Apply learned knowledge
  if debug and learnedPorts and hasIndex(learnedPorts,serviceName) then print skyblue("Agent: Using learned knowledge - "+serviceName+" runs on port "+learnedPorts[serviceName])
  if debug and learnedTypes and hasIndex(learnedTypes,objectType) then print skyblue("Agent: Using learned knowledge - type '"+objectType+"' = "+learnedTypes[objectType])
  if debug and isHeadless then print green("Debug: Headless mode - will get shell object without opening terminal")
  //Validate target is not empty
  targetIp=step.target
  if not targetIp or targetIp=="" then
    result.error="Empty target IP"
    result.critical=true
    return result
  end if
  //Debug output to see what we're building
  if debug then print green("Debug: Building argv with target="+targetIp+", service="+serviceName+", type="+objectType)
  //Use Attack.scanCustom for headless shell fetching
  if isHeadless then
    if outLvl>=2 then print skyblue("Agent: Getting shell in headless mode...")
    ex=Attack.scanCustom([targetIp,serviceName,objectType],true)
    if typeof(ex)!="shell" then
      result.error="Could not get shell on "+targetIp
      return result
    end if
    shell=Exploit.getShell(ex,false,[],true)
    if shell isa Error then
      result.error="Failed to wrap shell: "+shell.message
      return result
    end if
    //Check if root access required
    needRoot=false
    if hasIndex(step,"needRoot") then needRoot=step.needRoot
    if indexOf(lower(step.description),"root")!=null then needRoot=true
    //Escalate to root if needed
    if needRoot and shell.user.raw!="root" then
      if outLvl>=2 then print skyblue("Agent: Escalating to root...")
      shell=ShellObject.headlessSu(shell)
      if shell isa Error then
        result.error="Could not escalate to root: "+shell.message
        return result
      end if
      if shell.user.raw!="root" then
        result.error="Root escalation did not succeed"
        return result
      end if
      if outLvl>=2 then print green("Agent: Root access obtained")
    end if
    //Install libraries if requested
    if hasIndex(step,"libsToInstall") and len(step.libsToInstall)>0 then
      if debug then print green("Debug: Installing libraries: "+join(step.libsToInstall,", "))
      if hasIndex(Obj.commands,"libs") then
        libsCmd=Obj.commands["libs"]
        for libName in step.libsToInstall;if outLvl>=2 then print skyblue("Agent: Installing "+libName+" library...");libsCmd(["-g","-p","/lib",libName]);end for
      else
        print yellow("Agent: Warning - libs command not available")
      end if
    end if
    //Store shell in context for next steps
    result.success=true
    result.shell=shell
    context.shell=shell
    if shell.user.raw=="root" then context.rootShell=shell
    result.message="Shell obtained on "+targetIp
    if outLvl>=2 then print green("Agent: Shell ready for next step")
    return result
  end if
  //Interactive mode - get shell first, install libs if needed, then open terminal
  if outLvl>=2 then print skyblue("Agent: Getting shell...")
  ex=Attack.scanCustom([targetIp,serviceName,objectType],true)
  if typeof(ex)!="shell" then
    result.error="Could not get shell on "+targetIp
    return result
  end if
  shell=Exploit.getShell(ex,false,[],true)
  if shell isa Error then
    result.error="Failed to wrap shell: "+shell.message
    return result
  end if
  //Check if root access required
  needRoot=false
  if hasIndex(step,"needRoot") then needRoot=step.needRoot
  if indexOf(lower(step.description),"root")!=null then needRoot=true
  if debug then print green("Debug: needRoot="+needRoot+", current user="+shell.user.raw)
  //Escalate to root if needed
  if needRoot and shell.user.raw!="root" then
    if outLvl>=2 then print skyblue("Agent: Escalating to root...")
    shell=ShellObject.headlessSu(shell)
    if shell isa Error then
      result.error="Could not escalate to root: "+shell.message
      return result
    end if
    if shell.user.raw!="root" then
      result.error="Root escalation did not succeed"
      return result
    end if
    if outLvl>=2 then print green("Agent: Root access obtained")
    if debug then print green("Debug: After escalation, user="+shell.user.raw)
  end if
  //Install libraries if requested (always in headless mode)
  if hasIndex(step,"libsToInstall") and len(step.libsToInstall)>0 then
    if debug then print green("Debug: Installing libraries in headless mode: "+join(step.libsToInstall,", "))
    if hasIndex(Obj.commands,"libs") then
      libsCmd=Obj.commands["libs"]
      for libName in step.libsToInstall;if outLvl>=2 then print skyblue("Agent: Installing "+libName+" library...");libsCmd(["-g","-p","/lib",libName]);end for
    else
      print yellow("Agent: Warning - libs command not available")
    end if
  end if
  //Store the headless shell in context so ai.src can open the interactive session
  //at the top level of Command.ai. Opening it from deep inside _executePlan causes
  //the session to fall back through the proxy/pivot call stack to MAIN instead of
  //staying in the current context (proxy or normal).
  if outLvl>=2 then print skyblue("Agent: Shell ready, opening...")
  result.success=true
  context.shell=shell
  //Mark root shell so ai.src picks it up via context.rootShell
  if shell.user.raw=="root" then context.rootShell=shell
  context.target=step.target
  return result
end function