// =============================================================================
// AGENT_COMMAND_KNOWLEDGE
// Agent command knowledge; dynamically learns command syntax and usage from man pages.
// =============================================================================
AgentCommandKnowledge={}
//Get command metadata dynamically from knowledge cache (populated from man pages)
AgentCommandKnowledge.get=function(cmdName)
  outLvl=globals.G_agent.config.outputLevel
  //Load knowledge if needed
  if not hasIndex(globals.G_agent,"commandKnowledgeCache") then globals.G_agent.commandKnowledgeCache={}
  if len(globals.G_agent.commandKnowledgeCache.indexes)==0 then
    savedLevel=outLvl
    outLvl=0
    globals.G_agent.loadKnowledge
    outLvl=savedLevel
  end if
  //Check cache first
  normalizedName=trim(lower(cmdName))
  if hasIndex(globals.G_agent.commandKnowledgeCache,normalizedName) then return globals.G_agent.commandKnowledgeCache[normalizedName]
  //Try to learn it from man page
  return globals.G_agent.getCommandInfo(cmdName)
end function
//Learn flag meanings from parsed man page flags (already extracted by getCommandInfo)
//Returns map of semantic meanings -> flag letters
AgentCommandKnowledge.getSemanticFlags=function(cmdName)
  knowledge=self.get(cmdName)
  if not knowledge or not hasIndex(knowledge,"flags") then return {}
  semanticMap={}
  //Map flag descriptions to semantic meanings
  for flag in knowledge.flags.indexes
    desc=lower(knowledge.flags[flag])
    flagLetter=flag[1]  //Strip leading dash
    //Common patterns
    if indexOf(desc,"random")!=null then semanticMap.random=flagLetter
    if indexOf(desc,"localhost")!=null or (indexOf(desc,"local")!=null and indexOf(desc,"scan")!=null) then semanticMap.localhost=flagLetter
    if indexOf(desc,"public")!=null then semanticMap.public=flagLetter
    if indexOf(desc,"recursive")!=null or indexOf(desc,"recurse")!=null then semanticMap.recursive=flagLetter
    if indexOf(desc,"force")!=null then semanticMap.force=flagLetter
    if indexOf(desc,"verbose")!=null then semanticMap.verbose=flagLetter
    if indexOf(desc,"quiet")!=null or indexOf(desc,"silent")!=null then semanticMap.quiet=flagLetter
    if indexOf(desc,"all")!=null then semanticMap.all=flagLetter
    if indexOf(desc,"port")!=null then semanticMap.port=flagLetter
    if indexOf(desc,"pattern")!=null then semanticMap.pattern=flagLetter
    if indexOf(desc,"count")!=null or indexOf(desc,"number")!=null then semanticMap.count=flagLetter
  end for
  return semanticMap
end function