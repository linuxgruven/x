// =============================================================================
// AGENT_PARSER_FIELDS
// Per-command field extraction and clarification fallbacks.
// =============================================================================
//Translate "ssh/ftp into <ip> using <user> and password of <pass>" into a shell command.
//Returns null if andPart is not an ssh/ftp-into phrase.
AgentParser._translateConnIntoPart=function(andPart)
  andPart=trim(andPart)
  andPartLower=lower(andPart)
  if indexOf(andPartLower,"ssh into")==null and indexOf(andPartLower,"ftp into")==null then return null
  protocol="ssh"
  if indexOf(andPartLower,"ftp into")!=null then protocol="ftp"
  ipMatch=null
  partsSplit=split(andPart," ")
  nParts=len(partsSplit)
  wi=0;while wi<nParts
    if indexOf(lower(partsSplit[wi]),"into")!=null and wi+1<nParts then
      ipMatch=partsSplit[wi+1]
      break
    end if
  wi+=1;end while
  user="root"
  if indexOf(andPartLower,"using")!=null then
    wi=0;while wi<nParts
      if indexOf(lower(partsSplit[wi]),"using")!=null and wi+1<nParts then
        user=partsSplit[wi+1]
        break
      end if
    wi+=1;end while
  end if
  password=null
  if indexOf(andPartLower,"password")!=null then
    wi=0;while wi<nParts
      if indexOf(lower(partsSplit[wi]),"of")!=null and wi+1<nParts then
        prevWord=""
        if wi>0 then prevWord=lower(partsSplit[wi-1])
        if indexOf(prevWord,"password")!=null then
          password=partsSplit[wi+1]
          break
        end if
      end if
    wi+=1;end while
  end if
  if ipMatch==null then return andPart
  connCmd=protocol
  if password!=null then connCmd=connCmd+" -p "+password
  connCmd=connCmd+" "+user+"@"+ipMatch
  return connCmd
end function
//Mutates parsed; returns final parsed result (or error / re-parse).
//Action-specific field extraction (split out for build obfuscator scope limits).
AgentParser._extractActionPhase=function(Obj,command,cmd,parsed,headlessMode,debug,ips)
  if ips==null then ips=[]
  //Write command - extract quoted content and filename after "to"
  if parsed.action=="write" then
    //Extract quoted content first
    if indexOf(cmd,"""")!=null then
      quoteStart=indexOf(cmd,"""")
      afterFirstQuote=cmd[quoteStart+1:]
      quoteEnd=indexOf(afterFirstQuote,"""")
      if quoteEnd!=null then
        parsed.content=afterFirstQuote[:quoteEnd]
        if debug then print green("[DEBUG] Agent: Extracted quoted content: '"+parsed.content+"'")
      end if
    end if
    //Extract filename after prepositions or at end
    prepositions=[" to "," in "," into "," on "," onto "]
    for prep in prepositions
      if indexOf(cmd,prep)!=null then
        prepIdx=indexOf(cmd,prep)
        afterPrep=cmd[prepIdx+len(prep):]
        //Get first word after preposition
        filenameParts=split(trim(afterPrep)," ")
        if len(filenameParts)>0 then
          parsed.target=filenameParts[0]
          if debug then print green("[DEBUG] Agent: Extracted filename '"+parsed.target+"' after '"+prep+"'")
          break
        end if
      end if
    end for
    //If no preposition found, try to get last word as filename
    if not hasIndex(parsed,"target") then
      words=split(cmd," ")
      if len(words)>0 then
        //Get last word that's not inside quotes
        lastWord=words[len(words)-1]
        //Skip common words that aren't filenames
        if lastWord!="file" and lastWord!="text" and len(lastWord)>0 then
          parsed.target=lastWord
          if debug then print green("[DEBUG] Agent: Using last word '"+parsed.target+"' as filename")
        end if
      end if
    end if
  end if
  //Link command - extract source and destination from "from X to Y" pattern
  if parsed.action=="ln" then
    cmdRaw=lower(parsed.raw)  //Use lowercased version for indexOf
    fromIdx=indexOf(cmdRaw," from ")
    toIdx=indexOf(cmdRaw," to ")
    if fromIdx!=null and toIdx!=null and toIdx>fromIdx then
      //Extract source (between "from" and "to") from original case-preserved command
      afterFrom=parsed.raw[fromIdx+6:]  //Skip " from "
      beforeTo=afterFrom[:indexOf(lower(afterFrom)," to ")]
      parsed.source=trim(beforeTo)
      //Extract destination (after "to")
      afterTo=parsed.raw[toIdx+4:]  //Skip " to "
      destParts=split(trim(afterTo)," ")
      if len(destParts)>0 then parsed.destination=destParts[0]
      if debug then print green("[DEBUG] Agent: Extracted link source='"+parsed.source+"' destination='"+parsed.destination+"'")
    end if
  end if
  //Mv/Cp commands - extract source and destination from "X to Y" pattern
  if parsed.action=="mv" or parsed.action=="cp" then
    cmdRaw=lower(parsed.raw)  //Use lowercased version for indexOf
    toIdx=indexOf(cmdRaw," to ")
    if toIdx!=null then
      //Extract source (before "to") from original case-preserved command
      beforeTo=parsed.raw[:toIdx]
      //Remove command words (move/copy/mv/cp) from the beginning
      cmdWords=["move","copy","rename","duplicate","mv","cp","Move","Copy","Rename","Duplicate"]
      for cmdWord in cmdWords
        if indexOf(beforeTo,cmdWord)!=null then
          beforeTo=beforeTo.replace(cmdWord,"")
          break
        end if
      end for
      parsed.source=trim(beforeTo)
      //Extract destination (after "to")
      afterTo=parsed.raw[toIdx+4:]  //Skip " to "
      destParts=split(trim(afterTo)," ")
      if len(destParts)>0 then parsed.destination=destParts[0]
      if debug then print green("[DEBUG] Agent: Extracted "+parsed.action+" source='"+parsed.source+"' destination='"+parsed.destination+"'")
    end if
  end if
  //Chmod command - extract file and permission value from "of X to Y" or "chmod X to Y" pattern
  if parsed.action=="chmod" then
    cmdRaw=lower(parsed.raw)
    ofIdx=indexOf(cmdRaw," of ")
    toIdx=indexOf(cmdRaw," to ")
    if ofIdx!=null and toIdx!=null and toIdx>ofIdx then
      //Extract file (between "of" and "to")
      afterOf=parsed.raw[ofIdx+4:]  //Skip " of "
      beforeTo=afterOf[:indexOf(lower(afterOf)," to ")]
      parsed.target=trim(beforeTo)
      //Extract permission value (after "to")
      afterTo=parsed.raw[toIdx+4:]  //Skip " to "
      permParts=split(trim(afterTo)," ")
      if len(permParts)>0 then
        parsed.permValue=permParts[0]
        if debug then print green("[DEBUG] Agent: Extracted chmod target='"+parsed.target+"' permValue='"+parsed.permValue+"'")
      end if
    else if toIdx!=null and indexOf(cmdRaw,"chmod")!=null then
      //Handle "chmod X to Y" pattern (no "of")
      chmodIdx=indexOf(cmdRaw,"chmod")
      afterChmod=parsed.raw[chmodIdx+5:]  //Skip "chmod"
      beforeTo=afterChmod[:indexOf(lower(afterChmod)," to ")]
      parsed.target=trim(beforeTo)
      //Extract permission value (after "to")
      afterTo=parsed.raw[toIdx+4:]  //Skip " to "
      permParts=split(trim(afterTo)," ")
      if len(permParts)>0 then
        parsed.permValue=permParts[0]
        if debug then print green("[DEBUG] Agent: Extracted chmod target='"+parsed.target+"' permValue='"+parsed.permValue+"'")
      end if
    else
      //Handle "give/grant full permissions to X" pattern
      if indexOf(cmdRaw,"full permission")!=null or indexOf(cmdRaw,"full access")!=null then
        parsed.permValue="777"
        //Extract target - last word that's not "permission"/"permissions"/"access"
        words=split(cmd," ")
        li1=len(words)-1;while li1>=0
          if words[li1]!="permission" and words[li1]!="permissions" and words[li1]!="access" and words[li1]!="to" and len(words[li1])>0 then
            parsed.target=parsed.raw.split(" ")[li1]  //Get from original case-preserved command
            break
          end if
        li1-=1;end while
        if debug then print green("[DEBUG] Agent: Extracted chmod target='"+parsed.target+"' with full permissions (777)")
      else if indexOf(cmdRaw,"remove")!=null and indexOf(cmdRaw,"permission")!=null or indexOf(cmdRaw,"revoke")!=null and indexOf(cmdRaw,"permission")!=null then
        parsed.permValue="000"
        //Extract target - last word that's not "permission"/"permissions"/"all"
        words=split(cmd," ")
        li2=len(words)-1;while li2>=0
          if words[li2]!="permission" and words[li2]!="permissions" and words[li2]!="all" and words[li2]!="to" and words[li2]!="from" and len(words[li2])>0 then
            parsed.target=parsed.raw.split(" ")[li2]  //Get from original case-preserved command
            break
          end if
        li2-=1;end while
        if debug then print green("[DEBUG] Agent: Extracted chmod target='"+parsed.target+"' with no permissions (000)")
      else if indexOf(cmdRaw,"read only")!=null or indexOf(cmdRaw,"readonly")!=null then
        parsed.permValue="444"  //Read only for owner, group, and others
        //Extract target - last word that's not "read"/"only"/"permission"
        words=split(cmd," ")
        li3=len(words)-1;while li3>=0
          if words[li3]!="read" and words[li3]!="only" and words[li3]!="permission" and words[li3]!="permissions" and words[li3]!="to" and len(words[li3])>0 then
            parsed.target=parsed.raw.split(" ")[li3]  //Get from original case-preserved command
            break
          end if
        li3-=1;end while
        if debug then print green("[DEBUG] Agent: Extracted chmod target='"+parsed.target+"' with read only (444)")
      end if
    end if
  end if
  //Chown/chgrp commands - extract file and owner/group from "of X to Y" pattern
  if parsed.action=="chown" or parsed.action=="chgrp" then
    cmdRaw=lower(parsed.raw)
    ofIdx=indexOf(cmdRaw," of ")
    toIdx=indexOf(cmdRaw," to ")
    if ofIdx!=null and toIdx!=null and toIdx>ofIdx then
      //Extract file (between "of" and "to")
      afterOf=parsed.raw[ofIdx+4:]  //Skip " of "
      beforeTo=afterOf[:indexOf(lower(afterOf)," to ")]
      parsed.target=trim(beforeTo)
      //Extract owner/group (after "to")
      afterTo=parsed.raw[toIdx+4:]  //Skip " to "
      ownerParts=split(trim(afterTo)," ")
      if len(ownerParts)>0 then
        if parsed.action=="chown" then
          parsed.user=ownerParts[0]
          if debug then print green("[DEBUG] Agent: Extracted chown target='"+parsed.target+"' user='"+parsed.user+"'")
        else
          parsed.group=ownerParts[0]
          if debug then print green("[DEBUG] Agent: Extracted chgrp target='"+parsed.target+"' group='"+parsed.group+"'")
        end if
      end if
    end if
  end if
  //Chog command - extract file and user from "of X to Y" or "chog USER FILE" pattern
  if parsed.action=="chog" then
    cmdRaw=lower(parsed.raw)
    ofIdx=indexOf(cmdRaw," of ")
    toIdx=indexOf(cmdRaw," to ")
    if ofIdx!=null and toIdx!=null and toIdx>ofIdx then
      //Extract file (between "of" and "to")
      afterOf=parsed.raw[ofIdx+4:]  //Skip " of "
      beforeTo=afterOf[:indexOf(lower(afterOf)," to ")]
      parsed.target=trim(beforeTo)
      //Extract user (after "to")
      afterTo=parsed.raw[toIdx+4:]  //Skip " to "
      userParts=split(trim(afterTo)," ")
      if len(userParts)>0 then parsed.user=userParts[0]
      if debug then print green("[DEBUG] Agent: Extracted chog target='"+parsed.target+"' user='"+parsed.user+"'")
    else
      //Handle direct "chog USER FILE" pattern
      chogIdx=indexOf(cmdRaw,"chog")
      if chogIdx!=null then
        afterChog=parsed.raw[chogIdx+4:]  //Skip "chog"
        parts=split(trim(afterChog)," ")
        if len(parts)>=2 then
          parsed.user=parts[0]
          parsed.target=parts[1]
          if debug then print green("[DEBUG] Agent: Extracted chog user='"+parsed.user+"' target='"+parsed.target+"'")
        end if
      end if
    end if
  end if
  //Es command - extract IP/port or library from "scan [service] on [ip]" or "scan [library] library"
  if parsed.action=="es" then
    cmdRaw=lower(parsed.raw)
    onIdx=indexOf(cmdRaw," on ")
    libraryIdx=indexOf(cmdRaw," library")
    //Pattern 1: "scan [service] on [ip]" -> es IP PORT
    if onIdx!=null then
      //Extract IP (after "on")
      afterOn=parsed.raw[onIdx+4:]  //Skip " on "
      ipParts=split(trim(afterOn)," ")
      if len(ipParts)>0 then
        parsed.target=ipParts[0]
        //Extract service (before "on")
        beforeOn=cmdRaw[:onIdx]
        //Look for service keywords
        serviceMap={"ssh":"22","ftp":"21","http":"80","web":"80","smtp":"25","router":"0"}
        for service in indexes(serviceMap)
          if indexOf(beforeOn,service)!=null then
            parsed.port=serviceMap[service]
            parsed.service=service
            break
          end if
        end for
        if debug then print green("[DEBUG] Agent: Extracted es target='"+parsed.target+"' port='"+parsed.port+"' service='"+parsed.service+"'")
      end if
    else if libraryIdx!=null then
      //Pattern 2: "scan [library] library" -> es LIBRARY
      beforeLibrary=cmdRaw[:libraryIdx]
      //Extract library name (last word before "library")
      words=split(trim(beforeLibrary)," ")
      if len(words)>0 then
        parsed.library=words[len(words)-1]
        if debug then print green("[DEBUG] Agent: Extracted es library='"+parsed.library+"'")
      end if
    else
      //Check if there's a direct library reference after "es"
      esIdx=indexOf(cmdRaw,"es ")
      if esIdx!=null then
        afterEs=parsed.raw[esIdx+3:]  //Skip "es "
        parts=split(trim(afterEs)," ")
        if len(parts)>0 then
          //Could be IP PORT or just LIBRARY
          if len(parts)>=2 and indexOf(parts[0],".")!=null then
            //Likely IP PORT format
            parsed.target=parts[0]
            parsed.port=parts[1]
            if debug then print green("[DEBUG] Agent: Extracted es target='"+parsed.target+"' port='"+parsed.port+"'")
          else
            //Likely library name
            parsed.library=parts[0]
            if debug then print green("[DEBUG] Agent: Extracted es library='"+parsed.library+"'")
          end if
        end if
      end if
    end if
  end if
  //WiFi command - extract operation flags from natural language
  if parsed.action=="iwlist" then
    cmdRaw=lower(parsed.raw)
    //Default to listing networks for any wifi query
    parsed.flag="-l"
    if indexOf(cmdRaw,"list")!=null or indexOf(cmdRaw,"show")!=null or indexOf(cmdRaw,"scan")!=null or indexOf(cmdRaw,"available")!=null then
      parsed.flag="-l"
      if debug then print green("[DEBUG] Agent: WiFi list networks detected, flag='-l'")
    end if
  end if
  //Cat/read command - extract filename after read/view/display/show
  if parsed.action=="cat" then
    //Use case-preserved raw command for filename extraction
    cmdRaw=lower(parsed.raw)
    triggerWords=["read","view","display","show"]
    for trigger in triggerWords
      triggerIdx=indexOf(cmdRaw,trigger+" ")
      if triggerIdx!=null then
        afterTrigger=parsed.raw[triggerIdx+len(trigger)+1:]  //Skip trigger word and space using original case
        //Handle "show me <file>" pattern
        if trigger=="show" and indexOf(lower(afterTrigger),"me ")!=null then
          afterMe=afterTrigger[indexOf(lower(afterTrigger),"me ")+3:]
          filenameParts=split(trim(afterMe)," ")
        else
          filenameParts=split(trim(afterTrigger)," ")
        end if
        if len(filenameParts)>0 then
          parsed.target=filenameParts[0]
          if debug then print green("[DEBUG] Agent: Extracted filename '"+parsed.target+"' after '"+trigger+"'")
          break
        end if
      end if
    end for
  end if
  //Rm command - extract filename from "remove/delete X" pattern
  if parsed.action=="rm" then
    cmdRaw=lower(parsed.raw)
    triggerWords=["remove","delete","erase"]
    for trigger in triggerWords
      triggerIdx=indexOf(cmdRaw,trigger+" ")
      if triggerIdx!=null then
        afterTrigger=parsed.raw[triggerIdx+len(trigger)+1:]  //Skip trigger word and space
        filenameParts=split(trim(afterTrigger)," ")
        if len(filenameParts)>0 then
          parsed.target=filenameParts[0]
          if debug then print green("[DEBUG] Agent: Extracted rm target='"+parsed.target+"' after '"+trigger+"'")
          break
        end if
      end if
    end for
  end if
  //Grep command - extract pattern and file from "search for X in Y"
  if parsed.action=="grep" then
    forIdx=indexOf(cmd," for ")
    inIdx=indexOf(cmd," in ")
    if forIdx!=null and inIdx!=null and inIdx>forIdx then
      //Extract pattern (between "for" and "in")
      afterFor=cmd[forIdx+5:]  //Skip " for "
      beforeIn=afterFor[:indexOf(afterFor," in ")]
      parsed.pattern=trim(beforeIn)
      //Extract filename (after "in")
      afterIn=cmd[inIdx+4:]  //Skip " in "
      filenameParts=split(trim(afterIn)," ")
      if len(filenameParts)>0 then parsed.target=filenameParts[0]
      if debug then print green("[DEBUG] Agent: Extracted grep pattern='"+parsed.pattern+"' file='"+parsed.target+"'")
    end if
  end if
  //Find command - extract pattern from "find files named X"
  if parsed.action=="find" then
    namedIdx=indexOf(cmd," named ")
    calledIdx=indexOf(cmd," called ")
    triggerIdx=null
    triggerLen=0
    if namedIdx!=null then
      triggerIdx=namedIdx
      triggerLen=7  //" named "
    else if calledIdx!=null then
      triggerIdx=calledIdx
      triggerLen=8  //" called "
    end if
    if triggerIdx!=null then
      //Extract pattern after "named" or "called"
      afterTrigger=cmd[triggerIdx+triggerLen:]
      patternParts=split(trim(afterTrigger)," ")
      if len(patternParts)>0 then
        parsed.pattern=patternParts[0]
        //Clear target since we want to search current directory
        if hasIndex(parsed,"target") and parsed.target==parsed.pattern then parsed.target=null
        if debug then print green("[DEBUG] Agent: Extracted find pattern='"+parsed.pattern+"'")
      end if
    end if
  end if
  //Nmap command - detect special flags from keywords
  if parsed.action=="nmap" then
    if indexOf(cmd,"random")!=null then
      parsed.flags="-r"
      if debug then print green("[DEBUG] Agent: Detected 'random' for nmap, setting flags='-r'")
    else if indexOf(cmd,"localhost")!=null or indexOf(cmd,"local")!=null then
      parsed.flags="-l"
      if debug then print green("[DEBUG] Agent: Detected 'localhost' for nmap, setting flags='-l'")
    else if indexOf(cmd,"public")!=null then
      parsed.flags="-p"
      if debug then print green("[DEBUG] Agent: Detected 'public' for nmap, setting flags='-p'")
    end if
  end if
  //File operations - extract filename/path from "called", "named", or "name"
  fileOps=["touch","mkdir","rm","mv","cp","cat","write","grep","chmod","chown","copy","move","remove"]
  if indexOf(fileOps,parsed.action)!=null then
    if indexOf(cmd,"called")!=null or indexOf(cmd,"named")!=null or indexOf(cmd," name ")!=null then
      triggerWord=null
      if indexOf(cmd,"called")!=null then triggerWord="called"
      if indexOf(cmd,"named")!=null then triggerWord="named"
      if indexOf(cmd," name ")!=null then triggerWord=" name "
      if triggerWord then
        triggerIdx=indexOf(cmd,triggerWord)
        afterTrigger=cmd[triggerIdx+len(triggerWord):]
        nameParts=split(trim(afterTrigger)," ")
        if len(nameParts)>0 then
          parsed.target=nameParts[0]
          if debug then print green("[DEBUG] Agent: Extracted filename '"+parsed.target+"' for "+parsed.action)
        end if
      end if
    end if
  end if
  //chmod specific - parse permission values from natural language
  if parsed.action=="chmod" then
    //Map permission descriptions to chmod values
    if indexOf(cmd,"remove all")!=null or indexOf(cmd,"no permissions")!=null or indexOf(cmd,"zero permissions")!=null then
      parsed.permValue="000"
      if debug then print green("[DEBUG] Agent: Mapped 'remove all permissions' to chmod 000")
    else if indexOf(cmd,"full")!=null or indexOf(cmd,"all permissions")!=null or indexOf(cmd,"777")!=null then
      parsed.permValue="777"
      if debug then print green("[DEBUG] Agent: Mapped 'full permissions' to chmod 777")
    else if indexOf(cmd,"read only")!=null or indexOf(cmd,"readonly")!=null then
      parsed.permValue="444"
      if debug then print green("[DEBUG] Agent: Mapped 'read only' to chmod 444")
    else if indexOf(cmd,"executable")!=null or indexOf(cmd,"execute")!=null then
      parsed.permValue="755"
      if debug then print green("[DEBUG] Agent: Mapped 'executable' to chmod 755")
    else
      //Try to extract numeric permission value (777, 644, etc)
      words=split(cmd," ")
      for word in words
        if len(word)==3 then
          //Check if it's a valid 3-digit permission (0-7 for each digit)
          isValid=true
          li4=0;while li4<=2
            digit=word[li4].val
            if digit==null or digit<0 or digit>7 then
              isValid=false
              break
            end if
          li4+=1;end while
          if isValid then
            parsed.permValue=word
            if debug then print green("[DEBUG] Agent: Extracted permission value: "+word)
            break
          end if
        end if
      end for
    end if
  end if
  if parsed.action=="scan" then
    //Detect tool preference
    if indexOf(cmd,"nmap")!=null then parsed.tool="nmap" else parsed.tool="scan"
    //Detect random scan flag
    if indexOf(cmd,"random")!=null then
      parsed.flag="-r"
      //Don't set a target - scan -r handles finding a random network
      if debug then print green("[DEBUG] Agent: Detected 'random' for scan, setting flag='-r'")
    end if
    //Detect local/localhost scan flag
    if indexOf(cmd,"local")!=null or indexOf(cmd,"localhost")!=null then
      parsed.flag="-l"
      //Don't set a target - scan -l scans localhost
      if debug then print green("[DEBUG] Agent: Detected 'local/localhost' for scan, setting flag='-l'")
    end if
    //Detect service type
    if indexOf(cmd,"router")!=null then
      parsed.service="router"
    else if indexOf(cmd,"ssh")!=null then
      parsed.service="ssh"
    else if indexOf(cmd,"ftp")!=null then
      parsed.service="ftp"
    else if indexOf(cmd,"http")!=null or indexOf(cmd,"web")!=null then
      parsed.service="http"
    else if indexOf(cmd,"smtp")!=null or indexOf(cmd,"mail")!=null then
      parsed.service="smtp"
    end if
    //Detect scan mode from commandPatterns.scan.subtypes
    scanPattern=null
    if hasIndex(globals.G_agent,"_commandPatterns") and hasIndex(globals.G_agent._commandPatterns,"scan") then
      scanPattern=globals.G_agent._commandPatterns["scan"]
    end if
    if scanPattern and hasIndex(scanPattern,"subtypes") then
      for subtypeName in indexes(scanPattern.subtypes)
        subtype=scanPattern.subtypes[subtypeName]
        for subKeyword in subtype.keywords
          if indexOf(cmd,subKeyword)!=null then
            parsed.scanMode=subtype.mode
            parsed.summary=subtype.summary
            break
          end if
        end for
        if hasIndex(parsed,"scanMode") then break
      end for
    end if
    //Check for 'system' keyword
    if indexOf(cmd,"system")!=null then
      parsed.scanMode="local"
      parsed.summary="Scan local system"
      parsed.tool="scan"  //Force scan for system scans
    end if
    //Smart defaults based on IP type
    if not hasIndex(parsed,"scanMode") then
      if len(ips)>0 then
        parsed.scanMode="ip"
        parsed.summary="Scan "+ips[0]
        //Choose tool based on IP type
        if globals.G_agent._isPrivateIp(ips[0]) then
          parsed.tool="scan"  //Use scan for private IPs
          parsed.scanMode="ip"  //Scan specific IP
          parsed.summary="Scan "+ips[0]
        else
          //Public IP - prefer nmap (stealthier)
          if not hasIndex(parsed,"tool") then parsed.tool="nmap"
        end if
      else
        parsed.scanMode="auto"
      end if
    end if
  else if parsed.action=="cd" then
    //Extract path from cd command
    words=split(command," ")
    cdIdx=-1
    _len=len(words);li5=0;while li5<_len
      if words[li5]=="cd" then
        cdIdx=li5
        break
      end if
    li5+=1;end while
    if cdIdx>=0 and cdIdx+1<len(words) then
      //Get the path after "cd"
      pathWord=words[cdIdx+1]
      //Map special keywords
      if pathWord=="root" then
        parsed.path="/"
      else if pathWord=="home" then
        parsed.path=""  //Empty means home directory
      else
        parsed.path=pathWord
      end if
    end if
  else if parsed.action=="ls" then
    //Extract path from ls command
    words=split(command," ")
    lsIdx=-1
    _len=len(words);li6=0;while li6<_len
      if words[li6]=="ls" or words[li6]=="list" then
        lsIdx=li6
        break
      end if
    li6+=1;end while
