// =============================================================================
// MISSIONS
// Mission library; management and automation utilities for X shell missions.
// =============================================================================
Mission={}
Mission.attrs=["type","completed"]
Mission.extractBold=function(text)
	startTag=indexOf(text,"<b>")
	endTag=indexOf(text,"</b>")
	if startTag!=null and endTag!=null then return text[startTag+3:endTag].trim
	return null
end function
Mission._ensureCache=function(metaLib)
  if Exploit.haveAlready(metaLib) then
    if Exploit.canScan(metaLib) then Exploit.headless(metaLib)
  else
    z=Exploit.get(metaLib)
    if not z then return false
    Info.info("Adding "+lib_name(metaLib)+":"+version(metaLib))
    Exploit.headless(metaLib)
  end if
  return true
end function
Mission.getObject=function(public,local,i,needRoot=false)
  router=get_router(public)
  if not router then return
  if typeof(router)=="router" then
    fallbackResult=null
    _mx=Library.mxFor(null)
    if i and hasIndex(i,"Obj") then _mx=Library.mxFor(i.Obj)
    _ports=Exploit.extract(router,public,_mx)
    if _ports isa Error then return
    for m in _ports
      if m isa Error then continue
      if m.local_ip!=local and not (hasIndex(i,"anyUser") and i.anyUser) then continue
      if not self._ensureCache(m.metaLib) then break
      for ez in Exploit._ex(Exploit.getCacheKey(m.metaLib))
        if needRoot then
          if ez.u=="r" then
            x=Exploit.overflow(m.metaLib,ez.m,ez.s,null,"missions")
            if not x or x isa number then continue
            if ez.e=="s" then return x
            if not fallbackResult then fallbackResult=x
          end if
        else
          validUser=false
          if hasIndex(i,"anyUser") and i.anyUser then
            if ez.u=="u" or ez.u=="r" then validUser=true
          else
            if ez.u=="u" or ez.u=="r" or ez.u=="g" then validUser=true
          end if
          if validUser and (ez.e!="l" and ez.e!="i") then
            x=Exploit.overflow(m.metaLib,ez.m,ez.s,null,"missions")
            if not x or x isa number then continue
            if ez.e=="s" then return x
            if not fallbackResult then fallbackResult=x
          end if
        end if
      end for
    end for
    if fallbackResult then return fallbackResult
  end if
end function
Mission.getObjectShell=function(public,local=null)
  router=get_router(public)
  if not router then return
  if typeof(router)=="router" then
    rootShell=null
    userShell=null
    guestShell=null
    _ports=Exploit.extract(router,public,Library.mxFor(null))
    if _ports isa Error then return
    for m in _ports
      if m isa Error then continue
      if local!=null then
        if m.local_ip!=local then continue
      else
        if __m_idx==0 then continue
      end if
      if not self._ensureCache(m.metaLib) then break
      for ez in Exploit._ex(Exploit.getCacheKey(m.metaLib))
        if ez.e=="s" then
          x=Exploit.overflow(m.metaLib,ez.m,ez.s,null,"missions")
          if not x or x isa number then continue
          if ez.u=="r" then
            if not rootShell then rootShell=x
          else if ez.u=="u" then
            if not userShell then userShell=x
          else if ez.u=="g" then
            if not guestShell then guestShell=x
          end if
        end if
      end for
    end for
    if rootShell then return rootShell
    if userShell then return userShell
    if guestShell then return guestShell
  end if
end function
Mission.getPasswd=function(obj,i)
  passwdFile=Io.getFileObj(obj,"/etc/passwd")
  if passwdFile isa Error then return ["error",yellow("Could not retrieve /etc/passwd")]
  if not has_permission(passwdFile,"r") then return ["error",yellow("No read permission on /etc/passwd")]
  // Read passwd file content
  for line in split(get_content(passwdFile),char(10));if not line then continue;pass=split(line,":");if i.anyUser==true or pass[0]==i.username then return ["success",Crack.hash(pass[1])];end for
  return ["error",yellow("Could not find the specified user in /etc/passwd")]
end function
Mission.getRootBounce=function(public,local,i)
  if not i then i={}
  //Agent may pass an already-captured router shell in i.shell (skip re-scan)
  ex=null
  shell=null
  if hasIndex(i,"shell") and i.shell then
    if typeof(i.shell)=="shell" then
      ex=i.shell
      shell=Exploit.getShell(ex,false,[],true)
    else if typeof(i.shell)=="map" and hasIndex(i.shell,"shell") and typeof(i.shell.shell)=="shell" then
      shell=i.shell
      ex=i.shell.shell
    end if
  end if
  if not shell then
    //Use live session Obj for metaxploit (OPSEC - avoid home IP in router logs)
    _sess=null
    if hasIndex(i,"Obj") and i.Obj then
      _sess=i.Obj
    else if globals.G_proxy then
      _sess=globals.G_proxy
    end if
    //Need router shell (port 0). find -s alone prefers non-router shells - use --router.
    if not Library.mxFor(_sess) then return ["error",yellow("No metaxploit for remote scan (load on proxy)")]
    _attempts=[[public,"kernel_router","s"],[public,"router","s"],[public,"find","s","--router"]]
    _lastErr="no shell exploit succeeded"
    for _args in _attempts
      ex=Attack.scanCustom(_args,true,_sess)
      if typeof(ex)=="shell" then break
      if ex isa Error then
        if hasIndex(ex,"message") then _lastErr=str(ex.message) else _lastErr=str(ex)
      else if ex then
        _lastErr="scanCustom returned "+typeof(ex)
      end if
      ex=null
    end for
    if typeof(ex)!="shell" then return ["error",yellow("Could not get a shell on the router ("+_lastErr+")")]
    shell=Exploit.getShell(ex,false,[],true)
  end if
  if not shell or shell isa Error then
    why="getShell failed"
    if shell isa Error and hasIndex(shell,"message") then why=str(shell.message)
    return ["error",yellow("Could not get a shell on the router ("+why+")")]
  end if
  //check if we are root on the router (required to scan local libs / install bounce lib)
  if shell.user.raw!="root" then shell=ShellObject.headlessSu(shell)
  if shell isa Error then
    if hasIndex(i,"anyUser") and i.anyUser then
      r=Crack.returnRootPass(ex)
      if not r isa Error then return ["success",r]
    else
      return ["error",yellow("Could not get root on the router")]
    end if
  end if
  //Check to make sure we are root
  if shell.user.raw!="root" then return ["error",yellow("Could not get a root shell on the router")]
  //Wipe the log
  Log.shellLog(shell.shell)
  //Need packed metaxploit to load local /lib (same as scan --e / --l)
  ShellObject.packMeta(shell)
  //Helpers: same backend as scan --e / --l
  isRootComputer=function(c)
    if typeof(c)!="computer" then return false
    u=Utility.getUserEX(c)
    if not u then return false
    if hasIndex(u,"user") and u.user=="root" then return true
    if hasIndex(u,"raw") and u.raw=="root" then return true
    if hasIndex(u,"name") and u.name=="root" then return true
    return false
  end function
  //From nested-router computer, get root shell and bounce to original LAN
  hopFromComputer=function(comp)
    co=Exploit.getComputer(comp,true)
    if not co or co isa Error then return null
    raw=Exploit.returnShell(co,true)
    if typeof(raw)!="shell" then return null
    hop=Exploit.getShell(raw,false,[],true)
    if not hop or hop isa Error then return null
    if hop.user.raw!="root" then hop=ShellObject.headlessSu(hop)
    if not hop or hop isa Error or hop.user.raw!="root" then return null
    ShellObject.packMeta(hop)
    c2=Exploit.scanForExploit(hop,["-u","root","bounce",local],true,true)
    if isRootComputer(c2) then return c2
    c2=Exploit.scanForExploit(hop,["-u","root","computer",local],true,true)
    if isRootComputer(c2) then return c2
    if globals.G_settings.vulnerableLib and globals.G_settings.vulnerableLibIndex!=null and globals.G_settings.vulnerableLibIndex!=-1 then
      SavedLibs.getFile(hop,["-p","/lib",globals.G_settings.vulnerableLib])
      c2=Exploit.scanLocalCustom(hop,[globals.G_settings.vulnerableLib,globals.G_settings.vulnerableLibIndex,local],true,true)
      if isRootComputer(c2) then return c2
    end if
    return null
  end function
  //Direct LAN, then nested gateway (e.g. 172.16.3.9 via 172.16.3.1)
  bounceTargets=[local]
  _parts=split(local,"\.")
  if len(_parts)==4 then
    _gw=_parts[0]+"."+_parts[1]+"."+_parts[2]+".1"
    if _gw!=local then push(bounceTargets,_gw)
  end if
  tryTargets=function(useLocalCustom)
    for _bt in bounceTargets
      if useLocalCustom then
        c=Exploit.scanLocalCustom(shell,[globals.G_settings.vulnerableLib,globals.G_settings.vulnerableLibIndex,_bt],true,true)
      else
        c=Exploit.scanForExploit(shell,["-u","root","bounce",_bt],true,true)
        if not isRootComputer(c) then c=Exploit.scanForExploit(shell,["-u","root","computer",_bt],true,true)
      end if
      if not isRootComputer(c) then continue
      if _bt==local then return c
      hopped=hopFromComputer(c)
      if hopped then return hopped
    end for
    return null
  end function
  //1) scan --e: root bounce from libraries already on the router
  computer=tryTargets(false)
  if computer then return computer
  //2) No local root bounce - install config bounce lib, then scan --e again (and --l as pin)
  hasHackLib=globals.G_settings.vulnerableLib and globals.G_settings.vulnerableLibIndex!=null and globals.G_settings.vulnerableLibIndex!=-1
  if not hasHackLib then return ["error",yellow("No root lan bounce via scan --e and bounce lib not set (config -v/-x)")]
  SavedLibs.getFile(shell,["-p","/lib",globals.G_settings.vulnerableLib])
  computer=tryTargets(false)
  if computer then return computer
  computer=tryTargets(true)
  if computer then return computer
  return ["error",yellow("Unable to get a computer bounce to the target (scan --l)")]
end function
Mission.init=function(m)
	self.mail=m
	self.inbox=m.inbox
	self.metaMail=m.inbox.metaMail
	self.completed=false
	self._c=self._strip(m.content)
	if indexOf(self._c,"customer is satisfied")!=null then self.completed=true
	self.setType
end function
Mission.setType=function
	if indexOf(self._c,"academic record")!=null then
		self.type="academic"
	else if indexOf(self._c,"police record")!=null then
		self.type="police"
  else if indexOf(self._c,"stop working")!=null then
    self.type="corruption"
	else if indexOf(self._c,"enter a remote machine and get a file")!=null then
		self.type="getfile"
	else if indexOf(self._c,"delete a file that could incriminate")!=null then
		self.type="deletefile"
	else if indexOf(self._c,"login credentials")!=null then
		self.type="credentials"
	else if indexOf(self._c,"phantom supplier")!=null then
		self.type="fraud"
	else if indexOf(self._c,"corrupt backup files")!=null then
		self.type="sabotage"
	else if indexOf(self._c,"leaking confidential information")!=null then
		self.type="espionage"
	else
		self.type="unknown"
	end if
end function
Mission.getHeadless=function(ex,m=null)
  type=typeof(ex)
  if type=="shell" then
    _=new ShellObject
    return _.run(_,ex,false,[],true)
  else if type=="computer" then
    _=new ComputerObject
    return _.run(_,ex,true)
  else if type=="file" then
    _=new FileObject
    return _.run(_,ex,m,true)
  end if
end function
Mission.info=function
	if self.type=="academic" then
		return self.getAcademic
	else if self.type=="police" then
		return self.getPolice
  else if self.type=="corruption" then
    return self.getCorruption
	else if self.type=="getfile" then
		return self.getRemoteFile
	else if self.type=="deletefile" then
		return self.getDeleteFile
	else if self.type=="credentials" then
		return self.getCredentials
	else if self.type=="fraud" then
		return self.getFraud
	else if self.type=="sabotage" then
		return self.getSabotage
	else if self.type=="espionage" then
		return self.getEspionage
	end if
end function
Mission._strip=function(t)
	// Strip HTML/rich-text tags
	while true
		s=indexOf(t,"<")
		if s==null then break
		e=indexOf(t,">")
		if e==null then break
		t=t[:s]+t[e+1:]
	end while
	// Strip ANSI escape codes
	n=len(t)
	i=0
	out=[]
	while i<n
		ch=t[i]
		if ch==char(27) and i+1<n and t[i+1]=="[" then
			i=i+2
			while i<n
				c=t[i]
				if (c>="A" and c<="Z") or (c>="a" and c<="z") then
					i=i+1
					break
				end if
				i=i+1
			end while
			continue
		end if
		push(out,ch)
		i=i+1
	end while
	return join(out,"").trim
end function
Mission._find=function(key)
	idx=indexOf(self._c,key)
	if idx==null then return null
	return self._c[idx+len(key):]
end function
Mission.getCorruption=function
  i={}
  i.skip=false
  //Extract IP
  t=self._find("public IP of the victim is ")
  if not t then
    i.answer=yellow("Could not parse corruption mission IP from mail")
    i.skip=true
    return i
  end if
  i.ip=split(split(t,"\. ")[0],char(10))[0].trim
  //Extract target LAN IP
  t=self._find("victim's local IP is ")
  if not t then
    i.answer=yellow("Could not parse corruption mission target IP from mail")
    i.skip=true
    return i
  end if
  i.target=split(t,char(10))[0].trim
  //We should first check if the lan ip is forwarded by the router
  ex=self.getObject(i.ip,i.target,i,true)
  if ex then
    if typeof(ex)=="shell" then
      obj=self.getHeadless(ex,{"public_ip":i.ip,"local_ip":i.target})
      if obj.user.raw!="root" then obj=ShellObject.headlessSu(obj)
      if not obj isa Error then
        Log.shellLog(obj.shell)
        obj.commands["rn"](["/boot","boots"])
        obj.commands["home"]
        i.answer=green("Successfully corrupted the target's boot process")
        return i
      end if
    end if
  end if
  //If we reach here, we couldn't get a shell on the target via router bounce
  //Check that we have vulnerable lib settings
  if not globals.G_settings.vulnerableLib or not globals.G_settings.vulnerableLibIndex then
    i={}
    i.answer=yellow("Vulnerable library or index not set in settings")
    i.skip=true
    return i
  end if
  //Attack via router bounce
  obj=self.getRootBounce(i.ip,i.target,i)
  if obj isa list then
    i.answer=obj[1]
    i.skip=true
    return i
  end if
  if typeof(obj)!="computer" then
    i.answer=yellow("Could not get target computer on "+i.target)
    i.skip=true
    return i
  end if
  computer=self.getHeadless(obj,{"public_ip":i.ip,"local_ip":i.target})
  if computer.user.raw!="root" then
    i.answer=yellow("Lost our root computer, most likely Admin is cock blocking")
    i.skip=true
    return i
  end if
  Log.computerLog(computer.computer)
  computer.commands["rn"](["/boot","boots"])
  computer.commands["home"]
  i.answer=green("Successfully corrupted the target's boot process")
  return i
end function
Mission.getAcademic=function
	i={}
  i.skip=false
	//Extract public IP
	t=self._find("public IP of the victim is ")
	if not t then
		i.answer=yellow("Could not parse academic mission IP")
		i.skip=true
		return i
	end if
	i.ip=split(t,char(10))[0].trim
	//Extract LAN IP
	t=self._find("database is located is ")
	if not t then
		i.answer=yellow("Could not parse academic mission target IP")
		i.skip=true
		return i
	end if
	i.target=split(t,char(10))[0].trim
	//Extract student name
	t=self._find("modify belongs to: ")
	if not t then
		i.answer=yellow("Could not parse academic mission student name")
		i.skip=true
		return i
	end if
	i.student=split(t,char(10))[0].replace(":","").replace("\.","").trim
	//Extract subject
	t=self._find("modify the subject ")
	if not t then
		i.answer=yellow("Could not parse academic mission subject")
		i.skip=true
		return i
	end if
	i.subject=split(t," to ")[0].trim
	//Determine requested action
	if indexOf(self._c,"academic qualification by at least one point")!=null then
		i.requested="Add 1 to the current grade"
	else if indexOf(self._c,"change the note to approved at least")!=null then
		i.requested="Change the grade to 8 or better, or just add 7 the the current grade"
	end if
  //We need to get a shell on the target Lan first
  ex=self.getObjectShell(i.ip)
  if typeof(ex)!="shell" then
    i.answer=yellow("Could not get a shell from the network "+i.ip)
    i.skip=true
    return i
  end if
  obj=self.getHeadless(ex,{"public_ip":i.ip,"local_ip":i.target})
  Command.open(globals.G_main,["admin"])
  Command.open(obj,["student"])
  print green("Modify the academic record as follows:")
  print green("Student: ")+white(i.student)
  print green("Subject: ")+white(i.subject)
  print green(" Action: ")+white(i.requested)
  if Gui.yesNo("Did you successfully modify the academic record?") then
    i.answer=green("Successfully modified academic record for "+i.student)
  else
    i.answer=yellow("Failed to modify academic record for "+i.student)
    i.skip=true
  end if
  //Clear the log
  if obj.user.raw!="root" then obj=ShellObject.headlessSu(obj)
  if not obj isa Error then Log.shellLog(obj.shell)
  return i
end function
Mission.getPolice=function
	i={}
	i.skip=false
	//Extract public IP
	t=self._find("public IP of the victim is ")
	if not t then
		i.answer=yellow("Could not parse police mission IP")
		i.skip=true
		return i
	end if
	i.ip=split(t,char(10))[0].trim
  i.target=i.ip
	//Extract convict name
	t=self._find("modify belongs to: ")
	if not t then
		i.answer=yellow("Could not parse police mission convict name")
		i.skip=true
		return i
	end if
	i.convict=split(t,char(10))[0].replace(":","").replace("\.","").trim
	//Determine action type and extract details
	if indexOf(self._c,"delete the record completely")!=null then
		i.type="deleteComplete"
		i.requested="Delete the entire police record for "+i.convict
	else if indexOf(self._c,"client wants to delete the charge")!=null then
		i.type="delete"
		t=self._find("delete the charge of ")
		i.charge=split(t,"\.")[0].trim
		i.requested="Delete the charge: "+i.charge
	else if indexOf(self._c,"client wants to add the charge")!=null then
		i.type="add"
		t=self._find("add the charge of ")
		i.charge=split(t," in the year")[0].trim
		t=self._find("in the year ")
		i.year=split(t,"\.")[0].trim
		i.requested="Add charge: "+i.charge+" in year "+i.year
	else if indexOf(self._c,"client wants to modify the charge")!=null then
		i.type="modify"
		t=self._find("modify the charge of ")
		i.charge=split(t," so that")[0].trim
		t=self._find("date of the crime is ")
		i.change=split(t,char(10))[0].trim
		i.requested="Modify charge: "+i.charge+" - Change date to: "+i.change
	end if
  //We need to get a shell on the target Lan first
  ex=self.getObjectShell(i.ip)
  if typeof(ex)!="shell" then
    i.answer=yellow("Could not get a shell from the network "+i.ip)
    i.skip=true
    return i
  end if
  obj=self.getHeadless(ex,{"public_ip":i.ip,"local_ip":i.target})
  Command.open(globals.G_main,["admin"])
  Command.open(obj,["police"])
  print green("Modify the police record as follows:")
  print green("Convict: ")+white(i.convict)
  if hasIndex(i,"charge") then print green(" Charge: ")+white(i.charge)
  if hasIndex(i,"year") then print green("   Year: ")+white(i.year)
  if hasIndex(i,"change") then print green(" Change: ")+white(i.change)
  print green(" Action: ")+white(i.requested)
  if Gui.yesNo("Did you successfully modify the police record?") then
    i.answer=green("Successfully modified police record for "+i.convict)
  else
    i.answer=yellow("Failed to modify police record for "+i.convict)
    i.skip=true
  end if
  //Clear the log
  if obj.user.raw!="root" then obj=ShellObject.headlessSu(obj)
  if not obj isa Error then Log.shellLog(obj.shell)
  return i
end function
Mission.getRemoteFile=function
	i={}
  i.skip=false
	//Extract public IP
	t=self._find("public IP of the victim is ")
	if not t then
		i.answer=yellow("Could not parse getfile mission IP")
		i.skip=true
		return i
	end if
	i.ip=split(split(t," and")[0],char(10))[0].trim
	//Extract target LAN IP
	t=self._find("local IP where the file is located is ")
	if not t then
		i.answer=yellow("Could not parse getfile mission target IP")
		i.skip=true
		return i
	end if
	i.target=split(t," ")[0].trim
	//Extract file path
	t=self._find("on the path ")
	if t then
		i.filePath=split(t,char(10))[0].trim
		if i.filePath[-1:]=="." then i.filePath=i.filePath[:-1]
	else
		i.filePath=""
	end if
  i.needRshell=false
  //Check the router to see if we can get a shell on the target directly
  ex=self.getObjectShell(i.ip,i.target)
  if ex and typeof(ex)=="shell" then
    obj=self.getHeadless(ex,{"public_ip":i.ip,"local_ip":i.target})
    fileObj=Io.getFileObj(obj,i.filePath)
    if not fileObj isa Error then
      Io.download(obj,[i.filePath])
      i.answer=green("Successfully downloaded "+split(i.filePath,"/")[-1]+" via direct shell on target")
      return i
    end if
  end if
  i.needRshell=true
  //Check if rshell bypass is enabled
  if not globals.G_rshell.servers and not self.inbox.bypassRshell then
    i.answer=yellow("No RShell servers available")
    i.skip=true
    return i
  end if
  if not globals.G_settings.vulnerableLib or not globals.G_settings.vulnerableLibIndex then
    i={}
    i.answer=yellow("Vulnerable library or index not set in settings")
    i.skip=true
    return i
  end if
  //Attack via router bounce
  obj=self.getRootBounce(i.ip,i.target,i)
  if obj isa list then
    i.answer=obj[1]
    i.skip=true
    return i
  end if
  if typeof(obj)!="computer" then
    i.answer=yellow("Could not get target computer on "+i.target)
    i.skip=true
    return i
  end if
  computer=self.getHeadless(obj,{"public_ip":i.ip,"local_ip":i.target})
  if computer.user.raw=="root" then Log.computerLog(computer.computer)
  Net.snoop(computer,["-B"])
  Command.open(computer,["email","--login","--l"])
  if globals.G_rshell.servers then
    if globals.G_settings.rshell then Rshell.list else RshellLite.list
  end if
  if Gui.yesNo("Did you successfully download the file?") then
    i.answer=green("Successfully downloaded "+split(i.filePath,"/")[-1]+" via router bounce")
  else
    i.answer=yellow("Failed to download the file")
    i.skip=true
  end if
  return i
end function
Mission.getDeleteFile=function
	i={}
  i.skip=false
	//Extract public IP
	t=self._find("at the public IP ")
	if not t then
		t=self._find("at the ")
	end if
	if not t then
		i.answer=yellow("Could not parse deletefile mission IP")
		i.skip=true
		return i
	end if
	i.ip=split(split(t," and")[0]," address")[0].trim
	//Extract LAN IP
	t=self._find("the local IP ")
	if not t then
		t=self._find("in the LAN ")
	end if
	if not t then
		i.answer=yellow("Could not parse deletefile mission target IP")
		i.skip=true
		return i
	end if
	i.target=split(t,"\. ")[0].trim
  ex=self.getObject(i.ip,i.target,i,true)
  if ex and not ex isa list then
    obj=self.getHeadless(ex,{"public_ip":i.ip,"local_ip":i.target})
    files=Io.getAll(obj.root)
    for file in files
      if indexOf(name(file),".bin")!=null then
        if has_permission(file,"w") then
          Command.qrm(obj,[path(file)])
          i.answer=green("Successfully deleted "+name(file)+" from target")
          return i
        end if
      end if
    end for
  end if
  //If we reach here, the target lan ip was not forwarded by the router
  //try for a root bounce
  obj=self.getRootBounce(i.ip,i.target,i)
  if obj isa list then
    i.answer=obj[1]
    i.skip=true
    return i
  end if
  if typeof(obj)!="computer" then
    i.answer=yellow("Could not get target computer on "+i.target)
    i.skip=true
    return i
  end if
  computer=self.getHeadless(obj,{"public_ip":i.ip,"local_ip":i.target})
  if computer.user.raw=="root" then Log.computerLog(computer.computer)
  files=Io.getAll(computer.root)
  for file in files
    if indexOf(name(file),".bin")!=null then
      if has_permission(file,"w") then
        Command.qrm(computer,[path(file)])
        i.answer=green("Successfully deleted "+name(file)+" from target")
        return i
      end if
    end if
  end for
  //If we reach here, we couldn't find the file
  //Lets try for a rshell
  i.needRshell=true
  //Check if rshell bypass is enabled
  if not globals.G_rshell.servers and not self.inbox.bypassRshell then
    i.answer=yellow("No RShell servers available")
    i.skip=true
    return i
  end if
  if not globals.G_settings.vulnerableLib or not globals.G_settings.vulnerableLibIndex then
    i={}
    i.answer=yellow("Vulnerable library or index not set in settings")
    i.skip=true
    return i
  end if
  //Attack via router bounce
  obj=self.getRootBounce(i.ip,i.target,i)
  if obj isa list then
    i.answer=obj[1]
    i.skip=true
    return i
  end if
  if typeof(obj)!="computer" then
    i.answer=yellow("Could not get target computer on "+i.target)
    i.skip=true
    return i
  end if
  computer=self.getHeadless(obj,{"public_ip":i.ip,"local_ip":i.target})
  if computer.user.raw!="root" then
    i.answer=yellow("Lost our root computer, most likely Admin is cock blocking")
    i.skip=true
    return i
  end if
  if computer.user.raw=="root" then Log.computerLog(computer.computer)
  files=Io.getAll(computer.root)
	if not files isa Error then
    for file in files
      if name(file)=="system.log" then continue
      if is_folder(file) then continue
      fileExt=split(name(file),"\.")[-1]
      if hasIndex(Text.specialFiles,fileExt)!=null then
        print green(name(file)+":")
        print "  "+white(path(file))
      end if
    end for
  end if
  Net.snoop(computer,["-B"])
  Command.open(computer,["email","--login","--l"])
  if globals.G_rshell.servers then
    if globals.G_settings.rshell then Rshell.list else RshellLite.list
  end if
  if Gui.yesNo("Did you successfully delete the .bin file?") then
    i.answer=green("Successfully deleted .bin file via router bounce")
  else
    i.answer=yellow("Failed to delete the .bin file")
    i.skip=true
  end if
  return i
end function
Mission.getCredentials=function
	i={}
  i.skip=false
	//Check if specific user or any user
	if indexOf(self._c,"credentials of any user")!=null then
		i.anyUser=true
		i.username="Any User"
	else if indexOf(self._c,"credentials of the user")!=null then
		//Extract specific username
		t=self._find("credentials of the user ")
		i.username=split(t,"\.")[0].trim
		i.anyUser=false
	end if
	//Extract public IP
	t=self._find("public IP of the victim is ")
	if not t then
		i.answer=yellow("Could not parse credentials mission IP")
		i.skip=true
		return i
	end if
	i.ip=split(split(t,"\. ")[0],char(10))[0].trim
	//Extract LAN IP
	t=self._find("victim's local IP is ")
	if not t then
		i.answer=yellow("Could not parse credentials mission target IP")
		i.skip=true
		return i
	end if
	i.target=split(t,char(10))[0].trim
  //We should first check if the lan ip is forwarded by the router
  ex=self.getObject(i.ip,i.target,i,false)
  if typeof(ex)=="shell" and i.anyUser then
    r=Crack.returnRootPass(ex)
    if not r isa Error then
      i.answer=r
      return i
    end if
  end if
  if ex and not ex isa list then
    obj=null
    obj=self.getHeadless(ex,{"public_ip":i.ip,"local_ip":i.target})
    result=self.getPasswd(obj,i)
    if result[0]=="success" then
      i.answer=result[1]
      return i
    end if
  end if
  //If we reach here, we couldn't get the credentials from a edge router bounce
  //try for a root bounce
  obj=self.getRootBounce(i.ip,i.target,i)
  if obj isa list and obj[0]=="success" then
    i.answer=obj[1]
    return i
  end if
  if typeof(obj)!="computer" then
    i.answer=yellow("Could not get target computer on "+i.target)
    i.skip=true
    return i
  end if
  obj=self.getHeadless(obj,{"public_ip":i.ip,"local_ip":i.target})
  Log.computerLog(obj.computer)
  result=self.getPasswd(obj,i)
  i.answer=result[1]
  if result[0]=="error" then i.skip=true
  return i
end function
Mission.getFraud=function
  i={}
  i.skip=false
  //Extract suspect name
  t=self._find("suspects that ")
  if t then i.suspect=split(t," has")[0].trim
  //Extract public IP
  t=self._find("public IP ")
  if t then i.ip=split(t,",")[0].trim
  //Extract local IP
  t=self._find("local IP ")
  if t then i.target=split(t,"\. ")[0].trim
  i.answer=yellow("Fraud mission not yet automated. Manual investigation required.")
  i.skip=true
  return i
end function
