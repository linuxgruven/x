end function
Mail={}
Mail.attrs=["id","from","subject"]
Mail.init=function(i,s)
	self.inbox=i
	self.metaMail=i.metaMail
	self.id=s[indexOf(s,"MailID: "):][8:].split(char(10))[0]
	self.from=s[indexOf(s,"From: "):][6:].split(char(10))[0]
	self.subject=s[indexOf(s,"Subject: "):][9:].split(char(10))[0]
	// XFIX1.0: MetaMail ops have a 2s global cooldown
	// XFIX1.0: System.tryWait(2)
	self.content=read(self.metaMail,self.id)
	self.content=self.content[indexOf(self.content,"Subject: "):].split(char(10))[1:].join(char(10))
	if self.isMission==true then
		self.mission=new Mission
		self.mission.init(self)
	end if
end function
Mail.isMission=function;return self.subject=="Mission Contract";end function
Inbox={}
Inbox.account={"user":null,"pass":null}
Inbox.init=function(argv)
  self.metaMail=null
  credsFile=File(globals.G_main.computer,path(globals.G_main.dir.data)+"/.erc")
  if credsFile then
    content=get_content(credsFile)
    if content then
      // Decrypt credentials (format: user::pass)
      decrypted=Encryption.encrypt(content,Kernel.key,false)
      parts=split(decrypted,"::")
      if len(parts)==2 then
        self.account.user=parts[0]
        self.account.pass=parts[1]
        self.metaMail=mail_login(self.account.user,self.account.pass)
      end if
    end if
  end if
  // If no creds file or login failed, try argv
  if not self.metaMail or self.metaMail isa string then
    if argv and len(argv)>1 then self.metaMail=mail_login(argv[0],argv[1])
  end if
  // If still no login, setup account
  if not self.metaMail or self.metaMail isa string then Email.setup(true)
  // Final check
  if typeof(self.metaMail)!="MetaMail" then
    if self.metaMail isa string then return Error.set(self.metaMail) else return Error.set("Failed to login to the local mail account.")
  end if
end function
Inbox.list=function
	// XFIX1.0: MetaMail ops have a 2s global cooldown
	// XFIX1.0: System.tryWait(2)
	s=fetch(self.metaMail)
	for i in indexes(s);m=new Mail;m.init(self,s[i]);s[i]=m;end for
	return s
end function
Inbox.missions=function
	f=function(o);return o.isMission==true;end function
	m=self.list.select(@f)
	f=function(o);return o.mission;end function
	m=m.map(@f)
	f=function(o);return o.type;end function
	m=m.sort(@f)
	return m
end function
Inbox.stats=function
	missions=self.missions
	stats={}
	stats.total=len(missions)
	stats.completed=0
	stats.pending=0
	stats.academic=0
	stats.police=0
	stats.corruption=0
	stats.getfile=0
	stats.deletefile=0
	stats.credentials=0
	stats.fraud=0
	stats.sabotage=0
	stats.espionage=0
	stats.academicCompleted=0
	stats.policeCompleted=0
	stats.corruptionCompleted=0
	stats.getfileCompleted=0
	stats.deletefileCompleted=0
	stats.credentialsCompleted=0
	stats.fraudCompleted=0
	stats.sabotageCompleted=0
	stats.espionageCompleted=0
	for mission in missions
		t=mission.type
		if mission.completed then
			stats.completed+=1
			if t=="academic" then
				stats.academicCompleted+=1
			else if t=="police" then
				stats.policeCompleted+=1
			else if t=="corruption" then
				stats.corruptionCompleted+=1
			else if t=="getfile" then
				stats.getfileCompleted+=1
			else if t=="deletefile" then
				stats.deletefileCompleted+=1
			else if t=="credentials" then
				stats.credentialsCompleted+=1
			else if t=="fraud" then
				stats.fraudCompleted+=1
			else if t=="sabotage" then
				stats.sabotageCompleted+=1
			else if t=="espionage" then
				stats.espionageCompleted+=1
			end if
		else
			stats.pending+=1
		end if
		if t=="academic" then
			stats.academic+=1
		else if t=="police" then
			stats.police+=1
		else if t=="corruption" then
			stats.corruption+=1
		else if t=="getfile" then
			stats.getfile+=1
		else if t=="deletefile" then
			stats.deletefile+=1
		else if t=="credentials" then
			stats.credentials+=1
		else if t=="fraud" then
			stats.fraud+=1
		else if t=="sabotage" then
			stats.sabotage+=1
		else if t=="espionage" then
			stats.espionage+=1
		end if
	end for
	return stats
end function
Inbox.display=function
	stats=self.stats
	Info.info("Mission Statistics:")
	print yellow("Total missions: ")+white(str(stats.total))
	print yellow("Completed: ")+green(str(stats.completed))+yellow(" | Pending: ")+orange(str(stats.pending))
	print ""
	print yellow("Academic: ")+white(str(stats.academic))+yellow(" (Completed: ")+green(str(stats.academicCompleted))+yellow(")")
	print yellow("Police: ")+white(str(stats.police))+yellow(" (Completed: ")+green(str(stats.policeCompleted))+yellow(")")
	print yellow("Corruption: ")+white(str(stats.corruption))+yellow(" (Completed: ")+green(str(stats.corruptionCompleted))+yellow(")")
	print yellow("Get File: ")+white(str(stats.getfile))+yellow(" (Completed: ")+green(str(stats.getfileCompleted))+yellow(")")
	print yellow("Delete File: ")+white(str(stats.deletefile))+yellow(" (Completed: ")+green(str(stats.deletefileCompleted))+yellow(")")
	print yellow("Credentials: ")+white(str(stats.credentials))+yellow(" (Completed: ")+green(str(stats.credentialsCompleted))+yellow(")")
	print ""
	missions=self.missions
	if not missions or not len(missions) then return Info.info("No missions found")
	Info.info("Mission Details:")
	for mission in missions
		status="["+green("+")+"]"
		if not mission.completed then status="["+red("-")+"]"
		missionType=mission.type.upper
		if mission.type=="academic" then missionType=cyan(missionType)
		if mission.type=="police" then missionType=yellow(missionType)
		if mission.type=="corruption" then missionType=red(missionType)
		if mission.type=="getfile" then missionType=green(missionType)
		if mission.type=="deletefile" then missionType=orange(missionType)
		if mission.type=="credentials" then missionType=white(missionType)
		print(status+" "+missionType)
		info=mission.info
		if info.skip then
			print "  "+info.answer
		else
			print "  "+white("Target: ")+green(info.ip)
			if hasIndex(info,"target") then print "  "+white("LAN IP: ")+green(info.target)
			if hasIndex(info,"anyUser") then
				if info.anyUser then
					print "  "+white("Any User: ")+green(info.answer)
				else
					print "  "+white("Username: ")+green(info.username)
					print "  "+white("Password: ")+green(info.answer)
				end if
			end if
			if hasIndex(info,"filePattern") then print "  "+white("File Pattern: ")+green(info.filePattern)
			if hasIndex(info,"filePath") then print "  "+white("File Path: ")+green(info.filePath)
		end if
	end for
end function