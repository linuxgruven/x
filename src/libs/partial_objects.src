PartialObject._SCAN_VULN_FOUND="New vulnerability found:"
PartialObject._SCAN_COMPUTER="* Computer"
PartialObject._SCAN_FILE="* File"
PartialObject._HTML_BOLD_OPEN="<b>"
PartialObject._HTML_BOLD_CLOSE="</b>"
