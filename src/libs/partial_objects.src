PartialObject._MSG_SUCCESS_FILE="File created successfully"
PartialObject._MSG_SUCCESS_CHMOD="Permissions changed successfully"
PartialObject._MSG_SUCCESS_COPY="File copied successfully"
PartialObject._MSG_SUCCESS_MOVE="File moved successfully"
