    print ""
    print Man.space+bold("reset 10")
    print Man.space*2+"Reset library 10"
    print Man.see
    print Man.space+bold("scan")+", "+bold("update")+", "+bold("find")
  end function
  hc=function;Man.help(["hc"]);end function
  smpt=function;Man.help(["smpt"]);end function
  find=function
