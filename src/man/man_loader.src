// =============================================================================
// MAN
// Man page lazy loader; loads man pages on-demand from disk with minimal memory footprint.
// =============================================================================
Man={
  "space":"    ",
  "options":"<b>OPTIONS</b>",
  "usage":"<b>Usage:</b>",
  "example":"<b>EXAMPLE:</b>",
  "description":"<b>DESCRIPTION</b>",
  "synopsis":"<b>SYNOPSIS</b>",
  "name":"<b>NAME</b>",
  "see":"<b>SEE ALSO</b>",
  "notes":"<b>NOTES</b>",
  "mission_types":"<b>MISSION TYPES</b>",
  "automation":"<b>AUTOMATION</b>",
  "rshell_info":"<b>RSHELL SERVERS</b>",
  "configuration":"<b>CONFIGURATION</b>",
  "_manDir":null
}
//Resolve man directory based on current shell context (local vs server)
Man.getManDir=function
  s=System.getSystem
  if s isa Error then return null
  if s and s.dir and s.dir.man then return s.dir.man
  return null
end function
//Get man page content for AI agent - returns lines array or null
Man.getManPage=function(cmdName)
  if not cmdName or typeof(cmdName)!="string" then return null
  cmd=trim(lower(cmdName))
  if len(cmd)==0 then return null
  //Special aliases for commands with symbols/special characters
  aliases={
    ">":"arrow",
    ">>":"arrow2",
    "!":"bang",
    "!!":"bang2",
    "!!!":"bang3"
  }
  //Check if command has an alias mapping
  if aliases.hasIndex(cmd) then cmd=aliases[cmd]
  //Find the man page file
  manDir=Man.getManDir
  if not manDir then return null
  manFiles=get_files(manDir)
  if not manFiles then return null
  targetFile=null
  //First try exact match
  for f in manFiles
    if name(f)==cmd then
      targetFile=f
      break
    end if
  end for
  //If no exact match, try prefix match (shortcuts)
  if not targetFile then
    for f in manFiles
      if indexOf(name(f),cmd)==0 then
        targetFile=f
        break
      end if
    end for
  end if
  if not targetFile then return null
  //Load and return content as lines
  content=get_content(targetFile)
  if not content then return null
  lines=split(content,char(10))
  if not lines or typeof(lines)!="list" then return null
  return lines
end function
//Main help function - loads man pages on demand
Man.help=function(argv,tty=true)
  if not argv then argv=["man"]
  cmd=argv[0]
  //Handle special commands
  if cmd=="apropos" or cmd=="search" then return Man.find(argv[1:])
  if cmd=="dump" then return Man._dump(argv[1:])
  //Special aliases for commands with symbols/special characters
  aliases={
    "and":"and",
    ";":"and",
    ">":"arrow",
    ">>":"arrow2",
    "!":"bang",
    "!!":"bang2",
    "!!!":"bang3",
    "|":"pipe",
    "pipe":"pipe",
    "post":"post"
  }
  //Check if command has an alias mapping
  if aliases.hasIndex(cmd) then cmd=aliases[cmd]
  //Initialize man directory if not set
  //Use System.getSystem to get correct computer (main or server)
  //Look for command man page file
  manDir=Man.getManDir
  if not manDir then return Error.set("Man pages directory is not available")
  manFiles=get_files(manDir)
  if not manFiles then return Error.set("Man pages directory is empty")
  targetFile=null
  //First try exact match
  for f in manFiles
    if name(f)==cmd then
      targetFile=f
      break
    end if
  end for
  //If no exact match, try prefix match (shortcuts)
  if not targetFile then
    matches=[]
    for f in manFiles
      if indexOf(name(f),cmd)==0 then push(matches,f)
    end for
    //If single match found, use it
    if len(matches)==1 then
      targetFile=matches[0]
    else if len(matches)>1 then
      //Multiple matches - show them
      names=[]
      for m in matches;push(names,name(m));end for
      return Error.set("Ambiguous command '"+cmd+"'. Did you mean: "+names.join(", ")+"?")
    end if
  end if
  if not targetFile then return Error.set("No manual entry for '"+cmd+"'")
  //Read man page content into LOCAL variable
  //This will go out of scope after print, freeing memory automatically
  content=get_content(targetFile)
  if not content then return Error.set("Failed to load man page for '"+cmd+"'")
  //When not tty: return content for pipe capture
  if not tty then return content
  //Display the man page
  print content
  //After return, 'content' variable goes out of scope and memory is freed
end function
//Search/apropos functionality - searches across all man pages
Man.find=function(argv)
  if not argv or len(argv)==0 then return Warning.set("Usage: man search [-e] [-v] TERM [TERM...]")
  exactMatch=false
  verbose=false
  searchTerms=[]
  for arg in argv
    if arg=="-e" then
      exactMatch=true
    else if arg=="-v" then
      verbose=true
    else
      push(searchTerms,arg)
    end if
  end for
  if len(searchTerms)==0 then return Warning.set("Usage: man search [-e] [-v] TERM [TERM...]")
  //Initialize man directory if needed
  //Get all man page files
  manDir=Man.getManDir
  if not manDir then return Error.set("No man pages found")
  manFiles=get_files(manDir)
  if not manFiles then return Error.set("No man pages found")
  Info.info("Searching man pages for [ "+searchTerms.join(" ")+" ]...")
  matches={}
  matchCount=0
  //Search through each man page file
  for manFile in manFiles
    //Extract command name from filename
    cmdName=name(manFile)
    //Read the file content
    content=get_content(manFile)
    if not content then continue
    //Search for terms in content
    matchFound=false
    for term in searchTerms
      pattern=null
      if exactMatch then pattern="\b"+term+"\b" else pattern="(?i)"+term+"(?-i)"
      if is_match(content,pattern) then
        matchFound=true
        break
      end if
    end for
    if matchFound then
      matchCount+=1
      if verbose then
        //Verbose mode: show full content with highlighting
        print yellow("-"*31+" ["+cmdName+"] "+"-"*32)
        lines=content.split(char(10))
        for line in lines
          lineMatched=false
          for term in searchTerms
            pattern=null
            if exactMatch then pattern="\b"+term+"\b" else pattern="(?i)"+term+"(?-i)"
            if is_match(line,pattern) then
              lineMatched=true
              break
            end if
          end for
          if lineMatched then print orange(line) else print line
        end for
      else
        //Compact mode: extract just the summary line
        lines=content.split(char(10))
        summary=cmdName
        //Look for "command - description" pattern in NAME section
        for line in lines
          clean=line.replace("<b>","").replace("</b>","").trim
          if is_match(clean,"^\w+\s+-\s+.+") then
            parts=clean.split(" - ")
            if len(parts)>=2 then summary=cmdName+" - "+parts[1:].join(" - ")
            break
          end if
        end for
        matches[cmdName]=summary
      end if
    end if
  end for
  //Display results for compact mode
  if not verbose then
    if len(matches)==0 then return Info.info("[ "+searchTerms.join(" ")+" ] not found in man pages")
    //Sort and display
    keys=indexes(matches)
    keys.sort
    for key in keys;print matches[key];end for
  end if
  //Summary
  if matchCount==1 then Info.info("Found "+matchCount+" man page") else Info.info("Found "+matchCount+" man pages")
end function
//Metalib help - for exploit/library menu commands
Man.metalib=function(argv)
  if not argv then return Error.set("Man what?")
  A=argv[0]
  rules=function
    print Man.name
    print Man.space+"rules - shows firewall rules if available"
    print Man.synopsis
    print Man.space+bold("rules")
    print Man.description
    print Man.space+"Display firewall rules on remote system. Shows configured firewall rulesets including port"
    print Man.space+"blocking, IP filtering, and access control policies. Use during LAN scans to assess network"
    print Man.space+"security posture. Reveals firewall configuration for penetration testing and security audit."
    print Man.options
    print Man.space+bold("rules")
    print Man.space*2+"Show firewall rules"
    print Man.space*2+"Display current rulesets"
    print Man.example
    print Man.space+yellow("# Basic Usage")
    print Man.space+bold("rules")
    print Man.space*2+"Show firewall config"
    print ""
    print Man.space+yellow("# During LAN Scan")
    print Man.space+bold("rules")
    print Man.space*2+"Check security rules"
    print Man.see
    print Man.space+bold("nmap")+", "+bold("ifconfig")
  end function
  mshow=function
    print Man.name
    print Man.space+"show - shows extra net session information"
    print Man.synopsis
    print Man.space+bold("show")
    print Man.description
    print Man.space+"Toggle display of extended network session information. Shows additional details about active"
    print Man.space+"network connections, session status, and connection metadata. Run command again to enable or"
    print Man.space+"disable feature. Useful for monitoring network activity and debugging connection issues."
    print Man.options
    print Man.space+bold("show")
    print Man.space*2+"Toggle extra info display"
    print Man.space*2+"Enable or disable feature"
    print Man.example
    print Man.space+yellow("# Toggle Display")
    print Man.space+bold("show")
    print Man.space*2+"Enable extra info"
    print ""
    print Man.space+bold("show")
    print Man.space*2+"Disable extra info"
    print Man.see
    print Man.space+bold("net")+", "+bold("ifconfig")
  end function
  mscan=function
    print Man.name
    print Man.space+"scan - scans libraries to get updated exploit data"
    print Man.synopsis
    print Man.space+bold("scan ")+bold("-s|--single|INDEX")
    print Man.space+bold("scan ")+bold("-x|--upsingle")
    print Man.space+bold("scan ")+bold("-o|--object")
    print Man.space+bold("scan ")+bold("-a|--all")
    print Man.space+bold("scan ")+bold("-u|--upall")
    print Man.space+bold("scan ")+bold("-z|--allobj")
    print Man.description
    print Man.space+"Update exploit database by scanning libraries for new vulnerabilities. Scan single entry"
    print Man.space+"points or all libraries. Filter for object-only exploits. Automatically run update after"
    print Man.space+"scan with -x or -u flags. Essential for maintaining current exploit knowledge base."
    print Man.options
    print Man.space+bold("-s|--single|INDEX")
    print Man.space*2+"Scan single entry point"
    print Man.space*2+"Use exploit index or flag"
    print ""
    print Man.space+bold("-x|--upsingle")
    print Man.space*2+"Scan single and update"
    print Man.space*2+"Combined scan and update"
    print ""
    print Man.space+bold("-o|--object")
    print Man.space*2+"Scan for objects only"
    print Man.space*2+"Filter object exploits"
    print ""
    print Man.space+bold("-a|--all")
    print Man.space*2+"Scan all entry points"
    print Man.space*2+"Full exploit scan"
    print ""
    print Man.space+bold("-u|--upall")
    print Man.space*2+"Scan all and update"
    print Man.space*2+"Full scan with update"
    print ""
    print Man.space+bold("-z|--allobj")
    print Man.space*2+"Scan all for objects"
    print Man.space*2+"All object exploits"
    print Man.example
    print Man.space+yellow("# Single Entry")
    print Man.space+bold("scan -s")
    print Man.space*2+"Scan single"
    print ""
    print Man.space+bold("scan --single")
    print Man.space*2+"Scan by flag"
    print ""
    print Man.space+bold("scan 5")
    print Man.space*2+"Scan by index"
    print ""
    print Man.space+yellow("# With Update")
