  man=function;Man.help(["man"]);end function
  mwhois=function;Man.help(["whois"]);end function
  a={
    "get":@get,
    "whois":@mwhois,
    "man":@man,
    "map":@mmap,
    "recon":@recon,
    "scan":@mscan,
    "update":@mupdate,
    "hc":@hc,
    "reset":@reset,
    "smpt":@smpt,
    "find":@find,
    "show":@mshow,
    "rules":@rules
  }
  if not hasIndex(a,A) then return Error.set("Check your syntax, there is no help for [ "+A+" ]")
  a[A]
end function
//Browse file menu help
Man.browseFiles=function(argv)
  if not argv then return Error.set("Man what?")
  A=argv[0]
  b=yellow("<[==========================================================]>")
  man=function
    print b
    print Man.usage+"man [command] - :X help system"
    print b
  end function
  peek=function
    print b
    print "view => Display the contents of a file."
    print "peek => Display the contents of a file."
    print b
  end function
  get=function
    print b
    print "get => Download a file to main."
    print Man.usage+"get (y) will use default location"
    print b
  end function
  get2=function
    print b
    print "get => Download a text file."
    print b
  end function
  set=function
    print b
    print "set => Over-write a file."
    print Man.usage+"set (new text)"
    print b
  end function
  rm=function
    print b
    print "rm => Delete a file."
    print b
  end function
  echo=function
    print b
    print "echo => Append some text to a file's contents."
    print b
  end function
  mscan=function
    print b
    print "scan => Scan for and crack passwords."
    print b
  end function
  mv=function
    print b
    print "mv => Move the file to a different location."
    print b
  end function
  cp=function
    print b
    print "cp => Copy the file to a different location."
    print b
  end function
  zip=function
    print b
    print "zip => Creates a zip archive from a text file."
    print b
  end function
  lock=function
    print b
    print "lock => Creates a password protected archive from a text file."
    print b
  end function
  rn=function
    print b
    print "rn (name) => Rename the file."
    print Man.usage+"rn (name)"
    print b
  end function
  info=function
    print b
    print "info => Get full information about a selected file."
    print b
  end function
  share=function
    print b
    print "share => Add a file to the share folder."
    print b
  end function
  vfile=function
    print b
    print "vfile => Add a file to the virtual cache."
    print b
  end function
  libs=function
    print b
    print "libs => Add a library|file to the shared library folder."
    print b
  end function
  chog=function
    print b
    print "chog => Apply both owner and group ownership."
    print Man.usage+"chog (-r) [owner|group]"
    print b
  end function
  mchown=function
    print b
    print "chown => Change ownership."
    print Man.usage+"chown [opt:-r] [owner]."
    print b
  end function
  mchmod=function
    print b
    print "chmod => Change permissions."
    print Man.usage+"chmod [opt:-r] [u,g,o+wrx]"
    print Man.usage+"chmod [opt:-r] [000]"
    print b
  end function
  mchgrp=function
    print b
    print "chgrp => Change the group ownership."
    print Man.usage+"chgrp [opt:-r] [new group]"
    print b
  end function
  qrm=function
    print b
    print "qrm => Quietly removes a file|folder."
    print Man.usage+"qrm"
    print b
  end function
  a={
    "qrm":@qrm,
    "man":@man,
    "libs":@libs,
    "vfile":@vfile,
    "share":@share,
    "info":@info,
    "peek":@peek,
    "view":@peek,
    "get":@get,
    "get2":@get2,
    "set":@set,
    "rm":@rm,
    "echo":@echo,
    "scan":@mscan,
    "mv":@mv,
    "cp":@cp,
    "zip":@zip,
    "lock":@lock,
    "rn":@rn,
    "chog":@chog,
    "chown":@mchown,
    "chmod":@mchmod,
    "chgrp":@mchgrp
  }
  if not hasIndex(a,A) then return Error.set("Check your syntax, there is no help for [ "+A+" ]")
  a[A]
end function
