//Dump command - export man pages to files
Man._dump=function(argv)
  //Initialize man directory if needed
  //Get all man page files
  manDir=Man.getManDir
  if not manDir then return Error.set("No man pages found")
  manFiles=get_files(manDir)
  if not manFiles then return Error.set("No man pages found")
  //Determine dump behavior
  if not argv or len(argv)==0 then
    //Dump all man pages
    Info.info("Dumping man pages...")
    t=["-"*32+" [X MAN PAGES] "+"-"*33]
    //Sort files by name
    fileNames=[]
    for f in manFiles;push(fileNames,name(f));end for
    fileNames.sort
    for fname in fileNames
      //Find file object
      targetFile=null
      for f in manFiles
        if name(f)==fname then
          targetFile=f
          break
        end if
      end for
      if not targetFile then continue
      content=get_content(targetFile)
      if not content then continue
      //Strip formatting tags
      s=content.replace("<color=#ffffff>","").replace("<color=#36abe8>","").replace("<color=#20ff98>","").replace("<color=#e4ff34>","").replace("<color=#ff4b4b>","").replace("</color>","").replace("<color=#7e17e6>","").replace("<color=#ff0000>","").replace("<color=#ffa500>","").replace("<b>","").replace("</b>"," ")
      push(t,s)
      if (__fname_idx+1)!=len(fileNames) then push(t,"-"*80)
    end for
    //Split into 160KB chunks
    fullContent=join(t,char(10))
    chunks=[]
    while len(fullContent)>0
      if len(fullContent)<=160000 then
        push(chunks,fullContent)
        break
      end if
      push(chunks,fullContent[:160000])
      fullContent=fullContent[160000:]
    end while
    //Write chunks to files
    c=System.getSystem.computer
    chunkNum=1
    for chunk in chunks
      f=Command.touch(globals.G_main,[path(globals.G_main.dir.current)+"/man_pages_"+chunkNum])
      if not f then return Error.set("Failed to create man_pages_"+chunkNum)
      r=set_content(f,chunk)
      if r isa string then return Error.set(r)
      chunkNum+=1
    end for
    Info.info("Finished")
  else
    //Dump specific command
    cmd=argv[0]
    Info.info("Dumping man page for "+cmd+"...")
    targetFile=null
    for f in manFiles
      if name(f)==cmd then
        targetFile=f
        break
      end if
    end for
    if not targetFile then return Error.set("No manual entry for '"+cmd+"'")
    content=get_content(targetFile)
    if not content then return Error.set("Failed to load man page for '"+cmd+"'")
    //Strip formatting tags
    t=["-"*32+" [X MAN PAGE: "+upper(cmd)+"] "+"-"*33]
    s=content.replace("<color=#ffffff>","").replace("<color=#36abe8>","").replace("<color=#20ff98>","").replace("<color=#e4ff34>","").replace("<color=#ff4b4b>","").replace("</color>","").replace("<color=#7e17e6>","").replace("<color=#ff0000>","").replace("<color=#ffa500>","").replace("<b>","").replace("</b>"," ")
    push(t,s)
    c=System.getSystem.computer
    f=Command.touch(globals.G_main,[path(globals.G_main.dir.current)+"/man_"+cmd+".txt"])
    if not f then return Error.set("Failed to create man_"+cmd+".txt")
    r=set_content(f,join(t,char(10)))
    if r isa string then return Error.set(r)
    Info.info("Finished - created man_"+cmd+".txt")
  end if
end function