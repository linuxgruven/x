testLearnBash="// ================================================================
// x Bash Learning Guide & Tutorial Test Script
// ================================================================
// This script teaches new players how to use x's bash scripting
// language through working examples. Every section defines
// real functions, calls them, and prints results so you can
// see exactly what happens.
//
// Run this script with:   @learn_bash
//
// Each section builds on the previous ones. Read the comments
// to understand what each line does, then check the output.
// ================================================================

// ---------------------------------------------------------------
// HELPER: assert function used throughout for self-checking
// ---------------------------------------------------------------
func assert(label, actual, expected)
  if _getvar(actual) == _getvar(expected)
    _print <color=#00ff00>  [PASS]</color> _getvar(label) <color=#888888>= _getvar(actual)</color>
  else
    _print <color=#ff0000>  [FAIL]</color> _getvar(label) <color=#ffff00> expected:</color>_getvar(expected) <color=#ffff00> got:</color>_getvar(actual)
  endif
endfunc

// ---------------------------------------------------------------
// HELPER: section header printer
// ---------------------------------------------------------------
func printHeader(title)
  _print
  _print <color=#eb0cc6>============================================</color>
  _print <color=#eb0cc6>  _getvar(title)</color>
  _print <color=#eb0cc6>============================================</color>
endfunc

// ---------------------------------------------------------------
// HELPER: lesson sub-header printer
// ---------------------------------------------------------------
func printLesson(title)
  _print
  _print <color=#00bfff>--- _getvar(title) ---</color>
endfunc

// ---------------------------------------------------------------
// HELPER: tip printer (educational notes)
// ---------------------------------------------------------------
func printTip(msg)
  _print <color=#ffff00>  TIP:</color> _getvar(msg)
endfunc

// ---------------------------------------------------------------
// HELPER: note printer (general info)
// ---------------------------------------------------------------
func printNote(msg)
  _print <color=#aaaaaa>  NOTE:</color> _getvar(msg)
endfunc

_print
_print <color=#eb0cc6>============================================================</color>
_print <color=#eb0cc6>    x BASH LEARNING GUIDE & TUTORIAL</color>
_print <color=#eb0cc6>    A hands-on walkthrough of the bash scripting language</color>
_print <color=#eb0cc6>============================================================</color>
_print <color=#aaaaaa>  Every example defines a function and calls it.</color>
_print <color=#aaaaaa>  Read the source code alongside the output to learn.</color>
_print

// ###############################################################
//
//   CHAPTER 1: FUNDAMENTALS
//   Variables, printing, basic types
//
// ###############################################################

printHeader(CHAPTER 1: FUNDAMENTALS)

// ===================================================================
// LESSON 1.1 - HELLO WORLD & PRINTING
// ===================================================================
// The most basic thing you can do: print text to the screen.
// _print sends text to the terminal output.
// ===================================================================

printLesson(Lesson 1.1: Hello World & Printing)

// A function that takes no arguments and returns nothing.
// This is called a ""void"" function - it just does work.
func helloWorld()
  _print <color=#00ff00>  Hello World! Welcome to x bash.</color>
endfunc

// Call the function - just use its name with ()
helloWorld()

printTip(_print queues output. _printnow prints immediately.)
printNote(Void functions do work but don't return a value.)

// ===================================================================
// LESSON 1.2 - VARIABLES: SET AND GET
// ===================================================================
// Variables store values. Use _setvar() to store, _getvar() to read.
// Variables can hold strings, numbers, lists, and more.
// ===================================================================

printLesson(Lesson 1.2: Variables - Assign and Read)

// Function that demonstrates basic variable usage
func variableBasics()
  // Store a string
  _setvar(name, tux)
  _print <color=#aaaaaa>  Assign name = tux -> name is now:</color> _getvar(name)

  // Store a number
  _setvar(level, 42)
  _print <color=#aaaaaa>  Assign level = 42 -> level is now:</color> _getvar(level)

  // Store a decimal
  _setvar(ratio, 3.14)
  _print <color=#aaaaaa>  Assign ratio = 3.14 -> ratio is now:</color> _getvar(ratio)

  // Overwrite a variable - the old value is gone
  _setvar(name, root)
  _print <color=#aaaaaa>  After overwrite, name is now:</color> _getvar(name)
endfunc

variableBasics()
printTip(Variables in functions are LOCAL - they don't leak out.)

// ===================================================================
// LESSON 1.3 - ARITHMETIC
// ===================================================================
// _setvar() automatically evaluates math expressions.
// Supported: + - * / % ** (add, subtract, multiply, divide, mod, power)
// ===================================================================

printLesson(Lesson 1.3: Arithmetic Expressions)

// A mini-calculator function
func showArithmetic()
  _setvar(a, 10)
  _setvar(b, 3)

  _setvar(sum, _getvar(a) + _getvar(b))
  _print <color=#aaaaaa>  10 + 3 =</color> _getvar(sum)

  _setvar(diff, _getvar(a) - _getvar(b))
  _print <color=#aaaaaa>  10 - 3 =</color> _getvar(diff)

  _setvar(prod, _getvar(a) * _getvar(b))
  _print <color=#aaaaaa>  10 * 3 =</color> _getvar(prod)

  _setvar(quot, _getvar(a) / _getvar(b))
  _print <color=#aaaaaa>  10 / 3 =</color> _getvar(quot)

  _setvar(mod, _getvar(a) % _getvar(b))
  _print <color=#aaaaaa>  10 % 3 =</color> _getvar(mod)

  _setvar(pow, 2 ** 10)
  _print <color=#aaaaaa>  2 ** 10 =</color> _getvar(pow)
endfunc

showArithmetic()
printTip(Operator precedence: ** first then * / % then + -)

// Verify arithmetic with asserts
func testArithmetic()
  _setvar(r, 7 + 3)
  assert(7+3 equals 10, _getvar(r), 10)

  _setvar(r, 6 * 7)
  assert(6x7 equals 42, _getvar(r), 42)

  _setvar(r, 2 ** 8)
  assert(2pow8 equals 256, _getvar(r), 256)

  _setvar(r, 17 % 5)
  assert(17mod5 equals 2, _getvar(r), 2)

  _setvar(r, 3 * 4 + 2)
  assert(3x4+2 equals 14 precedence, _getvar(r), 14)

  _setvar(r, -3 + -2)
  assert(neg3+neg2 equals neg5, _getvar(r), -5)
endfunc

testArithmetic()

// ===================================================================
// LESSON 1.4 - LISTS (ARRAYS)
// ===================================================================
// Lists store multiple values in order.
// Create with [item1, item2, ...] syntax.
// Use _push, _pop, _pull to modify.
// ===================================================================

printLesson(Lesson 1.4: Lists / Arrays)

// Function that builds and manipulates a list
func listDemo()
  // Create a list
  _setvar(fruits, [apple, banana, cherry])
  _print <color=#aaaaaa>  Created list: [apple, banana, cherry]</color>
  _print <color=#aaaaaa>  Length:</color> len(_getvar(fruits))

  // Push adds to the end
  _push fruits date
  _print <color=#aaaaaa>  After _push fruits date, length:</color> len(_getvar(fruits))

  // Pop removes from the end
  _pop fruits
  _print <color=#aaaaaa>  After _pop fruits, length:</color> len(_getvar(fruits))

  // Pull removes from the start
  _pull fruits
  _print <color=#aaaaaa>  After _pull fruits, length:</color> len(_getvar(fruits))

  // Check if item exists
  _setvar(found, _in(_getvar(fruits), banana))
  _print <color=#aaaaaa>  Is 'banana' in list?</color> _getvar(found)
  _setvar(miss, _in(_getvar(fruits), grape))
  _print <color=#aaaaaa>  Is 'grape' in list?</color> _getvar(miss)
endfunc

listDemo()
printTip(_push and _pop use command-style: _push arrName value)
printTip(The _in builtin returns 1 if found or 0 if not)

// Verify list operations
func testListOps()
  _setvar(arr, [])
  _push arr x
  _push arr y
  _push arr z
  _setvar(r, len(_getvar(arr)))
  assert(push 3 items gives len 3, _getvar(r), 3)

  _pop arr
  _setvar(r, len(_getvar(arr)))
  assert(pop brings len to 2, _getvar(r), 2)

  _pull arr
  _setvar(r, len(_getvar(arr)))
  assert(pull brings len to 1, _getvar(r), 1)

  _setvar(arr, [a, b, c])
  _setvar(r, _in(_getvar(arr), b))
  assert(_in finds b in list, _getvar(r), 1)
  _setvar(r, _in(_getvar(arr), z))
  assert(_in does not find z, _getvar(r), 0)
endfunc

testListOps()

// ###############################################################
//
//   CHAPTER 2: FUNCTIONS IN DEPTH
//   Parameters, return values, scope, patterns
//
// ###############################################################

printHeader(CHAPTER 2: FUNCTIONS IN DEPTH)

// ===================================================================
// LESSON 2.1 - FUNCTIONS WITH PARAMETERS
// ===================================================================
// Functions can take parameters (inputs).
// Inside the function, use _getvar(paramName) to read them.
// ===================================================================

printLesson(Lesson 2.1: Function Parameters)

// One parameter
func greet(name)
  _print <color=#00ff00>  Hello, _getvar(name)!</color>
endfunc

greet(Hacker)
greet(Player)

// Two parameters
func introduce(name, role)
  _print <color=#aaaaaa>  _getvar(name) is a _getvar(role)</color>
endfunc

introduce(tux, pentester)
introduce(root, sysadmin)

// Verify parameters work
func addNums(a, b)
  _return _getvar(a) + _getvar(b)
endfunc

_setvar(r, addNums(15, 27))
assert(addNums(15 27) returns 42, _getvar(r), 42)

// Three parameters
func clamp(val, lo, hi)
  if _getvar(val) < _getvar(lo)
    _return _getvar(lo)
  elif _getvar(val) > _getvar(hi)
    _return _getvar(hi)
  else
    _return _getvar(val)
  endif
endfunc

_setvar(r, clamp(50, 0, 10))
assert(clamp 50 within 0-10 is 10, _getvar(r), 10)
_setvar(r, clamp(-5, 0, 10))
assert(clamp -5 within 0-10 is 0, _getvar(r), 0)
_setvar(r, clamp(5, 0, 10))
assert(clamp 5 within 0-10 is 5, _getvar(r), 5)

printTip(Functions can take 0 to many parameters separated by commas.)

// ===================================================================
// LESSON 2.2 - RETURN VALUES
// ===================================================================
// Functions can give back a value using _return.
// Capture it with _setvar(result, myFunc())
// ===================================================================

printLesson(Lesson 2.2: Return Values)

// Return a number
func getAnswer()
  _return 42
endfunc

_setvar(r, getAnswer())
_print <color=#aaaaaa>  getAnswer() returned:</color> _getvar(r)
assert(getAnswer returns 42, _getvar(r), 42)

// Return a computed result
func circleArea(radius)
  _return _getvar(radius) * _getvar(radius) * 3
endfunc

_setvar(r, circleArea(5))
_print <color=#aaaaaa>  circleArea(5) = 5*5*3 =</color> _getvar(r)
assert(circleArea(5) is 75, _getvar(r), 75)

// Return a compound string using join (dash is safe as join delimiter)
func makeTag(prefix, id)
  _setvar(parts, [])
  _push parts _getvar(prefix)
  _push parts _getvar(id)
  _return join(_getvar(parts), -)
endfunc

_setvar(r, makeTag(srv, web1))
_print <color=#aaaaaa>  makeTag(srv, web1) =</color> _getvar(r)
assert(makeTag gives srv-web1, _getvar(r), srv-web1)

// Return from conditional
func grade(score)
  if _getvar(score) >= 90
    _return A
  elif _getvar(score) >= 80
    _return B
  elif _getvar(score) >= 70
    _return C
  elif _getvar(score) >= 60
    _return D
  else
    _return F
  endif
endfunc

_setvar(r, grade(95))
assert(grade 95 is A, _getvar(r), A)
_setvar(r, grade(85))
assert(grade 85 is B, _getvar(r), B)
_setvar(r, grade(55))
assert(grade 55 is F, _getvar(r), F)

printTip(_return passes a value back. The caller captures it in a variable.)

// ===================================================================
// LESSON 2.3 - VOID FUNCTIONS (NO RETURN)
// ===================================================================
// Not every function needs to return a value.
// Some just do work: print, modify state, etc.
// Calling them as _setvar(r, voidFunc()) gives empty string.
// ===================================================================

printLesson(Lesson 2.3: Void Functions - No Return Value)

// A void function that just prints
func banner(text)
  _print <color=#eb0cc6>  *** _getvar(text) ***</color>
endfunc

banner(This is a banner)

// A void function that logs info
func logAction(action, target)
  _print <color=#aaaaaa>  [LOG] _getvar(action) -> _getvar(target)</color>
endfunc

logAction(SCAN, 192.168.0.1)
logAction(CONNECT, port 22)

// Verify void returns empty
func doNothing()
endfunc

_setvar(r, doNothing())
assert(void func returns empty, _getvar(r), )

// A void function with side effect (local only)
func workWithoutReturn()
  _setvar(tmp, working)
  // tmp is local and will be discarded
endfunc

workWithoutReturn()
printNote(Void functions are great for printing or performing actions.)

// ===================================================================
// LESSON 2.4 - SCOPE ISOLATION
// ===================================================================
// Variables inside a function are LOCAL - they do NOT affect
// variables with the same name outside the function.
// This is critical for avoiding bugs!
// ===================================================================

printLesson(Lesson 2.4: Scope Isolation)

func scopeDemo()
  // This 'x' is local to scopeDemo
  _setvar(x, inside_func)
  _return _getvar(x)
endfunc

// Set an outer 'x'
_setvar(x, outside)

// Call the function - it sets its own 'x' internally
_setvar(inner, scopeDemo())

// Our outer 'x' is untouched!
assert(outer x unchanged after func, _getvar(x), outside)
assert(func returned its local x, _getvar(inner), inside_func)

// Another scope demo: parameter shadows outer var
_setvar(name, original)

func echoName(name)
  _return _getvar(name)
endfunc

_setvar(r, echoName(temporary))
assert(param shadows outer var, _getvar(r), temporary)
assert(outer name unchanged, _getvar(name), original)

printTip(Function variables are always local. This prevents accidental overwrites.)

// ===================================================================
// LESSON 2.5 - FUNCTIONS CALLING FUNCTIONS
// ===================================================================
// Functions can call other functions! This is how you build
// complex programs from simple pieces.
// ===================================================================

printLesson(Lesson 2.5: Functions Calling Functions)

func increment(n)
  _return _getvar(n) + 1
endfunc

func doubleVal(n)
  _return _getvar(n) * 2
endfunc

// A function that chains two others
func doubleThenIncrement(n)
  _setvar(doubled, doubleVal(_getvar(n)))
  _setvar(result, increment(_getvar(doubled)))
  _return _getvar(result)
endfunc

// 5 -> double=10 -> increment=11
_setvar(r, doubleThenIncrement(5))
_print <color=#aaaaaa>  doubleThenIncrement(5): 5*2=10, 10+1=11 =</color> _getvar(r)
assert(doubleThenIncrement(5) is 11, _getvar(r), 11)

// A 3-step pipeline
func pipeline(n)
  _setvar(s1, increment(_getvar(n)))
  _setvar(s2, doubleVal(_getvar(s1)))
  _setvar(s3, increment(_getvar(s2)))
  _return _getvar(s3)
endfunc

// 3 -> inc=4 -> double=8 -> inc=9
_setvar(r, pipeline(3))
assert(pipeline(3): 3+1=4 *2=8 +1=9, _getvar(r), 9)

printTip(Build complex logic by combining simple functions.)

// ===================================================================
// LESSON 2.6 - RECURSION
// ===================================================================
// A function can call ITSELF! This is called recursion.
// Always have a base case to stop, or you'll loop forever.
// ===================================================================

printLesson(Lesson 2.6: Recursion)

// Classic: factorial  (5! = 5 * 4 * 3 * 2 * 1 = 120)
func factorial(n)
  if _getvar(n) <= 1
    _return 1
  else
    _setvar(prev, factorial(_getvar(n) - 1))
    _return _getvar(n) * _getvar(prev)
  endif
endfunc

_setvar(r, factorial(1))
assert(factorial(1) is 1, _getvar(r), 1)
_setvar(r, factorial(5))
assert(factorial(5) is 120, _getvar(r), 120)
_setvar(r, factorial(7))
assert(factorial(7) is 5040, _getvar(r), 5040)

// Recursive countdown
func countdownMsg(n)
  if _getvar(n) <= 0
    _print <color=#00ff00>  Liftoff!</color>
    _return 0
  else
    _print <color=#aaaaaa>  Countdown: _getvar(n)</color>
    _return countdownMsg(_getvar(n) - 1)
  endif
endfunc

_setvar(r, countdownMsg(3))
assert(countdown reaches 0, _getvar(r), 0)

// Recursive sum 1..n
func recursiveSum(n)
  if _getvar(n) <= 0
    _return 0
  else
    _setvar(rest, recursiveSum(_getvar(n) - 1))
    _return _getvar(n) + _getvar(rest)
  endif
endfunc

_setvar(r, recursiveSum(10))
assert(recursiveSum 1..10 is 55, _getvar(r), 55)

printTip(Always have a base case! Without one recursion never stops.)
printNote(x bash supports recursion up to 1000 levels deep.)

// ###############################################################
//
//   CHAPTER 3: CONTROL FLOW
//   if/elif/else, for, while, until, switch, break, continue
//
// ###############################################################

printHeader(CHAPTER 3: CONTROL FLOW)

// ===================================================================
// LESSON 3.1 - IF / ELIF / ELSE
// ===================================================================
// Branch your code based on conditions.
// Comparison operators: == != < > <= >=
// Logical operators: and  or  not  !
// ===================================================================

printLesson(Lesson 3.1: if / elif / else Conditionals)

// Function demonstrating if/elif/else
func weatherAdvice(temp)
  if _getvar(temp) >= 35
    _return Stay inside - heat warning!
  elif _getvar(temp) >= 25
    _return Nice day for hacking outdoors
  elif _getvar(temp) >= 15
    _return Bring a jacket
  elif _getvar(temp) >= 0
    _return Bundle up!
  else
    _return Freezing - stay home
  endif
endfunc

_setvar(r, weatherAdvice(40))
assert(40deg: heat warning, _getvar(r), Stay inside - heat warning!)
_setvar(r, weatherAdvice(20))
assert(20deg: bring jacket, _getvar(r), Bring a jacket)
_setvar(r, weatherAdvice(-5))
assert(neg5deg: freezing, _getvar(r), Freezing - stay home)

// Function demonstrating logical operators
func canAccess(isAdmin, hasKey)
  if _getvar(isAdmin) == 1 or _getvar(hasKey) == 1
    _return granted
  else
    _return denied
  endif
endfunc

_setvar(r, canAccess(1, 0))
assert(admin access granted, _getvar(r), granted)
_setvar(r, canAccess(0, 1))
assert(key access granted, _getvar(r), granted)
_setvar(r, canAccess(0, 0))
assert(no access denied, _getvar(r), denied)

// ===================================================================
// LESSON 3.2 - FOR LOOPS
// ===================================================================
// for loops iterate over lists or ranges.
// range(start, end) generates numbers from start to end inclusive.
// ===================================================================

printLesson(Lesson 3.2: for Loops)

// Sum numbers 1 to 10 using a for loop
func sumRange(start, finish)
  _setvar(total, 0)
  for i in range(_getvar(start), _getvar(finish))
    _setvar(total, _getvar(total) + _getvar(i))
  endfor
  _return _getvar(total)
endfunc

_setvar(r, sumRange(1, 10))
_print <color=#aaaaaa>  Sum of 1 to 10 =</color> _getvar(r)
assert(sum 1..10 is 55, _getvar(r), 55)

// Loop over a list using join builtin
func joinNames(names)
  _return join(_getvar(names), ~)
endfunc

_setvar(names, [Alice, Bob, Charlie])
_setvar(r, joinNames(_getvar(names)))
_print <color=#aaaaaa>  Joined names:</color> _getvar(r)

// Count items matching a condition
func countEven(limit)
  _setvar(count, 0)
  for i in range(1, _getvar(limit))
    if _getvar(i) % 2 == 0
      _setvar(count, _getvar(count) + 1)
    endif
  endfor
  _return _getvar(count)
endfunc

_setvar(r, countEven(10))
assert(even numbers 1-10 is 5, _getvar(r), 5)
_setvar(r, countEven(20))
assert(even numbers 1-20 is 10, _getvar(r), 10)

printTip(for i in range(1, 5) gives i = 1, 2, 3, 4, 5)
printTip(for item in [a, b, c] iterates over list items)

// ===================================================================
// LESSON 3.3 - WHILE LOOPS
// ===================================================================
// while loops repeat as long as a condition is true.
// Great for counting, searching, or waiting.
// ===================================================================

printLesson(Lesson 3.3: while Loops)

// Double a number until it exceeds a target
func doubleUntilOver(start, target)
  _setvar(val, _getvar(start))
  _setvar(steps, 0)
  while _getvar(val) <= _getvar(target)
    _setvar(val, _getvar(val) * 2)
    _setvar(steps, _getvar(steps) + 1)
  endwhile
  _return _getvar(steps)
endfunc

_setvar(r, doubleUntilOver(1, 100))
_print <color=#aaaaaa>  Doublings to exceed 100 starting from 1:</color> _getvar(r)
assert(doublings from 1 to pass 100 is 7, _getvar(r), 7)

// Collatz conjecture: always reaches 1 (famous unsolved problem!)
func collatzSteps(n)
  _setvar(steps, 0)
  while to_int(_getvar(n)) != 1
    if _getvar(n) % 2 == 0
      _setvar(n, floor(_getvar(n) / 2))
    else
      _setvar(n, _getvar(n) * 3 + 1)
    endif
    _setvar(steps, _getvar(steps) + 1)
  endwhile
  _return _getvar(steps)
endfunc

_setvar(r, collatzSteps(6))
_print <color=#aaaaaa>  Collatz steps for 6:</color> _getvar(r)
assert(collatz(6) takes 8 steps, _getvar(r), 8)
_setvar(r, collatzSteps(27))
assert(collatz(27) takes 111 steps, _getvar(r), 111)

printTip(While loops need a condition that eventually becomes false!)

// ===================================================================
// LESSON 3.4 - UNTIL LOOPS
// ===================================================================
// until is the opposite of while: it loops UNTIL the condition
// becomes true. Same as ""while NOT condition"".
// ===================================================================

printLesson(Lesson 3.4: until Loops)

func countToTarget(target)
  _setvar(n, 0)
  until _getvar(n) == _getvar(target)
    _setvar(n, _getvar(n) + 1)
  enduntil
  _return _getvar(n)
endfunc

_setvar(r, countToTarget(5))
assert(until counts to 5, _getvar(r), 5)

// Find first multiple of 7 above a number
func nextMultipleOf7(start)
  _setvar(n, _getvar(start) + 1)
  until _getvar(n) % 7 == 0
    _setvar(n, _getvar(n) + 1)
  enduntil
  _return _getvar(n)
endfunc

_setvar(r, nextMultipleOf7(10))
assert(next multiple of 7 after 10 is 14, _getvar(r), 14)
_setvar(r, nextMultipleOf7(20))
assert(next multiple of 7 after 20 is 21, _getvar(r), 21)

printTip(until loops are great when you're waiting for a specific condition.)

// ===================================================================
// LESSON 3.5 - BREAK AND CONTINUE
// ===================================================================
// break   - exit the loop immediately
// continue - skip the rest of this iteration, go to next
// ===================================================================

printLesson(Lesson 3.5: break and continue)

// break: find the first number divisible by both 3 and 7
func firstDivisibleBy3And7(limit)
  _setvar(found, -1)
  for i in range(1, _getvar(limit))
    if _getvar(i) % 3 == 0
      if _getvar(i) % 7 == 0
        _setvar(found, _getvar(i))
        break
      endif
    endif
  endfor
  _return _getvar(found)
endfunc

_setvar(r, firstDivisibleBy3And7(100))
assert(first div by 3 and 7 is 21, _getvar(r), 21)

// continue: sum only odd numbers
func sumOdds(limit)
  _setvar(total, 0)
  for i in range(1, _getvar(limit))
    if _getvar(i) % 2 == 0
      continue
    endif
    _setvar(total, _getvar(total) + _getvar(i))
  endfor
  _return _getvar(total)
endfunc

// Odd 1-10: 1+3+5+7+9 = 25
_setvar(r, sumOdds(10))
assert(sum odds 1-10 is 25, _getvar(r), 25)

printTip(break exits the entire loop. continue skips to the next iteration.)

// ===================================================================
// LESSON 3.6 - SWITCH / CASE
// ===================================================================
// switch tests a value against multiple cases.
// Only the first matching case runs. default runs if none match.
// ===================================================================

printLesson(Lesson 3.6: switch / case Statements)

func portService(port)
  _setvar(service, unknown)
  switch _getvar(port)
    case 21
      _setvar(service, FTP)
    case 22
      _setvar(service, SSH)
    case 25
      _setvar(service, SMTP)
    case 80
      _setvar(service, HTTP)
    case 443
      _setvar(service, HTTPS)
    case 3306
      _setvar(service, MySQL)
    default
      _setvar(service, unknown)
  endswitch
  _return _getvar(service)
endfunc

_setvar(r, portService(22))
_print <color=#aaaaaa>  Port 22 =</color> _getvar(r)
assert(port 22 is SSH, _getvar(r), SSH)
_setvar(r, portService(80))
assert(port 80 is HTTP, _getvar(r), HTTP)
_setvar(r, portService(443))
assert(port 443 is HTTPS, _getvar(r), HTTPS)
_setvar(r, portService(9999))
assert(port 9999 is unknown, _getvar(r), unknown)

// Switch with string values
func commandHelp(cmd)
  _setvar(help, )
  switch _getvar(cmd)
    case scan
      _setvar(help, Scans a target IP for open ports)
    case exploit
      _setvar(help, Attempts to exploit a vulnerability)
    case nmap
      _setvar(help, Network mapper - discover hosts)
    default
      _setvar(help, No help available for that command)
  endswitch
  _return _getvar(help)
endfunc

_setvar(r, commandHelp(scan))
_setvar(helpLen, len(_getvar(r)))
assert(scan help is nonempty, _getvar(helpLen), 32)
_setvar(r, commandHelp(bogus))
assert(bogus gets default help, _getvar(r), No help available for that command)

printTip(switch is cleaner than long if/elif chains when checking one value.)

