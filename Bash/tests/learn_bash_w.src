// A function that behaves differently based on type
func describe(thing)
  _setvar(t, typeof_val(thing))
  if _getvar(t) == list
    _setvar(l, len(_getvar(thing)))
    _setvar(desc, concat(list_with_, to_string(_getvar(l))))
    _setvar(desc, concat(_getvar(desc), _items))
    _return _getvar(desc)
  else
    _return concat(value:_, _getvar(thing))
  endif
endfunc

_setvar(myList, [a, b, c])
_setvar(r, describe(_getvar(myList)))
_print <color=#aaaaaa>  describe([a,b,c]) =</color> _getvar(r)

printTip(typeof_val checks the type of a variable or value.)

