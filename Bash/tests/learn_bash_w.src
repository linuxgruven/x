  _print <color=#aaaaaa>  round of 3.5 =</color> _getvar(r)
  _setvar(r, abs(-42))
  _print <color=#aaaaaa>  abs of -42 =</color> _getvar(r)
  _setvar(r, min(5, 12))
  _print <color=#aaaaaa>  min of 5, 12 =</color> _getvar(r)
  _setvar(r, max(5, 12))
  _print <color=#aaaaaa>  max of 5, 12 =</color> _getvar(r)
  _setvar(r, random(1, 100))
  _print <color=#aaaaaa>  random 1 to 100 =</color> _getvar(r)
endfunc

mathShowcase()

// Practical math: distance between two points (Manhattan distance)
func manhattanDist(x1, y1, x2, y2)
  _setvar(dx, abs(_getvar(x1) - _getvar(x2)))
  _setvar(dy, abs(_getvar(y1) - _getvar(y2)))
  _return _getvar(dx) + _getvar(dy)
endfunc

_setvar(r, manhattanDist(0, 0, 3, 4))
assert(manhattan (0,0)-(3,4) is 7, _getvar(r), 7)
_setvar(r, manhattanDist(5, 5, 5, 5))
assert(manhattan same point is 0, _getvar(r), 0)

// Practical math: is a year a leap year?
func isLeapYear(year)
  if _getvar(year) % 400 == 0
    _return 1
  elif _getvar(year) % 100 == 0
    _return 0
  elif _getvar(year) % 4 == 0
    _return 1
  else
    _return 0
  endif
endfunc

_setvar(r, isLeapYear(2000))
assert(2000 is leap year, _getvar(r), 1)
_setvar(r, isLeapYear(1900))
assert(1900 is not leap year, _getvar(r), 0)
_setvar(r, isLeapYear(2024))
assert(2024 is leap year, _getvar(r), 1)
_setvar(r, isLeapYear(2023))
assert(2023 is not leap year, _getvar(r), 0)

// Practical math: GCD (Euclidean algorithm)
func gcd(a, b)
  while _getvar(b) != 0
    _setvar(t, _getvar(b))
    _setvar(b, _getvar(a) % _getvar(b))
    _setvar(a, _getvar(t))
  endwhile
  _return _getvar(a)
endfunc

_setvar(r, gcd(48, 18))
assert(gcd(48, 18) is 6, _getvar(r), 6)
_setvar(r, gcd(100, 75))
assert(gcd(100, 75) is 25, _getvar(r), 25)

// LCM using GCD
func lcm(a, b)
  _setvar(g, gcd(_getvar(a), _getvar(b)))
  _return _getvar(a) * _getvar(b) / _getvar(g)
endfunc

_setvar(r, lcm(4, 6))
assert(lcm(4, 6) is 12, _getvar(r), 12)

printTip(The random builtin gives a random integer in [min, max] inclusive.)

