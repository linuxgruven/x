// LESSON 6.5 - WRITING FILES
// ===================================================================
// _fs_write creates or overwrites a file.
// _fs_mkdir creates directories.
// Be careful - this modifies the file system!
// ===================================================================

printLesson(Lesson 6.5: Writing Files & Directories)

func writeDemo()
  // Demonstrate file writing and directory creation
  _fs_mkdir tmp_test
  _print <color=#00ff00>  Created directory:</color> tmp_test

  // Change into the new directory, write a file, then come back
  _fs_cd tmp_test
  _fs_write hello.txt Hello from x bash!
  _print <color=#00ff00>  Wrote file:</color> hello.txt

  // Read it back to verify using file_read() builtin
  _setvar(contents, file_read(""hello.txt""))
  _print <color=#aaaaaa>  Contents:</color> _getvar(contents)
  _setvar(wroteOk, file_exists(""hello.txt""))
  assert(6.5a hello.txt exists, _getvar(wroteOk), 1)

  // Return to original directory
  _fs_cd ..
endfunc

writeDemo()

printTip(_fs_write <path> <text> creates or overwrites a file.)
printTip(_fs_mkdir <path> creates a directory.)
printNote(Be careful with _fs_write - it overwrites existing files!)

