// A function that reports file status
func fileReport(path)
  _setvar(exists, _File(_getvar(path)))
  if not _getvar(exists)
    _return not found
  endif
  _setvar(isDir, _getvar(exists).is_folder)
  if _getvar(isDir)
    _return directory
  else
    _return file
  endif
endfunc

_setvar(r, fileReport(/etc))
_print <color=#aaaaaa>  /etc is a:</color> _getvar(r)
_setvar(r, fileReport(/etc/passwd))
_print <color=#aaaaaa>  /etc/passwd is a:</color> _getvar(r)

printTip(Use _File to get a file object. Returns null if the path does not exist.)
printTip(Access .is_folder on a _File result to check if it is a directory.)

// ===================================================================
// LESSON 6.4 - READING FILES
// ===================================================================
// _fs_read reads file contents into a variable.
// Useful for parsing configs, checking passwords, etc.
// ===================================================================

printLesson(Lesson 6.4: Reading Files)

func readAndCheck(path)
  _setvar(exists, _File(_getvar(path)))
  if not _getvar(exists)
    _print <color=#ff0000>  File not found:</color> _getvar(path)
    _return
  endif
  _setvar(content, _fs_read _getvar(path))
  _setvar(cl, len(_getvar(content)))
  _print <color=#aaaaaa>  Read _getvar(path): _getvar(cl) characters</color>
  _return _getvar(cl)
endfunc

readAndCheck(/etc/passwd)

printTip(_fs_read <path> stores file content in a variable.)
printNote(Always check the _File result before reading to avoid errors.)

