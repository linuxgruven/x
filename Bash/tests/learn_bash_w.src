// ###############################################################
//
//   CHAPTER 10: ADVANCED PATTERNS
//   Function composition, state machines, complex algorithms
//
// ###############################################################

printHeader(CHAPTER 10: ADVANCED PATTERNS)

// ===================================================================
// LESSON 10.1 - FUNCTION COMPOSITION
// ===================================================================
// Chain multiple functions together for complex transformations.
// ===================================================================

printLesson(Lesson 10.1: Function Composition)

// Build a pipeline: clean user input
func cleanInput(text)
  _setvar(trimmed, trim_str(_getvar(text)))
  _setvar(lowered, lower(_getvar(trimmed)))
  _return _getvar(lowered)
endfunc

_setvar(r, cleanInput(  HELLO WORLD  ))
assert(cleanInput trims and lowers, _getvar(r), hello world)

// Build a tag function using join (dash is safe as join delimiter)
func makeID(prefix, number)
  _setvar(numStr, to_string(_getvar(number)))
  _setvar(parts, [])
  _push parts _getvar(prefix)
  _push parts _getvar(numStr)
  _return join(_getvar(parts), -)
endfunc

_setvar(r, makeID(SRV, 1))
assert(makeID SRV-1, _getvar(r), SRV-1)
_setvar(r, makeID(SRV, 42))
assert(makeID SRV-42, _getvar(r), SRV-42)
_setvar(r, makeID(SRV, 100))
assert(makeID SRV-100, _getvar(r), SRV-100)

// Generate a batch of IDs
func generateIDs(prefix, count)
  _setvar(ids, [])
  for i in range(1, _getvar(count))
    _setvar(id, makeID(_getvar(prefix), _getvar(i)))
    _push ids _getvar(id)
  endfor
  _return _getvar(ids)
endfunc

_setvar(servers, generateIDs(WEB, 5))
_setvar(r, len(_getvar(servers)))
_print <color=#aaaaaa>  Generated IDs:</color> _getvar(servers)
assert(generated 5 server IDs, _getvar(r), 5)

printTip(Small reusable functions compose into powerful pipelines.)

// ===================================================================
// LESSON 10.2 - STATE MACHINE: LOGIN SIMULATOR
// ===================================================================
// Simulate a login system with attempt tracking.
// ===================================================================

printLesson(Lesson 10.2: State Machine - Login Simulator)
_print   Simulating a login with 3 attempts (wrong, wrong, correct):

// Simulate checking a password
func checkPassword(input, correct)
  if _getvar(input) == _getvar(correct)
    _return granted
  else
    _return denied
  endif
endfunc

// Login system with max attempts
func loginSystem(attempts, password)
  _setvar(maxAttempts, _getvar(attempts))
  _setvar(attempt, 0)
  _setvar(status, locked)

  while _getvar(attempt) < _getvar(maxAttempts)
    _setvar(attempt, _getvar(attempt) + 1)
    // Simulate trying the right password on the last attempt
    if _getvar(attempt) == _getvar(maxAttempts)
      _setvar(result, checkPassword(_getvar(password), _getvar(password)))
    else
      _setvar(result, checkPassword(wrong, _getvar(password)))
    endif

    if _getvar(result) == granted
      _setvar(status, granted)
      _print <color=#00ff00>  Attempt _getvar(attempt): Access granted (correct password)</color>
      _setvar(attempt, _getvar(maxAttempts))
    else
      _print <color=#ff0000>  Attempt _getvar(attempt): Access denied (wrong password)</color>
    endif
  endwhile

  _return _getvar(status)
endfunc

_setvar(r, loginSystem(3, secret123))
_print   Final status: _getvar(r)
assert(login succeeds on last attempt, _getvar(r), granted)
_print   TIP: State machines track status across iterations - here: locked -> denied -> denied -> granted.

// ===================================================================
// LESSON 10.3 - ITERATIVE ALGORITHMS: FIZZBUZZ
// ===================================================================
// The classic programming interview question!
// For 1 to N: print Fizz (div by 3), Buzz (div by 5),
//             FizzBuzz (div by both), or the number.
// ===================================================================

printLesson(Lesson 10.3: FizzBuzz)

func fizzBuzz(n)
  _setvar(fizzes, 0)
  _setvar(buzzes, 0)
  _setvar(fizzbuzzes, 0)

  for i in range(1, _getvar(n))
    if _getvar(i) % 15 == 0
      _setvar(fizzbuzzes, _getvar(fizzbuzzes) + 1)
    elif _getvar(i) % 3 == 0
      _setvar(fizzes, _getvar(fizzes) + 1)
    elif _getvar(i) % 5 == 0
      _setvar(buzzes, _getvar(buzzes) + 1)
    endif
  endfor

  _print <color=#aaaaaa>  FizzBuzz(1-_getvar(n)): Fizzes=_getvar(fizzes) Buzzes=_getvar(buzzes) FizzBuzzes=_getvar(fizzbuzzes)</color>
  _return _getvar(fizzbuzzes)
endfunc

_setvar(r, fizzBuzz(15))
assert(fizzbuzz 1-15 has 1 fizzbuzz (15), _getvar(r), 1)
_setvar(r, fizzBuzz(30))
assert(fizzbuzz 1-30 has 2 fizzbuzzes (15 30), _getvar(r), 2)

// ===================================================================
// LESSON 10.4 - COMPLEX CALL CHAINS
// ===================================================================
// Show how functions build on each other.
// ===================================================================

printLesson(Lesson 10.4: Complex Call Chains)

// Simple building blocks
func square(n)
  _return _getvar(n) * _getvar(n)
endfunc

func halve(n)
  _return _getvar(n) / 2
endfunc

func negate(n)
  _return _getvar(n) * -1
endfunc

// Complex pipeline using building blocks
func transform(n)
  // n -> square -> halve -> increment -> negate
  _setvar(s1, square(_getvar(n)))
  _setvar(s2, halve(_getvar(s1)))
  _setvar(s3, increment(_getvar(s2)))
  _setvar(s4, negate(_getvar(s3)))
  _return _getvar(s4)
endfunc

// 10 -> 100 -> 50 -> 51 -> -51
_setvar(r, transform(10))
_print <color=#aaaaaa>  transform(10): 10->100->50->51->-51 =</color> _getvar(r)
assert(transform(10) is -51, _getvar(r), -51)

// 4 -> 16 -> 8 -> 9 -> -9
_setvar(r, transform(4))
assert(transform(4) is -9, _getvar(r), -9)

// ===================================================================
// LESSON 10.5 - DIAMOND CALL PATTERN
// ===================================================================
// Multiple paths through different functions converge.
// ===================================================================

printLesson(Lesson 10.5: Diamond Call Pattern)

func pathA(n)
  _return _getvar(n) * 2
endfunc

func pathB(n)
  _return _getvar(n) * 3
endfunc

func merge(n)
  _setvar(left, pathA(_getvar(n)))
  _setvar(right, pathB(_getvar(n)))
  _return _getvar(left) + _getvar(right)
endfunc

// merge(10): pathA(10)=20, pathB(10)=30, 20+30=50
_setvar(r, merge(10))
assert(diamond merge(10) is 50, _getvar(r), 50)

// Deeper diamond
func deepMerge(n)
  _setvar(m, merge(_getvar(n)))
  _setvar(s, square(_getvar(n)))
  _return _getvar(m) + _getvar(s)
endfunc

// deepMerge(5): merge(5)=10+15=25, square(5)=25, 25+25=50
_setvar(r, deepMerge(5))
assert(deepMerge(5) is 50, _getvar(r), 50)

printTip(Complex programs are just simple functions combined in creative ways.)

// ###############################################################
//
//   CHAPTER 11: BUILTIN CHAINING & NESTING
//   Using builtins inside expressions and other builtins
//
// ###############################################################

printHeader(CHAPTER 11: BUILTIN CHAINING)

printLesson(Lesson 11.1: Nested Builtin Calls)

// upper of a substr result
func upperFirst3(s)
  _return upper(substr(_getvar(s), 0, 3))
endfunc

_setvar(r, upperFirst3(hello))
assert(upper first 3 of hello is HEL, _getvar(r), HEL)
_setvar(r, upperFirst3(world))
assert(upper first 3 of world is WOR, _getvar(r), WOR)

// lower of upper (roundtrip)
func caseRoundtrip(s)
  _return lower(upper(_getvar(s)))
endfunc

_setvar(r, caseRoundtrip(Hello))
assert(lower+upper roundtrip is hello, _getvar(r), hello)

// len in arithmetic
func lenSum(a, b)
  _return len(_getvar(a)) + len(_getvar(b))
endfunc

_setvar(r, lenSum(hello, world))
assert(lenSum hello+world is 10, _getvar(r), 10)

// concat with to_string
func labeledNum(label, num)
  _return concat(_getvar(label), :, to_string(_getvar(num)))
endfunc

_setvar(r, labeledNum(score, 100))
assert(labeledNum score 100, _getvar(r), score:100)

// len of to_string
func digitCount(num)
  _return len(to_string(_getvar(num)))
endfunc

_setvar(r, digitCount(12345))
assert(12345 has 5 digits, _getvar(r), 5)
_setvar(r, digitCount(7))
assert(7 has 1 digit, _getvar(r), 1)
_setvar(r, digitCount(100))
assert(100 has 3 digits, _getvar(r), 3)

// Chained math builtins
func clampedAbs(n, lo, hi)
  _setvar(a, abs(_getvar(n)))
  _setvar(b, max(_getvar(a), _getvar(lo)))
  _return min(_getvar(b), _getvar(hi))
endfunc

_setvar(r, clampedAbs(-50, 0, 10))
assert(clampAbs neg50 0 10 is 10, _getvar(r), 10)
_setvar(r, clampedAbs(-3, 0, 10))
assert(clampAbs neg3 0 10 is 3, _getvar(r), 3)
_setvar(r, clampedAbs(7, 0, 10))
assert(clampAbs 7 0 10 is 7, _getvar(r), 7)

// Multiple builtins in one expression
_setvar(r, abs(-7) + abs(3))
assert(absNeg7 plus abs3 is 10, _getvar(r), 10)

_setvar(r, max(min(abs(-10), 7), floor(3.9)))
assert(complex nested math is 7, _getvar(r), 7)

_setvar(r, floor(abs(-7) + ceil(2.1)))
assert(floor+abs+ceil combo is 10, _getvar(r), 10)

printTip(Builtins can be nested: e.g. upper + substr chained together works!)

// ###############################################################
//
//   CHAPTER 12: RECON TOOLKIT
//   Building practical scanning & recon functions
//
// ###############################################################

printHeader(CHAPTER 12: RECON TOOLKIT)

// ===================================================================
// LESSON 12.1 - PORT SCANNER WRAPPER
// ===================================================================
// Wrap the scanning builtins in friendly functions.
// ===================================================================

printLesson(Lesson 12.1: Recon Wrapper Functions)

// Formatted port count for a target
func portCount(ip)
  _setvar(ports, _net_ports _getvar(ip))
  if _getvar(ports)
    _return len(_getvar(ports))
  else
    _return 0
  endif
endfunc

_setvar(myIP, get_publicIP())
_setvar(r, portCount(_getvar(myIP)))
_print <color=#aaaaaa>  Ports open on self:</color> _getvar(r)
if _getvar(r) > 0
  _print <color=#00ff00>  [PASS] Found at least 1 open port on self</color>
else
  _print <color=#ffff00>  [NOTE] No ports found (host may be firewalled)</color>
endif

// Security assessment function
func assessTarget(ip)
  _print <color=#00bfff>  [RECON] Assessing:</color> _getvar(ip)
  _setvar(reachable, _net_ping _getvar(ip))
  if _getvar(reachable) != 1
    _print <color=#ff0000>  Host unreachable</color>
    _return unreachable
  endif
  _print <color=#00ff00>  Host is up</color>

  _setvar(ports, _net_ports _getvar(ip))
  if _getvar(ports)
    _setvar(numPorts, len(_getvar(ports)))
    _print <color=#aaaaaa>  Open ports:</color> _getvar(numPorts)
  else
    _setvar(numPorts, 0)
    _print <color=#aaaaaa>  No open ports found</color>
  endif

  if _getvar(numPorts) > 5
    _return high-exposure
  elif _getvar(numPorts) > 2
    _return moderate
  elif _getvar(numPorts) > 0
    _return low-exposure
  else
    _return stealthy
  endif
endfunc

_setvar(assessment, assessTarget(_getvar(myIP)))
_print <color=#eb0cc6>  Assessment:</color> _getvar(assessment)

printTip(Wrap system calls in functions for cleaner, reusable code.)

// ===================================================================
// LESSON 12.2 - FIREWALL AND ROUTER INFO
// ===================================================================

printLesson(Lesson 12.2: Router & Firewall Info)

func routerReport(ip)
  _print <color=#00bfff>  [ROUTER] Checking:</color> _getvar(ip)
  _setvar(info, _net_router _getvar(ip))
  if _getvar(info)
    _print <color=#00ff00>  Router info retrieved</color>
  else
    _print <color=#aaaaaa>  No router info available</color>
  endif

  _setvar(rules, _net_fwrules _getvar(ip))
  if _getvar(rules)
    _setvar(ruleCount, len(_getvar(rules)))
    _print <color=#aaaaaa>  Firewall rules:</color> _getvar(ruleCount)
  else
    _print <color=#aaaaaa>  No firewall rules found</color>
  endif
endfunc

routerReport(get_publicIP())

printTip(_net_router and _net_fwrules return structured data.)

