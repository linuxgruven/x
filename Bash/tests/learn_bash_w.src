printHeader(CHAPTER 13: PROCESS MANAGEMENT)

printLesson(Lesson 13.1: Listing Processes)

func processDemo()
  _print <color=#aaaaaa>  Current running processes:</color>
  _sys_procs
  _print
  printNote(Use _sys_kill <pid> to terminate a process.)
endfunc

processDemo()

// ===================================================================
// LESSON 13.2 - SLEEP / TIMING
// ===================================================================

printLesson(Lesson 13.2: Sleep and Timing)

func timingDemo()
  _setvar(before, timestamp())
  _print <color=#aaaaaa>  Timestamp before sleep:</color> _getvar(before)

  sleep 1

  _setvar(after, timestamp())
  _print <color=#aaaaaa>  Timestamp after 1s sleep:</color> _getvar(after)

  _setvar(elapsed, _getvar(after) - _getvar(before))
  _print <color=#aaaaaa>  Elapsed:</color> _getvar(elapsed)
endfunc

timingDemo()

_pause
printTip(sleep N suspends the script for N seconds. Useful for timed operations.)
printTip(The timestamp builtin returns Unix time - use it to measure how long things take.)

// ###############################################################
//
//   CHAPTER 14: PUTTING IT ALL TOGETHER
//   Complex programs that use everything we've learned
//
