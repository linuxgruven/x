// ###############################################################
//
//   CHAPTER 8: PRACTICAL PROGRAMS
//   Real mini-programs that combine everything learned
//
// ###############################################################

printHeader(CHAPTER 8: PRACTICAL PROGRAMS)

// ===================================================================
// LESSON 8.1 - PRIME NUMBER CHECKER
// ===================================================================
// A classic algorithm: is this number prime?
// ===================================================================

printLesson(Lesson 8.1: Prime Number Checker)

func isPrime(n)
  if _getvar(n) < 2
    _return 0
  endif
  _setvar(i, 2)
  while _getvar(i) * _getvar(i) <= _getvar(n)
    if _getvar(n) % _getvar(i) == 0
      _return 0
    endif
    _setvar(i, _getvar(i) + 1)
  endwhile
  _return 1
endfunc

// Test the prime checker
_setvar(r, isPrime(1))
assert(1 is not prime, _getvar(r), 0)
_setvar(r, isPrime(2))
assert(2 is prime, _getvar(r), 1)
_setvar(r, isPrime(7))
assert(7 is prime, _getvar(r), 1)
_setvar(r, isPrime(9))
assert(9 is not prime (3*3), _getvar(r), 0)
_setvar(r, isPrime(13))
assert(13 is prime, _getvar(r), 1)
_setvar(r, isPrime(100))
assert(100 is not prime, _getvar(r), 0)

// Count primes in a range
func countPrimes(limit)
  _setvar(count, 0)
  for i in range(2, _getvar(limit))
    _setvar(p, isPrime(_getvar(i)))
    if _getvar(p) == 1
      _setvar(count, _getvar(count) + 1)
    endif
  endfor
  _return _getvar(count)
endfunc

_setvar(r, countPrimes(10))
_print <color=#aaaaaa>  Primes up to 10:</color> _getvar(r)
assert(primes up to 10 is 4 (2,3,5,7), _getvar(r), 4)
_setvar(r, countPrimes(20))
assert(primes up to 20 is 8, _getvar(r), 8)

// List primes up to N
func listPrimes(limit)
  _setvar(primes, [])
  for i in range(2, _getvar(limit))
    _setvar(p, isPrime(_getvar(i)))
    if _getvar(p) == 1
      _push primes _getvar(i)
    endif
  endfor
  _return _getvar(primes)
endfunc

_setvar(primeList, listPrimes(30))
_print <color=#aaaaaa>  Primes up to 30:</color> join(_getvar(primeList), , )
_setvar(r, len(_getvar(primeList)))
assert(10 primes under 30, _getvar(r), 10)

printTip(Check divisibility up to sqrt(n) for efficiency.)

// ===================================================================
// LESSON 8.2 - FIBONACCI GENERATOR
// ===================================================================
// The famous sequence: 0, 1, 1, 2, 3, 5, 8, 13, 21, ...
// Each number is the sum of the two before it.
// ===================================================================

printLesson(Lesson 8.2: Fibonacci Generator)

// Iterative fibonacci (fast!)
func fibonacci(n)
  if _getvar(n) <= 0
    _return 0
  endif
  if _getvar(n) == 1
    _return 1
  endif
  _setvar(a, 0)
  _setvar(b, 1)
  _setvar(i, 2)
  while _getvar(i) <= _getvar(n)
    _setvar(temp, _getvar(b))
    _setvar(b, _getvar(a) + _getvar(b))
    _setvar(a, _getvar(temp))
    _setvar(i, _getvar(i) + 1)
  endwhile
  _return _getvar(b)
endfunc

_setvar(r, fibonacci(0))
assert(fib(0) is 0, _getvar(r), 0)
_setvar(r, fibonacci(1))
assert(fib(1) is 1, _getvar(r), 1)
_setvar(r, fibonacci(5))
assert(fib(5) is 5, _getvar(r), 5)
_setvar(r, fibonacci(10))
assert(fib(10) is 55, _getvar(r), 55)
_setvar(r, fibonacci(20))
assert(fib(20) is 6765, _getvar(r), 6765)

// Build and display fibonacci sequence
func fibSequence(count)
  _setvar(seq, [])
  for i in range(0, _getvar(count))
    _setvar(val, fibonacci(_getvar(i)))
    _push seq _getvar(val)
  endfor
  _return _getvar(seq)
endfunc

_setvar(seq, fibSequence(12))
_print <color=#aaaaaa>  First 13 Fibonacci numbers:</color>
_print <color=#00ff00>  _getvar(seq)</color>

printTip(Iterative is much faster than recursive for fibonacci.)

// ===================================================================
// LESSON 8.3 - SORTING: BUBBLE SORT
// ===================================================================
// A simple sorting algorithm that swaps adjacent elements.
// Not the fastest, but easy to understand!
// ===================================================================

printLesson(Lesson 8.3: Sorting - Bubble Sort)

// Note: x bash lists don't support index assignment easily,
// so we use a comparison-based approach with variables
func bubbleSortDemo()
  // We'll sort 5 numbers using variables (since list index
  // assignment isn't directly supported)
  _setvar(a, 5)
  _setvar(b, 2)
  _setvar(c, 8)
  _setvar(d, 1)
  _setvar(e, 4)
  _print <color=#aaaaaa>  Before: _getvar(a), _getvar(b), _getvar(c), _getvar(d), _getvar(e)</color>

  // Multiple passes - swap adjacent if out of order
  // Pass 1
  if _getvar(a) > _getvar(b)
    _setvar(t, _getvar(a))
    _setvar(a, _getvar(b))
    _setvar(b, _getvar(t))
  endif
  if _getvar(b) > _getvar(c)
    _setvar(t, _getvar(b))
    _setvar(b, _getvar(c))
    _setvar(c, _getvar(t))
  endif
  if _getvar(c) > _getvar(d)
    _setvar(t, _getvar(c))
    _setvar(c, _getvar(d))
    _setvar(d, _getvar(t))
  endif
  if _getvar(d) > _getvar(e)
    _setvar(t, _getvar(d))
    _setvar(d, _getvar(e))
    _setvar(e, _getvar(t))
  endif
  // Pass 2
  if _getvar(a) > _getvar(b)
    _setvar(t, _getvar(a))
    _setvar(a, _getvar(b))
    _setvar(b, _getvar(t))
  endif
  if _getvar(b) > _getvar(c)
    _setvar(t, _getvar(b))
    _setvar(b, _getvar(c))
    _setvar(c, _getvar(t))
  endif
  if _getvar(c) > _getvar(d)
    _setvar(t, _getvar(c))
    _setvar(c, _getvar(d))
    _setvar(d, _getvar(t))
  endif
  // Pass 3
  if _getvar(a) > _getvar(b)
    _setvar(t, _getvar(a))
    _setvar(a, _getvar(b))
    _setvar(b, _getvar(t))
  endif
  if _getvar(b) > _getvar(c)
    _setvar(t, _getvar(b))
    _setvar(b, _getvar(c))
    _setvar(c, _getvar(t))
  endif
  // Pass 4
  if _getvar(a) > _getvar(b)
    _setvar(t, _getvar(a))
    _setvar(a, _getvar(b))
    _setvar(b, _getvar(t))
  endif

  _print <color=#00ff00>  After:  _getvar(a), _getvar(b), _getvar(c), _getvar(d), _getvar(e)</color>
endfunc

bubbleSortDemo()
printNote(Bubble sort compares neighbors and swaps if needed. Repeat until sorted.)

// ===================================================================
// LESSON 8.4 - ITERATIVE POWER (EXPONENTIATION)
// ===================================================================
// Calculate base^exp without the ** operator.
// ===================================================================

printLesson(Lesson 8.4: Iterative Power)

func power(base, exp)
  _setvar(result, 1)
  _setvar(i, 0)
  while _getvar(i) < _getvar(exp)
    _setvar(result, _getvar(result) * _getvar(base))
    _setvar(i, _getvar(i) + 1)
  endwhile
  _return _getvar(result)
endfunc

_setvar(r, power(2, 0))
assert(2^0 is 1, _getvar(r), 1)
_setvar(r, power(2, 10))
assert(2^10 is 1024, _getvar(r), 1024)
_setvar(r, power(3, 5))
assert(3^5 is 243, _getvar(r), 243)
_setvar(r, power(10, 3))
assert(10^3 is 1000, _getvar(r), 1000)

// ===================================================================
// LESSON 8.5 - LIST STATISTICS
// ===================================================================
// Functions that analyze a list of numbers.
// ===================================================================

printLesson(Lesson 8.5: List Statistics)

// Find minimum value
func listMin(lst)
  _setvar(best, 999999)
  for item in _getvar(lst)
    if _getvar(item) < _getvar(best)
      _setvar(best, _getvar(item))
    endif
  endfor
  _return _getvar(best)
endfunc

// Find maximum value
func listMax(lst)
  _setvar(best, -999999)
  for item in _getvar(lst)
    if _getvar(item) > _getvar(best)
      _setvar(best, _getvar(item))
    endif
  endfor
  _return _getvar(best)
endfunc

// Sum all values
func listSum(lst)
  _setvar(total, 0)
  for item in _getvar(lst)
    _setvar(total, _getvar(total) + _getvar(item))
  endfor
  _return _getvar(total)
endfunc

// Average
func listAvg(lst)
  _setvar(total, listSum(_getvar(lst)))
  _setvar(count, len(_getvar(lst)))
  _return _getvar(total) / _getvar(count)
endfunc

// Range (max - min)
func listRange(lst)
  _setvar(lo, listMin(_getvar(lst)))
  _setvar(hi, listMax(_getvar(lst)))
  _return _getvar(hi) - _getvar(lo)
endfunc

_setvar(data, [10, 25, 3, 47, 18, 9, 33])

_setvar(r, listMin(_getvar(data)))
_print <color=#aaaaaa>  Min:</color> _getvar(r)
assert(list min is 3, _getvar(r), 3)

_setvar(r, listMax(_getvar(data)))
_print <color=#aaaaaa>  Max:</color> _getvar(r)
assert(list max is 47, _getvar(r), 47)

_setvar(r, listSum(_getvar(data)))
_print <color=#aaaaaa>  Sum:</color> _getvar(r)
assert(list sum is 145, _getvar(r), 145)

_setvar(r, listRange(_getvar(data)))
_print <color=#aaaaaa>  Range:</color> _getvar(r)
assert(list range is 44, _getvar(r), 44)

printTip(Build reusable utility functions like these for your own scripts!)

// ===================================================================
// LESSON 8.6 - SEARCH ALGORITHMS
// ===================================================================
// Find items in a list.
// ===================================================================

printLesson(Lesson 8.6: Search Functions)

// Linear search: find index of item
func findIndex(lst, target)
  _setvar(idx, 0)
  for item in _getvar(lst)
    if _getvar(item) == _getvar(target)
      _return _getvar(idx)
    endif
    _setvar(idx, _getvar(idx) + 1)
  endfor
  _return -1
endfunc

_setvar(arr, [apple, banana, cherry, date, elderberry])
_setvar(r, findIndex(_getvar(arr), cherry))
assert(findIndex cherry is 2, _getvar(r), 2)
_setvar(r, findIndex(_getvar(arr), elderberry))
assert(findIndex elderberry is 4, _getvar(r), 4)
_setvar(r, findIndex(_getvar(arr), fig))
assert(findIndex fig not found is -1, _getvar(r), -1)

// Count occurrences
func countOccurrences(lst, target)
  _setvar(count, 0)
  for item in _getvar(lst)
    if _getvar(item) == _getvar(target)
      _setvar(count, _getvar(count) + 1)
    endif
  endfor
  _return _getvar(count)
endfunc

_setvar(arr, [a, b, a, c, a, b])
_setvar(r, countOccurrences(_getvar(arr), a))
assert(count of 'a' is 3, _getvar(r), 3)
_setvar(r, countOccurrences(_getvar(arr), b))
assert(count of 'b' is 2, _getvar(r), 2)
_setvar(r, countOccurrences(_getvar(arr), z))
assert(count of 'z' is 0, _getvar(r), 0)

// Filter: return items above a threshold
func filterAbove(lst, threshold)
  _setvar(result, [])
  for item in _getvar(lst)
    if _getvar(item) > _getvar(threshold)
      _push result _getvar(item)
    endif
  endfor
  _return _getvar(result)
endfunc

_setvar(nums, [1, 5, 3, 8, 2, 9, 4, 7])
_setvar(above5, filterAbove(_getvar(nums), 5))
_setvar(r, len(_getvar(above5)))
_print <color=#aaaaaa>  Items above 5:</color> _getvar(r)
assert(3 items above 5 (8, 9, 7), _getvar(r), 3)

printTip(Searching and filtering are fundamental operations you'll use constantly.)

