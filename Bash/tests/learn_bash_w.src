printHeader(CHAPTER 14: PUTTING IT ALL TOGETHER)

// ===================================================================
// LESSON 14.1 - NETWORK INVENTORY TOOL
// ===================================================================
// Combine scanning + file writing + formatting
// ===================================================================

printLesson(Lesson 14.1: Network Inventory Builder)

func buildInventory()
  _setvar(myIP, get_publicIP())
  _setvar(myLAN, get_lanIP())
  _setvar(user, get_user())
  _setvar(dt, date())

  _print <color=#eb0cc6>  +=== NETWORK INVENTORY ===+</color>
  _print <color=#aaaaaa>  Generated:</color> _getvar(dt)
  _print <color=#aaaaaa>  User:</color> _getvar(user)
  _print <color=#aaaaaa>  LAN:</color> _getvar(myLAN)
  _print <color=#aaaaaa>  Public:</color> _getvar(myIP)

  _setvar(ports, _net_ports _getvar(myIP))
  if _getvar(ports)
    _setvar(portCount, len(_getvar(ports)))
    _print <color=#aaaaaa>  Open ports:</color> _getvar(portCount)
    for port in _getvar(ports)
      _print <color=#00bfff>    -</color> _getvar(port)
    endfor
  else
    _print <color=#aaaaaa>  No open ports found</color>
  endif

  _print <color=#eb0cc6>  +=== END INVENTORY ===+</color>
endfunc

buildInventory()

printTip(This combines: networking, looping, switch, formatting, and functions.)

// ===================================================================
// LESSON 14.2 - MEGA FUNCTION CHAIN
// ===================================================================
// One huge chain: create a value, transform it through 7 functions.
// ===================================================================

printLesson(Lesson 14.2: Mega Function Chain)

_setvar(v, 3)
_print <color=#aaaaaa>  Start: _getvar(v)</color>

_setvar(v, square(_getvar(v)))
_print <color=#aaaaaa>  -> square: _getvar(v)</color>

_setvar(v, increment(_getvar(v)))
_print <color=#aaaaaa>  -> increment: _getvar(v)</color>

_setvar(v, doubleVal(_getvar(v)))
_print <color=#aaaaaa>  -> double: _getvar(v)</color>

_setvar(v, increment(_getvar(v)))
_print <color=#aaaaaa>  -> increment: _getvar(v)</color>

_setvar(v, halve(_getvar(v)))
_print <color=#aaaaaa>  -> halve: _getvar(v)</color>

// 3 -> 9 -> 10 -> 20 -> 21 -> 10
_setvar(r, floor(_getvar(v)))
_print <color=#00ff00>  Final (floored): _getvar(r)</color>
assert(mega chain 3->9->10->20->21->10 is 10, _getvar(r), 10)

// ===================================================================
// LESSON 14.3 - COMPREHENSIVE VERIFICATION
// ===================================================================
// Final verification that key features work together.
// ===================================================================

printLesson(Lesson 14.3: Final Verification Suite)

// Math + functions
_setvar(r, factorial(6))
assert(factorial(6) is 720, _getvar(r), 720)

_setvar(r, fibonacci(15))
assert(fibonacci(15) is 610, _getvar(r), 610)

_setvar(r, gcd(84, 56))
assert(gcd(84, 56) is 28, _getvar(r), 28)

_setvar(r, lcm(6, 10))
assert(lcm(6, 10) is 30, _getvar(r), 30)

_setvar(r, power(2, 8))
assert(power(2, 8) is 256, _getvar(r), 256)

// String + functions
_setvar(r, reverseStr(abcdef))
assert(reverse abcdef is fedcba, _getvar(r), fedcba)

_setvar(r, isPalindrome(elle))
assert(elle is palindrome, _getvar(r), 1)

_setvar(r, repeatStr(xo, 3))
assert(repeat xo 3 is xoxoxo, _getvar(r), xoxoxo)

_setvar(r, startsWith(helloworld, hello))
assert(helloworld starts with hello, _getvar(r), 1)

// List + functions
_setvar(data, [5, 1, 9, 3, 7])
_setvar(r, listMin(_getvar(data)))
assert(list min is 1, _getvar(r), 1)
_setvar(r, listMax(_getvar(data)))
assert(list max is 9, _getvar(r), 9)
_setvar(r, listSum(_getvar(data)))
assert(list sum is 25, _getvar(r), 25)

// Prime checks
_setvar(r, isPrime(97))
assert(97 is prime, _getvar(r), 1)
_setvar(r, isPrime(100))
assert(100 is not prime, _getvar(r), 0)

// Type checks
_setvar(r, to_yesno(1))
assert(toYesno 1 is yes, _getvar(r), yes)
_setvar(r, to_truefalse(0))
assert(toTrueFalse 0 is false, _getvar(r), false)

// Nested builtins
_setvar(r, len(concat(abc, def)))
assert(len+concat gives 6, _getvar(r), 6)
_setvar(r, upper(substr(testing, 0, 4)))
assert(upper+substr gives TEST, _getvar(r), TEST)

// Environment sanity
_setvar(u, get_user())
_setvar(h, get_home())
if len(_getvar(u)) > 0
  _setvar(pass, 1)
else
  _setvar(pass, 0)
endif
assert(environment user exists, _getvar(pass), 1)
if len(_getvar(h)) > 0
  _setvar(pass, 1)
else
  _setvar(pass, 0)
endif
assert(environment home exists, _getvar(pass), 1)


// ###############################################################
//
//   CHAPTER 15: MAPS & JSON
//   Key-value data structures and serialization
//
// ###############################################################

printHeader(CHAPTER 15: MAPS & JSON)

// ===================================================================
// LESSON 15.1 - CREATING MAPS
// ===================================================================
// Maps store key-value pairs. Create them with map(k1, v1, k2, v2, ...)
// Keys are always strings. Values can be any type.
// ===================================================================

printLesson(Lesson 15.1: Creating Maps)

// Create a simple config map
_setvar(cfg, map(""host"", ""10.0.0.1"", ""port"", 22, ""user"", ""root""))

// Check the type
_setvar(t, typeof_val(_getvar(cfg)))
assert(15.1a map type is map, _getvar(t), map)

// Check length
_setvar(n, map_len(_getvar(cfg)))
assert(15.1b map has 3 keys, _getvar(n), 3)

printTip(Use alternating key-value pairs: mymap = map k1 v1 k2 v2)
printNote(Keys are always converted to strings internally.)

// ===================================================================
// LESSON 15.2 - READING MAP VALUES
// ===================================================================
// map_get(map, key) retrieves a value by its key.
// Returns """" if the key doesn't exist.
// ===================================================================

printLesson(Lesson 15.2: Reading Map Values)

_setvar(h, map_get(_getvar(cfg), ""host""))
assert(15.2a get host, _getvar(h), 10.0.0.1)

_setvar(p, map_get(_getvar(cfg), ""port""))
assert(15.2b get port, _getvar(p), 22)

_setvar(u, map_get(_getvar(cfg), ""user""))
assert(15.2c get user, _getvar(u), root)

printTip(Use map_get to retrieve values by key. Missing keys return empty.)

// ===================================================================
// LESSON 15.3 - MODIFYING MAPS
// ===================================================================
// map_set(map, key, value) adds or updates a key in the map.
// map_del(map, key) removes a key. Both return the modified map.
// ===================================================================

printLesson(Lesson 15.3: Modifying Maps)

// Add a new key
_setvar(cfg, map_set(_getvar(cfg), ""timeout"", 30))
_setvar(n, map_len(_getvar(cfg)))
assert(15.3a set adds key, _getvar(n), 4)

_setvar(tv, map_get(_getvar(cfg), ""timeout""))
assert(15.3b new key value, _getvar(tv), 30)

// Update existing key
_setvar(cfg, map_set(_getvar(cfg), ""port"", 8080))
_setvar(p, map_get(_getvar(cfg), ""port""))
assert(15.3c update existing key, _getvar(p), 8080)

// Delete a key
_setvar(cfg, map_del(_getvar(cfg), ""timeout""))
_setvar(n, map_len(_getvar(cfg)))
assert(15.3d delete shrinks map, _getvar(n), 3)

printTip(map_set returns the modified map - always reassign it!)
printNote(map_del also returns the modified map with the key removed.)

// ===================================================================
// LESSON 15.4 - INSPECTING MAPS
// ===================================================================
// map_has(map, key) checks if a key exists (1 or 0).
// map_keys(map) returns a list of all keys.
// map_values(map) returns a list of all values.
// ===================================================================

printLesson(Lesson 15.4: Inspecting Maps)

_setvar(has_host, map_has(_getvar(cfg), ""host""))
_print   map_has(cfg, ""host"") -> _getvar(has_host)  (key exists)
assert(15.4a has existing key, _getvar(has_host), 1)

_setvar(has_foo, map_has(_getvar(cfg), ""foo""))
_print   map_has(cfg, ""foo"")  -> _getvar(has_foo)  (key missing)
assert(15.4b missing key returns 0, _getvar(has_foo), 0)

_setvar(ks, map_keys(_getvar(cfg)))
_setvar(kl, len(_getvar(ks)))
_print   map_keys(cfg) -> _getvar(ks)  (count: _getvar(kl))
assert(15.4c keys count matches len, _getvar(kl), 3)

_setvar(vs, map_values(_getvar(cfg)))
_setvar(vl, len(_getvar(vs)))
_print   map_values(cfg) -> _getvar(vs)  (count: _getvar(vl))
assert(15.4d values count matches len, _getvar(vl), 3)

printTip(map_has returns 1 or 0 - useful in if conditions.)
printNote(map_keys and map_values return lists you can loop over.)

// ===================================================================
// LESSON 15.5 - MAPS AND FUNCTIONS
// ===================================================================
// Maps can be passed to and returned from functions.
// This lets you build structured data.
// ===================================================================

printLesson(Lesson 15.5: Maps and Functions)

// Function that builds a map from pre-set variables
func makeTarget(myip, myport)
  _setvar(t, map(""ip"", ""placeholder"", ""port"", 0, ""status"", ""unknown""))
  _setvar(t, map_set(_getvar(t), ""ip"", _getvar(myip)))
  _setvar(t, map_set(_getvar(t), ""port"", _getvar(myport)))
  _return _getvar(t)
endfunc

_setvar(target, makeTarget(""192.168.0.5"", 443))
_setvar(tt, typeof_val(_getvar(target)))
assert(15.5a function returns map, _getvar(tt), map)

_setvar(taddr, map_get(_getvar(target), ""ip""))
assert(15.5b returned map ip, _getvar(taddr), 192.168.0.5)

_setvar(tport, map_get(_getvar(target), ""port""))
assert(15.5c returned map port, _getvar(tport), 443)

// Function that updates a map
// Yield before next func block
_sleep 0.01

func markScanned(tgt)
  _setvar(tgt, map_set(_getvar(tgt), ""status"", ""scanned""))
  _return _getvar(tgt)
endfunc

_setvar(target, markScanned(_getvar(target)))
_setvar(st, map_get(_getvar(target), ""status""))
assert(15.5d updated via function, _getvar(st), scanned)

printTip(Functions can build and return maps - great for structured data.)

// ===================================================================
// LESSON 15.6 - JSON SERIALIZATION
// ===================================================================
// json(map) converts a map to a JSON string.
// json_parse(string) converts a JSON string back to a map.
// Round-tripping preserves all keys and values.
// ===================================================================

printLesson(Lesson 15.6: JSON Serialization)

// Create a test map
_setvar(data, map(""name"", ""server1"", ""ip"", ""10.0.0.5"", ""port"", 22))

// Serialize to JSON
_setvar(j, json(_getvar(data)))
_setvar(jt, typeof_val(_getvar(j)))
assert(15.6a json returns string, _getvar(jt), string)
_print <color=#aaaaaa>  JSON output:</color> _getvar(j)

// Parse it back
_setvar(parsed, json_parse(_getvar(j)))
_setvar(pt, typeof_val(_getvar(parsed)))
assert(15.6b json_parse returns map, _getvar(pt), map)

// Verify round-trip preserves values
_setvar(pname, map_get(_getvar(parsed), ""name""))
assert(15.6c round-trip name, _getvar(pname), server1)

_setvar(pip, map_get(_getvar(parsed), ""ip""))
assert(15.6d round-trip ip, _getvar(pip), 10.0.0.5)

_setvar(pport, map_get(_getvar(parsed), ""port""))
assert(15.6e round-trip port, _getvar(pport), 22)

printTip(Use json to serialize a map to string. Use json_parse to deserialize back.)
printNote(Round-tripping preserves all key-value data.)


// ###############################################################
//
//   CHAPTER 16: MAP FILE PERSISTENCE
//   Saving and loading maps to/from disk
//
// ###############################################################

printHeader(CHAPTER 16: MAP FILE PERSISTENCE)

// ===================================================================
// LESSON 16.1 - SAVING MAPS TO FILES
// ===================================================================
// map_save(map, path) serializes a map to JSON and writes it to a file.
// If the file doesn't exist, it will be created automatically.
// Returns 1 on success, 0 on failure.
// ===================================================================

printLesson(Lesson 16.1: Saving Maps to Files)

// Build a config map
_setvar(svr, map(""host"", ""server1"", ""port"", 22, ""user"", ""root""))

// Save it to disk
_setvar(ok, map_save(_getvar(svr), ""learn_bash_test.json""))
assert(16.1a map_save returns 1, _getvar(ok), 1)

// Verify the file was created
_setvar(exists, file_exists(""learn_bash_test.json""))
assert(16.1b file was created, _getvar(exists), 1)

// Read the raw file content to see the JSON
_setvar(raw, file_read(""learn_bash_test.json""))
_print <color=#aaaaaa>  Saved file content:</color> _getvar(raw)

printTip(map_save handles JSON serialization and file creation automatically.)
printNote(Relative paths are resolved from the current working directory.)

// ===================================================================
// LESSON 16.2 - LOADING MAPS FROM FILES
// ===================================================================
// map_load(path) reads a JSON file and parses it back into a map.
// Returns """" if the file doesn't exist or can't be parsed.
// ===================================================================

printLesson(Lesson 16.2: Loading Maps from Files)

// Load the file we just saved
_setvar(loaded, map_load(""learn_bash_test.json""))
_setvar(lt, typeof_val(_getvar(loaded)))
assert(16.2a map_load returns map, _getvar(lt), map)

// Verify the data survived the round-trip
_setvar(lh, map_get(_getvar(loaded), ""host""))
assert(16.2b loaded host matches, _getvar(lh), server1)

_setvar(lp, map_get(_getvar(loaded), ""port""))
assert(16.2c loaded port matches, _getvar(lp), 22)

_setvar(lu, map_get(_getvar(loaded), ""user""))
assert(16.2d loaded user matches, _getvar(lu), root)

_setvar(ll, map_len(_getvar(loaded)))
assert(16.2e loaded map has 3 keys, _getvar(ll), 3)

printTip(map_load reads a JSON file and returns a parsed map.)

// ===================================================================
// LESSON 16.3 - ERROR HANDLING
// ===================================================================
// map_load returns """" for missing files - check before using the value.
// ===================================================================

printLesson(Lesson 16.3: Error Handling)

_setvar(bad, map_load(""no_such_file_xyz.json""))
assert(16.3a missing file returns empty, _getvar(bad), )

// Pattern: Check before using
_setvar(result, map_load(""learn_bash_test.json""))
if typeof_val(_getvar(result)) == map
  _setvar(pass, 1)
else
  _setvar(pass, 0)
endif
assert(16.3b type-check pattern works, _getvar(pass), 1)

printTip(Always check typeof_val before using a map_load result!)
printNote(A missing or corrupt file returns empty string, not a map.)

// ===================================================================
// LESSON 16.4 - PRACTICAL EXAMPLE: CONFIG MANAGER
// ===================================================================
// Combine everything: build a config, save it, load it, modify it,
// save again. This is a real-world pattern for persistent settings.
// ===================================================================

printLesson(Lesson 16.4: Practical Config Manager)

// Step 1: Create initial config
func createConfig(cname, cip, cport)
  _setvar(c, map(""name"", ""tmp"", ""ip"", ""tmp"", ""port"", 0))
  _setvar(c, map_set(_getvar(c), ""name"", _getvar(cname)))
  _setvar(c, map_set(_getvar(c), ""ip"", _getvar(cip)))
  _setvar(c, map_set(_getvar(c), ""port"", _getvar(cport)))
  _setvar(today, date())
  _setvar(c, map_set(_getvar(c), ""created"", _getvar(today)))
  _return _getvar(c)
endfunc

_setvar(cfgname, prod-server)
_setvar(cfgip, 10.0.0.100)
_setvar(myconf, createConfig(_getvar(cfgname), _getvar(cfgip), 443))
_setvar(ct, typeof_val(_getvar(myconf)))
assert(16.4a config is map, _getvar(ct), map)

// Step 2: Save to disk
_setvar(ok, map_save(_getvar(myconf), ""learn_bash_config.json""))
assert(16.4b save config ok, _getvar(ok), 1)

// Step 3: Load it back (simulating a fresh session)
_setvar(restored, map_load(""learn_bash_config.json""))
_setvar(rn, map_get(_getvar(restored), ""name""))
assert(16.4c restored name, _getvar(rn), prod-server)

// Step 4: Modify and re-save
_setvar(restored, map_set(_getvar(restored), ""port"", 8443))
_setvar(ok, map_save(_getvar(restored), ""learn_bash_config.json""))
assert(16.4d re-save ok, _getvar(ok), 1)

// Step 5: Verify the update persisted
_setvar(final, map_load(""learn_bash_config.json""))
_setvar(fp, map_get(_getvar(final), ""port""))
assert(16.4e updated port persisted, _getvar(fp), 8443)

_print <color=#aaaaaa>  Config manager pattern complete - save, load, modify, repeat!</color>

printTip(This save-load-modify-save pattern is how real configs work.)
printNote(You can use this for scan results, target lists, credentials, etc.)

_sleep 0.01

_print
