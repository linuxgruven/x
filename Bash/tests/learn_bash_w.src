printHeader(CHAPTER 4: STRING MASTERY)

// ===================================================================
// LESSON 4.1 - STRING FUNCTIONS OVERVIEW
// ===================================================================

printLesson(Lesson 4.1: String Functions)

// Demonstrate each string builtin
func stringShowcase()
  _setvar(myStr, hello)
  _setvar(myStr2, HELLO)
  _setvar(mySub, ell)
  _setvar(myOld, l)
  _setvar(myNew, rr)
  _setvar(myFoo, foo)
  _setvar(myBar, bar)
  _setvar(res, len(myStr))
  _print <color=#aaaaaa>  len of ""hello"" =</color> _getvar(res)
  _setvar(res, upper(myStr))
  _print <color=#aaaaaa>  upper of ""hello"" =</color> _getvar(res)
  _setvar(res, lower(myStr2))
  _print <color=#aaaaaa>  lower of ""HELLO"" =</color> _getvar(res)
  _setvar(res, substr(_getvar(myStr), 1, 4))
  _print <color=#aaaaaa>  substr ""hello"" 1 4 =</color> _getvar(res)
  _setvar(res, contains(myStr, mySub))
  _print <color=#aaaaaa>  contains ""hello"" ""ell"" =</color> _getvar(res)
  _setvar(res, replace(myStr, myOld, myNew))
  _print <color=#aaaaaa>  replace ""hello"" ""l"" ""rr"" =</color> _getvar(res)
  _setvar(res, trim_str(myStr))
  _print <color=#aaaaaa>  trim_str of ""hello"" =</color> _getvar(res)
  _setvar(res, concat(myFoo, myBar))
  _print <color=#aaaaaa>  concat ""foo"" + ""bar"" =</color> _getvar(res)
endfunc

stringShowcase()

// ===================================================================
// LESSON 4.2 - PRACTICAL STRING FUNCTIONS
// ===================================================================

printLesson(Lesson 4.2: Practical String Functions)

// Check if a string starts with a prefix
func startsWith(str, prefix)
  _setvar(prefixLen, len(_getvar(prefix)))
  _setvar(chunk, substr(_getvar(str), 0, _getvar(prefixLen)))
  if _getvar(chunk) == _getvar(prefix)
    _return 1
  else
    _return 0
  endif
endfunc

_setvar(r, startsWith(/home/tux, /home))
assert(startsWith /home/tux /home = 1, _getvar(r), 1)
_setvar(r, startsWith(/var/log, /home))
assert(startsWith /var/log /home = 0, _getvar(r), 0)

// Reverse a string character by character
func reverseStr(s)
  _setvar(out, )
  _setvar(i, len(_getvar(s)) - 1)
  while _getvar(i) >= 0
    _setvar(ch, substr(_getvar(s), _getvar(i), _getvar(i) + 1))
    _setvar(out, concat(_getvar(out), _getvar(ch)))
    _setvar(i, _getvar(i) - 1)
  endwhile
  _return _getvar(out)
endfunc

_setvar(r, reverseStr(hello))
assert(reverse 'hello' is 'olleh', _getvar(r), olleh)
_setvar(r, reverseStr(abc))
assert(reverse 'abc' is 'cba', _getvar(r), cba)

// Check if a string is a palindrome
func isPalindrome(s)
  _setvar(rev, reverseStr(_getvar(s)))
  if _getvar(s) == _getvar(rev)
    _return 1
  else
    _return 0
  endif
endfunc

_setvar(r, isPalindrome(elle))
assert(elle is palindrome, _getvar(r), 1)
_setvar(r, isPalindrome(hello))
assert(hello is not palindrome, _getvar(r), 0)

// Repeat a string N times
func repeatStr(s, n)
  _setvar(out, )
  _setvar(i, 0)
  while _getvar(i) < _getvar(n)
    _setvar(out, concat(_getvar(out), _getvar(s)))
    _setvar(i, _getvar(i) + 1)
  endwhile
  _return _getvar(out)
endfunc

_setvar(r, repeatStr(ab, 4))
assert(repeat 'ab' 4 times is 'abababab', _getvar(r), abababab)

// Build a simple progress bar
func progressBar(current, total, width)
  _setvar(filled, _getvar(current) * _getvar(width) / _getvar(total))
  _setvar(filled, floor(_getvar(filled)))
  _setvar(bar, repeatStr(#, _getvar(filled)))
  _return _getvar(bar)
endfunc

_setvar(r, progressBar(7, 10, 20))
_print <color=#aaaaaa>  Progress 7/10:</color> _getvar(r)

_setvar(r, progressBar(3, 10, 20))
_print <color=#aaaaaa>  Progress 3/10:</color> _getvar(r)

printTip(Build complex output by combining concat and string functions.)

// ===================================================================
// LESSON 4.3 - SPLIT AND JOIN
// ===================================================================
// split_str breaks a string into a list.
// join combines a list back into a string.
// ===================================================================

printLesson(Lesson 4.3: split_str and join)

// Split a delimited string into parts
func splitByDash(text)
  _setvar(parts, split_str(_getvar(text), -))
  _return _getvar(parts)
endfunc

_setvar(parts, splitByDash(home-tux-files))
_setvar(r, len(_getvar(parts)))
assert(splitting home-tux-files gives 3 parts, _getvar(r), 3)

// Join with a custom separator
func formatList(items, separator)
  _return join(_getvar(items), _getvar(separator))
endfunc

_setvar(colors, [red, green, blue])
_setvar(r, formatList(_getvar(colors), -))
_print <color=#aaaaaa>  Joined with dash:</color> _getvar(r)
assert(join with dash gives red-green-blue, _getvar(r), red-green-blue)

_setvar(nums, [1, 2, 3, 4])
_setvar(r, formatList(_getvar(nums), :))
_print <color=#aaaaaa>  Joined with colon:</color> _getvar(r)

printTip(split_str and join are inverses - one splits a string and the other joins a list.)

