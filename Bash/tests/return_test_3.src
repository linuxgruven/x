// get_user returns a non-empty string
_setvar(r, get_user())
_setvar(check, len(_getvar(r)))
if _getvar(check) > 0
  _setvar(pass, 1)
else
  _setvar(pass, 0)
endif
assert(get_user returns non-empty string, _getvar(pass), 1)

// get_home returns a non-empty path
