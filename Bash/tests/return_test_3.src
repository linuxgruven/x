if _getvar(check) > 0
  _setvar(pass, 1)
else
  _setvar(pass, 0)
endif
assert(get_shell_type returns non-empty, _getvar(pass), 1)

// _fs_pwd returns a path
_setvar(r, _fs_pwd)
