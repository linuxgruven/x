// Return Test Part 2 - Sections 6-10

func assert(label, actual, expected)
  if _getvar(actual) == _getvar(expected)
    _print <color=#00ff00>[PASS]</color> _getvar(label)
  else
    _print <color=#ff0000>[FAIL]</color> _getvar(label) <color=#ffff00> expected:</color>_getvar(expected) <color=#ffff00> got:</color>_getvar(actual)
  endif
endfunc

_print
_print <color=#eb0cc6>============================================</color>
_print <color=#eb0cc6>     RETURN TESTS PART 2 (Sections 6-10)</color>
_print <color=#eb0cc6>============================================</color>
_print

// ===================================================================
// SECTION 6 - ARITHMETIC EXPRESSIONS
// ===================================================================
_print <color=#00bfff>--- Section 6: Arithmetic Expressions ---</color>

// Addition
_setvar(r, 7 + 3)
assert(7 + 3 is 10, _getvar(r), 10)

// Subtraction
_setvar(r, 10 - 4)
assert(10 - 4 is 6, _getvar(r), 6)

// Multiplication
_setvar(r, 6 * 7)
assert(6 * 7 is 42, _getvar(r), 42)

// Division
_setvar(r, 20 / 4)
assert(20 / 4 is 5, _getvar(r), 5)

// Modulo
_setvar(r, 17 % 5)
assert(17 mod 5 is 2, _getvar(r), 2)

// Power
_setvar(r, 2 ** 8)
assert(2 ** 8 is 256, _getvar(r), 256)

// Negative result
_setvar(r, 3 - 10)
assert(3 - 10 is -7, _getvar(r), -7)

// Zero
_setvar(r, 5 - 5)
assert(5 - 5 is 0, _getvar(r), 0)

// Compound expression
_setvar(a, 10)
_setvar(b, 3)
_setvar(r, _getvar(a) + _getvar(b) * 2)
assert(10 + 3*2 is 16, _getvar(r), 16)

// Nested function in arithmetic
_setvar(r, len(hello) + len(world))
assert(len hello + len world is 10, _getvar(r), 10)

// len in arithmetic subtraction
_setvar(r, len(hello) - 2)
assert(len hello minus 2 is 3, _getvar(r), 3)

_print

// ===================================================================
// SECTION 7 - COMPARISON OPERATORS
// ===================================================================
_print <color=#00bfff>--- Section 7: Comparison Operators ---</color>

// Equal - true
_setvar(r, 0)
if 5 == 5
  _setvar(r, 1)
endif
assert(5 == 5 is true, _getvar(r), 1)

// Equal - false
_setvar(r, 0)
if 5 == 6
  _setvar(r, 1)
endif
assert(5 == 6 is false, _getvar(r), 0)

// Not equal - true
_setvar(r, 0)
if 5 != 6
  _setvar(r, 1)
endif
assert(5 != 6 is true, _getvar(r), 1)

// Not equal - false
_setvar(r, 0)
if 5 != 5
  _setvar(r, 1)
endif
assert(5 != 5 is false, _getvar(r), 0)

// Greater than
_setvar(r, 0)
if 10 > 5
  _setvar(r, 1)
endif
assert(10 > 5 is true, _getvar(r), 1)

// Less than
_setvar(r, 0)
if 3 < 7
  _setvar(r, 1)
endif
assert(3 < 7 is true, _getvar(r), 1)

// Greater or equal - equal
_setvar(r, 0)
if 5 >= 5
  _setvar(r, 1)
endif
assert(5 >= 5 is true, _getvar(r), 1)

// Greater or equal - greater
_setvar(r, 0)
if 6 >= 5
  _setvar(r, 1)
endif
assert(6 >= 5 is true, _getvar(r), 1)

// Less or equal - equal
_setvar(r, 0)
if 5 <= 5
  _setvar(r, 1)
endif
assert(5 <= 5 is true, _getvar(r), 1)

// Less or equal - less
_setvar(r, 0)
if 4 <= 5
  _setvar(r, 1)
endif
assert(4 <= 5 is true, _getvar(r), 1)

// String equality
_setvar(r, 0)
if hello == hello
  _setvar(r, 1)
endif
assert(string hello == hello is true, _getvar(r), 1)

// String inequality
_setvar(r, 0)
if hello != world
  _setvar(r, 1)
endif
assert(string hello != world is true, _getvar(r), 1)

_print

// ===================================================================
// SECTION 8 - FUNCTION RETURN VALUES
// ===================================================================
_print <color=#00bfff>--- Section 8: Function Return Values ---</color>

// Return number
func retNum()
  _return 42
endfunc
_setvar(r, retNum())
assert(func returns number 42, _getvar(r), 42)

// Return string
func retStr()
  _return hello
endfunc
_setvar(r, retStr())
assert(func returns string hello, _getvar(r), hello)

// Return computed value
func compute(a, b)
  _return _getvar(a) * _getvar(b) + 1
endfunc
_setvar(r, compute(3, 4))
assert(func 3*4+1 returns 13, _getvar(r), 13)

// Return from conditional
func ternary(cond)
  if _getvar(cond) == 1
    _return yes
  else
    _return no
  endif
endfunc
_setvar(r, ternary(1))
assert(ternary 1 returns yes, _getvar(r), yes)
_setvar(r, ternary(0))
assert(ternary 0 returns no, _getvar(r), no)

// Return from loop
func firstPositive(list)
  for item in _getvar(list)
    if _getvar(item) > 0
      _return _getvar(item)
    endif
  endfor
  _return -1
endfunc
_setvar(r, firstPositive([-3, -1, 5, 2]))
assert(firstPositive finds 5, _getvar(r), 5)
_setvar(r, firstPositive([-3, -1, -2]))
assert(firstPositive all neg returns -1, _getvar(r), -1)

// Nested function calls as return
func addOne(n)
  _return _getvar(n) + 1
endfunc
func addTwo(n)
  _return addOne(addOne(_getvar(n)))
endfunc
_setvar(r, addTwo(5))
assert(nested addTwo 5 returns 7, _getvar(r), 7)

// Recursive function return
func factorial(n)
  if _getvar(n) <= 1
    _return 1
  else
    _setvar(sub, factorial(_getvar(n) - 1))
    _return _getvar(n) * _getvar(sub)
  endif
endfunc
_setvar(r, factorial(5))
assert(factorial 5 is 120, _getvar(r), 120)

_print

// ===================================================================
// SECTION 9 - LOOP CONSTRUCTS RETURN/ACCUMULATE
// ===================================================================
_print <color=#00bfff>--- Section 9: Loop Accumulation ---</color>

// for loop accumulation
_setvar(sum, 0)
for i in range(1, 5)
  _setvar(sum, _getvar(sum) + _getvar(i))
endfor
assert(for 1 to 5 sums to 15, _getvar(sum), 15)

// for loop over list
_setvar(result, )
for item in [xx, yy, zz]
  _setvar(result, concat(_getvar(result), _getvar(item)))
endfor
assert(for over list concats xxyyzz, _getvar(result), xxyyzz)

// while loop countdown
_setvar(n, 5)
_setvar(count, 0)
while _getvar(n) > 0
  _setvar(count, _getvar(count) + 1)
  _setvar(n, _getvar(n) - 1)
endwhile
assert(while counts down 5 iterations, _getvar(count), 5)

// while with break
_setvar(i, 0)
while _getvar(i) < 100
  if _getvar(i) == 3
    break
  endif
  _setvar(i, _getvar(i) + 1)
endwhile
assert(while breaks at 3, _getvar(i), 3)

// for with continue
_setvar(sum, 0)
for i in range(1, 5)
  if _getvar(i) == 3
    continue
  endif
  _setvar(sum, _getvar(sum) + _getvar(i))
endfor
assert(for skips 3 sums 1+2+4+5=12, _getvar(sum), 12)

// until loop
_setvar(n, 0)
until _getvar(n) == 3
  _setvar(n, _getvar(n) + 1)
enduntil
assert(until counts to 3, _getvar(n), 3)

_print

// ===================================================================
// SECTION 10 - CONDITIONAL RETURNS
// ===================================================================
_print <color=#00bfff>--- Section 10: Conditional Returns ---</color>

// if true branch
_setvar(r, miss)
if 1 == 1
  _setvar(r, true_branch)
else
  _setvar(r, false_branch)
endif
assert(if true takes true branch, _getvar(r), true_branch)

// if false branch
_setvar(r, miss)
if 1 == 2
  _setvar(r, true_branch)
else
  _setvar(r, false_branch)
endif
assert(if false takes false branch, _getvar(r), false_branch)

// elif chain
_setvar(val, 2)
_setvar(r, miss)
if _getvar(val) == 1
  _setvar(r, one)
elif _getvar(val) == 2
  _setvar(r, two)
elif _getvar(val) == 3
  _setvar(r, three)
else
  _setvar(r, other)
endif
assert(elif chain picks two, _getvar(r), two)

// elif falls through to else
_setvar(val, 99)
_setvar(r, miss)
if _getvar(val) == 1
  _setvar(r, one)
elif _getvar(val) == 2
  _setvar(r, two)
else
  _setvar(r, other)
endif
assert(elif fallthrough to else, _getvar(r), other)

_print

