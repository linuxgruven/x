print "<color=#20ff98>Installing X's bash test scripts...</color>"
import_code("./learn_bash_w.src")
import_code("./bash_map_test_w.src")
import_code("./return_test_w.src")
import_code("./func_test_w.src")
import_code("./cast_test_w.src")
import_code("./edge_test_w.src")
import_code("./switch_test_w.src")
import_code("./stress_test_w.src")
import_code("./bash_pipe_test_w.src")
import_code("./find_pipe_test_w.src")
import_code("./bash_try_catch_w.src")
import_code("./builtin_vars_test_w.src")
import_code("./menu_test_w.src")
import_code("./bounce_test_w.src")
import_code("./lan_test_w.src")
import_code("./local_test_w.src")
import_code("./scan_test_w.src")
import_code("./shell_test_w.src")
import_code("./wifi_test_w.src")
import_code("./fmon_w.src")
import_code("./dmon_w.src")
// Get computer and setup directory
c=host_computer(get_shell)
home=File(c,home_dir)
if not home then exit("<color=red>Unable to access home directory</color>")
_findAll=function(dir,fName,results)
  for sub in get_folders(dir)
    if name(sub)==fName then push(results,sub)
    _findAll(sub,fName,results)
  end for
end function
payloadDir=File(c,home_dir+"/payload")
if not payloadDir then
  print "<color=#ffff00>Locating payload...</color>"
  _found=[]
  _findAll(File(c,"/"),"payload",_found)
  if not _found then exit("<color=red>payload folder not found. Please run X at least once to set up X's file structure.</color>")
  if len(_found)==1 then
    payloadDir=_found[0]
    print "<color=#20ff98>Found payload at: "+path(payloadDir)+"</color>"
  else
    print "<color=#ffff00>Multiple payload folders found:</color>"
    _i=0
    _len=len(_found)
    while _i<_len
      print "<color=#ffffff>  ["+(_i+1)+"] "+path(_found[_i])+"</color>"
      _i=_i+1
    end while
    print "<color=#ffffff>  [0] Cancel</color>"
    _choice=to_int(user_input("<color=#87ceeb>Select payload (0 to cancel, 1-"+_len+"): </color>"))
    if _choice==0 then exit("<color=#ffff00>Cancelled.</color>")
    if _choice<1 or _choice>_len then exit("<color=red>Invalid selection.</color>")
    payloadDir=_found[_choice-1]
    print "<color=#20ff98>Using payload at: "+path(payloadDir)+"</color>"
  end if
end if
payload=path(payloadDir)
bashDir=File(c,payload+"/data/bash")
if not bashDir then exit("<color=red>payload/data/bash not found. Please run X at least once.</color>")
p=path(bashDir)
print("<color=#20ff98>Installing test scripts to "+p+"</color>")
// Install each test script
touch(c,p,"learn_bash")
f=File(c,p+"/learn_bash")
set_content(f,testLearnBash)
print "<color=#aaaaaa>  Installed learn_bash</color>"
touch(c,p,"bash_map_test")
