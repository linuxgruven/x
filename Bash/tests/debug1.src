endfunc
helloWorld()

// -- CH1: Variables --
func variableBasics()
  _setvar(name, tux)
  _print <color=#aaaaaa>  name =</color> _getvar(name)
  _setvar(level, 42)
  _print <color=#aaaaaa>  level =</color> _getvar(level)
endfunc
variableBasics()

// -- CH1: Arithmetic --
func arithmeticDemo()
  _setvar(a, 10)
  _setvar(b, 3)
  _setvar(sum, _getvar(a) + _getvar(b))
  assert(10+3 is 13, _getvar(sum), 13)
  _setvar(r, 2 ** 10)
  assert(2pow10 is 1024, _getvar(r), 1024)
endfunc
arithmeticDemo()

// -- CH1: Lists --
func listDemo()
  _setvar(fruits, [apple, banana, cherry])
  _setvar(r, len(_getvar(fruits)))
  assert(list has 3 items, _getvar(r), 3)
  _push fruits date
  _setvar(r, len(_getvar(fruits)))
  assert(after push has 4, _getvar(r), 4)
endfunc
listDemo()

_print <color=#eb0cc6>=== CHAPTER 1 DONE ===</color>

// -- CH2: Functions --
_print <color=#eb0cc6>=== CHAPTER 2 START ===</color>
func add(a, b)
  _return _getvar(a) + _getvar(b)
endfunc
_setvar(r, add(3, 4))
assert(add 3+4 = 7, _getvar(r), 7)

func greet(who)
  _return Hello _getvar(who)
endfunc
_setvar(r, greet(tux))
assert(greet returns string, _getvar(r), Hello tux)

// Void function
func doNothing()
  _setvar(x, 1)
endfunc
_setvar(r, doNothing())
assert(void returns empty, _getvar(r), )

// Recursion
func factorial(n)
  if _getvar(n) <= 1
    _return 1
  endif
  _setvar(prev, factorial(_getvar(n) - 1))
  _return _getvar(n) * _getvar(prev)
endfunc
_setvar(r, factorial(5))
assert(5! = 120, _getvar(r), 120)

_print <color=#eb0cc6>=== CHAPTER 2 DONE ===</color>

// -- CH3: Control Flow --
_print <color=#eb0cc6>=== CHAPTER 3 START ===</color>
func testIf(x)
  if _getvar(x) > 0
    _return positive
  else if _getvar(x) < 0
    _return negative
  else
    _return zero
  endif
endfunc
_setvar(r, testIf(5))
assert(5 is positive, _getvar(r), positive)

func countTo(n)
  _setvar(sum, 0)
  for i in range(1, _getvar(n))
    _setvar(sum, _getvar(sum) + _getvar(i))
  endfor
  _return _getvar(sum)
endfunc
_setvar(r, countTo(10))
assert(sum 1..10 is 55, _getvar(r), 55)

func whileCount(n)
  _setvar(i, 0)
  while _getvar(i) < _getvar(n)
    _setvar(i, _getvar(i) + 1)
  endwhile
  _return _getvar(i)
endfunc
_setvar(r, whileCount(5))
assert(while counts to 5, _getvar(r), 5)

_print <color=#eb0cc6>=== CHAPTER 3 DONE ===</color>
