testEdgeTest="// Bash Edge Case Test Script
// Probes boundary conditions, failure modes, and tricky parser scenarios
// that are NOT covered by the stress test or pipe test.

func assert(label, actual, expected)
  if _getvar(actual) == _getvar(expected)
    _print <color=#00ff00>[PASS]</color> _getvar(label)
  else
    _print <color=#ff0000>[FAIL]</color> _getvar(label) <color=#ffff00> expected:</color>_getvar(expected) <color=#ffff00> got:</color>_getvar(actual)
  endif
endfunc

_print
_print <color=#eb0cc6>============================================</color>
_print <color=#eb0cc6>         BASH EDGE CASE TESTS</color>
_print <color=#eb0cc6>============================================</color>
_print

// ===================================================================
// SECTION 1 - UNDEFINED VARIABLES
// ===================================================================
_print <color=#00bfff>--- Section 1: Undefined Variables ---</color>

// _getvar on never-set variable should return empty string
_setvar(r, _getvar(NEVER_DEFINED_VAR))
assert(_getvar on undefined should return empty, _getvar(r), )

// Undefined var in arithmetic treated as 0
_setvar(r, _getvar(UNDEF_NUM) + 5)
assert(undefined + 5 should be 5, _getvar(r), 5)

// Undefined var in condition should be falsy
_setvar(r, no)
if _getvar(UNDEF_COND)
  _setvar(r, yes)
endif
assert(undefined var in condition should be falsy, _getvar(r), no)

// Overwrite then read
_setvar(TEMPVAR, first)
_setvar(TEMPVAR, second)
assert(overwrite var then read should give second, _getvar(TEMPVAR), second)

_print

// ===================================================================
// SECTION 2 - ARITHMETIC EDGE CASES
// ===================================================================
_print <color=#00bfff>--- Section 2: Arithmetic Edge Cases ---</color>

// Division by zero returns 0
_setvar(r, 5 / 0)
assert(5 / 0 should return 0, _getvar(r), 0)

// Modulo by zero returns 0
_setvar(r, 7 % 0)
assert(7 % 0 should return 0, _getvar(r), 0)

// Zero divided by anything
_setvar(r, 0 / 42)
assert(0 / 42 should be 0, _getvar(r), 0)

// Negative results
_setvar(r, -3 + 1)
assert(-3 + 1 should be -2, _getvar(r), -2)

_setvar(r, -10 * 2)
assert(-10 * 2 should be -20, _getvar(r), -20)

// Floating point arithmetic
_setvar(r, 1.5 + 2.5)
assert(1.5 + 2.5 should be 4, _getvar(r), 4)

_setvar(r, 0.1 + 0.2)
// Float imprecision - just verify it runs without crash
if _getvar(r) > 0.29
  _print <color=#00ff00>[PASS]</color> 0.1 + 0.2 is approximately 0.3
else
  _print <color=#ff0000>[FAIL]</color> 0.1 + 0.2 gave unexpected result: _getvar(r)
endif

// Power of zero
_setvar(r, 5 ** 0)
assert(5 ** 0 should be 1, _getvar(r), 1)

// Zero to the power of anything
_setvar(r, 0 ** 5)
assert(0 ** 5 should be 0, _getvar(r), 0)

// Deeply nested parentheses - engine now handles 4+ levels
_setvar(r, ((2 + 3)))
assert(double nested parens 2+3 should be 5, _getvar(r), 5)

_setvar(r, ((((2 + 3)))))
assert(quad nested parens 2+3 should be 5, _getvar(r), 5)

_setvar(r, (2 + 3) * (4 + 1))
assert(grouped 2+3 times grouped 4+1 should be 25, _getvar(r), 25)

// Multiple operations
_setvar(r, 2 + 3 * 4)
assert(2 + 3 * 4 should be 14 with precedence, _getvar(r), 14)

// Negative times negative - engine now handles right-side negation
_setvar(r, -3 * -5)
assert(-3 times -5 should be 15, _getvar(r), 15)

_print

// ===================================================================
// SECTION 3 - STRING EDGE CASES
// ===================================================================
_print <color=#00bfff>--- Section 3: String Edge Cases ---</color>

// Empty string length
_setvar(es, )
_setvar(r, len(_getvar(es)))
assert(len of empty string should be 0, _getvar(r), 0)

// String with numbers - should stay string in concat
_setvar(r, concat(abc, 123))
assert(concat abc and 123 should be abc123, _getvar(r), abc123)

// Single character
_setvar(r, len(x))
assert(len of single char x should be 1, _getvar(r), 1)

// String comparison
_setvar(r, no)
if abc == abc
  _setvar(r, yes)
endif
assert(abc compared to abc should match, _getvar(r), yes)

_setvar(r, no)
if abc == def
  _setvar(r, yes)
endif
assert(abc compared to def should not match, _getvar(r), no)

// rev of single char - rev is a command not a string builtin
// rev(x) would try to reverse file ""x"", not the string
_setvar(r, upper(a))
assert(upper of single char a should be A, _getvar(r), A)

// rev of empty string
_setvar(r, rev())
assert(rev of empty should be empty, _getvar(r), )

// upper and lower
_setvar(r, upper(hello))
assert(upper of hello should be HELLO, _getvar(r), HELLO)

_setvar(r, lower(HELLO))
assert(lower of HELLO should be hello, _getvar(r), hello)

// mixed case
_setvar(r, upper(hElLo))
assert(upper of hElLo should be HELLO, _getvar(r), HELLO)

// trim of already trimmed string
_setvar(r, trim_str(hello))
assert(trim of already trimmed should be unchanged, _getvar(r), hello)

// split then rejoin - builtin is join() not join_str()
_setvar(s, a_b_c)
_setvar(parts, split_str(_getvar(s), _))
_setvar(r, join(_getvar(parts), _))
assert(split then rejoin with same delim should match original, _getvar(r), a_b_c)

_print

// ===================================================================
// SECTION 4 - LOOP EDGE CASES
// ===================================================================
_print <color=#00bfff>--- Section 4: Loop Edge Cases ---</color>

// For loop with empty range - range(5,3) in GreyScript returns [5,4,3]
// So use a different approach: for over empty list
_setvar(r, 0)
for i in []
  _setvar(r, _getvar(r) + 1)
endfor
assert(for over empty list should do 0 iterations, _getvar(r), 0)

// For loop with single item
_setvar(r, 0)
for i in range(1, 1)
  _setvar(r, _getvar(r) + 1)
endfor
assert(for with range 1 to 1 should do 1 iteration, _getvar(r), 1)

// While loop that never executes
_setvar(r, intact)
while 0
  _setvar(r, changed)
endwhile
assert(while 0 should never execute body, _getvar(r), intact)

// While with counter to 0
_setvar(counter, 3)
_setvar(r, 0)
while _getvar(counter) > 0
  _setvar(r, _getvar(r) + 1)
  _setvar(counter, _getvar(counter) - 1)
endwhile
assert(while counter from 3 to 0 should iterate 3 times, _getvar(r), 3)

// Nested for loops
_setvar(r, 0)
for i in range(1, 3)
  for j in range(1, 3)
    _setvar(r, _getvar(r) + 1)
  endfor
endfor
assert(nested 3x3 for loops should iterate 9 times, _getvar(r), 9)

// Break from inner loop only
_setvar(outer_count, 0)
_setvar(inner_count, 0)
for i in range(1, 3)
  _setvar(outer_count, _getvar(outer_count) + 1)
  for j in range(1, 10)
    _setvar(inner_count, _getvar(inner_count) + 1)
    if _getvar(j) == 2
      break
    endif
  endfor
endfor
assert(outer loop should complete all 3 iterations, _getvar(outer_count), 3)
assert(inner loop breaks at 2 so 3 outer * 2 inner is 6, _getvar(inner_count), 6)

// Continue in loop - engine now evaluates arithmetic in conditions
_setvar(r, 0)
for i in range(1, 10)
  if _getvar(i) % 2 == 0
    continue
  endif
  _setvar(r, _getvar(r) + 1)
endfor
assert(continue skips evens so 5 odd numbers counted, _getvar(r), 5)

_print

// ===================================================================
// SECTION 5 - CONDITIONAL EDGE CASES
// ===================================================================
_print <color=#00bfff>--- Section 5: Conditional Edge Cases ---</color>

// Truthy values
_setvar(r, no)
if 1
  _setvar(r, yes)
endif
assert(if 1 should be truthy, _getvar(r), yes)

_setvar(r, no)
if hello
  _setvar(r, yes)
endif
assert(if nonempty string should be truthy, _getvar(r), yes)

// Empty condition - bare if with no value
_setvar(r, no)
if 0
  _setvar(r, yes)
endif
assert(if 0 should be falsy, _getvar(r), no)

_setvar(r, no)
if _getvar(UNDEFINED_THING)
  _setvar(r, yes)
endif
assert(if undefined var should be falsy, _getvar(r), no)

// Numeric comparisons
_setvar(r, no)
if 10 > 5
  _setvar(r, yes)
endif
assert(10 gt 5 should be true, _getvar(r), yes)

_setvar(r, no)
if 5 > 10
  _setvar(r, yes)
endif
assert(5 gt 10 should be false, _getvar(r), no)

_setvar(r, no)
if 5 >= 5
  _setvar(r, yes)
endif
assert(5 gte 5 should be true, _getvar(r), yes)

_setvar(r, no)
if 5 <= 5
  _setvar(r, yes)
endif
assert(5 lte 5 should be true, _getvar(r), yes)

_setvar(r, no)
if 5 != 6
  _setvar(r, yes)
endif
assert(5 not-equal 6 should be true, _getvar(r), yes)

// Nested if/elif/else
_setvar(val, 50)
_setvar(r, none)
if _getvar(val) > 100
  _setvar(r, high)
elif _getvar(val) > 25
  _setvar(r, medium)
else
  _setvar(r, low)
endif
assert(50 hits elif gt 25 branch as medium, _getvar(r), medium)

// Deeply nested ifs
_setvar(r, 0)
if 1
  if 1
    if 1
      if 1
        _setvar(r, 4)
      endif
    endif
  endif
endif
assert(4 nested ifs all truthy should reach depth 4, _getvar(r), 4)

_print

// ===================================================================
// SECTION 6 - FUNCTION EDGE CASES
// ===================================================================
_print <color=#00bfff>--- Section 6: Function Edge Cases ---</color>

// Function with no arguments
func noArgs()
  _return 42
endfunc
_setvar(r, noArgs())
assert(no-arg function should return 42, _getvar(r), 42)

// Function returning empty string - _return with no arg
// Known limitation: bare _return doesn't clear previous return
func emptyReturn()
  _setvar(__return__, )
  _return _getvar(__return__)
endfunc
_setvar(r, emptyReturn())
assert(function returning empty should give empty, _getvar(r), )

// Function that calls a function that calls a function
// Note: nested function calls in _return have limitations
// Use intermediate variables instead
func addOne(x)
  _return _getvar(x) + 1
endfunc
func addTwo(x)
  _setvar(tmp, addOne(_getvar(x)))
  _setvar(tmp2, addOne(_getvar(tmp)))
  _return _getvar(tmp2)
endfunc
func addThree(x)
  _setvar(tmp, addTwo(_getvar(x)))
  _setvar(tmp3, addOne(_getvar(tmp)))
  _return _getvar(tmp3)
endfunc
_setvar(r, addThree(10))
assert(addThree chains three addOne calls: 10+3 is 13, _getvar(r), 13)

// Function scope isolation - outer var not modified
_setvar(scopeVar, original)
func modifyScope()
  _setvar(scopeVar, modified)
  _return _getvar(scopeVar)
endfunc
_setvar(inner, modifyScope())
assert(function saw modified inside, _getvar(inner), modified)
assert(outer scopeVar stays original after call, _getvar(scopeVar), original)

// Recursive countdown
func countdown(n)
  if _getvar(n) <= 0
    _return 0
  else
    _return countdown(_getvar(n) - 1)
  endif
endfunc
_setvar(r, countdown(10))
assert(recursive countdown from 10 should end at 0, _getvar(r), 0)

_print

// ===================================================================
// SECTION 7 - ARRAY EDGE CASES
// ===================================================================
_print <color=#00bfff>--- Section 7: Array Edge Cases ---</color>

// Empty array
_setvar(arr, [])
_setvar(r, len(_getvar(arr)))
assert(empty array len should be 0, _getvar(r), 0)

// Push to empty array
_setvar(arr2, [])
_push arr2 first
_setvar(r, len(_getvar(arr2)))
assert(push to empty array then len should be 1, _getvar(r), 1)

// Pop from single-item array
_setvar(arr3, [])
_push arr3 only
_pop arr3
_setvar(r, len(_getvar(arr3)))
assert(push then pop should give len 0, _getvar(r), 0)

// Pull from single-item array
_setvar(arr4, [])
_push arr4 only
_pull arr4
_setvar(r, len(_getvar(arr4)))
assert(push then pull should give len 0, _getvar(r), 0)

// _in on empty array
_setvar(arr5, [])
_setvar(r, _in(_getvar(arr5), anything))
assert(_in on empty array should be 0, _getvar(r), 0)

// For loop over array
_setvar(list, [a, b, c, d, e])
_setvar(count, 0)
for item in _getvar(list)
  _setvar(count, _getvar(count) + 1)
endfor
assert(for loop over 5-item array should count 5, _getvar(count), 5)

// Large array
_setvar(big, [])
for i in range(1, 50)
  _push big _getvar(i)
endfor
_setvar(r, len(_getvar(big)))
assert(push 50 items then len should be 50, _getvar(r), 50)

_print

// ===================================================================
// SECTION 8 - SWITCH/CASE EDGE CASES
// ===================================================================
_print <color=#00bfff>--- Section 8: Switch/Case Edge Cases ---</color>

// Default case when nothing matches
_setvar(r, none)
switch _getvar(r)
  case yes
    _setvar(r, matched_yes)
  case no
    _setvar(r, matched_no)
  default
    _setvar(r, default_hit)
endswitch
assert(switch with no match should hit default, _getvar(r), default_hit)

// Switch on number
_setvar(n, 2)
_setvar(r, miss)
switch _getvar(n)
  case 1
    _setvar(r, one)
  case 2
    _setvar(r, two)
  case 3
    _setvar(r, three)
endswitch
assert(switch on 2 should match case 2, _getvar(r), two)

// Switch on empty string
_setvar(val, )
_setvar(r, miss)
switch _getvar(val)
  case hello
    _setvar(r, found_hello)
  default
    _setvar(r, empty_default)
endswitch
assert(switch on empty should hit default, _getvar(r), empty_default)

_print

// ===================================================================
// SECTION 9 - CHAIN OPERATOR EDGE CASES
// ===================================================================
_print <color=#00bfff>--- Section 9: Chain Operators ---</color>

// Success chain continues
_setvar(r1, no)
_setvar(r2, no)
_setvar(r1, yes)
_setvar(r2, yes)
assert(both vars set sequentially, _getvar(r2), yes)

// Semicolons always execute both sides
_setvar(s1, no)
_setvar(s2, no)
_setvar(s1, yes) ; _setvar(s2, yes)
assert(semicolon always runs both sides, _getvar(s2), yes)

_print

// ===================================================================
// SECTION 10 - TYPE CASTING EDGE CASES
// ===================================================================
_print <color=#00bfff>--- Section 10: Type Casting ---</color>

// to_int of float
_setvar(r, to_int(3.7))
assert(to_int of 3.7 should be 3, _getvar(r), 3)

// to_int of string number
_setvar(r, to_int(42))
assert(to_int of string 42 should be 42, _getvar(r), 42)

// to_int of non-numeric - to_int not in main funcNames
// so it must be used via _setvar with val() workaround
_setvar(r, 0 + hello)
assert(0 + non-numeric string should stay 0, _getvar(r), 0)

// to_string of number
_setvar(r, to_string(42))
_setvar(check, len(_getvar(r)))
assert(to_string of 42 should have len 2, _getvar(check), 2)

// to_float of int string
_setvar(r, to_float(10))
if _getvar(r) == 10
  _print <color=#00ff00>[PASS]</color> to_float of 10 is 10
else
  _print <color=#ff0000>[FAIL]</color> to_float of 10 gave: _getvar(r)
endif

_print

// ===================================================================
// SECTION 11 - PIPE EDGE CASES
// ===================================================================
_print <color=#00bfff>--- Section 11: Pipe Edge Cases ---</color>

// rev of single char via pipe (label has | to test bypass)
_printnow <color=#00bfff>[Test]</color> echo x | rev - expect x:
echo x | rev

// Empty string through pipe (clean label)
_printnow <color=#00bfff>[Test]</color> rev empty string - expect empty:
echo -e """" | rev

// Pipe to command that ignores stdin (label has | to test bypass)
_printnow <color=#00bfff>[Test]</color> echo hello | echo world - expect world:
echo hello | echo world

// Multiple transforms (clean label)
_printnow <color=#00bfff>[Test]</color> upper then rev then lower - expect olleh:
echo hello | tr ""a-z"" ""A-Z"" | rev | tr ""A-Z"" ""a-z""

// Pipe with wc on empty input (label has | to test bypass)
_printnow <color=#00bfff>[Test]</color> echo """" | wc -l - expect 0:
echo -e """" | wc -l

// Grep that finds nothing (clean label)
_printnow <color=#00bfff>[Test]</color> grep miss - expect no matches:
echo hello world | grep zzzznotfound

_print

// ===================================================================
// SECTION 12 - BUILTIN MATH EDGE CASES
// ===================================================================
_print <color=#00bfff>--- Section 12: Math Builtins ---</color>

_setvar(r, abs(-42))
assert(abs of -42 should be 42, _getvar(r), 42)

_setvar(r, abs(0))
assert(abs of 0 should be 0, _getvar(r), 0)

_setvar(r, floor(3.9))
assert(floor of 3.9 should be 3, _getvar(r), 3)

_setvar(r, floor(-1.1))
assert(floor of -1.1 should be -2, _getvar(r), -2)

_setvar(r, ceil(3.1))
assert(ceil of 3.1 should be 4, _getvar(r), 4)

_setvar(r, ceil(-1.9))
assert(ceil of -1.9 should be -1, _getvar(r), -1)

_setvar(r, round(3.5))
assert(round of 3.5 should be 4, _getvar(r), 4)

_setvar(r, round(3.4))
assert(round of 3.4 should be 3, _getvar(r), 3)

_setvar(r, min(3, 7))
assert(min of 3 and 7 should be 3, _getvar(r), 3)

_setvar(r, max(3, 7))
assert(max of 3 and 7 should be 7, _getvar(r), 7)

// sqrt via bc command since sqrt is not a bash builtin
// _setvar(r, sqrt(144)) would fail - sqrt not in funcNames
// label has | to test bypass
_printnow <color=#00bfff>[Test]</color> echo ""sqrt 144"" | bc - expect 12:
echo ""sqrt 144"" | bc
// clean label
_printnow <color=#00bfff>[Test]</color> bc sqrt 0 - expect 0:
echo ""sqrt 0"" | bc

_print

// ===================================================================
// SECTION 13 - VARIABLE IN EXPRESSIONS
// ===================================================================
_print <color=#00bfff>--- Section 13: Variables in Expressions ---</color>

// Variable in arithmetic
_setvar(x, 10)
_setvar(r, _getvar(x) + _getvar(x))
assert(x+x where x is 10 should be 20, _getvar(r), 20)

_setvar(r, _getvar(x) * _getvar(x))
assert(x*x where x is 10 should be 100, _getvar(r), 100)

// Variable in comparison
_setvar(a, 5)
_setvar(b, 10)
_setvar(r, no)
if _getvar(a) < _getvar(b)
  _setvar(r, yes)
endif
assert(5 lt 10 via vars should be true, _getvar(r), yes)

// Variable overwrite in loop
_setvar(total, 0)
for i in range(1, 5)
  _setvar(total, _getvar(total) + _getvar(i))
endfor
assert(sum 1 to 5 via accumulator should be 15, _getvar(total), 15)

// Variable from function used in arithmetic
// Note: _setvar(r, func() + N) discards +N - known limitation
// Workaround: use intermediate variable
func getTen()
  _return 10
endfunc
_setvar(base, getTen())
_setvar(r, _getvar(base) + 5)
assert(getTen return 10 then +5 should be 15, _getvar(r), 15)

_print

// ===================================================================
// SECTION 14 - MIXED STRESS
// ===================================================================
_print <color=#00bfff>--- Section 14: Mixed Stress ---</color>

// Fibonacci via loop - range(1,10) = 10 iterations = fib(11) = 89
_setvar(a, 0)
_setvar(b, 1)
for i in range(1, 10)
  _setvar(temp, _getvar(b))
  _setvar(b, _getvar(a) + _getvar(b))
  _setvar(a, _getvar(temp))
endfor
assert(fibonacci after 10 iterations should be 89, _getvar(b), 89)

// Nested function with conditions
func classify(n)
  if _getvar(n) > 0
    _return positive
  elif _getvar(n) < 0
    _return negative
  else
    _return zero
  endif
endfunc
_setvar(r, classify(5))
assert(classify 5 should be positive, _getvar(r), positive)
_setvar(r, classify(-3))
assert(classify -3 should be negative, _getvar(r), negative)
_setvar(r, classify(0))
assert(classify 0 should be zero, _getvar(r), zero)

// Accumulate in nested loops with condition
_setvar(r, 0)
for i in range(1, 5)
  for j in range(1, 5)
    if _getvar(i) == _getvar(j)
      _setvar(r, _getvar(r) + 1)
    endif
  endfor
endfor
assert(count pairs where i equals j in 5x5 should be 5, _getvar(r), 5)

// Large accumulation
_setvar(total, 0)
for i in range(1, 200)
  _setvar(total, _getvar(total) + 1)
endfor
assert(counting 200 iterations should total 200, _getvar(total), 200)

// Function call inside loop
func square(n)
  _return _getvar(n) * _getvar(n)
endfunc
_setvar(sum_sq, 0)
for i in range(1, 5)
  _setvar(sq, square(_getvar(i)))
  _setvar(sum_sq, _getvar(sum_sq) + _getvar(sq))
endfor
assert(sum of squares 1+4+9+16+25 should be 55, _getvar(sum_sq), 55)

_print
_print <color=#eb0cc6>============================================</color>
_print <color=#eb0cc6>       EDGE CASE TESTS COMPLETE</color>
_print <color=#eb0cc6>============================================</color>
_print"
