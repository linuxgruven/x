_print <color=#aaaaaa>  to_string of 42 =</color> _getvar(numStr)
_setvar(num, to_int(99))
_print <color=#aaaaaa>  to_int of 99 =</color> _getvar(num)
_setvar(dec, to_float(3.14))
_print <color=#aaaaaa>  to_float of 3.14 =</color> _getvar(dec)
_setvar(r, to_yesno(1))
_print <color=#aaaaaa>  to_yesno of 1 =</color> _getvar(r)
_setvar(r, to_truefalse(0))
_print <color=#aaaaaa>  to_truefalse of 0 =</color> _getvar(r)

