// Bash Function Stress Test
// Comprehensive coverage of func/endfunc, _return, params,
// nesting, recursion, scope, side effects, edge cases.

func assert(label, actual, expected)
  if _getvar(actual) == _getvar(expected)
    _print <color=#00ff00>[PASS]</color> _getvar(label)
  else
    _print <color=#ff0000>[FAIL]</color> _getvar(label) <color=#ffff00> expected:</color>_getvar(expected) <color=#ffff00> got:</color>_getvar(actual)
  endif
endfunc

_print
_print <color=#eb0cc6>============================================</color>
_print <color=#eb0cc6>     BASH FUNCTION STRESS TESTS</color>
_print <color=#eb0cc6>============================================</color>
_print

// ===================================================================
// SECTION 1 - BASIC DEFINITIONS & CALLS
// ===================================================================
_print <color=#00bfff>--- Section 1: Basic Definitions & Calls ---</color>

// No-return void function (standalone call)
func sayHello()
  _setvar(__side, done)
endfunc
_setvar(__side, before)
sayHello()
assert(void func scope isolated, _getvar(__side), before)

// Function with _return
func five()
  _return 5
endfunc
_setvar(r, five())
assert(no-param func returns 5, _getvar(r), 5)

// Function returning string
func hello()
  _return hello
endfunc
_setvar(r, hello())
assert(func returns string hello, _getvar(r), hello)

// Function returning empty string
func empty()
  _return
endfunc
_setvar(r, empty())
assert(func returning empty gives empty, _getvar(r), )

// 1-param function
func double(n)
  _return _getvar(n) * 2
endfunc
_setvar(r, double(7))
assert(double 7 is 14, _getvar(r), 14)

// 2-param function
func add(a, b)
  _return _getvar(a) + _getvar(b)
endfunc
_setvar(r, add(3, 8))
assert(add 3 8 is 11, _getvar(r), 11)

// 3-param function
func clamp(v, lo, hi)
  if _getvar(v) < _getvar(lo)
    _return _getvar(lo)
  elif _getvar(v) > _getvar(hi)
    _return _getvar(hi)
  else
    _return _getvar(v)
  endif
endfunc
_setvar(r, clamp(50, 0, 10))
assert(clamp 50 to 0-10 is 10, _getvar(r), 10)
_setvar(r, clamp(-5, 0, 10))
assert(clamp -5 to 0-10 is 0, _getvar(r), 0)
_setvar(r, clamp(5, 0, 10))
assert(clamp 5 to 0-10 is 5, _getvar(r), 5)

// 4-param function
func calc(a, b, c, d)
  _return _getvar(a) + _getvar(b) + _getvar(c) + _getvar(d)
endfunc
_setvar(r, calc(1, 2, 3, 4))
assert(4-param calc 1+2+3+4 is 10, _getvar(r), 10)

// 5-param function
func sum5(a, b, c, d, e)
  _return _getvar(a) + _getvar(b) + _getvar(c) + _getvar(d) + _getvar(e)
endfunc
_setvar(r, sum5(10, 20, 30, 40, 50))
assert(5-param sum 10-50 is 150, _getvar(r), 150)

_print

// ===================================================================
// SECTION 2 - SCOPE ISOLATION
// ===================================================================
_print <color=#00bfff>--- Section 2: Scope Isolation ---</color>

// Outer var unchanged after func sets same name
_setvar(x, outer)
func setX()
  _setvar(x, inner)
endfunc
setX()
assert(outer x unchanged after func sets x, _getvar(x), outer)

// Param name shadows outer var
_setvar(y, original)
func shadow(y)
  _return _getvar(y)
endfunc
_setvar(r, shadow(replaced))
assert(param shadows outer y, _getvar(r), replaced)
assert(outer y unchanged after shadow, _getvar(y), original)

// Var created in func does not leak
_setvar(leak, )
func makeLocal()
  _setvar(leak, leaked_value)
  _setvar(secret, 42)
  _return ok
endfunc
_setvar(tmp, makeLocal())
assert(leak var not polluted by func, _getvar(leak), )
assert(secret var does not leak from func, _getvar(secret), )

// Multiple calls to same func are isolated
func bump(n)
  _setvar(local, _getvar(n) + 100)
  _return _getvar(local)
endfunc
_setvar(a, bump(1))
_setvar(b, bump(2))
_setvar(c, bump(3))
assert(bump 1 gives 101, _getvar(a), 101)
assert(bump 2 gives 102, _getvar(b), 102)
assert(bump 3 gives 103, _getvar(c), 103)

// Func does not see vars set by a previous call to same func
func accumTest()
  _setvar(accum, _getvar(accum) + 1)
  _return _getvar(accum)
endfunc
_setvar(accum, 0)
_setvar(r1, accumTest())
_setvar(r2, accumTest())
assert(first accumTest returns 1, _getvar(r1), 1)
assert(second accumTest also returns 1 (isolated), _getvar(r2), 1)

_print

// ===================================================================
// SECTION 3 - FUNCTIONS CALLING FUNCTIONS
// ===================================================================
_print <color=#00bfff>--- Section 3: Functions Calling Functions ---</color>

// 2-level chain
func addOne(n)
  _return _getvar(n) + 1
endfunc
func addTwo(n)
  _setvar(tmp, addOne(_getvar(n)))
  _return addOne(_getvar(tmp))
endfunc
_setvar(r, addTwo(10))
assert(addTwo 10 via two addOne calls is 12, _getvar(r), 12)

// 3-level chain via intermediate vars
func tripleStep(n)
  _setvar(s1, addOne(_getvar(n)))
  _setvar(s2, addTwo(_getvar(s1)))
  _return _getvar(s2)
endfunc
_setvar(r, tripleStep(5))
assert(tripleStep 5 is 5+1+2=8, _getvar(r), 8)

// 4-level chain
func quadStep(n)
  _setvar(s1, addOne(_getvar(n)))
  _setvar(s2, addOne(_getvar(s1)))
  _setvar(s3, addOne(_getvar(s2)))
  _setvar(s4, addOne(_getvar(s3)))
  _return _getvar(s4)
endfunc
_setvar(r, quadStep(0))
assert(quadStep 0 via 4 addOne calls is 4, _getvar(r), 4)

// Function calling a different function that also calls another
func mul2(n)
  _return _getvar(n) * 2
endfunc
func mul2add1(n)
  _setvar(d, mul2(_getvar(n)))
  _return addOne(_getvar(d))
endfunc
_setvar(r, mul2add1(5))
assert(mul2add1 5 is 5*2+1=11, _getvar(r), 11)

// Cross-calling: uses double and add
func combine(a, b)
  _setvar(da, double(_getvar(a)))
  _setvar(ab, add(_getvar(da), _getvar(b)))
  _return _getvar(ab)
endfunc
_setvar(r, combine(3, 7))
assert(combine double(3)+7 is 13, _getvar(r), 13)

_print

// ===================================================================
// SECTION 4 - RECURSION
// ===================================================================
_print <color=#00bfff>--- Section 4: Recursion ---</color>

// Factorial (classic recursion)
func factorial(n)
  if _getvar(n) <= 1
    _return 1
  else
    _setvar(prev, factorial(_getvar(n) - 1))
    _return _getvar(n) * _getvar(prev)
  endif
endfunc
_setvar(r, factorial(1))
assert(factorial 1 is 1, _getvar(r), 1)
_setvar(r, factorial(5))
assert(factorial 5 is 120, _getvar(r), 120)
_setvar(r, factorial(7))
assert(factorial 7 is 5040, _getvar(r), 5040)

// Recursive countdown
func countdown(n)
  if _getvar(n) <= 0
    _return 0
  else
    _return countdown(_getvar(n) - 1)
  endif
endfunc
_setvar(r, countdown(8))
assert(countdown 8 reaches 0, _getvar(r), 0)

// Recursive fibonacci (limited by depth)
func fib(n)
  if _getvar(n) <= 1
    _return _getvar(n)
  else
    _setvar(a, fib(_getvar(n) - 1))
    _setvar(b, fib(_getvar(n) - 2))
    _return _getvar(a) + _getvar(b)
  endif
endfunc
_setvar(r, fib(0))
assert(fib 0 is 0, _getvar(r), 0)
_setvar(r, fib(1))
assert(fib 1 is 1, _getvar(r), 1)
_setvar(r, fib(5))
assert(fib 5 is 5, _getvar(r), 5)
_setvar(r, fib(7))
assert(fib 7 is 13, _getvar(r), 13)

// Recursive sum 1..n
func recSum(n)
  if _getvar(n) <= 0
    _return 0
  else
    _setvar(rest, recSum(_getvar(n) - 1))
    _return _getvar(n) + _getvar(rest)
  endif
endfunc
_setvar(r, recSum(5))
assert(recSum 5 is 15, _getvar(r), 15)

// Recursive power
func power(base, exp)
  if _getvar(exp) <= 0
    _return 1
  else
    _setvar(rest, power(_getvar(base), _getvar(exp) - 1))
    _return _getvar(base) * _getvar(rest)
  endif
endfunc
_setvar(r, power(2, 0))
assert(power 2^0 is 1, _getvar(r), 1)
_setvar(r, power(2, 5))
assert(power 2^5 is 32, _getvar(r), 32)
_setvar(r, power(3, 3))
assert(power 3^3 is 27, _getvar(r), 27)

_print

// ===================================================================
// SECTION 5 - RETURN_VALUE EDGE CASES
// ===================================================================
_print <color=#00bfff>--- Section 5: _return Edge Cases ---</color>

// _return 0 (falsy but valid)
func retZero()
  _return 0
endfunc
_setvar(r, retZero())
assert(func returning 0 gives 0, _getvar(r), 0)

// _return negative
func retNeg()
  _return -42
endfunc
_setvar(r, retNeg())
assert(func returning -42 gives -42, _getvar(r), -42)

// _return float
func retFloat()
  _return 3.14
endfunc
_setvar(r, retFloat())
assert(func returning 3.14 gives 3.14, _getvar(r), 3.14)

// _return from variable
func retFromVar()
  _setvar(v, 99)
  _return _getvar(v)
endfunc
_setvar(r, retFromVar())
assert(func returning var value gives 99, _getvar(r), 99)

// _return from arithmetic
func retArith()
  _return 7 * 8
endfunc
_setvar(r, retArith())
assert(func returning 7*8 gives 56, _getvar(r), 56)

// _return from builtin
func retLen()
  _return len(hello)
endfunc
_setvar(r, retLen())
assert(retLen returns 5 from len of hello, _getvar(r), 5)

// _return from concat
func retConcat(a, b)
  _return concat(_getvar(a), _getvar(b))
endfunc
_setvar(r, retConcat(foo, bar))
assert(func returning concat gives foobar, _getvar(r), foobar)

// _return inside if branch
func absVal(n)
  if _getvar(n) < 0
    _return _getvar(n) * -1
  else
    _return _getvar(n)
  endif
endfunc
_setvar(r, absVal(-7))
assert(absVal -7 returns 7, _getvar(r), 7)
_setvar(r, absVal(3))
assert(absVal 3 returns 3, _getvar(r), 3)
_setvar(r, absVal(0))
assert(absVal 0 returns 0, _getvar(r), 0)

// _return inside while loop
func firstOver(threshold)
  _setvar(i, 1)
  while _getvar(i) <= 100
    if _getvar(i) > _getvar(threshold)
      _return _getvar(i)
    endif
    _setvar(i, _getvar(i) + 1)
  endwhile
  _return -1
endfunc
_setvar(r, firstOver(10))
assert(firstOver 10 returns 11, _getvar(r), 11)
_setvar(r, firstOver(0))
assert(firstOver 0 returns 1, _getvar(r), 1)

// _return inside for loop
func sumRange(lo, hi)
  _setvar(total, 0)
  for i in range(_getvar(lo), _getvar(hi))
    _setvar(total, _getvar(total) + _getvar(i))
  endfor
  _return _getvar(total)
endfunc
_setvar(r, sumRange(1, 5))
assert(sumRange 1 to 5 is 15, _getvar(r), 15)
_setvar(r, sumRange(1, 10))
assert(sumRange 1 to 10 is 55, _getvar(r), 55)

_print

// ===================================================================
// SECTION 6 - FUNCTIONS WITH CONTROL FLOW
// ===================================================================
_print <color=#00bfff>--- Section 6: Functions with Control Flow ---</color>

// if/elif/else inside function
func classify(n)
  if _getvar(n) > 0
    _return positive
  elif _getvar(n) < 0
    _return negative
  else
    _return zero
  endif
endfunc
_setvar(r, classify(5))
assert(classify 5 is positive, _getvar(r), positive)
_setvar(r, classify(-3))
assert(classify -3 is negative, _getvar(r), negative)
_setvar(r, classify(0))
assert(classify 0 is zero, _getvar(r), zero)

// while loop inside function
func countTo(n)
  _setvar(i, 0)
  while _getvar(i) < _getvar(n)
    _setvar(i, _getvar(i) + 1)
  endwhile
  _return _getvar(i)
endfunc
_setvar(r, countTo(7))
assert(countTo 7 returns 7, _getvar(r), 7)

// for loop inside function
func sumList(lst)
  _setvar(total, 0)
  for item in _getvar(lst)
    _setvar(total, _getvar(total) + _getvar(item))
  endfor
  _return _getvar(total)
endfunc
_setvar(arr, [10, 20, 30, 40])
_setvar(r, sumList(_getvar(arr)))
assert(sumList of [10 20 30 40] is 100, _getvar(r), 100)

// switch inside function
func dayType(day)
  _setvar(result, unknown)
  switch _getvar(day)
    case monday
      _setvar(result, weekday)
    case saturday
      _setvar(result, weekend)
    case sunday
      _setvar(result, weekend)
    default
      _setvar(result, weekday)
  endswitch
  _return _getvar(result)
endfunc
_setvar(r, dayType(monday))
assert(dayType monday is weekday, _getvar(r), weekday)
_setvar(r, dayType(saturday))
assert(dayType saturday is weekend, _getvar(r), weekend)
_setvar(r, dayType(tuesday))
assert(dayType tuesday default is weekday, _getvar(r), weekday)

// Nested if inside for inside function
func findFirst(lst, target)
  _setvar(idx, 0)
  for item in _getvar(lst)
    if _getvar(item) == _getvar(target)
      _return _getvar(idx)
    endif
    _setvar(idx, _getvar(idx) + 1)
  endfor
  _return -1
endfunc
_setvar(arr, [apple, banana, cherry, date])
_setvar(r, findFirst(_getvar(arr), cherry))
assert(findFirst cherry in list is 2, _getvar(r), 2)
_setvar(r, findFirst(_getvar(arr), apple))
assert(findFirst apple in list is 0, _getvar(r), 0)
_setvar(r, findFirst(_getvar(arr), grape))
assert(findFirst grape not in list is -1, _getvar(r), -1)

_print

// ===================================================================
// SECTION 7 - FUNCTION CALLED IN VARIOUS CONTEXTS
// ===================================================================
_print <color=#00bfff>--- Section 7: Functions in Various Contexts ---</color>

// Function result in condition (via intermediate var)
func isPositive(n)
  if _getvar(n) > 0
    _return 1
  else
    _return 0
  endif
endfunc
_setvar(check, isPositive(5))
_setvar(r, no)
if _getvar(check) == 1
  _setvar(r, yes)
endif
assert(isPositive 5 used in condition, _getvar(r), yes)

_setvar(check, isPositive(-3))
_setvar(r, no)
if _getvar(check) == 1
  _setvar(r, yes)
endif
assert(isPositive -3 used in condition, _getvar(r), no)

// Function called in loop body
func square(n)
  _return _getvar(n) * _getvar(n)
endfunc
_setvar(total, 0)
for i in range(1, 5)
  _setvar(sq, square(_getvar(i)))
  _setvar(total, _getvar(total) + _getvar(sq))
endfor
assert(sum of squares 1-5 is 55, _getvar(total), 55)

// Function called many times in rapid succession
func inc(n)
  _return _getvar(n) + 1
endfunc
_setvar(v, 0)
_setvar(v, inc(_getvar(v)))
_setvar(v, inc(_getvar(v)))
_setvar(v, inc(_getvar(v)))
_setvar(v, inc(_getvar(v)))
_setvar(v, inc(_getvar(v)))
_setvar(v, inc(_getvar(v)))
_setvar(v, inc(_getvar(v)))
_setvar(v, inc(_getvar(v)))
_setvar(v, inc(_getvar(v)))
_setvar(v, inc(_getvar(v)))
assert(10 sequential inc calls from 0 gives 10, _getvar(v), 10)

// Function inside while loop
func isEven(n)
  if _getvar(n) % 2 == 0
    _return 1
  else
    _return 0
  endif
endfunc
_setvar(evens, 0)
_setvar(i, 1)
while _getvar(i) <= 10
  _setvar(check, isEven(_getvar(i)))
  if _getvar(check) == 1
    _setvar(evens, _getvar(evens) + 1)
  endif
  _setvar(i, _getvar(i) + 1)
endwhile
assert(count evens 1 to 10 is 5, _getvar(evens), 5)

// Function called on each element of array
func doubleStr(s)
  _return concat(_getvar(s), _getvar(s))
endfunc
_setvar(arr, [ha, bo, ok])
_setvar(results, )
for item in _getvar(arr)
  _setvar(d, doubleStr(_getvar(item)))
  _setvar(results, concat(_getvar(results), _getvar(d)))
endfor
assert(doubleStr on array gives hahabobookok, _getvar(results), hahabobookok)

_print

