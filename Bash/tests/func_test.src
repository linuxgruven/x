  _return _getvar(a)
endfunc
_setvar(r, flex(10))
assert(flex with 1 param returns 10, _getvar(r), 10)

func flex(a, b)
  _return _getvar(a) + _getvar(b)
endfunc
_setvar(r, flex(10, 20))
assert(redefined flex with 2 params returns 30, _getvar(r), 30)

