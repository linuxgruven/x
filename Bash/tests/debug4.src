// DEBUG TEST 4: Chapters 8-14 (Practical Programs, Advanced)
// Tests the later chapters that may have hidden issues.

func assert(label, actual, expected)
  if _getvar(actual) == _getvar(expected)
    _print <color=#00ff00>  [PASS]</color> _getvar(label)
  else
    _print <color=#ff0000>  [FAIL]</color> _getvar(label)
  endif
endfunc

// -- CH8: Practical Programs --
_print <color=#eb0cc6>=== CHAPTER 8 START ===</color>

// Fibonacci
func fib(n)
  if _getvar(n) <= 0
    _return 0
  endif
  if _getvar(n) == 1
    _return 1
  endif
  _setvar(a, 0)
  _setvar(b, 1)
  for i in range(2, _getvar(n))
    _setvar(temp, _getvar(b))
    _setvar(b, _getvar(a) + _getvar(b))
    _setvar(a, _getvar(temp))
  endfor
  _return _getvar(b)
endfunc
_setvar(r, fib(10))
assert(fib 10 = 55, _getvar(r), 55)
_print <color=#00ff00>  8.1 fibonacci OK</color>

// isPrime
func isPrime(n)
  if _getvar(n) < 2
    _return 0
  endif
  _setvar(i, 2)
  while _getvar(i) * _getvar(i) <= _getvar(n)
    if _getvar(n) % _getvar(i) == 0
      _return 0
    endif
    _setvar(i, _getvar(i) + 1)
  endwhile
  _return 1
endfunc
_setvar(r, isPrime(17))
assert(17 is prime, _getvar(r), 1)
_setvar(r, isPrime(4))
assert(4 is not prime, _getvar(r), 0)
_print <color=#00ff00>  8.2 primes OK</color>

// Bubble sort (manual variables - list index assignment not supported)
_setvar(a, 5)
_setvar(b, 3)
_setvar(c, 8)
_setvar(d, 1)
_setvar(e, 4)
// Pass 1
if _getvar(a) > _getvar(b)
  _setvar(t, _getvar(a))
  _setvar(a, _getvar(b))
  _setvar(b, _getvar(t))
endif
if _getvar(b) > _getvar(c)
  _setvar(t, _getvar(b))
  _setvar(b, _getvar(c))
  _setvar(c, _getvar(t))
endif
if _getvar(c) > _getvar(d)
  _setvar(t, _getvar(c))
  _setvar(c, _getvar(d))
  _setvar(d, _getvar(t))
endif
if _getvar(d) > _getvar(e)
  _setvar(t, _getvar(d))
  _setvar(d, _getvar(e))
  _setvar(e, _getvar(t))
endif
// Pass 2
if _getvar(a) > _getvar(b)
  _setvar(t, _getvar(a))
  _setvar(a, _getvar(b))
  _setvar(b, _getvar(t))
endif
if _getvar(b) > _getvar(c)
  _setvar(t, _getvar(b))
  _setvar(b, _getvar(c))
  _setvar(c, _getvar(t))
endif
if _getvar(c) > _getvar(d)
  _setvar(t, _getvar(c))
  _setvar(c, _getvar(d))
  _setvar(d, _getvar(t))
endif
// Pass 3
if _getvar(a) > _getvar(b)
  _setvar(t, _getvar(a))
  _setvar(a, _getvar(b))
  _setvar(b, _getvar(t))
endif
if _getvar(b) > _getvar(c)
  _setvar(t, _getvar(b))
  _setvar(b, _getvar(c))
  _setvar(c, _getvar(t))
endif
_print <color=#aaaaaa>  Sorted: _getvar(a), _getvar(b), _getvar(c), _getvar(d), _getvar(e)</color>
assert(sort first is 1, _getvar(a), 1)
_print <color=#00ff00>  8.3 sort OK</color>

_print <color=#eb0cc6>=== CHAPTER 8 DONE ===</color>

