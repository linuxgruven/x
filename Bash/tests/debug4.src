// -- CH10: Advanced Patterns --
_print <color=#eb0cc6>=== CHAPTER 10 START ===</color>

// Map-like structure using lists
func makeCounter()
  _setvar(count, 0)
  _return _getvar(count)
endfunc
_setvar(c, makeCounter())
assert(counter starts at 0, _getvar(c), 0)

// Accumulator pattern
func sumList(lst)
  _setvar(total, 0)
  for item in _getvar(lst)
    _setvar(total, _getvar(total) + _getvar(item))
  endfor
  _return _getvar(total)
endfunc
_setvar(r, sumList([10, 20, 30]))
assert(sum of 10+20+30 = 60, _getvar(r), 60)
_print <color=#00ff00>  10.1 patterns OK</color>
_print <color=#eb0cc6>=== CHAPTER 10 DONE ===</color>

// -- CH11: Builtin Chaining --
_print <color=#eb0cc6>=== CHAPTER 11 START ===</color>
_setvar(r, upper(substr(hello, 0, 3)))
assert(upper+substr = HEL, _getvar(r), HEL)
_setvar(r, len(upper(hello)))
assert(len of upper = 5, _getvar(r), 5)
_setvar(r, floor(abs(-7) + ceil(2.1)))
assert(floor+abs+ceil = 10, _getvar(r), 10)
_print <color=#00ff00>  11 chaining OK</color>
_print <color=#eb0cc6>=== CHAPTER 11 DONE ===</color>

