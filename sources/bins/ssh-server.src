binSshServer="sshd=include_lib(""/lib/libssh.so"")
if not sshd then sshd=include_lib(current_path+""/libssh.so"")
if not sshd then
	shell=get_shell
	launch(shell,""/bin/apt-get"",""update"")
	launch(shell,""/bin/apt-get"",""install libssh.so"")
	sshd=include_lib(""/lib/libssh.so"")
end if
if not sshd then exit(""Error: Missing libssh.so library in the /lib path or the current folder"")
output=install_service(sshd)
if output!=true then exit(output)
print(""<b>Type 'Browser.exe ""+local_ip(get_router)+"":8080' to access the router configuration to make sure the service it's accessible</b>"")"