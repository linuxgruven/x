//==============================================================================
// BOOTSTRAP AND INITIALIZATION
//==============================================================================
//Check for bootstrap parameters with valid key
if params and params[0]==Kernel.key then
	//Additional parameters provided - special bootstrap mode
	if len(params)>1 then
    //Password cracking mode
    if params[1]=="pass" then
      Boot.crack(params[1])
    //Shell cracking mode
    else if params[1]=="shell" then
      Boot.crack(params[1])
    //Proxy initialization mode
    else if params[1]=="proxy" then
      Boot.initProxy
    //Pivot initialization mode
    else if params[1]=="pivot" then
      Boot.initPivot
    //Decoy initialization mode (with optional target IP)
    else if params[1]=="decoy" then
      if len(params)>2 then Boot.initDecoy(params[2]) else Boot.initDecoy
    //Brute force root mode (launched by Crack.suBrute from shell __su -b)
    else if params[1]=="brute" then
      Boot.brute
    end if
  //No additional parameters - standard initialization
  else
    Boot.init
  end if
	//Exit after bootstrap mode execution
	exit
//Parameters provided but key mismatch - unauthorized access attempt
else if params then
  exit("Key Mismatch")
end if
//Check if host is trusted (bypasses authentication)
if indexOf(Boot.trusted,public_ip_pc(host_computer(get_shell)))!=null then
	//Trusted host - direct initialization
	Boot.init
//Non-trusted host - requires authentication
else
	//Development mode - no password required
	if Kernel.password=="" then
		Boot.init
	//Production mode - App ID authentication required
	else
		//Loop until correct password entered
		while true
			//Prompt for App ID (char(0) hides input)
			if user_input(white("Enter App ID > ")+char(0))==Kernel.password then break
		end while
		//Authentication successful - initialize system
		Boot.init
	end if
end if